        "authority": {"project_file_write_authority": False, "engine_file_write_authority": False, "patch_apply_authority": False, "sandbox_only": True, "model_generation_called": llm.get("model_generation_called", False), "shell_false": True},
        "recommended_next_patch": "Patch 138 — Human Approval + Live Apply Gate" if sandbox_status == "GENERIC_REPAIR_SANDBOX_TESTS_PASS" and llm.get("llm_recommendation") == "APPROVE_SANDBOX_RESULT" else "Revise candidate before live apply gate",
        "next_commands": ["generic-repair-sandbox-show run", "generic-repair-sandbox-export"],
    }
    jp, _ = _p137_write(payload, "generic_repair_sandbox_run_v1")
    print("\n── Generic Repair Sandbox Run — Patch 137 ──────────")
    print("  Status      :", sandbox_status)
    print("  Compile     :", "PASS" if compile_pass else "ISSUES")
    print("  Test        :", "PASS" if test_pass else "ISSUES_OR_NOT_RUN")
    print("  LLM called  :", llm.get("model_generation_called"))
