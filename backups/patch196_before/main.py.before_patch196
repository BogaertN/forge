def _p136l_read_text(path_value: str, max_chars: int = 6000) -> str:
    try:
        p = Path(path_value or "")
        if p.exists() and p.is_file():
            text = p.read_text(encoding="utf-8", errors="replace")
            return text[:max_chars] + ("\n...TRUNCATED_BY_FORGE..." if len(text) > max_chars else "")
    except Exception as exc:
        return f"<read_error {exc!r}>"
    return "<missing>"


def _p136l_target_context(target_file: str, center_line: int | None = None, radius: int = 12) -> str:
    try:
        p = Path(target_file or "")
        if not p.exists():
            return "<target file missing>"
        lines = p.read_text(encoding="utf-8", errors="replace").splitlines()
        if not lines:
            return "<target file empty>"
        if center_line is None:
            start, end = 1, min(len(lines), 80)
        else:
            start = max(1, int(center_line) - radius)
            end = min(len(lines), int(center_line) + radius)
        return "\n".join(f"{i}: {lines[i-1]}" for i in range(start, end + 1))
    except Exception as exc:
        return f"<target_context_error {exc!r}>"


def _p136l_build_prompt(candidate: dict, verification: dict, llm: dict, probe: dict, impact: dict) -> str:
    target_file = candidate.get("target_file") or ""
    target_line = candidate.get("target_line")
    diff_text = _p136l_read_text(candidate.get("diff_path") or "", 6000)
    candidate_text = _p136l_read_text(candidate.get("candidate_file_path") or "", 6000)
    original_context = _p136l_target_context(target_file, target_line, 18)
    original_llm_response = _p136l_read_text(llm.get("raw_response_path") or "", 4000)
    stderr = probe.get("stderr_tail") or probe.get("error") or probe.get("stderr") or ""
    compile_info = candidate.get("candidate_compile") or {}
    return f"""You are Forge's local repair-review LLM. Your job is to review a proposed candidate diff BEFORE Forge is allowed to sandbox it.

STRICT SCOPE:
- Do not propose broad refactors.
- Do not discuss Chroma, ingestion receipts, embeddings, or unrelated corpus metadata.
- Focus only on the candidate repair and the failing file/test evidence below.
- You are reviewing; Forge will not apply your answer directly.

REQUIRED OUTPUT FORMAT:
RECOMMENDATION: APPROVE_CANDIDATE or REVISE_CANDIDATE or REJECT_CANDIDATE
MINIMALITY: one short sentence
CORRECTNESS: one short sentence
RISK: LOW or MEDIUM or HIGH, with one sentence
TESTS_TO_RUN: list the exact tests/checks Forge should run next
IF_REVISE: exact change needed, or NONE

TARGET:
{candidate.get('target')}

TARGET_FILE:
{target_file}

ORIGINAL FAILURE / PROBE STDERR:
{stderr}

ORIGINAL FILE CONTEXT AROUND FAILURE:
{original_context}

PRIOR FOCUSED LLM REPAIR PROPOSAL:
{original_llm_response}

CANDIDATE DIFF:
{diff_text}

CANDIDATE FILE COPY:
{candidate_text}

CANDIDATE COMPILE RESULT:
{json.dumps(compile_info, indent=2, sort_keys=True)}

CANDIDATE VERIFICATION RESULT:
{json.dumps(verification, indent=2, sort_keys=True)[:3000]}

PATCH IMPACT SUMMARY:
{json.dumps({k: impact.get(k) for k in ('status','matches','low_risk','medium_risk','high_risk','test_issues','no_test_result')}, indent=2, sort_keys=True)}

AUTHORITY:
- You cannot write files.
- Forge will save your answer and require deterministic checks plus human approval later.
"""


