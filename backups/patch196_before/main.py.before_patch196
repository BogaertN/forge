    return "failsafe_manager"


def _p176_candidate_root_candidates(candidate: str):
    home = _P176Path.home()
    roots = [
        home / "aiweb" / "engines" / candidate,
        home / "aiweb" / "engines" / f"{candidate}_frozen_v1",
        home / "aiweb" / "projects" / "recursive_lmm_grok1" / "engines" / candidate,
        home / "aiweb" / "projects" / "recursive_lmm_grok1" / "engines" / f"{candidate}_frozen_v1",
    ]
    # Deduplicate while preserving order.
    seen = set()
    out = []
    for root in roots:
        s = str(root)
        if s not in seen:
            seen.add(s)
            out.append(root)
    return out


def _p176_file_digest(path: _P176Path):
    try:
        if not path.is_file():
            return None
        h = _p176_hashlib.sha256()
        with path.open("rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p176_should_ignore(path: _P176Path) -> bool:
    parts = {part.lower() for part in path.parts}
    ignored = {".venv", "node_modules", "__pycache__", ".git", ".mypy_cache", ".pytest_cache", "chroma_db"}
    if parts & ignored:
        return True
    name = path.name.lower()
    if name in {".env", ".npmrc", ".git-credentials"}:
        return True
    if name.endswith((".pyc", ".pyo", ".so", ".bin", ".sqlite", ".db")):
        return True
    return False


def _p176_observe_candidate_files(candidate: str):
    observed_roots = []
    files = []
    skipped = 0
    for root in _p176_candidate_root_candidates(candidate):
        try:
            if not root.exists():
                continue
            root_info = {
                "path": str(root),
                "exists": True,
                "is_dir": root.is_dir(),
                "is_file": root.is_file(),
            }
            observed_roots.append(root_info)
            if root.is_file():
                if not _p176_should_ignore(root):
                    files.append({"path": str(root), "relative_path": root.name, "size": root.stat().st_size, "sha256": _p176_file_digest(root)})
                continue
            if root.is_dir():
                for p in sorted(root.rglob("*")):
                    if _p176_should_ignore(p):
                        skipped += 1
                        continue
                    if p.is_file():
                        try:
                            rel = str(p.relative_to(root))
                            files.append({"path": str(p), "relative_path": rel, "size": p.stat().st_size, "sha256": _p176_file_digest(p)})
                            if len(files) >= 200:
                                skipped += 1
                                break
                        except Exception:
                            skipped += 1
                if len(files) >= 200:
                    break
        except Exception as exc:
            observed_roots.append({"path": str(root), "exists": False, "error": str(exc)})
    return {
        "candidate": candidate,
        "root_candidates": [str(p) for p in _p176_candidate_root_candidates(candidate)],
        "observed_roots": observed_roots,
        "observed_root_count": len(observed_roots),
        "file_count_observed": len(files),
        "file_limit": 200,
        "skipped_count_estimate": skipped,
        "files": files,
    }


