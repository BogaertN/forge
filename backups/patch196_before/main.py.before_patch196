def cmd_generic_repair_llm(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    parts = (arg or "").split()
    target_arg = parts[0] if parts else "latest"
    token = parts[1] if len(parts) > 1 else ""
    if token != GENERIC_REPAIR_CONFIRM:
        print("\n── Generic Repair LLM — Patch 135 ─────────────────")
        print("  Status : REFUSED_MISSING_CONFIRM_TOKEN")
        print("  Needed :", GENERIC_REPAIR_CONFIRM)
