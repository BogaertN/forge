# Purpose: apply the latest verified repair candidate inside a Forge-owned sandbox copy,
# run the scoped compile/test checks there, then call the local LLM on the sandbox result.
# Authority: Forge memory writes only. No live AI.Web writes. No patch apply.
P137_SCHEMA_VERSION = "generic_repair_sandbox_v1_patch137R"
P137_DIR = MEMORY_DIR / "generic_repair_sandboxes_v1"
P137_CONFIRM = "CONFIRM_RUN_GENERIC_REPAIR_SANDBOX"


def _p137_now() -> str:
    from datetime import datetime
    return datetime.now().isoformat(timespec="seconds")


def _p137_safe_stamp() -> str:
    from datetime import datetime
    return datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p137_sha(path: Path) -> str:
    import hashlib
    h = hashlib.sha256()
    with Path(path).open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _p137_load_json(path: Path) -> dict:
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return {}


def _p137_write(payload: dict, stem: str):
    P137_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p137_safe_stamp()
    jp = P137_DIR / f"{stamp}_{stem}.json"
    mp = P137_DIR / f"{stamp}_{stem}.md"
    latest_jp = P137_DIR / f"latest_{stem}.json"
    latest_mp = P137_DIR / f"latest_{stem}.md"
    jp.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [f"# {payload.get('report_type', stem)}", ""]
    for k in ["status", "target", "target_file", "candidate_status", "review_status", "sandbox_status", "test_status", "llm_recommendation", "recommended_next_patch"]:
        if k in payload:
            lines.append(f"- **{k}**: `{payload.get(k)}`")
    if payload.get("problems"):
        lines.append("\n## Problems")
        for p in payload.get("problems", []):
            lines.append(f"- {p}")
    if payload.get("next_commands"):
        lines.append("\n## Next Commands")
        for c in payload.get("next_commands", []):
            lines.append(f"- `{c}`")
    mp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    latest_jp.write_text(jp.read_text(encoding="utf-8"), encoding="utf-8")
    latest_mp.write_text(mp.read_text(encoding="utf-8"), encoding="utf-8")
    return jp, mp


def _p137_latest_json(folder: Path, pattern: str) -> dict:
    latest = folder / f"latest_{pattern}.json"
    if latest.exists():
        return _p137_load_json(latest)
    files = sorted(folder.glob(f"*_{pattern}.json")) if folder.exists() else []
    return _p137_load_json(files[-1]) if files else {}


