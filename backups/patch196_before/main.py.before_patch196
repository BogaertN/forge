    installed = _p194_pip_list()

    if package.lower() not in installed:
        print()
        print(f"  ERROR: '{package}' is not installed.")
        print(f"  Install it first: forge-tool-install {package}")
        print()
        return

    pkg_ver = installed[package.lower()]

    print()
    print("── Forge Tool Wrap — Patch 194 ──────────────────────────────────────")
    print(f"  Package  : {package} {pkg_ver}")
    print(f"  Model    : {_P187_MODEL} via Ollama HTTP API")
    print()
    print("  Calling Qwen3 to generate a wrapper command...")
    print()

    prompt = (
        f"Write a Python function body for a Forge command wrapper around the '{package}' Python package.\n\n"
        f"Function: cmd_use_{package.lower().replace('-','_')}(session_id: str)\n\n"
        f"Required first two lines of the body (always include both):\n"
        f"    from agents.forge.memory import write_audit_entry\n"
        f"    import {package}\n\n"
        f"Then:\n"
        f"- Show one useful feature of {package}\n"
        f"- Print results clearly with a header\n"
        f"- Last line must be: write_audit_entry(session_id, 'USE_{package.upper()}_EXECUTED', '-', '-', 'ran')\n"
        f"- Under 20 lines total\n"
        f"- 4-space indentation. 8-space inside loops/ifs\n"
        f"- Return ONLY the function body. No def line. No markdown fences.\n"
    )

    result = _p187_call_ollama(prompt)

    if result["status"] != "OK":
        print(f"  ERROR: {result['status']}: {result.get('error','')[:200]}")
        print()
        return

    body    = result["visible_response"]
    elapsed = result["elapsed_seconds"]
    fn_name = f"cmd_use_{package.lower().replace('-','_')}"
    cmd_name = f"use-{package.lower()}"

    # Build with relative indentation preserved (same logic as p193)
    body_lines = body.split("\n")
    non_empty  = [l for l in body_lines if l.strip()]
    code_lines = [l for l in non_empty if not l.lstrip().startswith(("from ", "import "))]
    min_indent = min((len(l)-len(l.lstrip()) for l in code_lines), default=0) if code_lines else 0

    full_fn = (
        f"def {fn_name}(session_id: str):\n"
        f'    """\n'
        f"    Forge wrapper for {package} {pkg_ver}\n"
        f"    Generated by forge-tool-wrap via {_P187_MODEL}\n"
        f'    """\n'
    )
    for ln in body_lines:
        if ln.strip():
            extra = max(0, len(ln)-len(ln.lstrip())-min_indent)
            full_fn += f"    {' '*extra}{ln.lstrip()}\n"
        else:
            full_fn += "\n"

    # Save as a proposal
    ts = _p184_now()
    wrapper_path = _P194_TOOLS_DIR / "wrappers" / f"{package.lower()}_wrapper.json"
    wrapper_rec = {
        "package": package, "version": pkg_ver,
        "function_name": fn_name, "command_name": cmd_name,
        "generated_at": ts, "model": _P187_MODEL,
        "elapsed_seconds": elapsed, "full_function": full_fn,
        "status": "WRAPPER_READY_FOR_REVIEW",
    }
    wrapper_path.write_text(_p194_json.dumps(wrapper_rec, indent=2))

    print(f"  ✓ Generated in {elapsed}s")
    print()
    print("  Generated wrapper:")
    print()
    for line in full_fn.split("\n"):
        print(f"    {line}")
    print()
    print(f"  Saved to: {wrapper_path}")
    print()
    print("  To install this as a live Forge command:")
    print(f"    forge-tool-wrap-install {package.lower()}")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_TOOL_WRAP_GENERATED",
                      str(wrapper_path), cmd_name, f"wrapper for {package} generated in {elapsed}s")


