            checks.append(_patch122_tool_registry_parse(registry_path))
        else:
            checks.append({"name": "tool_registry_json_parse", "status": "FAIL", "error": "sandbox_tool_registry_missing"})
        for check in checks:
            if check.get("status") != "PASS":
