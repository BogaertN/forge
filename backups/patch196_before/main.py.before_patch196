def _p165_truthy_approval(approval: dict) -> bool:
    # Patch 165 must not infer approval from a template. Approval must be explicit and separate.
    if not isinstance(approval, dict):
        return False
    if approval.get("human_approval_present") is True and approval.get("approval_token_status") in {"APPROVED", "HUMAN_APPROVED", "CONFIRMED_APPROVED"}:
        return True
    return False


def _p165_payload() -> dict:
    backup = _p165_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_apply_dry_run_v1.json", {}) or _p165_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_plan_v1.json", {})
    approval = _p165_latest_json("forge_runtime_live_approval_v1/latest_forge_runtime_live_approval_v1.json", {})
    static = _p165_latest_json("forge_runtime_candidate_static_verify_v1/latest_forge_runtime_candidate_static_verify_v1.json", {})
    candidate = backup.get("candidate") or approval.get("candidate") or static.get("candidate") or "failsafe_manager"
    approval_token_status = approval.get("approval_token_status") or backup.get("approval_token_status") or "UNKNOWN"
    human_approval_present = _p165_truthy_approval(approval)
    planned_files = backup.get("planned_files") or []
    backup_ready = backup.get("status") in {"FORGE_RUNTIME_LIVE_BACKUP_APPLY_DRY_RUN_READY_GATE_LOCKED", "FORGE_RUNTIME_LIVE_BACKUP_APPLY_DRY_RUN_PLAN_READY_GATE_LOCKED"}
    static_ready = static.get("status") == "FORGE_RUNTIME_CANDIDATE_STATIC_VERIFICATION_READY_GATE_LOCKED"
    missing_sandbox = backup.get("missing_sandbox_sources") or []
    existing_live_targets = backup.get("existing_live_targets") or []
    gates = [
        {"id":"F01","name":"Static sandbox candidate verified","status":"PASS" if static_ready else "FAIL","detail": static.get("status") or "missing static verification"},
        {"id":"F02","name":"Backup/apply dry-run evidence exists","status":"PASS" if backup_ready else "FAIL","detail": backup.get("status") or "missing backup dry-run"},
        {"id":"F03","name":"Sandbox candidate sources available","status":"PASS" if len(missing_sandbox)==0 and len(planned_files)>0 else "FAIL","detail": f"missing_sandbox={len(missing_sandbox)} planned_files={len(planned_files)}"},
        {"id":"F04","name":"Live target conflict scan clean","status":"PASS" if len(existing_live_targets)==0 else "WARN","detail": f"existing_live_targets={len(existing_live_targets)}"},
        {"id":"F05","name":"Approval token exists as template","status":"PASS" if approval_token_status not in {None, "", "UNKNOWN"} else "WARN","detail": str(approval_token_status)},
        {"id":"F06","name":"Human approval present","status":"PASS" if human_approval_present else "LOCKED","detail":"explicit human approval not present" if not human_approval_present else "explicit human approval present"},
        {"id":"F07","name":"Runtime live write authority","status":"LOCKED","detail":"Patch 165 is a final gate only; it does not grant live runtime write authority"},
    ]
    problems = []
    for gate in gates:
        if gate.get("status") == "FAIL":
            problems.append(f"{gate.get('id')}: {gate.get('name')} — {gate.get('detail')}")
    planning_ready = len([g for g in gates if g.get("status") == "FAIL"]) == 0
    live_build_ready = bool(planning_ready and human_approval_present and False)
    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_FINAL_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_FINAL_APPROVAL_GATE_V1",
        "created_at": _p165_now(),
        "active_patch": "Patch 165 — Runtime Live Build Final Approval / Live Apply Gate",
        "current_phase": "S19K — Runtime Live Build Final Approval / Live Apply Gate",
        "next_patch": "Patch 166 — Runtime Live Build Execution Plan / Receipt Gate",
        "recommended_next_patch": "Patch 166 — Runtime Live Build Execution Plan / Receipt Gate",
        "status": "FORGE_RUNTIME_LIVE_FINAL_APPROVAL_GATE_READY_LOCKED" if planning_ready else "FORGE_RUNTIME_LIVE_FINAL_APPROVAL_GATE_HAS_BLOCKERS",
        "candidate": candidate,
        "planning_ready": planning_ready,
        "live_build_ready": live_build_ready,
        "human_approval_present": human_approval_present,
        "approval_token_status": approval_token_status,
        "planned_file_count": len(planned_files),
        "planned_files": planned_files,
        "problem_count": len(problems),
        "problems": problems,
        "gates": gates,
        "gate_summary": {"pass": sum(1 for g in gates if g.get("status")=="PASS"), "warn": sum(1 for g in gates if g.get("status")=="WARN"), "locked": sum(1 for g in gates if g.get("status")=="LOCKED"), "fail": sum(1 for g in gates if g.get("status")=="FAIL")},
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "runtime_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
            "live_apply_permitted": False,
        },
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 165 is the final approval/live-apply gate. It proves the evidence chain is assembled, but live runtime writes remain locked because explicit human approval and live write authority are not present.",
    }
    return payload


