def _p161_static_check_file(row: dict) -> dict:
    rel = row.get("relative_path") or ""
    path = Path(row.get("sandbox_path") or "")
    live_path = Path(row.get("planned_live_path_not_created") or "/__no_live_path__")
    sha_now = _p161_sha256_file(path) if path.exists() else None
    expected_sha = row.get("sha256")
    static_ok = False
    static_detail = "not checked"
    if not path.exists():
        static_detail = "sandbox file missing"
    elif expected_sha and sha_now != expected_sha:
        static_detail = "sha256 mismatch"
    else:
        try:
            if rel.endswith(".py"):
                compile(path.read_text(encoding="utf-8"), str(path), "exec")
                static_ok = True
                static_detail = "python compile parse OK"
            elif rel.endswith(".json"):
                json.loads(path.read_text(encoding="utf-8"))
                static_ok = True
                static_detail = "json parse OK"
            elif rel.endswith(".md"):
                text = path.read_text(encoding="utf-8")
                static_ok = len(text.strip()) > 0
                static_detail = "markdown nonempty" if static_ok else "markdown empty"
            else:
                static_ok = True
                static_detail = "static file present"
        except Exception as exc:
            static_ok = False
            static_detail = f"static parse failed: {exc}"
    return {
        "relative_path": rel,
        "sandbox_path": str(path),
        "planned_live_path_not_created": row.get("planned_live_path_not_created"),
        "exists": path.exists(),
        "sha256_expected": expected_sha,
        "sha256_now": sha_now,
        "hash_match": bool(path.exists() and expected_sha and sha_now == expected_sha),
        "static_ok": bool(static_ok),
        "static_detail": static_detail,
        "live_path_exists": live_path.exists() if str(live_path) != "/__no_live_path__" else False,
        "purpose": row.get("purpose"),
    }


