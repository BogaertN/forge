def cmd_forge_command_install(slug: str, session_id: str):
    """
    Install an approved command proposal into main.py.

    Usage: forge-command-install <slug>

    What this does step by step — clearly:
      1. Loads the approved proposal
      2. Shows a dry run summary
      3. Asks you to type INSTALL to confirm
      4. Backs up main.py and tool_registry.json
      5. Inserts the function into main.py
      6. Inserts the routing entry into main.py
      7. Adds to FORGE_EXPECTED_COMMANDS in main.py
      8. Runs python3 -m py_compile on the result
      9. If compile fails: restores from backup, stops
      10. Updates tool_registry.json
      11. Records the install in forge_command_generator_v1/installed/
      12. Audits every step

    Safety guarantees:
      - You must type INSTALL to proceed
      - Backup is made before any write
      - py_compile runs after every write
      - Auto-restore if compile fails
      - Full audit trail
    """
    import json as _j
    from agents.forge.memory import write_audit_entry

    slug = slug.strip()
    if not slug:
        print()
        print("  Usage: forge-command-install <slug>")
        print()
        return

    prop, err = _p185_load_proposal(slug)
    if err:
        print(f"\n  ERROR: {err}\n")
        return

    if not prop.get("approved"):
        print()
        print(f"  ERROR: Proposal '{slug}' is not approved.")
        print(f"  Run: forge-command-approve-proposal {slug}")
        print()
        return

    # Check not already installed
    installed_dir = MEMORY_DIR / "forge_command_generator_v1" / "installed"
    installed_dir.mkdir(parents=True, exist_ok=True)
    if (installed_dir / f"{prop['command_name']}_install.json").exists():
        print()
        print(f"  ERROR: Command '{prop['command_name']}' is already installed.")
        print(f"  Use: forge-command-install-verify {slug} to check it.")
        print()
        return

    fn   = prop["function_name"]
    cmd  = prop["command_name"]
    code = prop["function_code"]
    reg  = prop["tool_registry_entry"]

    # ── Show dry run first ────────────────────────────────────────────────────
    print()
    print("── Forge Command Install — Patch 185 ───────────────────────────────")
    print(f"  Command  : {cmd}")
    print(f"  Function : {fn}")
    print()
    print("  Three changes will be made to main.py:")
    print(f"    1. Insert function '{fn}' before __main__")
    print(f"    2. Insert routing: if '{cmd}': {fn}(session_id)")
    print(f"    3. Add '{cmd}' to FORGE_EXPECTED_COMMANDS")
    print()
    print("  One change to tool_registry.json:")
    print(f"    4. Add '{fn}' tool entry")
    print()
    print("  Backup will be made before any write.")
    print("  py_compile will run after write. Auto-restore on failure.")
    print()
    print("  ╔══════════════════════════════════════════════════════════════╗")
    print("  ║  Type  INSTALL  and press Enter to proceed.                 ║")
    print("  ║  Type anything else to cancel.                              ║")
    print("  ╚══════════════════════════════════════════════════════════════╝")
    print()

    try:
        confirm = input("  Your input: ").strip()
    except EOFError:
        confirm = ""

    if confirm != "INSTALL":
        print()
        print("  Cancelled. Nothing was written.")
        print()
        write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_CANCELLED",
                          fn, cmd, "user did not type INSTALL")
        return

    write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_APPROVED_BY_USER",
                      fn, cmd, "user typed INSTALL — proceeding")

    # ── Back up files ─────────────────────────────────────────────────────────
    main_py   = FORGE_ROOT / "main.py"
    reg_json  = FORGE_ROOT / "config" / "tool_registry.json"
    ts        = _p184_now()
    backup_dir = FORGE_ROOT / "backups" / f"before_install_{cmd}_{ts}"
    backup_dir.mkdir(parents=True, exist_ok=True)
    main_backup = backup_dir / "main.py.backup"
    reg_backup  = backup_dir / "tool_registry.json.backup"
    _p185_shutil.copy2(main_py, main_backup)
    _p185_shutil.copy2(reg_json, reg_backup)
    print(f"  ✓ Backup: {backup_dir}")
    write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_BACKUP_CREATED",
                      str(backup_dir), cmd, "backup created before install")

    # ── Read main.py ──────────────────────────────────────────────────────────
    main_content = main_py.read_text(encoding="utf-8")

    # ── Change 1: Insert function before __main__ ─────────────────────────────
    MAIN_ANCHOR = 'if __name__ == "__main__":\n    main()\n'
    if MAIN_ANCHOR not in main_content:
        print("  ERROR: Cannot find __main__ anchor in main.py. Aborting.")
        write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_FAILED",
                          fn, cmd, "anchor not found — no writes made")
        return

    fn_block = f"\n\n# ── LLM-generated command: {cmd} ──\n{code}\n\n"
    main_content = main_content.replace(MAIN_ANCHOR, fn_block + MAIN_ANCHOR, 1)
    print(f"  ✓ Function inserted")

    # ── Change 2: Insert routing ──────────────────────────────────────────────
    ROUTE_ANCHOR = '# ── Patch 184 — Command generator (self-modification foundation) ──'
    routing_line = (
        f'\n            # ── LLM-installed: {cmd} ──\n'
        f'            if user_input.lower() == "{cmd}":\n'
        f'                {fn}(session_id)\n'
        f'                continue\n'
    )
    if ROUTE_ANCHOR in main_content:
        main_content = main_content.replace(ROUTE_ANCHOR,
                                            routing_line + "            " + ROUTE_ANCHOR, 1)
        print(f"  ✓ Routing inserted")
    else:
        print("  WARNING: Could not find Patch 184 routing anchor. Routing not inserted.")
        write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_ROUTING_WARN",
                          fn, cmd, "routing anchor missing — function installed but no routing")

    # ── Change 3: Add to FORGE_EXPECTED_COMMANDS via existing pattern ─────────
    P185_LEDGER = 'for _p185_cmd in _PATCH185_COMMAND_INSTALLER_COMMANDS:'
    cmd_entry = f'    "{cmd}",\n'
    # Append to the _PATCH185 list right before the closing bracket
    P185_LIST_CLOSE = ']\n' + 'for _p185_cmd'
    if P185_LIST_CLOSE in main_content:
        main_content = main_content.replace(
            P185_LIST_CLOSE,
            cmd_entry + P185_LIST_CLOSE, 1
        )
        print(f"  ✓ Added to FORGE_EXPECTED_COMMANDS via ledger")
    else:
        print("  WARNING: Could not find commands list anchor.")

    # ── Run py_compile ────────────────────────────────────────────────────────
    with _p185_tempfile.NamedTemporaryFile(suffix=".py", delete=False, mode="w", encoding="utf-8") as tf:
        tf.write(main_content)
        tf_path = tf.name

    try:
        _p185_py_compile.compile(tf_path, doraise=True)
        print("  ✓ py_compile passed")
        Path(tf_path).unlink(missing_ok=True)
    except _p185_py_compile.PyCompileError as e:
        print(f"  ✗ py_compile FAILED: {e}")
        print("  Restoring from backup...")
        _p185_shutil.copy2(main_backup, main_py)
        _p185_shutil.copy2(reg_backup, reg_json)
        print("  ✓ Backup restored. Nothing changed.")
        Path(tf_path).unlink(missing_ok=True)
        _p185_err_clean = str(e).replace("\n", " ").replace("\r", " ")
        write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_COMPILE_FAILED",
                          fn, cmd, f"compile error — restored from backup: {_p185_err_clean}")
        return

    # ── Write main.py ─────────────────────────────────────────────────────────
    main_py.write_text(main_content, encoding="utf-8")
    print(f"  ✓ main.py written ({len(main_content.splitlines())} lines)")
    write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_MAIN_PY_WRITTEN",
                      str(main_py), cmd, f"function+routing inserted lines={len(main_content.splitlines())}")

    # ── Change 4: Update tool_registry.json ──────────────────────────────────
    registry = _j.loads(reg_json.read_text())
    if fn not in registry["tools"]:
        registry["tools"][fn] = reg
        reg_json.write_text(_j.dumps(registry, indent=2, sort_keys=True), encoding="utf-8")
        print(f"  ✓ tool_registry.json updated ({len(registry['tools'])} tools)")
        write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_REGISTRY_UPDATED",
                          str(reg_json), fn, f"tool added tools={len(registry['tools'])}")
    else:
        print(f"  ! Tool '{fn}' already in registry — skipped")

    # ── Record install ────────────────────────────────────────────────────────
    record = {
        "command_name":  cmd,
        "function_name": fn,
        "description":   prop["description"],
        "installed_at":  ts,
        "backup_dir":    str(backup_dir),
        "proposal_id":   prop["proposal_id"],
    }
    (installed_dir / f"{cmd}_install.json").write_text(_j.dumps(record, indent=2))

    print()
    print("── Install Complete ─────────────────────────────────────────────────")
    print(f"  Command '{cmd}' is now live in Forge.")
    print(f"  Restart Forge to use it.")
    print(f"  Verify: forge-command-install-verify {slug}")
    print(f"  Backup: {backup_dir}")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_COMMAND_INSTALL_COMPLETE",
                      fn, cmd, "install complete — restart Forge to use new command")


