# ─── PATCH 74 — HUMAN-APPROVED LOCKFILE CANDIDATE (NO FINAL AUTHORITY) ──────

_PATCH74_POLICY_VERSION = "patch74_human_approved_lockfile_candidate_v1"
_PATCH74_CANDIDATE_PREFIX = "engine_human_approved_lockfile_candidate"


def _patch74_candidate_path() -> Path:
    CODE_MANIFESTS_DIR.mkdir(parents=True, exist_ok=True)
    return CODE_MANIFESTS_DIR / f"{_patch60_timestamp()}_{_PATCH74_CANDIDATE_PREFIX}.json"


def _patch74_latest_candidate_path() -> Path | None:
    CODE_MANIFESTS_DIR.mkdir(parents=True, exist_ok=True)
    files = sorted(CODE_MANIFESTS_DIR.glob(f"*_{_PATCH74_CANDIDATE_PREFIX}.json"), reverse=True)
    return files[0] if files else None


def _patch74_load_latest_candidate(build_if_missing: bool = False) -> tuple[dict | None, Path | None, str | None]:
    path = _patch74_latest_candidate_path()
    if path and path.exists():
        try:
            return json.loads(path.read_text(encoding="utf-8")), path, None
        except Exception as e:
            return None, path, f"candidate read failed: {e}"
    if build_if_missing:
        candidate = _patch74_build_candidate()
        path = _patch74_save_candidate(candidate)
        return candidate, path, None
    return None, None, "approved candidate not built yet"


def _patch74_ledger_or_create() -> tuple[dict | None, Path, str | None]:
    return _patch72_load_ledger(create_if_missing=True)


def _patch74_review_counts(entries: list[dict]) -> dict:
    counts = {
        "total": len(entries),
        "approved": 0,
        "deferred": 0,
        "rejected": 0,
        "pending": 0,
        "holds": 0,
        "eligible_approved": 0,
    }
    for row in entries:
        st = str(row.get("review_status", "PENDING_REVIEW")).upper()
        if st == "APPROVED":
            counts["approved"] += 1
        elif st == "DEFERRED":
            counts["deferred"] += 1
        elif st == "REJECTED":
            counts["rejected"] += 1
        else:
            counts["pending"] += 1
        if row.get("is_hold_family"):
            counts["holds"] += 1
        if st == "APPROVED" and row.get("future_lockfile_eligible") and not row.get("is_hold_family"):
            counts["eligible_approved"] += 1
    return counts


def _patch74_build_candidate() -> dict:
    """Build a non-authoritative candidate lockfile from human-approved eligible rows only."""
    ledger, ledger_path, err = _patch74_ledger_or_create()
    if err or not ledger:
        return {
            "report_type": "engine_human_approved_lockfile_candidate",
            "policy_version": _PATCH74_POLICY_VERSION,
            "created_at": _patch72_now(),
            "status": "ERROR",
            "error": err or "ledger unavailable",
            "canonical_authority": False,
            "actual_lockfile_written": False,
            "engine_files_changed": False,
            "quarantine_written": False,
            "candidate_entries": [],
            "excluded_entries": [],
            "validation": {"status": "FAIL", "errors": [err or "ledger unavailable"], "warnings": []},
        }
    entries = list(ledger.get("entries", []) or [])
    candidate_entries: list[dict] = []
    excluded_entries: list[dict] = []
    errors: list[str] = []
    warnings: list[str] = []
    seen: set[str] = set()

    for row in sorted(entries, key=lambda r: str(r.get("engine_base", ""))):
        base = str(row.get("engine_base", "")).strip()
        review_status = str(row.get("review_status", "PENDING_REVIEW")).upper()
        is_hold = bool(row.get("is_hold_family"))
        eligible = bool(row.get("future_lockfile_eligible"))
        keep_path = str(row.get("recommended_keep_path", "")).strip()
        include = review_status == "APPROVED" and eligible and not is_hold
        if include:
            if not base:
                errors.append("approved eligible row missing engine_base")
                continue
            if not keep_path:
                errors.append(f"approved eligible row missing recommended_keep_path: {base}")
                continue
            if base in seen:
                errors.append(f"duplicate candidate engine_base: {base}")
                continue
            seen.add(base)
            candidate_entries.append({
                "engine_base": base,
                "canonical_path_candidate": keep_path,
                "review_status": review_status,
                "review_note": row.get("review_note", ""),
                "reviewed_at": row.get("reviewed_at"),
                "reviewed_by": row.get("reviewed_by"),
                "draft_decision": row.get("draft_decision"),
                "decision_confidence": row.get("decision_confidence"),
                "variant_count": row.get("variant_count"),
                "required_human_checks": list(row.get("required_human_checks", []) or []),
                "cautions": list(row.get("cautions", []) or []),
                "source": "engine_review_ledger_v1",
                "canonical_authority": False,
                "candidate_only": True,
                "no_engine_file_action": True,
                "no_quarantine_action": True,
            })
        else:
            reason = "pending human review"
            if review_status == "DEFERRED":
                reason = "deferred by human review"
            elif review_status == "REJECTED":
                reason = "rejected by human review"
            elif is_hold:
                reason = "hold family excluded"
            elif review_status == "APPROVED" and not eligible:
                reason = row.get("future_lockfile_block_reason") or "approved but not eligible"
            excluded_entries.append({
                "engine_base": base,
                "recommended_keep_path": keep_path,
                "review_status": review_status,
                "is_hold_family": is_hold,
                "future_lockfile_eligible": eligible,
                "draft_decision": row.get("draft_decision"),
                "reason": reason,
            })

    if not candidate_entries:
        warnings.append("No approved eligible rows are available for candidate lockfile.")
    counts = _patch74_review_counts(entries)
    validation_status = "PASS" if not errors else "FAIL"
    return {
        "report_type": "engine_human_approved_lockfile_candidate",
        "policy_version": _PATCH74_POLICY_VERSION,
        "created_at": _patch72_now(),
        "mode": "HUMAN_APPROVED_CANDIDATE_ONLY",
        "status": "VALID_CANDIDATE" if validation_status == "PASS" else "INVALID_CANDIDATE",
        "validation_status": validation_status,
        "canonical_authority": False,
        "actual_lockfile_written": False,
        "engine_files_changed": False,
        "quarantine_written": False,
        "source_ledger_path": str(ledger_path),
        "source_ledger_policy_version": ledger.get("policy_version"),
        "review_counts": counts,
        "included_count": len(candidate_entries),
        "excluded_count": len(excluded_entries),
        "candidate_entries": candidate_entries,
        "excluded_entries": excluded_entries,
        "validation": {
            "status": validation_status,
            "errors": errors,
            "warnings": warnings,
            "required_invariants": [
                "candidate_entries include approved rows only",
                "candidate_entries include future_lockfile_eligible rows only",
                "candidate_entries exclude HOLD families",
                "candidate_entries exclude pending/deferred/rejected rows",
                "candidate has no canonical authority",
                "candidate performs no engine file actions",
                "candidate performs no quarantine actions",
                "no duplicate candidate engine_base rows",
            ],
        },
    }


def _patch74_save_candidate(candidate: dict) -> Path:
