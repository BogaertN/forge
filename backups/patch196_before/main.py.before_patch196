def _p168_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19N" not in ids:
        rows.append({"id":"S19N","status":"ACTIVE","title":"Runtime Live Build Approval Receipt / Execution Decision Gate","patch":"Patch 168 — Runtime Live Build Approval Receipt / Execution Decision Gate","summary":"Verify approval receipt state and decide whether live build remains locked or can proceed toward a separately approved execution.","authority":"decision gate only; no implicit approval"})
    if "S19O" not in ids:
        rows.append({"id":"S19O","status":"NEXT","title":"Runtime Live Build Human Approval Token Entry Gate","patch":"Patch 169 — Runtime Live Build Human Approval Token Entry Gate","summary":"Provide a separate, explicit token-entry gate for human approval before any live runtime apply can be considered.","authority":"approval input gate only; no runtime writes"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M"}:
            row["status"] = "DONE"
