        "target_root": target_root,
        "backup_root": backup_root,
        "planned_file_count": len(planned_files),
        "planned_files": rows,
        "missing_sandbox_sources": missing_sandbox,
        "existing_live_targets": existing_live,
        "dry_run_counts": {
            "project_writes": 0,
            "engine_writes": 0,
            "runtime_writes": 0,
