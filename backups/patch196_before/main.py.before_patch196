def cmd_forge_tool_wrap_install(package: str, session_id: str):
    """
    Install a generated tool wrapper as a live Forge command.
    Requires typing WRAP-INSTALL to confirm. Backs up main.py first.
    Auto-restores if py_compile fails.

    Usage: forge-tool-wrap-install <package-name>
    Example: forge-tool-wrap-install rich

    Workflow:
      1. forge-tool-info rich           ← get info
      2. forge-tool-install rich        ← install package (if needed)
      3. forge-tool-wrap rich           ← generate wrapper
      4. forge-tool-wrap-install rich   ← YOU ARE HERE — make it a live command
      5. use-rich                       ← run it
    """
    import shutil as _sh, tempfile as _tf, py_compile as _pc
    from agents.forge.memory import write_audit_entry

    package = package.strip().lower()
    if not package:
        print("\n  Usage: forge-tool-wrap-install <package-name>\n")
        return

    wrappers_dir = _P194_TOOLS_DIR / "wrappers"
    matches = sorted(wrappers_dir.glob(f"{package}*_wrapper.json"))
    if not matches:
        print()
        print(f"  ERROR: No wrapper found for '{package}'")
        print(f"  Generate one first: forge-tool-wrap {package}")
        print()
        return

    wrapper_path = matches[-1]  # use latest
    rec          = _p194_json.loads(wrapper_path.read_text())

    if rec.get("installed"):
        print()
        print(f"  Already installed: {rec['command_name']}")
        print(f"  Just run: {rec['command_name']}")
        print()
        return

    fn_name  = rec["function_name"]
    cmd_name = rec["command_name"]
    full_fn  = rec["full_function"]

    print()
    print("── Tool Wrap Install — Patch 195 ───────────────────────────────────")
    print(f"  Package : {rec['package']} {rec['version']}")
    print(f"  Command : {cmd_name}")
    print(f"  Function: {fn_name}")
    print()
    print("  What will be added to main.py:")
    print()
    for line in full_fn.split("\n"):
        print(f"    {line}")
    print()
    print("  Backup made first. Auto-restore on compile failure.")
    print()
    print("  ╔══════════════════════════════════════════════════════════════╗")
    print("  ║  Type  WRAP-INSTALL  and press Enter to proceed.            ║")
    print("  ║  Type anything else to cancel.                              ║")
    print("  ╚══════════════════════════════════════════════════════════════╝")
    print()

    try:
        confirm = input("  Your input: ").strip()
    except EOFError:
        confirm = ""

    if confirm != "WRAP-INSTALL":
        print("\n  Cancelled. Nothing changed.\n")
        write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_CANCELLED",
                          fn_name, cmd_name, "user did not type WRAP-INSTALL")
        return

    write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_APPROVED",
                      fn_name, cmd_name, "user typed WRAP-INSTALL")

    # Backup
    main_py    = FORGE_ROOT / "main.py"
    reg_json   = FORGE_ROOT / "config" / "tool_registry.json"
    ts         = _p184_now()
    backup_dir = FORGE_ROOT / "backups" / f"before_wrap_install_{cmd_name}_{ts}"
    backup_dir.mkdir(parents=True, exist_ok=True)
    _sh.copy2(main_py, backup_dir / "main.py.backup")
    _sh.copy2(reg_json, backup_dir / "tool_registry.json.backup")
    print(f"  ✓ Backup: {backup_dir}")
    write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_BACKUP",
                      str(backup_dir), cmd_name, "backup created")

    main_content = main_py.read_text(encoding="utf-8")

    # Add function before __main__
    _MAIN_ANCHOR = 'if __name__ == "__main__":\n    main()\n'
    fn_block = f"\n\n# ── External tool wrapper: {cmd_name} ──\n{full_fn}\n\n"
    main_content = main_content.replace(_MAIN_ANCHOR, fn_block + _MAIN_ANCHOR, 1)

    # Add routing after Patch 194 routing block
    _ROUTE_ANCHOR = '# ── Patch 194 — External tool discovery ─────────────────────────'
    routing = (
        f'\n            # ── Wrapper: {cmd_name} ──\n'
        f'            if user_input.lower() == "{cmd_name}":\n'
        f'                {fn_name}(session_id)\n'
        f'                continue\n'
    )
    if _ROUTE_ANCHOR in main_content:
        main_content = main_content.replace(
            _ROUTE_ANCHOR, _ROUTE_ANCHOR + routing, 1
        )

    # Add to FORGE_EXPECTED_COMMANDS via patch 195 ledger
    _P195_LEDGER_CLOSE = ']\nfor _p195_cmd in _PATCH195_WRAP_INSTALL_COMMANDS:'
    if _P195_LEDGER_CLOSE in main_content:
        main_content = main_content.replace(
            _P195_LEDGER_CLOSE,
            f'    "{cmd_name}",\n' + _P195_LEDGER_CLOSE, 1
        )

    # py_compile check
    with _tf.NamedTemporaryFile(suffix=".py", delete=False, mode="w", encoding="utf-8") as tf:
        tf.write(main_content)
        tf_path = tf.name

    try:
        _pc.compile(tf_path, doraise=True)
        print("  ✓ py_compile passed")
        Path(tf_path).unlink(missing_ok=True)
    except Exception as e:
        err = str(e).replace("\n", " ").replace("\r", " ")
        print(f"  ✗ py_compile FAILED: {err}")
        print("  Restoring from backup...")
        _sh.copy2(backup_dir / "main.py.backup", main_py)
        print("  ✓ Restored. Nothing changed.")
        Path(tf_path).unlink(missing_ok=True)
        write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_COMPILE_FAILED",
                          fn_name, cmd_name, f"compile failed: {err}")
        return

    # Write main.py
    main_py.write_text(main_content, encoding="utf-8")
    lines = len(main_content.splitlines())
    print(f"  ✓ main.py written ({lines} lines)")
    write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_MAIN_PY_WRITTEN",
                      str(main_py), cmd_name, f"wrapper installed lines={lines}")

    # Update tool_registry.json
    registry = _p194_json.loads(reg_json.read_text())
    if fn_name not in registry["tools"]:
        registry["tools"][fn_name] = {
            "description": f"Forge wrapper for {rec['package']} {rec['version']}",
            "executes": False, "trust_level": 5.0, "writes": False
        }
        reg_json.write_text(_p194_json.dumps(registry, indent=2, sort_keys=True))
        print(f"  ✓ Registry updated ({len(registry['tools'])} tools)")
        write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_REGISTRY_UPDATED",
                          str(reg_json), fn_name, f"tool added")

    # Mark wrapper as installed
    rec["installed"] = True
    rec["installed_at"] = ts
    wrapper_path.write_text(_p194_json.dumps(rec, indent=2))

    print()
    print("── Wrap Install Complete ────────────────────────────────────────────")
    print(f"  Command '{cmd_name}' is now live.")
    print("  Restart Forge and run it.")
    print(f"  Backup: {backup_dir}")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_TOOL_WRAP_INSTALL_COMPLETE",
                      fn_name, cmd_name, "tool wrapper installed — restart Forge")



