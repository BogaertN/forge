        write_audit_entry(session_id, "GENERIC_REPAIR_LLM_REFUSED", str(GENERIC_REPAIR_DIR), "missing_confirm_token", "no_model_call")
        return
    plan = _p135_load(_p135_latest_plan_path())
    if not plan or (target_arg and target_arg != "latest" and str(plan.get("target")) != target_arg):
        plan = _p135_build_evidence_packet(target_arg)
        _p135_write(plan, "generic_repair_evidence_packet_v1")
    ollama = _p135_shutil.which("ollama")
    model = _p135_model()
    if not ollama:
        payload = {
            "schema_version": "generic_repair_llm_proposal_v1_patch135",
            "report_type": "GENERIC_REPAIR_LLM_PROPOSAL_V1",
            "created_at": _p135_now(),
            "status": "GENERIC_REPAIR_LLM_BLOCKED_OLLAMA_NOT_FOUND",
