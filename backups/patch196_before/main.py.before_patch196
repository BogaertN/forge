def _snapshot_shadow_inspect_status(blockers: list[str], warnings: list[str]) -> str:
    if blockers:
        return "LIVE_RESTORE_READINESS_BLOCKED_NO_AUTHORITY"
    if warnings:
        return "LIVE_RESTORE_READINESS_READY_WITH_WARNINGS_NO_AUTHORITY"
    return "LIVE_RESTORE_READINESS_READY_NO_AUTHORITY"


def _snapshot_shadow_inspect_build(arg: str = "latest") -> tuple[dict, Path, Path]:
    now = datetime.datetime.now().isoformat(timespec="seconds")
    ts = _patch60_timestamp()
    SNAPSHOT_SHADOW_INSPECTIONS_DIR.mkdir(parents=True, exist_ok=True)
    copy_path = _snapshot_shadow_copy_resolve_path(arg or "latest")
    copy_receipt = _snapshot_shadow_copy_load(copy_path) if copy_path and copy_path.exists() else None
    blockers: list[str] = []
    warnings: list[str] = []
    if not copy_path or not copy_path.exists():
        blockers.append("No Patch 86 shadow copy receipt found. Run snapshot-shadow-copy first.")
    if not copy_receipt:
        blockers.append("Shadow copy receipt could not be loaded as JSON.")
    copy_ok = False
    copy_problems: list[str] = []
    copy_warnings: list[str] = []
    if copy_receipt:
        copy_ok, copy_problems, copy_warnings = _snapshot_shadow_copy_validate_receipt(copy_receipt)
        if not copy_ok:
            blockers.append(f"Shadow copy receipt failed verification: {len(copy_problems)} problems")
            blockers.extend(copy_problems[:20])
        warnings.extend(copy_warnings)
    # Source shadow plan check
    plan_path = Path(str((copy_receipt or {}).get("source_shadow_plan") or "")) if copy_receipt else None
    plan = _snapshot_shadow_load(plan_path) if plan_path and plan_path.exists() else None
    plan_ok = False
    plan_problems: list[str] = []
    plan_warnings: list[str] = []
    if not plan_path or not str(plan_path):
        blockers.append("Shadow copy receipt does not reference a source shadow plan.")
    elif not plan_path.exists():
        blockers.append(f"Source shadow plan path no longer exists: {plan_path}")
    elif not plan:
        blockers.append(f"Source shadow plan could not be loaded as JSON: {plan_path}")
    else:
        plan_ok, plan_problems, plan_warnings = _snapshot_shadow_validate_plan(plan)
        if not plan_ok:
            blockers.append(f"Source shadow plan failed validation: {len(plan_problems)} problems")
            blockers.extend(plan_problems[:20])
        warnings.extend(plan_warnings)
    # Source snapshot receipt check
    snapshot_path = Path(str((copy_receipt or {}).get("source_snapshot_receipt") or "")) if copy_receipt else None
    snapshot_receipt = _snapshot_create_load(snapshot_path) if snapshot_path and snapshot_path.exists() else None
    snapshot_ok = False
    snapshot_problems: list[str] = []
    snapshot_warnings: list[str] = []
    if not snapshot_path or not str(snapshot_path):
        blockers.append("Shadow copy receipt does not reference a source snapshot receipt.")
    elif not snapshot_path.exists():
        blockers.append(f"Source snapshot receipt path no longer exists: {snapshot_path}")
    elif not snapshot_receipt:
        blockers.append(f"Source snapshot receipt could not be loaded as JSON: {snapshot_path}")
    else:
        snapshot_ok, snapshot_problems, snapshot_warnings = _snapshot_create_verify_receipt(snapshot_receipt)
        if not snapshot_ok:
            blockers.append(f"Source snapshot create receipt failed verification: {len(snapshot_problems)} problems")
            blockers.extend(snapshot_problems[:20])
        warnings.extend(snapshot_warnings)
    copied_rows = (copy_receipt or {}).get("copied_files") or []
    planned_rows = (plan or {}).get("planned_files") or []
    snapshot_rows = (snapshot_receipt or {}).get("copied_files") or []
    if copy_receipt and not copied_rows:
        blockers.append("Shadow copy receipt contains no copied file rows.")
    if plan and copied_rows and planned_rows and len(copied_rows) != len(planned_rows):
        blockers.append(f"Shadow copy row count differs from source plan: copied={len(copied_rows)} planned={len(planned_rows)}")
    if snapshot_receipt and copied_rows and snapshot_rows and len(copied_rows) != len(snapshot_rows):
        warnings.append(f"Shadow copy row count differs from source snapshot receipt: copied={len(copied_rows)} snapshot={len(snapshot_rows)}")
    inspected_files: list[dict] = []
    for idx, row in enumerate(copied_rows, start=1):
        rel = str(row.get("planned_shadow_relative_path") or "")
        shadow_file = str(row.get("shadow_file") or "")
        original_path = str(row.get("source_path") or "")
        expected_sha = row.get("expected_sha256")
        copied_sha = row.get("copied_sha256")
        hash_match = bool(expected_sha and copied_sha and expected_sha == copied_sha and row.get("hash_match") is True)
        file_warning = None
        if not hash_match:
            file_warning = "hash mismatch or missing hash in shadow copy receipt"
            blockers.append(f"Shadow file hash not ready for future restore review: {rel}")
        if original_path:
            lower_original = original_path.lower()
            if any(token in lower_original for token in ["/.ssh/", "/.gnupg/", "/.env", "secret", "credential", "token"]):
                blockers.append(f"Potential sensitive original path cannot be considered for restore: {original_path}")
        inspected_files.append({
            "index": idx,
            "original_live_path_for_future_restore_ONLY": original_path,
            "shadow_file": shadow_file,
            "planned_shadow_relative_path": rel,
            "snapshot_relative_path": row.get("snapshot_relative_path"),
            "expected_sha256": expected_sha,
            "copied_sha256": copied_sha,
            "hash_match": hash_match,
            "size_bytes": row.get("size_bytes"),
            "future_action": "WOULD_RESTORE_TO_ORIGINAL_PATH_ONLY_IN_A_SEPARATE_EXPLICIT_FUTURE_PATCH",
            "warning": file_warning,
        })
    status = _snapshot_shadow_inspect_status(blockers, warnings)
    no_authority_reason = "This report can only describe readiness. It cannot restore, copy, delete, move, or modify live files."
    report = {
        "schema_version": SNAPSHOT_SHADOW_INSPECT_SCHEMA_VERSION,
        "report_type": "SNAPSHOT_SHADOW_RESTORE_INSPECTION_V1_PATCH87",
        "created_at": now,
        "mode": "INSPECTION_REPORT_ONLY_NO_LIVE_RESTORE_NO_PROJECT_WRITE",
        "status": status,
        "authority": _snapshot_shadow_inspect_authority(),
        "source_shadow_copy_receipt": str(copy_path) if copy_path else None,
        "source_shadow_plan": str(plan_path) if plan_path else None,
        "source_snapshot_receipt": str(snapshot_path) if snapshot_path else None,
        "shadow_copy_root": (copy_receipt or {}).get("shadow_copy_root") if copy_receipt else None,
        "checks": {
            "shadow_copy_verify_pass": copy_ok,
            "source_shadow_plan_validate_pass": plan_ok,
            "source_snapshot_verify_pass": snapshot_ok,
            "all_hashes_match": all(r.get("hash_match") is True for r in inspected_files) if inspected_files else False,
            "live_restore_authority_present": False,
            "project_write_authority_present": False,
        },
        "counts": {
            "inspected_files": len(inspected_files),
            "hash_matches": sum(1 for r in inspected_files if r.get("hash_match") is True),
            "hash_not_ready": sum(1 for r in inspected_files if r.get("hash_match") is not True),
            "blockers": len(blockers),
            "warnings": len(warnings),
            "copy_verify_problems": len(copy_problems),
            "copy_verify_warnings": len(copy_warnings),
            "source_plan_problems": len(plan_problems),
            "source_plan_warnings": len(plan_warnings),
            "source_snapshot_problems": len(snapshot_problems),
            "source_snapshot_warnings": len(snapshot_warnings),
        },
        "blockers": blockers,
        "warnings": warnings,
        "inspected_files": inspected_files,
        "live_restore_readiness": {
            "ready_for_future_live_restore_PROPOSAL_ONLY": not blockers,
            "live_restore_authorized_now": False,
            "required_future_patch": "A separate future patch must add a proposal/gate before any live restore command may exist.",
            "no_authority_reason": no_authority_reason,
        },
        "plain_english": [
            "Patch 87 inspected the shadow copy created by Patch 86 and compared it against the source plan and snapshot receipt.",
            "This is still not a restore command. Live Forge and AI.Web project files were not modified by this command.",
            "If blockers are zero, the system is ready for a future live-restore proposal gate, not live restore itself.",
        ],
    }
    json_path = SNAPSHOT_SHADOW_INSPECTIONS_DIR / f"{ts}_{SNAPSHOT_SHADOW_INSPECT_PREFIX}.json"
    md_path = SNAPSHOT_SHADOW_INSPECTIONS_DIR / f"{ts}_{SNAPSHOT_SHADOW_INSPECT_PREFIX}.md"
    json_path.write_text(json.dumps(report, indent=2, ensure_ascii=False), encoding="utf-8")
    _snapshot_shadow_inspect_markdown(report, md_path)
    return report, json_path, md_path


def _snapshot_shadow_inspect_markdown(report: dict, md_path: Path) -> None:
    c = report.get("counts") or {}
    lines = [
        "# Patch 87 Shadow Restore Inspection / Live Restore Readiness Report",
        "",
        "Mode: INSPECTION REPORT ONLY. No live restore authority exists.",
        f"Created: `{report.get('created_at')}`",
        f"Status: `{report.get('status')}`",
        f"Shadow copy receipt: `{report.get('source_shadow_copy_receipt')}`",
        f"Shadow copy root: `{report.get('shadow_copy_root')}`",
        "",
        "## Counts",
        f"- Inspected files: `{c.get('inspected_files')}`",
        f"- Hash matches: `{c.get('hash_matches')}`",
        f"- Hash not ready: `{c.get('hash_not_ready')}`",
        f"- Blockers: `{c.get('blockers')}`",
        f"- Warnings: `{c.get('warnings')}`",
        "",
        "## Authority",
    ]
    for k, v in (report.get("authority") or {}).items():
        lines.append(f"- {k}: `{v}`")
    lines.extend(["", "## Readiness"])
    readiness = report.get("live_restore_readiness") or {}
    for k, v in readiness.items():
        lines.append(f"- {k}: `{v}`")
    lines.extend(["", "## Blockers"])
    for item in report.get("blockers") or ["None"]:
        lines.append(f"- {item}")
    lines.extend(["", "## Warnings"])
    for item in report.get("warnings") or ["None"]:
        lines.append(f"- {item}")
    lines.extend(["", "## Inspected Files"])
    for row in (report.get("inspected_files") or [])[:200]:
        lines.append(f"- `{row.get('planned_shadow_relative_path')}` → future original path `{row.get('original_live_path_for_future_restore_ONLY')}` hash_match=`{row.get('hash_match')}`")
    md_path.write_text("\n".join(lines), encoding="utf-8")


def _snapshot_shadow_inspect_validate_report(report: dict) -> tuple[bool, list[str], list[str]]:
    problems: list[str] = []
    warnings: list[str] = []
    if not isinstance(report, dict):
        return False, ["inspection report is not a JSON object"], warnings
    if report.get("schema_version") != SNAPSHOT_SHADOW_INSPECT_SCHEMA_VERSION:
        problems.append("schema_version mismatch")
    if report.get("mode") != "INSPECTION_REPORT_ONLY_NO_LIVE_RESTORE_NO_PROJECT_WRITE":
        problems.append("mode is not inspection-only")
    authority = report.get("authority") or {}
    for key in ["shadow_restore_plan_authority", "shadow_restore_copy_authority", "restore_authority", "live_restore_authority", "project_file_write_authority", "engine_file_write_authority", "delete_authority", "quarantine_authority", "shell_execution_authority", "chroma_write_authority", "snapshot_create_authority", "final_lockfile_authority"]:
        if authority.get(key) is not False:
            problems.append(f"forbidden authority flag not false: {key}")
    if authority.get("shadow_restore_inspection_authority") is not True:
        problems.append("shadow_restore_inspection_authority is not true")
    if (report.get("live_restore_readiness") or {}).get("live_restore_authorized_now") is not False:
        problems.append("live restore readiness incorrectly grants live_restore_authorized_now")
    if not report.get("inspected_files"):
        problems.append("inspection report contains no inspected_files rows")
    for row in report.get("inspected_files") or []:
        rel = str(row.get("planned_shadow_relative_path") or "")
        if not rel or rel.startswith("/") or ".." in Path(rel).parts:
            problems.append(f"unsafe inspected relative path: {rel}")
    if report.get("warnings"):
        warnings.extend(report.get("warnings") or [])
    if report.get("blockers"):
        problems.extend(report.get("blockers") or [])
    return not problems, problems, warnings


