def _patch97a_sha256(path: Path) -> str:
    import hashlib
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch97a_latest_report_path() -> Path | None:
    latest = SOURCE_LAW_CHUNK_PROBE_DIR / "latest_source_law_chunk_probe.json"
