    counts = (final or {}).get("counts") or {}
    return {
        "exists": exists,
        "path": str(final_path),
        "sha256": _patch116_sha256(final_path) if final_path.exists() else None,
        "report_type": (final or {}).get("report_type"),
        "canonical_authority": (final or {}).get("canonical_authority"),
        "actual_lockfile_written": (final or {}).get("actual_lockfile_written"),
        "included_count": (final or {}).get("included_count") or counts.get("included"),
