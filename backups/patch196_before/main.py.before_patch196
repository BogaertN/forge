def cmd_llm_plan_show(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    arg = (arg or "latest").strip().lower()
    if arg in {"latest", "template", ""}:
        path = _patch119_latest_template_path()
    elif arg in {"validation", "validate"}:
        path = _patch119_latest_validation_path()
    else:
        candidate = _PATCH119_ROOT / arg
        path = candidate if candidate.exists() else _patch119_latest_template_path()
    data = _patch119_load_json(path)
    print()
    print("── LLM Plan Show — Patch 119 ────────────────────────")
    print(f"  Path   : {path}")
    print(f"  Exists : {path.exists()}")
