        print("  Restoring from backup...")
        _sh.copy2(backup_path, main_py)
        print("  ✓ Restored. Nothing changed.")
        Path(tf_path).unlink(missing_ok=True)
        write_audit_entry(session_id, "FORGE_COMMAND_IMPLEMENT_COMPILE_FAILED",
                          fn_name, cmd_name, f"compile failed: {err_c}")
        return

    main_py.write_text(main_content, encoding="utf-8")
    lines = len(main_content.splitlines())
    print(f"  ✓ main.py written ({lines} lines)")
    write_audit_entry(session_id, "FORGE_COMMAND_IMPLEMENT_MAIN_PY_WRITTEN",
                      str(main_py), cmd_name, f"implemented lines={lines}")

    impl["installed"]    = True
    impl["installed_at"] = ts
    impl["status"]       = "IMPLEMENTATION_INSTALLED"
    impl_path.write_text(_j.dumps(impl, indent=2), encoding="utf-8")

    print()
    print("── Implementation Installed ─────────────────────────────────────────")
    print(f"  '{cmd_name}' now has a real implementation.")
    print("  Restart Forge and run the command.")
    print(f"  Backup: {backup_dir}")
    print("────────────────────────────────────────────────────────────────────")
