def _p194_ensure_dirs():
    for sub in ("installed", "wrappers"):
        (_P194_TOOLS_DIR / sub).mkdir(parents=True, exist_ok=True)
    return _P194_TOOLS_DIR


def _p194_pypi_json(package: str) -> dict:
    """Fetch package metadata from PyPI JSON API."""
    url = f"https://pypi.org/pypi/{package}/json"
    try:
        req = _p194_urllib.Request(url, headers={"User-Agent": "Forge/1.0"})
        with _p194_urllib.urlopen(req, timeout=15) as resp:
            return _p194_json.loads(resp.read().decode("utf-8"))
    except Exception as e:
        return {"_error": str(e)}


def _p194_pip_list() -> dict:
    """Return dict of {package_name: version} currently installed in venv."""
    try:
        r = _p194_sub.run(
            [_p194_sys.executable, "-m", "pip", "list", "--format=json"],
            capture_output=True, text=True, timeout=30
        )
        pkgs = _p194_json.loads(r.stdout)
        return {p["name"].lower(): p["version"] for p in pkgs}
    except Exception:
        return {}


def cmd_forge_tool_search(query: str, session_id: str):
    """
    Search PyPI for packages matching a query.
    Uses the PyPI search page — shows top results with descriptions.

    Usage: forge-tool-search <query>
    Example: forge-tool-search image processing
    Example: forge-tool-search pdf text extraction
    """
    import urllib.parse as _uparse
    from agents.forge.memory import write_audit_entry

    query = query.strip()
    if not query:
        print("\n  Usage: forge-tool-search <query>\n")
        return

    print()
    print("── PyPI Package Search — Patch 194 ─────────────────────────────────")
    print(f"  Query : {query}")
    print(f"  Source: pypi.org/search/")
    print()
    print("  Searching...")

    url = f"https://pypi.org/search/?q={_uparse.quote(query)}&o="
    try:
        req = _p194_urllib.Request(url, headers={"User-Agent": "Forge/1.0"})
        with _p194_urllib.urlopen(req, timeout=15) as resp:
            html = resp.read().decode("utf-8", errors="replace")
    except Exception as e:
        print(f"  ERROR: {e}")
        print()
        return

    # Parse results from HTML — use href pattern which is stable across redesigns
    import re as _re
    # Package hrefs: /project/<name>/
    name_hrefs = _re.findall(r'href="/project/([^"/]+)/[?"]?', html)
    # Deduplicate while preserving order
    seen = set()
    names = []
    for n in name_hrefs:
        if n.lower() not in seen:
            seen.add(n.lower())
            names.append(n)
    # Descriptions: try multiple class patterns
    descs = (
        _re.findall(r'class="package-snippet__description"[^>]*>([^<]+)<', html) or
        _re.findall(r'class="[^"]*description[^"]*"[^>]*>([^<]+)<', html) or
        []
    )

    if not names:
        print("  PyPI search returned no results for that query.")
        print(f"  Try: forge-tool-info <exact-package-name> for direct lookup")
        print(f"  Or browse: {url}")
        print()
        return

    installed = _p194_pip_list()

    print(f"  Results for: {query!r}\n")
    for i, name in enumerate(names[:10]):
        name_clean = name.strip()
        desc_clean = descs[i].strip() if i < len(descs) else "(no description)"
        inst_badge = " [INSTALLED]" if name_clean.lower() in installed else ""
        print(f"  {i+1:2d}. {name_clean}{inst_badge}")
        print(f"       {desc_clean[:70]}")
        print()

    print("  To get details : forge-tool-info <package-name>")
    print("  To install     : forge-tool-install <package-name>")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_TOOL_SEARCH",
                      url, str(len(names)), f"pypi search: {query}")


