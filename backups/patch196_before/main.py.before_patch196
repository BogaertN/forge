        "checks": checks,
        "problems": problems,
        "warnings": warnings,
        "live_apply_eligible": False,
        "live_apply_reason": "Patch 122R validates corrected sandbox target handling only. Future patches must bind tests, approval, and explicit self-update apply gates before live writes.",
        "authority": {
            "mode": "SANDBOX_ONLY",
            "sandbox_only": True,
            "live_self_write_authority": False,
            "project_file_write_authority": False,
            "patch_apply_authority": False,
