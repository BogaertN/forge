    md.append("")
    md.append("## Gates")
    for g in payload.get("gates", []):
        md.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')} — {g.get('detail')}")
    md_path.write_text("\n".join(md)+"\n", encoding="utf-8")
    _p174_shutil.copyfile(json_path, FORGE_RUNTIME_CANDIDATE_QUEUE_DIR / "latest_forge_runtime_candidate_queue_v1.json")
    _p174_shutil.copyfile(md_path, FORGE_RUNTIME_CANDIDATE_QUEUE_DIR / "latest_forge_runtime_candidate_queue_v1.md")
    return json_path, md_path


