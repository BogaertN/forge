        print("  Rule       : no real patch-apply without matching SANDBOX_APPLIED report")
        print(f"  Apply plan : {candidate}")
        print(f"  Target     : {target_file}")
        print(f"  Original   : {str(original_sha)[:16]}")
        print(f"  Future     : {str(future_sha)[:16]}")
