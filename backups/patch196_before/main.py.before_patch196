def _p172_payload() -> dict:
    explicit = _p172_latest_json("forge_runtime_live_explicit_approval_v1/latest_forge_runtime_live_explicit_approval_v1.json", {})
    token_validate = _p172_latest_json("forge_runtime_live_token_validate_v1/latest_forge_runtime_live_token_validate_v1.json", {})
    files = _p172_planned_files()
    candidate = explicit.get("candidate") or token_validate.get("candidate") or "failsafe_manager"
    human_approval = bool(explicit.get("human_approval_present") or False)
    token_entered = bool(explicit.get("approval_token_entered") or False)
    token_status = explicit.get("token_validation_status") or token_validate.get("token_validation_status") or "NOT_ENTERED"
    prior_runtime_writes = int(explicit.get("runtime_writes") or 0)
    prior_project_writes = int(explicit.get("project_writes") or 0)
    prior_engine_writes = int(explicit.get("engine_writes") or 0)
    explicit_found = bool(explicit)
    problems = []
    if not explicit_found:
        problems.append("latest Patch 171 explicit approval capture report is missing")
    if not files:
        problems.append("planned files could not be resolved from prior runtime-live reports")
    if prior_runtime_writes or prior_project_writes or prior_engine_writes:
        problems.append("prior explicit-approval report contains nonzero write counters")
    gates = [
        {"id":"H01","name":"Patch 171 explicit approval report exists","status":"PASS" if explicit_found else "FAIL","detail": explicit.get("status") or "missing"},
        {"id":"H02","name":"Prior write counters are zero","status":"PASS" if (prior_runtime_writes == 0 and prior_project_writes == 0 and prior_engine_writes == 0) else "FAIL","detail": f"runtime={prior_runtime_writes} project={prior_project_writes} engine={prior_engine_writes}"},
        {"id":"H03","name":"Human approval remains absent or non-executing","status":"LOCKED" if not human_approval else "WARN","detail": f"human_approval_present={human_approval}"},
        {"id":"H04","name":"Approval token is not executable in this patch","status":"LOCKED" if not token_entered else "WARN","detail": f"token_entered={token_entered} token_status={token_status}"},
        {"id":"H05","name":"Apply decision remains hold","status":"PASS" if (explicit.get("execution_decision") or "HOLD_FOR_HUMAN_APPROVAL") == "HOLD_FOR_HUMAN_APPROVAL" else "WARN","detail": explicit.get("execution_decision") or "HOLD_FOR_HUMAN_APPROVAL"},
        {"id":"H06","name":"Planned runtime files are visible","status":"PASS" if files else "FAIL","detail": f"planned_files={len(files)}"},
        {"id":"H07","name":"No-write receipt authority only","status":"PASS","detail":"Forge-owned memory report only; no AI.Web runtime writes"},
        {"id":"H08","name":"Live build remains not ready","status":"LOCKED","detail":"live_build_ready=False"},
    ]
    summary = {"pass":0,"warn":0,"locked":0,"fail":0}
    for g in gates:
        key = str(g.get("status", "")).lower()
        if key in summary:
            summary[key] += 1
    receipt = {
        "receipt_type": "RUNTIME_LIVE_BUILD_APPLY_HOLD_NO_WRITE_RECEIPT",
        "candidate": candidate,
        "approval_present": human_approval,
        "approval_token_entered": token_entered,
        "token_validation_status": token_status,
        "execution_decision": "HOLD_FOR_HUMAN_APPROVAL",
        "live_execution_performed": False,
        "runtime_writes_performed": 0,
        "project_writes_performed": 0,
        "engine_writes_performed": 0,
        "required_before_any_future_live_apply": "separate explicit human approval plus a later execution patch that rechecks all gates from disk",
        "no_write_reason": "Patch 172 is review/receipt only and carries no live apply authority.",
    }
    payload = {
        "report_type": "FORGE_RUNTIME_LIVE_APPLY_HOLD_REVIEW_NO_WRITE_RECEIPT_V1",
        "schema_version": FORGE_RUNTIME_LIVE_APPLY_HOLD_SCHEMA_VERSION,
        "created_at": _p172_now(),
        "active_patch": "Patch 172 — Runtime Live Build Apply Hold Review / No-Write Receipt",
        "current_phase": "S19R — Runtime Live Build Apply Hold Review / No-Write Receipt",
        "next_patch": "Patch 173 — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return",
        "recommended_next_patch": "Patch 173 — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return",
        "candidate": candidate,
        "status": "FORGE_RUNTIME_LIVE_APPLY_HOLD_REVIEW_READY_NO_WRITE_RECEIPT" if not problems else "FORGE_RUNTIME_LIVE_APPLY_HOLD_REVIEW_PROBLEMS_FOUND",
        "planning_ready": not problems,
        "live_build_ready": False,
        "human_approval_present": human_approval,
        "approval_token_entered": token_entered,
        "token_validation_status": token_status,
        "approval_capture_status": explicit.get("approval_capture_status") or "NOT_APPROVED",
        "execution_decision": "HOLD_FOR_HUMAN_APPROVAL",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "planned_file_count": len(files),
        "planned_files": files,
        "source_reports": _p172_source_report_summary(),
        "no_write_receipt": receipt,
        "receipt_fingerprint": "",
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "runtime_file_write_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
            "live_execution_authority": False,
        },
        "gates": gates,
        "gate_summary": summary,
        "problem_count": len(problems),
        "problems": problems,
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 172 reviews the apply-hold state and writes a no-write receipt. It performs zero live runtime writes and keeps failsafe_manager held until explicit approval plus a later execution patch exist.",
    }
    payload["receipt_fingerprint"] = _p172_hash_payload(receipt)
    return payload


def _p172_write_json_and_md(stem: str, payload: dict):
    FORGE_RUNTIME_LIVE_APPLY_HOLD_DIR.mkdir(parents=True, exist_ok=True)
