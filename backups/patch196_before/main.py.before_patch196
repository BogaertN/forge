def _patch122_copy_file(src: Path, dst: Path) -> dict:
    import shutil
    row = {"source": str(src), "target": str(dst), "copied": False, "source_sha256": None, "target_sha256": None, "ok": False, "problem": None}
    try:
        if not src.exists() or not src.is_file():
            row["problem"] = "source_missing_or_not_file"
            return row
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
        row["copied"] = True
        row["source_sha256"] = _patch122_sha256(src)
        row["target_sha256"] = _patch122_sha256(dst)
        row["ok"] = bool(row["source_sha256"] and row["source_sha256"] == row["target_sha256"])
        if not row["ok"]:
            row["problem"] = "sha_mismatch_after_copy"
    except Exception as exc:
        row["problem"] = str(exc)
    return row


def _patch122_safe_py_compile(path: Path) -> dict:
    import py_compile
    try:
        py_compile.compile(str(path), doraise=True)
        return {"name": "py_compile_main", "status": "PASS", "path": str(path)}
    except Exception as exc:
        return {"name": "py_compile_main", "status": "FAIL", "path": str(path), "error": str(exc)}


def _patch122_tool_registry_parse(path: Path) -> dict:
    data = _patch122_load_json(path, None)
    if not isinstance(data, dict):
        return {"name": "tool_registry_json_parse", "status": "FAIL", "path": str(path), "error": "not_json_object"}
    tools = data.get("tools") or {}
    return {
        "name": "tool_registry_json_parse",
        "status": "PASS" if isinstance(tools, dict) else "FAIL",
        "path": str(path),
        "tool_count": len(tools) if isinstance(tools, dict) else 0,
        "trust": data.get("current_trust_level"),
    }


def _patch122_expected_command_scan(path: Path, *, target_mode: str = "snapshot_replay") -> dict:
    """
    Patch 122R correction:
    The sandbox may be validating an older verified self-snapshot, not the current live patched Forge.
    In snapshot_replay mode, the correct question is: "is the copied baseline internally parseable
    and does it expose a command surface?" It is NOT correct to require Patch 122 commands to exist
    inside a snapshot that was taken before Patch 122 was installed.

    Future proposed-update sandboxing may use target_mode='proposed_update' and require the
    proposed command markers. Patch 122R keeps live self-write authority false in both modes.
    """
    import re
    try:
        src = path.read_text(encoding="utf-8")
        m = re.search(r"FORGE_EXPECTED_COMMANDS\s*=\s*\[(.*?)\]\s*", src, re.S)
        if not m:
            return {"name": "expected_command_scan", "status": "FAIL", "path": str(path), "error": "FORGE_EXPECTED_COMMANDS_not_found", "target_mode": target_mode}
        body = m.group(1)
        commands = re.findall(r"[\'\"]([^\'\"]+)[\'\"]", body)
        patch122_commands = [
            "forge-self-sandbox-policy",
            "forge-self-sandbox-plan",
            "forge-self-sandbox-apply",
            "forge-self-sandbox-show",
            "forge-self-sandbox-clean",
            "forge-self-sandbox-export",
        ]
        missing_patch122 = [cmd for cmd in patch122_commands if cmd not in commands]
        if target_mode == "proposed_update":
            status = "PASS" if not missing_patch122 else "FAIL"
            reason = "proposed_update_requires_patch122_commands"
        else:
            # Snapshot replay validates the copied restore baseline. It may predate Patch 122.
            status = "PASS" if len(commands) > 0 else "FAIL"
            reason = "snapshot_replay_baseline_command_surface_detected" if commands else "snapshot_replay_no_commands_detected"
        return {
            "name": "expected_command_scan",
            "status": status,
            "path": str(path),
            "target_mode": target_mode,
            "reason": reason,
            "expected_command_count": len(commands),
            "patch122_commands_missing_in_snapshot": missing_patch122,
            "patch122_commands_required": target_mode == "proposed_update",
        }
    except Exception as exc:
        return {"name": "expected_command_scan", "status": "FAIL", "path": str(path), "target_mode": target_mode, "error": str(exc)}


