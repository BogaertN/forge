def _p176_candidate_from_selector(selector: dict) -> str:
    for key in ("selected_candidate", "candidate", "runtime_candidate"):
        val = selector.get(key) if isinstance(selector, dict) else None
        if val:
            return _p176_sanitize_candidate(val)
    decision = selector.get("selection_decision", {}) if isinstance(selector, dict) else {}
    for key in ("selected_candidate", "candidate", "held_candidate"):
        val = decision.get(key) if isinstance(decision, dict) else None
        if val:
