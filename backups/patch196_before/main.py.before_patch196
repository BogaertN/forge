def cmd_forge_command_implement(slug, session_id):
    """
    Ask local Qwen3 to write a real implementation for an installed scaffold command.
    The generated code is saved for review. Nothing changes in main.py until
    you run forge-command-implement-install.

    Usage: forge-command-implement <slug>
    """
    import json as _j
    from agents.forge.memory import write_audit_entry

    slug = slug.strip()
    if not slug:
        print("\n  Usage: forge-command-implement <slug>\n")
        return

    record, err = _p187_load_install_record(slug)
    if err:
        print(f"\n  ERROR: {err}")
        print("  Command must be installed first with forge-command-install\n")
        return

    fn_name  = record["function_name"]
    cmd_name = record["command_name"]
    desc     = record["description"]

    print()
    print("── Forge Command Implement — Patch 187 ─────────────────────────────")
    print(f"  Command  : {cmd_name}")
    print(f"  Function : {fn_name}")
    print(f"  Model    : {_P187_MODEL} via Ollama")
    print(f"  Timeout  : {_P187_TIMEOUT}s")
    print()
    print("  Calling Ollama — this may take 15-60 seconds...")
    print()

    prompt = _p187_build_prompt(fn_name, cmd_name, desc)
    result = _p187_call_ollama(prompt)

    if result["status"] != "OK":
        print(f"  ERROR: {result['status']}")
        if result.get("error"):
            print(f"  Detail: {result['error'][:300]}")
        print()
        write_audit_entry(session_id, "FORGE_COMMAND_IMPLEMENT_FAILED",
                          fn_name, cmd_name, f"ollama: {result['status']}")
        return

    body    = result["visible_response"]
    elapsed = result["elapsed_seconds"]

    # Build full function — preserve relative indentation (Patch 193 fix)
    _body_lines = body.split("\n")
    _non_empty  = [l for l in _body_lines if l.strip()]
    _code_lines = [l for l in _non_empty
                   if not l.lstrip().startswith(("from ", "import "))]
    if _code_lines:
        _min_indent = min(len(l) - len(l.lstrip()) for l in _code_lines)
    elif _non_empty:
        _min_indent = min(len(l) - len(l.lstrip()) for l in _non_empty)
    else:
        _min_indent = 0
    full_fn = (
        f"def {fn_name}(session_id: str):\n"
        f'    """\n'
        f"    {desc}\n\n"
        f"    LLM-implemented via {_P187_MODEL} by forge-command-implement\n"
        f'    """\n'
    )
    for _ln in _body_lines:
        if _ln.strip():
            _actual = len(_ln) - len(_ln.lstrip())
            _extra  = max(0, _actual - _min_indent)
            full_fn += "    " + (" " * _extra) + _ln.lstrip() + "\n"
        else:
            full_fn += "\n"

    # Save
    _P187_IMPL_DIR.mkdir(parents=True, exist_ok=True)
    ts        = _p184_now()
    impl_path = _P187_IMPL_DIR / f"{cmd_name}_implementation.json"
    impl_rec  = {
        "command_name":    cmd_name,
        "function_name":   fn_name,
        "description":     desc,
        "generated_at":    ts,
        "model":           _P187_MODEL,
        "elapsed_seconds": elapsed,
        "generated_body":  body,
        "full_function":   full_fn,
        "status":          "IMPLEMENTATION_READY_FOR_REVIEW",
        "installed":       False,
    }
    impl_path.write_text(_j.dumps(impl_rec, indent=2), encoding="utf-8")

    print(f"  ✓ Generated in {elapsed}s")
    print()
    print("  Generated code:")
    print()
    for line in full_fn.split("\n"):
        print(f"    {line}")
    print()
    print("  Next steps:")
    print(f"    1. forge-command-implement-review {slug}")
    print(f"    2. forge-command-implement-install {slug}")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_COMMAND_IMPLEMENT_GENERATED",
                      str(impl_path), cmd_name, f"generated by {_P187_MODEL} in {elapsed}s")


