    json_path.write_text(_p182_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md = [
        "# Forge Runtime Candidate Sandbox Stage Manifest v1",
        "",
        f"Status: {payload.get('status')}",
        f"Candidate: {payload.get('selected_candidate')}",
        f"Planned stage root: {payload.get('planned_stage_root')}",
        f"Files in manifest: {len(payload.get('stage_manifest') or [])}",
        "",
        "This is a no-write copy plan. It does not create a sandbox and does not copy files.",
    ]
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")
    _p182_shutil.copyfile(json_path, FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_DIR / "latest_forge_runtime_candidate_sandbox_stage_v1.json")
    _p182_shutil.copyfile(md_path, FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_DIR / "latest_forge_runtime_candidate_sandbox_stage_v1.md")
    return json_path, md_path


