def _snapshot_manifest_build_dry_run() -> dict:
    from agents.forge.permissions import get_session_paths
    now = datetime.datetime.now().isoformat(timespec="seconds")
    latest_plan_path = _snapshot_latest_plan_path()
    readiness_path = _snapshot_latest_readiness_path()
    relationship_path = _snapshot_latest_relationship_path()
    direct_files = [
        (FORGE_ROOT / "main.py", "forge_main_py"),
        (CONFIG_DIR / "tool_registry.json", "tool_registry"),
        (CONFIG_DIR / "approved_paths.json", "approved_paths"),
        (CONFIG_DIR / "session_scope.json", "session_scope"),
        (AUDIT_LOG, "audit_log"),
        (CODE_MANIFESTS_DIR / "engine_review_ledger_v1.json", "engine_review_ledger"),
    ]
    if latest_plan_path:
        direct_files.append((latest_plan_path, "latest_snapshot_plan"))
    if readiness_path:
        direct_files.append((readiness_path, "latest_readiness_report"))
    if relationship_path:
        direct_files.append((relationship_path, "latest_relationship_report"))
    direct_rows = [_snapshot_manifest_hash_row(path, label) for path, label in direct_files]
    memory_roots = [
        (LLM_MEMORY_DIR, "llm_memory_v1"),
        (MEMORY_DIR / "snapshot_plans_v1", "snapshot_plans_v1"),
        (CODE_MANIFESTS_DIR, "code_manifests"),
    ]
    root_scans = [_snapshot_manifest_scan_root(path, label) for path, label in memory_roots]
    candidate_rows = _snapshot_manifest_candidate_roots_from_plan()
    candidate_roots = []
    for row in candidate_rows:
        base = row.get("engine_base") or "unknown_engine"
        candidate_path = row.get("candidate_path") or row.get("path") or row.get("root")
        if not candidate_path:
            candidate_roots.append({"root_label": base, "root": None, "exists": False, "counts": {"included": 0, "skipped": 0, "truncated": 0}, "content_copied": False})
            continue
        candidate_roots.append(_snapshot_manifest_scan_root(Path(candidate_path), f"candidate_engine::{base}"))
    total_direct_included = sum(1 for row in direct_rows if row.get("included"))
    total_direct_skipped = sum(1 for row in direct_rows if not row.get("included"))
    total_root_included = sum(scan.get("counts", {}).get("included", 0) for scan in root_scans + candidate_roots)
    total_root_skipped = sum(scan.get("counts", {}).get("skipped", 0) for scan in root_scans + candidate_roots)
    total_truncated = sum(scan.get("counts", {}).get("truncated", 0) for scan in root_scans + candidate_roots)
    return {
        "schema_version": SNAPSHOT_MANIFEST_SCHEMA_VERSION,
        "report_type": "SNAPSHOT_MANIFEST_DRY_RUN_V1_PATCH81",
        "created_at": now,
        "mode": "HASH_MANIFEST_DRY_RUN_ONLY_NO_FILE_COPY_NO_RESTORE",
        "authority": _snapshot_manifest_authority(),
        "scope": {
            "forge_root": str(FORGE_ROOT),
            "current_session_paths": get_session_paths(),
            "approved_paths_file": str(APPROVED_PATHS_FILE),
        },
        "source_plan": str(latest_plan_path) if latest_plan_path else None,
        "direct_files": direct_rows,
        "root_scans": root_scans,
        "candidate_engine_root_scans": candidate_roots,
        "counts": {
            "direct_files_included": total_direct_included,
            "direct_files_skipped": total_direct_skipped,
            "root_files_included": total_root_included,
            "root_files_skipped": total_root_skipped,
            "truncated_after_limit": total_truncated,
            "candidate_engine_roots": len(candidate_roots),
            "total_files_hashed": total_direct_included + total_root_included,
        },
        "invariants": {
            "content_copied": False,
            "restore_authority": False,
            "project_file_write_authority": False,
            "secret_markers_refused": True,
            "large_binary_archive_database_skipped": True,
