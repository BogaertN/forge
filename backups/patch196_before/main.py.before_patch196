def _p172_safe_read_json(path, default=None):
    try:
        p = _P172Path(path)
        if p.exists():
            return _p172_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p172_latest_json(rel_path: str, default=None):
