def _p158_gates(candidate: dict, runtime_plan: dict) -> list[dict]:
    shadow = _p158_latest_shadow_diff()
    snap = _p158_latest_snapshot_verify()
    gates = []

    def add(gid, name, status, detail):
        gates.append({"id": gid, "name": name, "status": status, "detail": detail})

    add("G01", "Runtime build plan exists",
        "PASS" if runtime_plan.get("status") == "FORGE_RUNTIME_BUILD_PLAN_READY_PLANNING_ONLY" else "FAIL",
        runtime_plan.get("status") or "missing")
    add("G02", "Selected candidate exists",
        "PASS" if candidate.get("engine") else "FAIL",
        candidate.get("engine") or "missing candidate")
    add("G03", "Candidate canonical test status clean",
        "PASS" if str(candidate.get("test_status") or "").upper() in {"PASS", "ALL_PASS", "PASSED"} else "WARN",
        str(candidate.get("test_status") or "unknown"))
    add("G04", "Live write authority locked",
        "PASS" if not candidate.get("live_write_authority") and not candidate.get("live_write_ready") else "FAIL",
        "no live runtime write authority granted by Patch 158")
    add("G05", "Snapshot verification evidence exists",
        "PASS" if (snap.get("status") or "").endswith("PASS") or snap.get("problem_count") == 0 else "WARN",
        snap.get("status") or "snapshot verification report not found")
    shadow_summary = shadow.get("summary") if isinstance(shadow.get("summary"), dict) else {}
    shadow_matches = shadow.get("shadow_match")
    if shadow_matches is None:
        shadow_matches = shadow_summary.get("shadow_matches_snapshot")
    shadow_problems = int(shadow.get("problem_count") or 0)
    add("G06", "Shadow restore forensic diff clean",
        "PASS" if shadow_matches is True and shadow_problems == 0 else "WARN",
        f"shadow_matches_snapshot={shadow_matches} problems={shadow_problems}")
    add("G07", "Source authority finality",
        "WARN" if candidate.get("source_authority_status") in {None, "", "CANDIDATE_OR_UNKNOWN"} else "PASS",
        str(candidate.get("source_authority_status") or "candidate/unknown; acceptable for sandbox planning only"))
    add("G08", "Dry-run scope",
        "PASS",
        "dry-run writes only to Forge-owned memory/forge_runtime_build_sandboxes_v1")
    return gates


def _p158_plan_payload() -> dict:
    runtime_plan = _p158_latest_runtime_build_plan()
    candidate = _p158_candidate()
