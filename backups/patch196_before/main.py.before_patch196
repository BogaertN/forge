def _patch131_load_json(path) -> dict:
    try:
        p = Path(path)
        if not p.exists():
            return {}
        return json.loads(p.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        return {}


def _patch131_sha256(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        h = hashlib.sha256()
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _patch131_write_json_md(payload: dict, stem: str):
    ENGINE_SOURCE_LAW_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")
    json_path = ENGINE_SOURCE_LAW_DIR / f"{stamp}_{stem}.json"
    md_path = ENGINE_SOURCE_LAW_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"Status: {payload.get('status')}",
        f"Created: {payload.get('created_at')}",
    ]
    if payload.get("summary"):
        lines.append("")
        lines.append("## Summary")
        for k, v in (payload.get("summary") or {}).items():
            lines.append(f"- {k}: {v}")
    if payload.get("recommended_next_patch"):
        lines.append("")
        lines.append(f"Recommended next patch: {payload.get('recommended_next_patch')}")
    md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    latest_json = ENGINE_SOURCE_LAW_DIR / f"latest_{stem}.json"
    latest_md = ENGINE_SOURCE_LAW_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


