def _p147_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p147_stamp() -> str:
    return _p147_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p147_ensure_dir() -> None:
    FORGE_DASHBOARD_ROADMAP_DIR.mkdir(parents=True, exist_ok=True)


def _p147_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p147_write(payload: dict, stem: str):
    _p147_ensure_dir()
    stamp = _p147_stamp()
    json_path = FORGE_DASHBOARD_ROADMAP_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_DASHBOARD_ROADMAP_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "panel_count"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("panels"):
        md.append("")
        md.append("## Panels")
        for panel in payload.get("panels") or []:
            md.append(f"- **{panel.get('panel_id')}** — `{panel.get('status')}` — {panel.get('title')}")
            for line in panel.get("lines") or []:
                md.append(f"  - {line}")
    if payload.get("build_sequence"):
        md.append("")
        md.append("## Build Sequence")
        for row in payload.get("build_sequence") or []:
            md.append(f"- **{row.get('id')}** — `{row.get('status')}` — {row.get('title')}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_DASHBOARD_ROADMAP_DIR / f"latest_{stem}.json"
    latest_md = FORGE_DASHBOARD_ROADMAP_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


