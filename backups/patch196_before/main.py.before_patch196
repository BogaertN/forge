def _p181_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19AA" not in ids:
        rows.append({"id":"S19AA","status":"ACTIVE","title":"Runtime Candidate Sandbox Execution Preflight / No-Write Gate","patch":"Patch 181 — Runtime Candidate Sandbox Execution Preflight / No-Write Gate","summary":"Check receipts, hashes, rollback matrix, and sandbox readiness before any Forge-owned sandbox staging is allowed."})
    if "S19AB" not in ids:
        rows.append({"id":"S19AB","status":"NEXT","title":"Runtime Candidate Sandbox Stage Manifest / No-Write Copy Plan","patch":"Patch 182 — Runtime Candidate Sandbox Stage Manifest / No-Write Copy Plan","summary":"Prepare a no-write copy/staging manifest for a future Forge-owned sandbox stage."})
    done_ids = {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R","S19S","S19T","S19U","S19V","S19W","S19X","S19Y","S19Z"}
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in done_ids:
            row["status"] = "DONE"
        elif rid == "S19AA":
            row["status"] = "ACTIVE"
        elif rid == "S19AB":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


