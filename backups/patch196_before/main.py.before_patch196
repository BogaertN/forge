    selected = None
    if isinstance(queue_decision, dict):
        selected = queue_decision.get("selected_candidate")
    if not selected and candidate_rows:
        selected = candidate_rows[0].get("candidate")
    if not selected:
        selected = "failsafe_manager"
    return {
        "selected_candidate": selected,
        "selection_mode": "PRESERVE_HELD_CANDIDATE_FOR_DRY_PLANNING_ONLY",
        "dry_plan_allowed": True,
        "live_apply_allowed": False,
        "reason": "Patch 174 deferred next selection into dry planning. Patch 175 preserves the held runtime candidate for dry-plan work only and grants no live write authority.",
        "candidate_source": "patch174_queue_review",
    }


