def _p154_write(payload: dict, stem: str):
    _p154_ensure_dir()
    stamp = _p154_stamp()
    json_path = FORGE_DASHBOARD_V2_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_DASHBOARD_V2_DIR / f"{stamp}_{stem}.md"
    html_path = FORGE_DASHBOARD_V2_DIR / f"{stamp}_{stem}.html"

    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "panel_count"):
        md.append(f"- **{key}**: `{payload.get(key)}`")
    md.append("")
    md.append("## Panels")
    for panel in payload.get("panels") or []:
        md.append(f"- **{panel.get('panel_id')}** — `{panel.get('status')}` — {panel.get('title')}")
        for line in panel.get("lines") or []:
            md.append(f"  - {line}")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    def esc(x):
        return str(x).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
    cards = []
    for panel in payload.get("panels") or []:
        lis = "".join(f"<li>{esc(line)}</li>" for line in panel.get("lines") or [])
        cards.append(
            f"<section class='card {esc(panel.get('severity','INFO')).lower()}'>"
            f"<h2>{esc(panel.get('title'))}</h2>"
            f"<p><strong>{esc(panel.get('status'))}</strong> · {esc(panel.get('panel_id'))}</p>"
            f"<ul>{lis}</ul>"
            f"</section>"
        )
    html = f"""<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>Forge Dashboard v2 Operator Panel</title>
<style>
body {{ font-family: system-ui, sans-serif; margin: 2rem; background: #101214; color: #e8e8e8; }}
h1 {{ margin-bottom: 0.25rem; }}
.meta {{ color: #aab; margin-bottom: 1.5rem; }}
.grid {{ display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }}
.card {{ border: 1px solid #333b44; border-radius: 12px; padding: 1rem; background: #181b20; }}
.card.good {{ border-color: #376b3a; }}
.card.warn {{ border-color: #7b6532; }}
.card.locked {{ border-color: #4c6a8b; }}
.card.info {{ border-color: #3f4854; }}
li {{ margin: 0.35rem 0; }}
</style>
</head>
<body>
<h1>Forge Dashboard v2 Operator Panel</h1>
<div class="meta">Current: {esc(payload.get('current_phase'))} · Next: {esc(payload.get('next_patch'))} · Generated: {esc(payload.get('created_at'))}</div>
<div class="grid">
{''.join(cards)}
</div>
</body>
</html>
"""
    html_path.write_text(html, encoding="utf-8")

    latest_json = FORGE_DASHBOARD_V2_DIR / f"latest_{stem}.json"
    latest_md = FORGE_DASHBOARD_V2_DIR / f"latest_{stem}.md"
    latest_html = FORGE_DASHBOARD_V2_DIR / f"latest_{stem}.html"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_html.write_text(html_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path, html_path


