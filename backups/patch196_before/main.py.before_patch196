def _p181_file_summary(scope, rollback):
    summary = {}
    if isinstance(rollback, dict):
        summary = dict(rollback.get("candidate_file_summary") or {})
    if not summary and isinstance(scope, dict):
        summary = dict(scope.get("candidate_file_summary") or scope.get("file_summary") or {})
    summary.setdefault("file_count", 0)
    summary.setdefault("python_file_count", 0)
    summary.setdefault("config_file_count", 0)
    summary.setdefault("duplicate_basenames", [])
    summary.setdefault("exact_sha_rows_present", False)
