def _p185_load_proposal(slug: str):
    """Find and return an approved proposal dict, or None with error message."""
    import json as _j
    cmd_gen_dir = MEMORY_DIR / "forge_command_generator_v1" / "proposals"
    matches = sorted(cmd_gen_dir.glob(f"*{slug}*_proposal.json"))
    if not matches:
        return None, f"No proposal found matching '{slug}'"
    if len(matches) > 1:
        names = ", ".join(m.stem for m in matches)
        return None, f"Multiple proposals match '{slug}': {names}"
    prop = _j.loads(matches[0].read_text())
    return prop, None


