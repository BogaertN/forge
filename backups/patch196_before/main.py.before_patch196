def _p152_write_report(payload: dict, stem: str):
    _p152_ensure_dirs()
    stamp = _p152_stamp()
    json_path = FORGE_SNAPSHOT_CREATE_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_SNAPSHOT_CREATE_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "snapshot_id", "snapshot_root", "created_file_count", "verified_file_count", "problem_count", "live_restore_authority"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("summary"):
        md.append("")
        md.append("## Summary")
        for k, v in (payload.get("summary") or {}).items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("domains"):
        md.append("")
        md.append("## Domains")
        for domain in payload.get("domains") or []:
            md.append(f"- **{domain.get('domain_id')}** — {domain.get('title')}: `{domain.get('status')}` files=`{domain.get('file_count')}` problems=`{len(domain.get('problems') or [])}`")
    if payload.get("problems"):
        md.append("")
        md.append("## Problems")
        for problem in payload.get("problems") or []:
            md.append(f"- `{problem}`")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_SNAPSHOT_CREATE_DIR / f"latest_{stem}.json"
    latest_md = FORGE_SNAPSHOT_CREATE_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


def _p152_candidate_sources() -> list[dict]:
    plan = _p152_latest_plan()
    sources = []
    # Explicitly include the core files first.
    core_paths = [
        FORGE_ROOT / "main.py",
        FORGE_ROOT / "config" / "tool_registry.json",
        FORGE_ROOT / "config" / "session_scope.json",
        FORGE_ROOT / "config" / "approved_paths.json",
    ]
    for p in core_paths:
        sources.append({"domain_id": "D01", "title": "Forge runtime core", "path": str(p)})

    # Pull planned include patterns from Patch 151 for memory evidence domains.
    for domain in plan.get("snapshot_domains") or []:
        did = domain.get("domain_id") or "DXX"
        title = domain.get("title") or "Unnamed domain"
        for raw in domain.get("include_patterns") or []:
            if not isinstance(raw, str):
                continue
            if not raw.startswith("/home/nic/forge"):
                # Audit-tail virtual source is handled separately.
                continue
            sources.append({"domain_id": did, "title": title, "path": raw})
    return sources


def _p152_iter_files(path: Path, max_files: int = 4000):
    if _p152_is_forbidden(path):
        return
    if path.is_file():
        yield path
        return
    if path.is_dir():
        count = 0
        for child in sorted(path.rglob("*")):
            if count >= max_files:
                break
            if _p152_is_forbidden(child):
                continue
            if child.is_file():
                count += 1
                yield child


def _p152_copy_file(src: Path, dest: Path) -> tuple[bool, str | None]:
    try:
        dest.parent.mkdir(parents=True, exist_ok=True)
        data = src.read_bytes()
        # Keep snapshots bounded; large files are skipped, not partially copied.
        if len(data) > 8 * 1024 * 1024:
            return False, f"SKIPPED_LARGE_FILE:{src}:{len(data)}"
        dest.write_bytes(data)
        return True, None
    except Exception as e:
        return False, f"COPY_ERROR:{src}:{e}"


def _p152_create_snapshot(target: str = "next") -> dict:
    _p152_ensure_dirs()
    stamp = _p152_stamp()
    snapshot_id = f"forge_snapshot_{stamp}"
    snapshot_root = FORGE_SNAPSHOT_ARCHIVE_DIR / snapshot_id
    files_root = snapshot_root / "files"
    snapshot_root.mkdir(parents=True, exist_ok=True)
    files_root.mkdir(parents=True, exist_ok=True)

    plan = _p152_latest_plan()
    domains: dict[str, dict] = {}
    entries = []
    problems = []
    seen_sources = set()
    total_bytes = 0
    max_total_bytes = 120 * 1024 * 1024

    for src_info in _p152_candidate_sources():
        did = src_info.get("domain_id") or "DXX"
        title = src_info.get("title") or "Unknown"
        domains.setdefault(did, {"domain_id": did, "title": title, "status": "READY", "file_count": 0, "problems": []})
        src_path = Path(src_info.get("path") or "")
        if not src_path.exists():
            msg = f"MISSING_SOURCE:{src_path}"
            domains[did]["problems"].append(msg)
            problems.append(msg)
            continue
        for file_path in _p152_iter_files(src_path):
            if str(file_path) in seen_sources:
                continue
            seen_sources.add(str(file_path))
            try:
                size = file_path.stat().st_size
            except Exception:
                size = 0
            if total_bytes + size > max_total_bytes:
                msg = f"SKIPPED_TOTAL_LIMIT:{file_path}"
                domains[did]["problems"].append(msg)
                problems.append(msg)
                continue
            rel = _p152_rel_safe_path(file_path)
            dest = files_root / rel
            ok, err = _p152_copy_file(file_path, dest)
            if not ok:
                domains[did]["problems"].append(err)
                problems.append(err)
                continue
            src_hash = _p152_sha256_file(file_path)
            dst_hash = _p152_sha256_file(dest)
            total_bytes += size
            entry = {
                "domain_id": did,
                "source_path": str(file_path),
                "snapshot_path": str(dest),
                "relative_path": rel,
                "size_bytes": size,
                "source_sha256": src_hash,
                "snapshot_sha256": dst_hash,
                "hash_match": bool(src_hash and dst_hash and src_hash == dst_hash),
            }
            entries.append(entry)
            domains[did]["file_count"] += 1
            if not entry["hash_match"]:
                msg = f"HASH_MISMATCH:{file_path}"
                domains[did]["problems"].append(msg)
                problems.append(msg)

    # Audit log tail is copied as evidence, never overwritten.
    try:
        audit_src = FORGE_ROOT / "logs" / "forge_audit.log"
        audit_dest = files_root / "audit_tail" / "forge_audit_tail_snapshot.txt"
        audit_dest.parent.mkdir(parents=True, exist_ok=True)
        lines = audit_src.read_text(encoding="utf-8", errors="replace").splitlines()[-5000:]
        audit_dest.write_text("\n".join(lines) + "\n", encoding="utf-8")
        entry = {
            "domain_id": "D05",
            "source_path": str(audit_src),
            "snapshot_path": str(audit_dest),
            "relative_path": "audit_tail/forge_audit_tail_snapshot.txt",
            "size_bytes": audit_dest.stat().st_size,
            "source_sha256": "TAIL_COPY_ONLY_DO_NOT_COMPARE_TO_FULL_LOG",
            "snapshot_sha256": _p152_sha256_file(audit_dest),
            "hash_match": True,
        }
        entries.append(entry)
        domains.setdefault("D05", {"domain_id": "D05", "title": "Audit tail capture", "status": "READY", "file_count": 0, "problems": []})["file_count"] += 1
    except Exception as e:
        msg = f"AUDIT_TAIL_COPY_ERROR:{e}"
        domains.setdefault("D05", {"domain_id": "D05", "title": "Audit tail capture", "status": "READY", "file_count": 0, "problems": []})["problems"].append(msg)
        problems.append(msg)

    for domain in domains.values():
        if domain["problems"]:
            domain["status"] = "READY_WITH_WARNINGS"
        if domain["file_count"] == 0 and not domain["problems"]:
            domain["status"] = "NO_FILES_FOUND"

    manifest = {
        "schema_version": FORGE_SNAPSHOT_CREATE_SCHEMA_VERSION,
        "report_type": "FORGE_SNAPSHOT_CREATE_VERIFY",
        "created_at": _p152_now(),
        "status": "FORGE_SNAPSHOT_CREATE_READY" if not [p for p in problems if p.startswith("HASH_MISMATCH") or p.startswith("COPY_ERROR")] else "FORGE_SNAPSHOT_CREATE_READY_WITH_WARNINGS",
        "active_patch": "Patch 152 — Snapshot Create / Verify",
        "current_phase": "S17B — Snapshot Create / Verify",
        "next_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "recommended_next_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "snapshot_id": snapshot_id,
        "snapshot_root": str(snapshot_root),
        "target": target or "next",
        "source_plan_status": plan.get("status") if plan else "MISSING_PLAN",
        "created_file_count": len(entries),
        "created_total_bytes": total_bytes,
        "domains": sorted(domains.values(), key=lambda d: d.get("domain_id") or ""),
        "files": entries,
        "problems": problems,
        "problem_count": len(problems),
        "live_restore_authority": False,
        "project_file_write_authority": False,
        "engine_file_write_authority": False,
        "snapshot_write_scope": str(FORGE_SNAPSHOT_ARCHIVE_DIR),
        "authority": {
            "forge_owned_snapshot_write": True,
            "live_restore_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "audit_log_overwrite": False,
        },
        "summary": {
            "snapshot_created": True,
            "snapshot_verified_at_creation": False,
            "file_count": len(entries),
            "domain_count": len(domains),
            "problem_count": len(problems),
            "append_only_roadmap_preserved": True,
        },
        "next_commands": [
            "forge-snapshot-create-verify",
            "forge-snapshot-create-export",
            "forge-build-sequence",
            "forge-status-api-build",
            "forge-dashboard-build",
        ],
    }
    manifest_path = snapshot_root / "snapshot_manifest.json"
    manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True), encoding="utf-8")
    manifest["manifest_path"] = str(manifest_path)
    manifest["manifest_sha256"] = _p152_sha256_file(manifest_path)
    manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True), encoding="utf-8")
    _p152_write_report(manifest, FORGE_SNAPSHOT_CREATE_STEM)
    return manifest


def _p152_verify_snapshot(snapshot: dict | None = None) -> dict:
    snapshot = snapshot or _p152_latest_snapshot()
    problems = []
    verified_count = 0
    files = snapshot.get("files") or []
    for entry in files:
        snap_path = Path(entry.get("snapshot_path") or "")
        expected = entry.get("snapshot_sha256")
        actual = _p152_sha256_file(snap_path)
        if not snap_path.exists():
            problems.append(f"MISSING_SNAPSHOT_FILE:{snap_path}")
            continue
        if expected and actual != expected:
            problems.append(f"SNAPSHOT_HASH_CHANGED:{snap_path}")
            continue
        verified_count += 1

    status = "FORGE_SNAPSHOT_CREATE_VERIFY_PASS" if files and not problems else "FORGE_SNAPSHOT_CREATE_VERIFY_FAIL"
    payload = {
        "schema_version": FORGE_SNAPSHOT_CREATE_SCHEMA_VERSION,
        "report_type": "FORGE_SNAPSHOT_CREATE_VERIFICATION",
        "created_at": _p152_now(),
        "status": status,
        "active_patch": "Patch 152 — Snapshot Create / Verify",
        "current_phase": "S17B — Snapshot Create / Verify",
        "next_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "recommended_next_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "snapshot_id": snapshot.get("snapshot_id"),
        "snapshot_root": snapshot.get("snapshot_root"),
        "created_file_count": len(files),
        "verified_file_count": verified_count,
        "problem_count": len(problems),
        "problems": problems,
        "live_restore_authority": False,
        "authority": {
            "verification_only": True,
            "live_restore_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
        },
        "summary": {
            "snapshot_created": bool(files),
            "snapshot_verified": bool(files and not problems),
            "file_count": len(files),
            "verified_file_count": verified_count,
        },
        "next_commands": ["forge-snapshot-create-export", "forge-build-sequence", "forge-status-api-build", "forge-dashboard-build", "Install Patch 153 when ready"],
    }
    _p152_write_report(payload, f"{FORGE_SNAPSHOT_CREATE_STEM}_verification")
    return payload


