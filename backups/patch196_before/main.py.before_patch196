def _p162_now() -> str:
    import datetime
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _p162_stamp() -> str:
    import datetime
    return datetime.datetime.now().strftime("%Y%m%d_%H%M%S")


def _p162_safe_json(path, default=None):
    try:
        p = Path(path)
        if not p.exists():
            return default if default is not None else {}
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default if default is not None else {}


def _p162_write_json_md(payload: dict, stem: str):
    FORGE_RUNTIME_LIVE_PREFLIGHT_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p162_stamp()
    jp = FORGE_RUNTIME_LIVE_PREFLIGHT_DIR / f"{stamp}_{stem}.json"
    mp = FORGE_RUNTIME_LIVE_PREFLIGHT_DIR / f"{stamp}_{stem}.md"
    latest_jp = FORGE_RUNTIME_LIVE_PREFLIGHT_DIR / f"latest_{stem}.json"
    latest_mp = FORGE_RUNTIME_LIVE_PREFLIGHT_DIR / f"latest_{stem}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(text + "\n", encoding="utf-8")
    latest_jp.write_text(text + "\n", encoding="utf-8")
    md = _p162_markdown(payload)
    mp.write_text(md, encoding="utf-8")
    latest_mp.write_text(md, encoding="utf-8")
    return jp, mp


def _p162_markdown(payload: dict) -> str:
    lines = [
        "# Forge Runtime Live Build Preflight — Patch 162",
        "",
        f"- Status: `{payload.get('status')}`",
        f"- Candidate: `{payload.get('candidate')}`",
        f"- Planning ready: `{payload.get('planning_ready')}`",
        f"- Live build ready: `{payload.get('live_build_ready')}`",
        f"- Human approval present: `{payload.get('human_approval_present')}`",
        f"- Next patch: `{payload.get('next_patch')}`",
        "",
        "## Gates",
    ]
    for g in payload.get("gates") or []:
        lines.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')}: {g.get('detail')}")
    lines.extend(["", "## Authority", "```json", json.dumps(payload.get("authority") or {}, indent=2, sort_keys=True), "```", ""])
    return "\n".join(lines)


