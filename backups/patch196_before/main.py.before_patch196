def _p180_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19Z" not in ids:
        rows.append({"id":"S19Z","status":"ACTIVE","title":"Runtime Candidate Dry-Plan Rollback Matrix / No-Write Restore Plan","patch":"Patch 180 — Runtime Candidate Dry-Plan Rollback Matrix / No-Write Restore Plan","summary":"Prepare rollback/restore planning before any sandbox execution or live apply.","authority":"rollback planning only; no runtime writes"})
    if "S19AA" not in ids:
        rows.append({"id":"S19AA","status":"NEXT","title":"Runtime Candidate Sandbox Execution Preflight / No-Write Gate","patch":"Patch 181 — Runtime Candidate Sandbox Execution Preflight / No-Write Gate","summary":"Check all receipts, scope rows, SHA rows, validation matrix, rollback matrix, and sandbox readiness before any sandbox execution patch.","authority":"preflight only; no runtime writes"})
    done_ids = {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R","S19S","S19T","S19U","S19V","S19W","S19X","S19Y"}
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in done_ids:
            row["status"] = "DONE"
        elif rid == "S19Z":
            row["status"] = "ACTIVE"
        elif rid == "S19AA":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


