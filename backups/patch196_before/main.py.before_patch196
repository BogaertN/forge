def _p135_now() -> str:
    return _p135_datetime.now().replace(microsecond=0).isoformat()


def _p135_stamp() -> str:
    return _p135_datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p135_load(path, default=None):
    try:
        p = _P135Path(path)
        if p.exists():
            return _p135_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p135_write(payload: dict, stem: str) -> tuple[_P135Path, _P135Path]:
    GENERIC_REPAIR_DIR.mkdir(parents=True, exist_ok=True)
    ts = _p135_stamp()
    jp = GENERIC_REPAIR_DIR / f"{ts}_{stem}.json"
    mp = GENERIC_REPAIR_DIR / f"{ts}_{stem}.md"
    latest_jp = GENERIC_REPAIR_DIR / f"latest_{stem}.json"
    latest_mp = GENERIC_REPAIR_DIR / f"latest_{stem}.md"
    raw = _p135_json.dumps(payload, indent=2, ensure_ascii=False, sort_keys=True)
    jp.write_text(raw, encoding="utf-8")
    latest_jp.write_text(raw, encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"Status: `{payload.get('status')}`",
        f"Created: `{payload.get('created_at')}`",
        f"Target: `{payload.get('target', 'unknown')}`",
        "",
        "## Plain English",
        "",
        str(payload.get("plain_english") or ""),
        "",
        "## Authority",
        "",
    ]
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- `{k}`: `{v}`")
    if payload.get("recommendation"):
        lines += ["", "## Recommendation", "", str(payload.get("recommendation"))]
    if payload.get("problems"):
        lines += ["", "## Problems", ""]
        for item in payload.get("problems") or []:
            lines.append(f"- {item}")
    if payload.get("next_commands"):
        lines += ["", "## Next Commands", ""]
        for item in payload.get("next_commands") or []:
            lines.append(f"- `{item}`")
    md = "\n".join(lines) + "\n"
    mp.write_text(md, encoding="utf-8")
    latest_mp.write_text(md, encoding="utf-8")
    return jp, mp


def _p135_sha(path) -> str | None:
    try:
        p = _P135Path(path)
        if not p.exists() or not p.is_file():
            return None
        h = _p135_hashlib.sha256()
        with p.open("rb") as f:
            for b in iter(lambda: f.read(1024 * 1024), b""):
                h.update(b)
        return h.hexdigest()
    except Exception:
        return None


def _p135_under(path, parent) -> bool:
    try:
        _P135Path(path).resolve().relative_to(_P135Path(parent).resolve())
        return True
    except Exception:
        return False


