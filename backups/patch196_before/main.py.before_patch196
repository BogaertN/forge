        if p.is_absolute():
            return False
        if ".." in p.parts:
            return False
        return True
    except Exception:
        return False


def _snapshot_shadow_copy_within(root: Path, child: Path) -> bool:
    try:
        root_r = Path(root).resolve()
        child_r = Path(child).resolve()
        return child_r == root_r or root_r in child_r.parents
    except Exception:
        return False


def _snapshot_shadow_copy_markdown(receipt: dict, md_path: Path) -> None:
    counts = receipt.get("counts", {})
    lines = [
        "# Patch 86 Shadow Restore Copy Sandbox Receipt",
        "",
        "Mode: FORGE-OWNED SHADOW COPY ONLY. No live restore authority exists.",
        f"Created: `{receipt.get('created_at')}`",
        f"Status: `{receipt.get('status')}`",
        f"Shadow root: `{receipt.get('shadow_copy_root')}`",
        "",
        "## Counts",
        f"- Files planned: `{counts.get('planned_files')}`",
        f"- Files copied: `{counts.get('files_copied')}`",
        f"- Hash mismatches: `{counts.get('hash_mismatches')}`",
        f"- Blockers: `{counts.get('blockers')}`",
        f"- Warnings: `{counts.get('warnings')}`",
        "",
        "## Authority",
    ]
    for k, v in receipt.get("authority", {}).items():
        lines.append(f"- {k}: `{v}`")
    lines.extend(["", "## Notes"])
    for note in receipt.get("plain_english", []):
        lines.append(f"- {note}")
    if receipt.get("blockers"):
        lines.extend(["", "## Blockers"])
        for item in receipt.get("blockers", [])[:50]:
            lines.append(f"- {item}")
    if receipt.get("warnings"):
        lines.extend(["", "## Warnings"])
        for item in receipt.get("warnings", [])[:50]:
            lines.append(f"- {item}")
    lines.extend(["", "## Copied Files"])
    for row in (receipt.get("copied_files") or [])[:200]:
        lines.append(f"- `{row.get('planned_shadow_relative_path')}` sha=`{row.get('copied_sha256_16')}` match=`{row.get('hash_match')}`")
    md_path.write_text("\n".join(lines), encoding="utf-8")


def _snapshot_shadow_copy_build(arg: str = "latest") -> tuple[dict, Path, Path]:
    import shutil as _shutil
    now = datetime.datetime.now().isoformat(timespec="seconds")
    ts = _patch60_timestamp()
    SNAPSHOT_SHADOW_COPIES_DIR.mkdir(parents=True, exist_ok=True)
    plan_path = _snapshot_shadow_resolve_path(arg or "latest")
    plan = _snapshot_shadow_load(plan_path) if plan_path and plan_path.exists() else None
    blockers: list[str] = []
    warnings: list[str] = []
    copied_files: list[dict] = []
    if not plan_path or not plan_path.exists():
        blockers.append("No shadow restore plan found. Run snapshot-shadow-plan first.")
    if not plan:
        blockers.append("Shadow restore plan could not be loaded as JSON.")
    if plan:
        ok, problems, plan_warnings = _snapshot_shadow_validate_plan(plan)
        warnings.extend(plan_warnings)
        if not ok:
            blockers.append(f"Shadow restore plan validation failed: {len(problems)} problems")
            for item in problems[:10]:
                blockers.append(f"plan: {item}")
    receipt_path = Path(str((plan or {}).get("source_snapshot_receipt") or ""))
    receipt = _snapshot_create_load(receipt_path) if receipt_path and receipt_path.exists() else None
    if plan and (not receipt_path or not receipt_path.exists()):
        blockers.append("Source snapshot receipt referenced by shadow plan does not exist.")
    if receipt:
        verify_ok, verify_problems, verify_warnings = _snapshot_create_verify_receipt(receipt)
        warnings.extend(verify_warnings)
        if not verify_ok:
            blockers.append(f"Source snapshot receipt verification failed: {len(verify_problems)} problems")
            for item in verify_problems[:10]:
                blockers.append(f"snapshot: {item}")
    archive_root = Path(str((plan or {}).get("source_archive_root") or ""))
    if plan and (not archive_root.exists() or not archive_root.is_dir()):
        blockers.append("Source snapshot archive root does not exist or is not a directory.")
    shadow_root = SNAPSHOT_SHADOW_COPIES_DIR / f"{ts}_shadow_restore_copy_sandbox"
    if shadow_root.exists():
        blockers.append(f"Shadow root already exists unexpectedly: {shadow_root}")
    if not blockers:
        shadow_root.mkdir(parents=True, exist_ok=False)
        for idx, row in enumerate((plan or {}).get("planned_files") or [], start=1):
            rel = str(row.get("planned_shadow_relative_path") or "")
            src_rel = str(row.get("snapshot_relative_path") or "")
            row_result = {
                "index": idx,
                "source_path": row.get("source_path"),
                "snapshot_archive_file": row.get("snapshot_archive_file"),
                "snapshot_relative_path": src_rel,
                "planned_shadow_relative_path": rel,
                "expected_sha256": row.get("sha256"),
                "expected_sha256_16": row.get("sha256_16"),
                "copied_sha256": None,
                "copied_sha256_16": None,
                "hash_match": False,
                "copied": False,
                "error": None,
            }
            if not _snapshot_shadow_copy_safe_rel(rel):
                row_result["error"] = f"unsafe planned shadow relative path: {rel}"
                copied_files.append(row_result)
                continue
            if not _snapshot_shadow_copy_safe_rel(src_rel):
                row_result["error"] = f"unsafe snapshot relative path: {src_rel}"
                copied_files.append(row_result)
                continue
            src_file = archive_root / src_rel
            if not src_file.exists() or not src_file.is_file():
                row_result["error"] = f"snapshot archive file missing: {src_file}"
                copied_files.append(row_result)
                continue
            if not _snapshot_shadow_copy_within(archive_root, src_file):
                row_result["error"] = f"snapshot archive file escapes archive root: {src_file}"
                copied_files.append(row_result)
                continue
            dest_file = shadow_root / rel
            if not _snapshot_shadow_copy_within(shadow_root, dest_file.parent if dest_file.parent.exists() else shadow_root):
                row_result["error"] = f"planned destination escapes shadow root: {dest_file}"
                copied_files.append(row_result)
                continue
            dest_file.parent.mkdir(parents=True, exist_ok=True)
            try:
                _shutil.copy2(src_file, dest_file)
                copied_sha = _snapshot_shadow_copy_full_sha(dest_file)
                row_result["copied"] = True
                row_result["shadow_file"] = str(dest_file)
                row_result["copied_sha256"] = copied_sha
                row_result["copied_sha256_16"] = copied_sha[:16] if copied_sha else None
                row_result["size_bytes"] = dest_file.stat().st_size if dest_file.exists() else None
                row_result["hash_match"] = bool(copied_sha and copied_sha == row.get("sha256"))
                if not row_result["hash_match"]:
                    row_result["error"] = "copied hash does not match expected snapshot hash"
            except Exception as e:
                row_result["error"] = str(e)
            copied_files.append(row_result)
    failed_rows = [r for r in copied_files if not r.get("copied") or r.get("hash_match") is not True]
    if failed_rows:
        blockers.append(f"One or more planned files failed shadow copy/hash verification: {len(failed_rows)}")
    receipt_payload = {
        "schema_version": SNAPSHOT_SHADOW_COPY_SCHEMA_VERSION,
        "report_type": "SNAPSHOT_SHADOW_COPY_SANDBOX_V1_PATCH86",
        "created_at": now,
        "mode": "FORGE_OWNED_SHADOW_COPY_ONLY_NO_LIVE_RESTORE",
        "status": "SHADOW_COPY_SANDBOX_READY_NO_LIVE_RESTORE" if not blockers else "SHADOW_COPY_SANDBOX_BLOCKED",
        "authority": _snapshot_shadow_copy_authority(),
        "source_shadow_plan": str(plan_path) if plan_path else None,
        "source_snapshot_receipt": str(receipt_path) if receipt_path else None,
        "source_archive_root": str(archive_root) if archive_root else None,
        "shadow_copy_root": str(shadow_root) if shadow_root.exists() else None,
        "copied_files": copied_files,
        "blockers": blockers,
        "warnings": warnings,
        "counts": {
            "planned_files": len((plan or {}).get("planned_files") or []),
            "files_copied": sum(1 for r in copied_files if r.get("copied")),
            "hash_matches": sum(1 for r in copied_files if r.get("hash_match") is True),
            "hash_mismatches": sum(1 for r in copied_files if r.get("copied") and r.get("hash_match") is not True),
            "failed_rows": len(failed_rows),
            "blockers": len(blockers),
            "warnings": len(warnings),
        },
        "plain_english": [
            "Patch 86 copied snapshot files only into a Forge-owned shadow area.",
            "This is not a restore. Live Forge and AI.Web project files were not modified by this command.",
            "A future restore-readiness patch must be separate and explicit before any live restore can exist.",
        ],
    }
    json_path = SNAPSHOT_SHADOW_COPIES_DIR / f"{ts}_{SNAPSHOT_SHADOW_COPY_PREFIX}.json"
    md_path = SNAPSHOT_SHADOW_COPIES_DIR / f"{ts}_{SNAPSHOT_SHADOW_COPY_PREFIX}.md"
    json_path.write_text(json.dumps(receipt_payload, indent=2, ensure_ascii=False), encoding="utf-8")
    _snapshot_shadow_copy_markdown(receipt_payload, md_path)
    return receipt_payload, json_path, md_path


def _snapshot_shadow_copy_validate_receipt(receipt: dict) -> tuple[bool, list[str], list[str]]:
    problems: list[str] = []
    warnings: list[str] = []
    if not isinstance(receipt, dict):
        return False, ["shadow copy receipt is not a JSON object"], warnings
    if receipt.get("schema_version") != SNAPSHOT_SHADOW_COPY_SCHEMA_VERSION:
        problems.append("schema_version mismatch")
    if receipt.get("mode") != "FORGE_OWNED_SHADOW_COPY_ONLY_NO_LIVE_RESTORE":
        problems.append("mode is not shadow-copy-only")
    authority = receipt.get("authority") or {}
    for key in ["restore_authority", "live_restore_authority", "project_file_write_authority", "engine_file_write_authority", "delete_authority", "quarantine_authority", "shell_execution_authority", "chroma_write_authority", "snapshot_create_authority", "final_lockfile_authority"]:
        if authority.get(key) is not False:
            problems.append(f"forbidden authority flag not false: {key}")
    shadow_root = Path(str(receipt.get("shadow_copy_root") or ""))
    if not shadow_root.exists() or not shadow_root.is_dir():
        problems.append("shadow_copy_root does not exist or is not a directory")
    copied_files = receipt.get("copied_files") or []
    if not copied_files:
        problems.append("receipt contains no copied_files rows")
    for row in copied_files:
        rel = str(row.get("planned_shadow_relative_path") or "")
        if not _snapshot_shadow_copy_safe_rel(rel):
            problems.append(f"unsafe copied relative path: {rel}")
            continue
        dest = shadow_root / rel
        if not dest.exists() or not dest.is_file():
            problems.append(f"copied file missing: {dest}")
            continue
        actual_sha = _snapshot_shadow_copy_full_sha(dest)
        expected_sha = row.get("expected_sha256")
        if actual_sha != expected_sha:
            problems.append(f"hash mismatch: {rel}")
    if receipt.get("warnings"):
        warnings.extend(receipt.get("warnings") or [])
    if receipt.get("blockers"):
        problems.extend(receipt.get("blockers") or [])
    return not problems, problems, warnings


