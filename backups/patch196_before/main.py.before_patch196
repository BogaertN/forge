    return payload




# ─── PATCH 151: SNAPSHOT / FORENSIC REPLAY PLAN ────────────────────────────
# Purpose:
#   Add a read-only Forge-owned snapshot and forensic replay planning layer.
#   This patch does not create live snapshots, does not restore anything, and
#   does not grant live apply authority. It defines the next safety layer that
#   Patch 152 will turn into snapshot creation and verification.
# Authority:
#   Forge-owned memory/report writes only. No project writes. No engine writes.
#   No patch apply authority. No shell execution.

FORGE_SNAPSHOT_PLAN_SCHEMA_VERSION = "forge_snapshot_forensic_replay_plan_v1_patch151"
FORGE_SNAPSHOT_PLAN_DIR = MEMORY_DIR / "forge_snapshot_forensic_replay_plan_v1"
FORGE_SNAPSHOT_PLAN_STEM = "forge_snapshot_forensic_replay_plan"
FORGE_SNAPSHOT_PLAN_EXPORT_STEM = "forge_snapshot_forensic_replay_plan_export"

PATCH151_COMMANDS = [
    "forge-snapshot-plan-policy",
    "forge-snapshot-plan-build",
    "forge-snapshot-plan-show",
    "forge-snapshot-plan-list",
    "forge-snapshot-plan-next",
    "forge-snapshot-plan-export",
]

for _patch151_cmd in PATCH151_COMMANDS:
    if _patch151_cmd not in FORGE_EXPECTED_COMMANDS:
        FORGE_EXPECTED_COMMANDS.append(_patch151_cmd)


def _p151_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p151_stamp() -> str:
    return _p151_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p151_ensure_dir() -> None:
    FORGE_SNAPSHOT_PLAN_DIR.mkdir(parents=True, exist_ok=True)


def _p151_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p151_sha256(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p151_write(payload: dict, stem: str):
    _p151_ensure_dir()
    stamp = _p151_stamp()
    json_path = FORGE_SNAPSHOT_PLAN_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_SNAPSHOT_PLAN_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "plan_target", "snapshot_evidence_created", "live_restore_authority"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("plan_summary"):
        md.append("")
        md.append("## Plan Summary")
        for item in payload.get("plan_summary") or []:
            md.append(f"- {item}")
    if payload.get("snapshot_domains"):
        md.append("")
        md.append("## Snapshot Domains")
        for domain in payload.get("snapshot_domains") or []:
            md.append(f"- **{domain.get('domain_id')}** — {domain.get('title')}: `{domain.get('status')}`")
    if payload.get("forbidden_paths"):
        md.append("")
        md.append("## Forbidden Paths")
        for item in payload.get("forbidden_paths") or []:
            md.append(f"- `{item}`")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_SNAPSHOT_PLAN_DIR / f"latest_{stem}.json"
    latest_md = FORGE_SNAPSHOT_PLAN_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


def _p151_latest_plan() -> dict:
    return _p151_safe_json(FORGE_SNAPSHOT_PLAN_DIR / f"latest_{FORGE_SNAPSHOT_PLAN_STEM}.json", {})


