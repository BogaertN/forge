        "sandbox_target_mode": sandbox_target_mode,
        "target_explanation": "snapshot_replay means the sandbox is expected to match the verified self-snapshot, even if that snapshot predates Patch 122 commands.",
        "plan_path": str(plan_path),
        "copied_count": len([r for r in copied if r.get("ok")]),
