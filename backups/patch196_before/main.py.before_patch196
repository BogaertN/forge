    return payload


def _p153_copy_shadow(plan: dict) -> dict:
    _p153_ensure_dirs()
    problems = []
    copied = []
    snapshot_root = Path(plan.get("snapshot_root") or "")
    files_root = snapshot_root / "files"
    shadow_root = Path(plan.get("shadow_root") or (FORGE_SHADOW_RESTORE_ROOT / f"shadow_restore_{_p153_stamp()}"))
    shadow_files_root = shadow_root / "shadow_files"
    manifest = _p153_snapshot_receipt()
    source_files = manifest.get("files") or []

    if plan.get("status") != "FORGE_SHADOW_RESTORE_PLAN_READY":
        problems.append(f"PLAN_NOT_READY:{plan.get('status')}")
    if not files_root.exists():
        problems.append(f"SNAPSHOT_FILES_ROOT_MISSING:{files_root}")

    for row in source_files:
        rel = row.get("relative_path")
        expected_sha = row.get("snapshot_sha256")
        if not rel:
            continue
        src = files_root / rel
        dest = shadow_files_root / rel
        if not src.exists():
            problems.append(f"SNAPSHOT_FILE_MISSING:{rel}")
            copied.append({"relative_path": rel, "status": "MISSING_SOURCE", "expected_sha256": expected_sha})
            continue
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dest)
            got_sha = _p153_sha256_file(dest)
            ok = got_sha == expected_sha
            if not ok:
                problems.append(f"SHADOW_HASH_MISMATCH:{rel}")
            copied.append({
                "relative_path": rel,
                "status": "COPIED" if ok else "HASH_MISMATCH",
                "expected_sha256": expected_sha,
                "shadow_sha256": got_sha,
                "shadow_path": str(dest),
            })
        except Exception as e:
            problems.append(f"SHADOW_COPY_ERROR:{rel}:{e}")
            copied.append({"relative_path": rel, "status": "COPY_ERROR", "problem": str(e), "expected_sha256": expected_sha})

    status = "FORGE_SHADOW_RESTORE_RUN_PASS" if not problems else "FORGE_SHADOW_RESTORE_RUN_WITH_PROBLEMS"
    payload = {
        "schema_version": FORGE_SHADOW_RESTORE_SCHEMA_VERSION,
        "report_type": "FORGE_SHADOW_RESTORE_RUN",
        "created_at": _p153_now(),
        "status": status,
        "active_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "current_phase": "S17C — Shadow Restore / Forensic Diff",
        "next_patch": "Patch 154 — Dashboard v2 / Operator Control Panel",
        "recommended_next_patch": "Patch 154 — Dashboard v2 / Operator Control Panel",
        "snapshot_id": plan.get("snapshot_id"),
        "snapshot_root": str(snapshot_root),
        "shadow_id": plan.get("shadow_id"),
        "shadow_root": str(shadow_root),
        "copied_file_count": len([r for r in copied if r.get("status") == "COPIED"]),
        "file_count": len(source_files),
        "problem_count": len(problems),
        "problems": problems,
        "copied_files": copied,
        "summary": {
            "shadow_copy_pass": not bool(problems),
            "live_restore_performed": False,
            "snapshot_file_count": len(source_files),
            "shadow_copied_file_count": len([r for r in copied if r.get("status") == "COPIED"]),
        },
        "next_commands": ["forge-shadow-restore-diff latest", "forge-shadow-restore-export", "forge-build-sequence"],
        "authority": _p153_authority(),
    }
    _p153_write_report(payload, FORGE_SHADOW_RUN_STEM)
    return payload


def _p153_build_diff(run: dict) -> dict:
    manifest = _p153_snapshot_receipt()
    files = manifest.get("files") or []
    shadow_root = Path(run.get("shadow_root") or "")
    shadow_files_root = shadow_root / "shadow_files"
    rows = []
    problems = []
    live_changed = 0
    live_missing = 0
    live_unchanged = 0
    shadow_mismatch = 0
    shadow_missing = 0
    for row in files:
        rel = row.get("relative_path")
        expected_sha = row.get("snapshot_sha256")
        source_path = Path(row.get("source_path") or "")
        shadow_path = shadow_files_root / rel if rel else None
        live_sha = _p153_sha256_file(source_path) if source_path else None
        shadow_sha = _p153_sha256_file(shadow_path) if shadow_path else None
        live_status = "UNCHANGED"
        if live_sha is None:
            live_status = "MISSING"
            live_missing += 1
        elif live_sha != expected_sha:
            live_status = "CHANGED_SINCE_SNAPSHOT"
            live_changed += 1
        else:
            live_unchanged += 1
        shadow_status = "MATCH"
        if shadow_sha is None:
            shadow_status = "MISSING"
            shadow_missing += 1
            problems.append(f"SHADOW_FILE_MISSING:{rel}")
        elif shadow_sha != expected_sha:
            shadow_status = "MISMATCH"
            shadow_mismatch += 1
            problems.append(f"SHADOW_FILE_MISMATCH:{rel}")
        rows.append({
            "relative_path": rel,
            "source_path": str(source_path),
            "snapshot_sha256": expected_sha,
            "live_sha256": live_sha,
            "live_status": live_status,
            "shadow_sha256": shadow_sha,
            "shadow_status": shadow_status,
        })

    status = "FORGE_SHADOW_RESTORE_FORENSIC_DIFF_READY" if not problems else "FORGE_SHADOW_RESTORE_FORENSIC_DIFF_WITH_PROBLEMS"
    payload = {
        "schema_version": FORGE_SHADOW_RESTORE_SCHEMA_VERSION,
        "report_type": "FORGE_SHADOW_RESTORE_FORENSIC_DIFF",
        "created_at": _p153_now(),
        "status": status,
        "active_patch": "Patch 153 — Shadow Restore / Forensic Diff",
        "current_phase": "S17C — Shadow Restore / Forensic Diff",
        "next_patch": "Patch 154 — Dashboard v2 / Operator Control Panel",
        "recommended_next_patch": "Patch 154 — Dashboard v2 / Operator Control Panel",
        "snapshot_id": manifest.get("snapshot_id"),
        "snapshot_root": manifest.get("snapshot_root"),
        "shadow_id": run.get("shadow_id"),
        "shadow_root": run.get("shadow_root"),
        "file_count": len(files),
        "problem_count": len(problems),
        "problems": problems,
        "diff_rows": rows,
        "summary": {
            "shadow_matches_snapshot": shadow_mismatch == 0 and shadow_missing == 0,
            "shadow_mismatch_count": shadow_mismatch,
            "shadow_missing_count": shadow_missing,
            "live_unchanged_count": live_unchanged,
            "live_changed_since_snapshot_count": live_changed,
            "live_missing_count": live_missing,
            "live_restore_performed": False,
        },
        "next_commands": ["forge-shadow-restore-export", "forge-build-sequence", "forge-status-api-build", "forge-dashboard-build", "Install Patch 154 when ready"],
        "authority": _p153_authority({"forensic_diff_only": True}),
    }
    _p153_write_report(payload, FORGE_SHADOW_DIFF_STEM)
    return payload


