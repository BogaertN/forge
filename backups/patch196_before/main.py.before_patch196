    "failsafe_manager",
    "system_log_engine",
    "symbolic_policy_engine",
}

_PATCH69_MANUAL_ALWAYS_TERMS = (
    "protoforge",
    "cold_archive",
    "memory_stack_engine",
    "drift_arbitration_engine",
)


def _patch69_latest_review_report() -> Path | None:
    CODE_MANIFESTS_DIR.mkdir(parents=True, exist_ok=True)
    candidates = sorted(
        CODE_MANIFESTS_DIR.glob("*engine_canonical_review.json"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    return candidates[0] if candidates else None


def _patch69_load_or_build_review() -> dict:
    latest = _patch69_latest_review_report()
    if latest:
        try:
            return json.loads(latest.read_text(encoding="utf-8"))
        except Exception:
            pass
    return _patch68_build_canonical_review()


def _patch69_decide_row(row: dict) -> dict:
    base = str(row.get("engine_base", ""))
    base_l = base.lower()
    cand = dict(row.get("provisional_keep", {}) or {})
    root = str(cand.get("root", ""))
    root_l = root.lower()
    tags = set(cand.get("status_tags", []) or [])
    flags = list(row.get("review_flags", []) or [])
    variants = list(row.get("variants", []) or [])
    active_primary = [v for v in variants if v.get("root_class") == "primary_aiweb_root" and "active_or_unfrozen" in set(v.get("status_tags", []) or [])]
    active_any = [v for v in variants if "active_or_unfrozen" in set(v.get("status_tags", []) or [])]

    required_checks: list[str] = []
    cautions: list[str] = []
    draft_decision = "DRAFT_KEEP_AFTER_HUMAN_REVIEW"
    decision_confidence = "medium"
    recommended_keep = root
    reason = "Highest scored candidate from Patch 68 review; no lockfile written."

    if any(term in base_l for term in _PATCH69_MANUAL_ALWAYS_TERMS) or any(term in root_l for term in ("protoforge", "cold_archive")):
        draft_decision = "HOLD_FOR_MANUAL_ARCHITECT_REVIEW"
        decision_confidence = "manual"
        required_checks.append("architect_review_required_before_lockfile")
        reason = "Engine family has runtime-wrapper, archive/frozen, or foundational ambiguity that must not be auto-decided."

    if "candidate_is_frozen" in flags or "frozen" in tags:
        if active_primary:
            recommended_keep = active_primary[0].get("root")
            draft_decision = "DRAFT_KEEP_ACTIVE_PRIMARY_OVER_FROZEN_CANDIDATE"
            decision_confidence = "medium"
            required_checks.append("verify_active_primary_supersedes_frozen_candidate")
            reason = "Patch 68 scored a frozen candidate, but an active primary AI.Web variant exists; draft favors active primary until reviewed."
        else:
            draft_decision = "HOLD_FROZEN_CANDIDATE_REVIEW"
            decision_confidence = "manual"
            required_checks.append("frozen_candidate_requires_human_review")
            reason = "Candidate is frozen and no active primary replacement was found."

    if "candidate_is_backup_or_archive" in flags or "backup_or_archive" in tags:
        draft_decision = "HOLD_ARCHIVE_AMBIGUITY_REVIEW"
        decision_confidence = "manual"
        required_checks.append("archive_or_backup_candidate_requires_human_review")
        reason = "Candidate appears backup/archive related; no automatic keep/lock decision is allowed."

    if "candidate_is_test_only" in flags or "test_only" in tags:
        draft_decision = "HOLD_TEST_ONLY_REVIEW"
        decision_confidence = "manual"
        required_checks.append("test_only_candidate_requires_human_review")
        reason = "Candidate appears test-only; it cannot become canonical without manual review."

    if root and not root_l.startswith(("aiweb/engines/", "aiweb/agents/", "aiweb/runtime_wrappers/", "aiweb/symbolic_layers/")):
        cautions.append("recommended path is not under primary aiweb root")
        if decision_confidence != "manual":
            decision_confidence = "low"

    if len(active_any) > 1:
        required_checks.append("compare_multiple_active_variants")
    if int(row.get("variant_count", 0) or 0) >= 6:
        required_checks.append("inspect_high_duplicate_variant_count")
    if base in _PATCH69_CORE_KEEP_BASES and decision_confidence != "manual":
        cautions.append("core runtime role candidate; verify against symbolic-runtime-map before lockfile")
        decision_confidence = "medium_high" if decision_confidence == "medium" else decision_confidence

    # Keep ordered unique checks.
    seen = set()
    required_checks = [x for x in required_checks if not (x in seen or seen.add(x))]
    seen = set()
    cautions = [x for x in cautions if not (x in seen or seen.add(x))]

    return {
        "engine_base": base,
        "draft_decision": draft_decision,
        "decision_confidence": decision_confidence,
        "recommended_keep_path": recommended_keep,
        "patch68_keep_candidate": root,
        "candidate_score": cand.get("canonical_score"),
        "candidate_tags": cand.get("status_tags", []),
        "status_from_review": row.get("status"),
        "review_flags": flags,
        "variant_count": row.get("variant_count"),
        "required_human_checks": required_checks,
        "cautions": cautions,
        "reason": reason,
        "no_file_action": True,
        "lockfile_written": False,
        "quarantine_written": False,
        "variants": row.get("variants", []),
    }


def _patch69_build_decision_draft() -> dict:
    review = _patch69_load_or_build_review()
    decisions = [_patch69_decide_row(row) for row in review.get("review", [])]
    counts: dict[str, int] = {}
    confidence_counts: dict[str, int] = {}
    for d in decisions:
        counts[d.get("draft_decision", "unknown")] = counts.get(d.get("draft_decision", "unknown"), 0) + 1
        confidence_counts[d.get("decision_confidence", "unknown")] = confidence_counts.get(d.get("decision_confidence", "unknown"), 0) + 1
    return {
        "report_type": "patch69_canonical_engine_decision_draft",
        "timestamp": datetime.datetime.now().isoformat(timespec="seconds"),
        "read_only": True,
        "implemented_destructive_action": False,
        "lockfile_written": False,
        "quarantine_written": False,
        "source_review_type": review.get("report_type"),
        "source_review_timestamp": review.get("timestamp"),
        "engine_count": review.get("engine_count"),
        "duplicate_group_count": review.get("duplicate_group_count"),
        "decision_count": len(decisions),
        "decision_counts": counts,
        "confidence_counts": confidence_counts,
        "policy": {
            "mode": "decision_draft_only",
            "forbidden": ["move", "delete", "rename", "quarantine", "promote", "lock", "edit_engine_files"],
            "next_phase": "canonical_lockfile_after_human_review_only",
            "rule": "Draft decisions are not authority. They are review aids for Nic before a lockfile exists.",
        },
        "decisions": decisions,
    }


