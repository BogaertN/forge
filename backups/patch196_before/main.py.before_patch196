def _p165_write_json_md(payload: dict, stem: str):
    import json
    FORGE_RUNTIME_LIVE_FINAL_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p165_stamp()
    jp = FORGE_RUNTIME_LIVE_FINAL_DIR / f"{stamp}_{stem}.json"
