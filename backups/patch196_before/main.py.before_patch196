def _patch125_now() -> str:
    return datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch125_iso_now() -> str:
    return datetime.datetime.now().isoformat(timespec="seconds")


def _patch125_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch125_write_json_md(payload: dict, prefix: str):
    CANONICAL_RELATIONSHIP_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch125_now()
    json_path = CANONICAL_RELATIONSHIP_DIR / f"{stamp}_{prefix}.json"
    md_path = CANONICAL_RELATIONSHIP_DIR / f"{stamp}_{prefix}.md"
    text = json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False)
    json_path.write_text(text + "\n", encoding="utf-8")
    md = _patch125_markdown(payload)
    md_path.write_text(md, encoding="utf-8")
    (CANONICAL_RELATIONSHIP_DIR / f"latest_{prefix}.json").write_text(text + "\n", encoding="utf-8")
    (CANONICAL_RELATIONSHIP_DIR / f"latest_{prefix}.md").write_text(md, encoding="utf-8")
    return json_path, md_path


def _patch125_markdown(payload: dict) -> str:
    lines = []
    lines.append(f"# {payload.get('report_type', 'CANONICAL_ENGINE_RELATIONSHIP_MAP')}\n")
    lines.append(f"Status: `{payload.get('status', 'UNKNOWN')}`\n")
    if payload.get("plain_english"):
        lines.append(payload.get("plain_english") + "\n")
    counts = payload.get("counts") or {}
    if counts:
        lines.append("## Counts")
        for k, v in counts.items():
            lines.append(f"- {k}: {v}")
        lines.append("")
    if payload.get("rows"):
        lines.append("## Canonical Relationship Rows")
        for row in payload.get("rows", [])[:120]:
            lines.append(f"### {row.get('engine_base')}")
            lines.append(f"- canonical_path: `{row.get('canonical_path')}`")
            lines.append(f"- resolved_path: `{row.get('resolved_path')}`")
            lines.append(f"- relationship_count: {row.get('relationship_count')}")
            lines.append(f"- risk_level: `{row.get('risk_level')}`")
            lines.append(f"- test_status: `{row.get('test_status')}`")
            if row.get("neighbors"):
                lines.append("- neighbors:")
                for n in row.get("neighbors", [])[:10]:
                    lines.append(f"  - {n.get('engine_base')} — {n.get('reason')} ({n.get('confidence')})")
            lines.append("")
    if payload.get("risk_rows"):
        lines.append("## Risk Neighbors")
        for row in payload.get("risk_rows", []):
            lines.append(f"- {row.get('engine_base')}: {row.get('risk_level')} — {row.get('risk_reason')}")
        lines.append("")
    lines.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- {k}: {v}")
    lines.append("")
    return "\n".join(lines)


