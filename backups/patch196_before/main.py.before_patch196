        }
    source_report = _patch97a_read_json(source_report_path) or {}
    for row in source_report.get("rows", []):
        json_scan = _patch97a_scan_json_dirs(row)
        sqlite_scan = _patch97a_scan_chroma_sqlite(row)
        status, ready, route, warnings, blockers = _patch97a_classify(row, json_scan, sqlite_scan)
        rows.append({
            "source_key": row.get("source_key"),
            "display_name": row.get("display_name"),
            "prior_patch97_status": row.get("status"),
            "prior_patch97_ready": row.get("source_law_ready"),
