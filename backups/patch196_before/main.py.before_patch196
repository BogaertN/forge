    write_audit_entry(session_id, "GENERIC_REVISION_CANDIDATE_LLM_CALL_STARTED", str(prompt_path), f"model={model}", "shell_false=true")
    result = _p140_run_proc(["ollama", "run", model, prompt], cwd=str(Path.home() / "forge"), timeout=240)
    raw = result.get("stdout") or ""
    err = result.get("stderr") or ""
    raw_path.write_text(raw, encoding="utf-8")
    err_path.write_text(err, encoding="utf-8")
    upper = raw.upper()
    if "USE_COREBREATHER_WRAPPER" in upper or "COREBREATHER" in upper or "COREBREATHER CLASS" in upper:
