def _snapshot_manifest_validate_payload(manifest: dict) -> tuple[bool, list[str]]:
    problems = []
    if not isinstance(manifest, dict):
        return False, ["manifest is not a JSON object"]
    if manifest.get("schema_version") != SNAPSHOT_MANIFEST_SCHEMA_VERSION:
        problems.append("schema_version mismatch")
    if manifest.get("mode") != "HASH_MANIFEST_DRY_RUN_ONLY_NO_FILE_COPY_NO_RESTORE":
        problems.append("mode is not dry-run only")
    authority = manifest.get("authority", {})
    for key, value in authority.items():
        if value is not False:
            problems.append(f"authority flag {key} is not false")
    invariants = manifest.get("invariants", {})
    if invariants.get("content_copied") is not False:
        problems.append("content_copied invariant is not false")
    if invariants.get("restore_authority") is not False:
        problems.append("restore_authority invariant is not false")
    if invariants.get("project_file_write_authority") is not False:
        problems.append("project_file_write_authority invariant is not false")
    counts = manifest.get("counts", {})
    if counts.get("total_files_hashed", 0) <= 0:
        problems.append("no files were hashed")
    # Verify every included file row has a hash and no content copy flag.
    rows = list(manifest.get("direct_files", []))
    for scan in manifest.get("root_scans", []) + manifest.get("candidate_engine_root_scans", []):
        rows.extend(scan.get("files", []))
    for row in rows:
        if row.get("included"):
            if not row.get("sha256") or len(str(row.get("sha256"))) != 64:
                problems.append(f"included row missing full sha256: {row.get('path')}")
            if row.get("content_copied") is not False:
                problems.append(f"included row content_copied not false: {row.get('path')}")
    return len(problems) == 0, problems


