def cmd_forge_command_regen_proposal(slug: str, session_id: str):
    """
    Regenerate the function code for an existing proposal using the fixed
    code generator. Use this to fix proposals that failed to install due to
    the quote-in-description bug.

    Usage: forge-command-regen-proposal <slug>

    What this does:
      1. Loads the existing proposal
