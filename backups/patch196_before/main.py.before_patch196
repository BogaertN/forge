from pathlib import Path as _Patch132Path
import json as _patch132_json
import hashlib as _patch132_hashlib
from datetime import datetime as _patch132_datetime

LLM_PATCH_PROPOSALS_DIR = FORGE_ROOT / "memory" / "llm_patch_proposals_v1"
LLM_PATCH_PROPOSALS_DIR.mkdir(parents=True, exist_ok=True)


def _patch132_iso_now() -> str:
    return _patch132_datetime.now().replace(microsecond=0).isoformat()


def _patch132_slug(value: str) -> str:
    s = "".join(ch if ch.isalnum() or ch in "._-" else "_" for ch in str(value or "target").strip())
    return s.strip("_") or "target"


def _patch132_load_json(path):
    try:
        p = _Patch132Path(path)
        if not p.exists():
            return {}
        with p.open("r", encoding="utf-8") as f:
            return _patch132_json.load(f)
    except Exception:
        return {}


def _patch132_sha256(path):
    try:
        h = _patch132_hashlib.sha256()
        p = _Patch132Path(path)
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _patch132_write_json_md(payload: dict, stem: str):
    LLM_PATCH_PROPOSALS_DIR.mkdir(parents=True, exist_ok=True)
    ts = _patch132_datetime.now().strftime("%Y_%m_%d_%H%M%S")
    json_path = LLM_PATCH_PROPOSALS_DIR / f"{ts}_{stem}.json"
    md_path = LLM_PATCH_PROPOSALS_DIR / f"{ts}_{stem}.md"
    json_path.write_text(_patch132_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md_lines = [f"# {payload.get('report_type', stem)}", "", f"Status: `{payload.get('status')}`", ""]
    if payload.get("target"):
        md_lines.append(f"Target: `{payload.get('target')}`")
    if payload.get("recommended_next_patch"):
        md_lines.append(f"Next: `{payload.get('recommended_next_patch')}`")
    if payload.get("summary"):
        md_lines.append("")
        md_lines.append("## Summary")
        for k, v in (payload.get("summary") or {}).items():
            md_lines.append(f"- **{k}**: `{v}`")
    if payload.get("authority"):
        md_lines.append("")
        md_lines.append("## Authority")
        for k, v in (payload.get("authority") or {}).items():
            md_lines.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md_lines) + "\n", encoding="utf-8")
    latest_json = LLM_PATCH_PROPOSALS_DIR / f"latest_{stem}.json"
    latest_md = LLM_PATCH_PROPOSALS_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


