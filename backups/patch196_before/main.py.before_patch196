    except Exception:
        return False

def _p138_find_dependency_candidates(module_name):
    from pathlib import Path
    module_name = str(module_name or "").strip()
    top = module_name.split(".")[0] if module_name else ""
    leaf = module_name.split(".")[-1] if module_name else ""
    if not top:
        return []
    roots = [
        Path.home() / "aiweb" / "engines",
        Path.home() / "aiweb",
    ]
    found = []
    def add(kind, path, reason):
        try:
            p = Path(path)
            if not p.exists():
                return
            sp = str(p.resolve())
            if any(x.get("path") == sp for x in found):
                return
            found.append({
                "kind": kind,
                "path": sp,
                "reason": reason,
                "requested_module": module_name,
                "top_level_module": top,
                "leaf_module": leaf,
            })
        except Exception:
            return

    for root in roots:
        if not root.exists():
            continue
        add("package_dir", root / top, "direct_top_package_match")
        add("module_file", root / f"{top}.py", "direct_top_file_match")
        if leaf and leaf != top:
            add("module_file", root / f"{leaf}.py", "direct_leaf_file_match")

    # bounded fallback under approved AI.Web tree. Skip hidden/cache/env dirs.
    for root in roots:
        if not root.exists():
            continue
        try:
            for p in root.rglob(top):
                if len(found) >= 16:
                    break
                parts = set(p.parts)
                if ".venv" in parts or "__pycache__" in parts or ".git" in parts or "node_modules" in parts:
                    continue
                if p.is_dir() and p.name == top:
                    add("package_dir", p, "bounded_rglob_top_package_match")
            for pattern, reason in [(f"{top}.py", "bounded_rglob_top_file_match"), (f"{leaf}.py", "bounded_rglob_leaf_file_match")]:
                if not pattern or pattern == ".py":
                    continue
                for p in root.rglob(pattern):
                    if len(found) >= 16:
                        break
                    parts = set(p.parts)
                    if ".venv" in parts or "__pycache__" in parts or ".git" in parts or "node_modules" in parts:
                        continue
                    if p.is_file():
                        add("module_file", p, reason)
        except Exception:
            continue
    return found

def _p138_install_dependency_candidate(new_parent, candidate, module_name):
    """Copy a dependency candidate into sandbox_packages using import-compatible shape.

    If the live dependency is a single file but the failing import expects
    package.module, create sandbox_packages/<top>/<file>.py plus __init__.py
    instead of sandbox_packages/<top>.py. That prevents the file from shadowing
    the package import path.
    """
    import shutil
    from pathlib import Path
    new_parent = Path(new_parent)
    dep_path = Path((candidate or {}).get("path") or "").resolve()
    module_name = str(module_name or (candidate or {}).get("requested_module") or dep_path.stem)
    top = module_name.split(".")[0] if module_name else dep_path.stem
    leaf = module_name.split(".")[-1] if module_name else dep_path.stem
    installed = []

    if (candidate or {}).get("kind") == "package_dir":
        dest = new_parent / top
        _p138_copytree_filtered(dep_path, dest)
        init = dest / "__init__.py"
        if not init.exists():
            init.write_text("# Forge sandbox package shim\n", encoding="utf-8")
        installed.append(str(dest))
        return {"strategy": "copy_package_dir", "installed_paths": installed, "package_dir": str(dest)}

    if (candidate or {}).get("kind") == "module_file":
        # Prefer package-shaped install because imports commonly use
        # from <top>.<leaf> import ...
        pkg_dir = new_parent / top
        pkg_dir.mkdir(parents=True, exist_ok=True)
        module_filename = dep_path.name
        dest = pkg_dir / module_filename
        shutil.copy2(dep_path, dest)

        init = pkg_dir / "__init__.py"
        stem = dep_path.stem
        init_text = (
            "# Forge sandbox package shim generated from module file dependency.\n"
            f"try:\n"
            f"    from .{stem} import *\n"
            f"except Exception:\n"
            f"    pass\n"
        )
        init.write_text(init_text, encoding="utf-8")
        installed.extend([str(dest), str(init)])
        return {"strategy": "copy_module_file_as_package", "installed_paths": installed, "package_dir": str(pkg_dir)}

    return {"strategy": "unsupported_dependency_candidate", "installed_paths": installed}

def _p138_copytree_filtered(src, dst):
    import shutil, os
    from pathlib import Path
    src = Path(src)
    dst = Path(dst)
    def ignore(dirpath, names):
        blocked = set()
        for n in names:
            if n in {"__pycache__", ".git", ".venv", "node_modules"}:
                blocked.add(n)
            if n.endswith((".pyc", ".pyo")):
                blocked.add(n)
        return blocked
    if dst.exists():
        shutil.rmtree(dst)
    shutil.copytree(src, dst, ignore=ignore)

def _p138_run_proc(argv, cwd=None, env=None, timeout=45):
    import subprocess, time
    started = _p138_now()
    try:
        cp = subprocess.run(
            argv,
            cwd=cwd,
            env=env,
            text=True,
            capture_output=True,
            timeout=timeout,
            shell=False,
        )
        return {
            "argv": argv,
            "cwd": str(cwd) if cwd else None,
            "started_at": started,
            "ended_at": _p138_now(),
            "returncode": cp.returncode,
            "stdout": cp.stdout[-12000:],
            "stderr": cp.stderr[-12000:],
            "timeout": False,
            "shell": False,
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "argv": argv,
            "cwd": str(cwd) if cwd else None,
            "started_at": started,
            "ended_at": _p138_now(),
            "returncode": None,
            "stdout": (exc.stdout or "")[-12000:] if isinstance(exc.stdout, str) else "",
            "stderr": (exc.stderr or "")[-12000:] if isinstance(exc.stderr, str) else "",
            "timeout": True,
            "shell": False,
        }
    except Exception as exc:
        return {
            "argv": argv,
            "cwd": str(cwd) if cwd else None,
            "started_at": started,
            "ended_at": _p138_now(),
            "returncode": None,
            "stdout": "",
            "stderr": f"{type(exc).__name__}: {exc}",
            "timeout": False,
            "shell": False,
        }

