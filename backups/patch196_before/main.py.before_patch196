def _p170_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19P" not in ids:
        rows.append({"id":"S19P","status":"ACTIVE","title":"Runtime Live Build Approval Token Validation / Final Execution Preflight","patch":"Patch 170 — Runtime Live Build Approval Token Validation / Final Execution Preflight","summary":"Validate approval token state and final preflight while performing zero live writes.","authority":"validation gate only; no runtime writes"})
