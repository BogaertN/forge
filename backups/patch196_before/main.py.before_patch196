def _patch109_latest_plan_path() -> Path:
    p = ENGINE_REVIEW_TRIAGE_DIR / f"latest_{ENGINE_REVIEW_TRIAGE_PLAN_PREFIX}.json"
    if p.exists():
        return p
    files = sorted(ENGINE_REVIEW_TRIAGE_DIR.glob(f"*_{ENGINE_REVIEW_TRIAGE_PLAN_PREFIX}.json")) if ENGINE_REVIEW_TRIAGE_DIR.exists() else []
    return files[-1] if files else p


def _patch109_row_for_engine(engine: str) -> tuple[dict | None, dict]:
    plan_path = _patch109_latest_plan_path()
    plan = _patch109_read_json(plan_path) if plan_path.exists() else _patch109_build_plan()
    fam = _patch109_slug(engine)
    for r in plan.get("rows") or []:
        if _patch109_slug(r.get("engine_family")) == fam:
            return r, plan
    return None, plan


def _patch109_parse_engine_args(arg: str) -> list[str]:
    raw = (arg or "").strip()
    if not raw:
        return []
    bits = [b.strip() for b in re.split(r"[,\s]+", raw) if b.strip()]
    if len(bits) == 1 and bits[0].lower() in {"latest", "next", "ready"}:
        plan = _patch109_build_plan()
        return [r.get("engine_family") for r in plan.get("rows") or [] if r.get("ready_for_triage_decision")][:1]
    return [_patch109_slug(b) for b in bits if _patch109_slug(b)]


