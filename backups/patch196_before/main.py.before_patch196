    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _patch129_write_json_md(payload: dict, stem: str, md_lines: Optional[list] = None):
    FORGE_MODE_REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch129_stamp()
    json_path = FORGE_MODE_REGISTRY_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_MODE_REGISTRY_DIR / f"{stamp}_{stem}.md"
    latest_json = FORGE_MODE_REGISTRY_DIR / f"latest_{stem}.json"
    latest_md = FORGE_MODE_REGISTRY_DIR / f"latest_{stem}.md"
    json_text = json.dumps(payload, indent=2, sort_keys=True)
    json_path.write_text(json_text + "\n", encoding="utf-8")
    latest_json.write_text(json_text + "\n", encoding="utf-8")
    if md_lines is None:
        md_lines = [f"# {stem}", "", f"Status: `{payload.get('status')}`", ""]
        for k, v in (payload.get("summary") or {}).items():
            md_lines.append(f"- `{k}`: `{v}`")
    md_text = "\n".join(md_lines).rstrip() + "\n"
    md_path.write_text(md_text, encoding="utf-8")
    latest_md.write_text(md_text, encoding="utf-8")
    return json_path, md_path


