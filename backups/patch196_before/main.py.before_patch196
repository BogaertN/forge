    from agents.forge.memory import write_audit_entry
    import os
    model = os.environ.get("FORGE_LLM_MODEL", "qwen3:8b")
    P140_DIR.mkdir(parents=True, exist_ok=True)
    ts = _p140_stamp()
    safe = _p140_safe_name(target)
    prompt_path = P140_DIR / f"{ts}_prompt_revision_candidate_{safe}.txt"
    raw_path = P140_DIR / f"{ts}_response_raw_revision_candidate_{safe}.txt"
    err_path = P140_DIR / f"{ts}_response_stderr_revision_candidate_{safe}.txt"
