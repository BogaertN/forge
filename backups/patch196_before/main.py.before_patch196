        "next_patch": "Patch 158 — Runtime Build Sandbox Plan / Dry Run",
        "recommended_next_patch": "Patch 158 — Runtime Build Sandbox Plan / Dry Run",
        "status": "FORGE_RUNTIME_BUILD_PLAN_READY_PLANNING_ONLY" if planning_ready else "FORGE_RUNTIME_BUILD_PLAN_HAS_PLANNING_BLOCKERS",
        "planning_ready": planning_ready,
        "live_build_ready": False,
        "selected_candidate": candidate,
        "shortlist_count": len(shortlisted),
        "candidate_shortlist": shortlisted,
        "runtime_module_map_status": runtime_map.get("status") or "NOT_BUILT_YET",
        "runtime_module_map_engine_count": runtime_map.get("canonical_engine_count"),
        "runtime_module_map_domain_count": runtime_map.get("domain_count"),
        "gates": gates,
        "blockers": blockers,
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
