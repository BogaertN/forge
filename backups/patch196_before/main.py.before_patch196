    if "S19U" not in ids:
        rows.append({"id":"S19U","status":"ACTIVE","title":"Runtime Candidate Dry-Plan Selector / No-Write Planning Gate","patch":"Patch 175 — Runtime Candidate Dry-Plan Selector / No-Write Planning Gate","summary":"Select or preserve the next runtime candidate for dry planning only, with no approval, execution, or live writes.","authority":"dry-plan selector only; no runtime writes"})
