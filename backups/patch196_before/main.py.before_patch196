def _p134_under(path: Path, parent: Path) -> bool:
    try:
        path.resolve().relative_to(parent.resolve())
        return True
    except Exception:
        return False


def _p134_find_engine_path(engine_name: str) -> Path:
    root = Path("/home/nic/aiweb") / "engines"
    direct = root / engine_name
    if direct.exists():
        return direct
    alt = root / engine_name.replace("-", "_")
    if alt.exists():
        return alt
    return direct


def _p134_find_test_candidates(target_path: Path) -> list[str]:
    try:
        p = Path(target_path)
        base = p if p.is_dir() else p.parent
        if not base.exists():
            return []
        found = []
        for pattern in ("test_*.py", "*_test.py", "tests.py"):
            found.extend(sorted(base.glob(pattern)))
        return [str(x) for x in found if x.is_file()]
    except Exception:
        return []


def _p134_resolve_target(arg: str) -> dict:
    raw = (arg or "").strip()
    if raw in {"", "latest", "plan"}:
        prior = _p134_load(_p134_latest_plan_path())
        if prior.get("target"):
            return prior.get("resolved_target") or {}
        raw = "stack_linker_breather"
    aiweb_root = Path("/home/nic/aiweb")
    forge_root = Path("/home/nic/forge")
    engines_root = aiweb_root / "engines"
    looks_like_path = raw.startswith("/") or raw.startswith("~") or "/" in raw or raw.endswith(".py")
    if looks_like_path:
        p = Path(raw).expanduser()
        if not p.is_absolute():
            p = (Path.cwd() / p).resolve()
        else:
            p = p.resolve()
        target_kind = "python_file" if p.suffix == ".py" else ("directory" if p.is_dir() else "path")
        engine_name = p.parent.name if p.suffix == ".py" else p.name
        scope_ok = _p134_under(p, aiweb_root) or _p134_under(p, forge_root)
        test_candidates = _p134_find_test_candidates(p)
        return {"raw": raw, "target": str(p), "target_kind": target_kind, "engine_name": engine_name, "scope_ok": scope_ok, "target_exists": p.exists(), "target_path": str(p), "test_candidates": test_candidates}
    engine_name = raw.replace("-", "_")
    engine_dir = _p134_find_engine_path(engine_name)
    test_candidates = _p134_find_test_candidates(engine_dir)
    return {"raw": raw, "target": engine_name, "target_kind": "canonical_or_engine_name", "engine_name": engine_name, "scope_ok": _p134_under(engine_dir, aiweb_root), "target_exists": engine_dir.exists(), "target_path": str(engine_dir), "test_candidates": test_candidates}


def _p134_plan_payload(target: str) -> dict:
    resolved = _p134_resolve_target(target)
    problems = []
    if not resolved.get("scope_ok"):
        problems.append("target is outside approved Forge/AI.Web diagnostic scope")
    if not resolved.get("target_exists"):
        problems.append("target path does not exist")
    if resolved.get("target_kind") != "python_file" and not resolved.get("test_candidates"):
        problems.append("no test-like Python file found beside target")
    status = "IMPORT_PROBE_PLAN_READY" if not problems else "IMPORT_PROBE_PLAN_READY_WITH_BLOCKERS"
