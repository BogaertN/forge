def _patch132_verify_payload(payload: dict) -> dict:
    problems = []
    warnings = []
    if not payload:
        problems.append("missing proposal payload")
    authority = payload.get("authority") or {}
    for key in ["project_file_write_authority", "engine_file_write_authority", "forge_self_write_authority", "patch_apply_authority", "shell_execution_authority", "ledger_mutation_authority", "chroma_write_authority"]:
        if authority.get(key) is not False:
            problems.append(f"authority flag must be false: {key}")
    if authority.get("requires_human_approval") is not True:
        problems.append("requires_human_approval must be true")
    target = ((payload.get("target_files") or {}).get("primary_target") or {})
    if not target.get("absolute"):
        problems.append("missing target path")
    elif not target.get("under_aiweb"):
        warnings.append("target path is not under /home/nic/aiweb")
    if target.get("exists") is not True:
        warnings.append("target path does not currently exist or is a directory without file sha")
    source_evidence = payload.get("source_evidence") or {}
    docs = source_evidence.get("candidate_documents") or []
    if not docs:
        warnings.append("no candidate source documents found for target")
    missing_docs = [d for d in docs if not d.get("exists")]
    if missing_docs:
        warnings.append(f"candidate source documents missing on disk: {len(missing_docs)}")
    if source_evidence.get("authority_claimed") is not False:
        problems.append("source authority must remain candidate-only in Patch 132")
