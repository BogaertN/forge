def _load_json(path: Path) -> dict:
    with open(path, "r") as f:
        return json.load(f)


def _save_json(path: Path, data: dict):
    with open(path, "w") as f:
        json.dump(data, f, indent=2)


def _make_session_id() -> str:
    now = datetime.datetime.now()
    return f"forge_{now.strftime('%Y_%m_%d_%H%M%S')}"


# Patch 130B — Dynamic Forge Boot Banner
# Read-only boot status surface.  No audit writes, no project writes, no authority changes.
def _boot_banner_load_json(path: Path) -> dict:
    try:
        if path and path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return {}


def _boot_banner_latest_json(pattern: str) -> dict:
    """Return the newest matching JSON file under Forge memory, or {} if unavailable."""
    try:
        matches = list(MEMORY_DIR.glob(pattern))
        if not matches:
            return {}
        newest = max(matches, key=lambda p: p.stat().st_mtime)
        return _boot_banner_load_json(newest)
    except Exception:
        return {}


def _boot_banner_short(value, fallback: str = "?") -> str:
    if value is None:
        return fallback
    text = str(value)
    return text if text else fallback


def _boot_banner_short_sha(value) -> str:
    text = _boot_banner_short(value, "")
    if not text:
        return "?"
    return text[:12]


def _boot_banner_tool_state() -> dict:
    registry = _boot_banner_load_json(CONFIG_DIR / "tool_registry.json")
    tools = registry.get("tools", {}) if isinstance(registry.get("tools", {}), dict) else {}
    return {
        "tools": len(tools) if tools else "?",
        "trust": registry.get("current_trust_level") or registry.get("trust_level") or "?",
    }


def _boot_banner_command_surface() -> dict:
    expected_commands = globals().get("FORGE_EXPECTED_COMMANDS", [])
    expected = len(expected_commands) if expected_commands else "?"
    found = "?"
    try:
        source = Path(__file__).read_text(encoding="utf-8")
        if expected_commands:
            found = sum(1 for cmd in expected_commands if f'"{cmd}"' in source or f"'{cmd}'" in source)
    except Exception:
        found = "?"
    return {"expected": expected, "found": found}


def _boot_banner_status_snapshot() -> dict:
    return _boot_banner_load_json(MEMORY_DIR / "forge_status_api_v1" / "latest_forge_status_api_snapshot_v1.json")


def _boot_banner_canonical_lockfile() -> dict:
