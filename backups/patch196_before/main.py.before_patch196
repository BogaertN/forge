def _patch128_stamp() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _patch128_safe_load_json(path: Path):
    try:
        if path and Path(path).exists():
            return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return None
    return None


def _patch128_latest_json(dir_path: Path, latest_name: str):
    p = dir_path / latest_name
    if p.exists():
        return p, _patch128_safe_load_json(p)
    return None, None


def _patch128_hash_file(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch128_write_json_md(payload: dict, prefix: str, md_lines: list[str] | None = None):
    FORGE_DASHBOARD_READONLY_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch128_stamp()
    json_path = FORGE_DASHBOARD_READONLY_DIR / f"{stamp}_{prefix}.json"
    latest_json_path = FORGE_DASHBOARD_READONLY_DIR / f"latest_{prefix}.json"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    latest_json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md_path = FORGE_DASHBOARD_READONLY_DIR / f"{stamp}_{prefix}.md"
    latest_md_path = FORGE_DASHBOARD_READONLY_DIR / f"latest_{prefix}.md"
    if md_lines is None:
        md_lines = [
            f"# {payload.get('report_type', prefix)}",
            "",
            f"Status: `{payload.get('status', 'UNKNOWN')}`",
            "",
            "This is a Forge-owned read-only dashboard/report artifact. It does not start a server and does not change project files.",
        ]
    md_text = "\n".join(md_lines) + "\n"
    md_path.write_text(md_text, encoding="utf-8")
    latest_md_path.write_text(md_text, encoding="utf-8")
    return json_path, md_path


