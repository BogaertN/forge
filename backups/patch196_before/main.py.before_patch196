# === PATCH 136: Generic Repair Patch Candidate Builder ===
# Purpose: Convert the latest generic LLM repair proposal into a Forge-memory-only
# candidate diff. This layer inspects current target file contents, verifies the
# current SHA against prior evidence when available, writes candidate artifacts only
# under /home/nic/forge/memory/generic_repair_candidates_v1, and never edits AI.Web.

import difflib as _p136_difflib
import py_compile as _p136_py_compile
import tempfile as _p136_tempfile

P136_MEMORY_DIR = Path.home() / "forge" / "memory" / "generic_repair_candidates_v1"
P136_CONFIRM = "CONFIRM_BUILD_GENERIC_REPAIR_CANDIDATE"


def _p136_now() -> str:
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _p136_stamp() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p136_sha_text(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8", errors="replace")).hexdigest()


def _p136_sha_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _p136_load_json(path: Path) -> dict:
    try:
        if path and path.exists():
            return json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        return {}
    return {}


def _p136_write(payload: dict, stem: str) -> tuple[Path, Path]:
    P136_MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    jp = P136_MEMORY_DIR / f"{_p136_stamp()}_{stem}.json"
    mp = P136_MEMORY_DIR / f"{_p136_stamp()}_{stem}.md"
    latest_jp = P136_MEMORY_DIR / f"latest_{stem}.json"
    latest_mp = P136_MEMORY_DIR / f"latest_{stem}.md"
    txt = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(txt, encoding="utf-8")
    latest_jp.write_text(txt, encoding="utf-8")
    md = [f"# {payload.get('report_type', stem)}", "", f"status: {payload.get('status')}", f"created_at: {payload.get('created_at')}"]
    for key in ("target", "target_file", "candidate_status", "recommended_next_patch"):
        if payload.get(key) is not None:
            md.append(f"{key}: {payload.get(key)}")
    md_text = "\n".join(md) + "\n"
    mp.write_text(md_text, encoding="utf-8")
    latest_mp.write_text(md_text, encoding="utf-8")
    return jp, mp


def _p136_latest_file(folder: Path, pattern: str) -> Path | None:
    try:
        files = [p for p in folder.glob(pattern) if p.is_file() and not p.name.startswith("latest_")]
        if files:
            return max(files, key=lambda p: p.stat().st_mtime)
        latest = folder / ("latest_" + pattern.replace("*", ""))
        if latest.exists():
            return latest
    except Exception:
        return None
    return None


