                "post-write disk verification",
            ],
        },
        "gates": gates,
        "warnings": warnings,
        "blockers": blockers,
        "next_patch": "Patch 182 — Runtime Candidate Sandbox Stage Manifest / No-Write Copy Plan",
        "recommended_next_patch": "Patch 182 — Runtime Candidate Sandbox Stage Manifest / No-Write Copy Plan",
    }
    payload["sandbox_preflight_fingerprint"] = _p181_hash_payload({k:v for k,v in payload.items() if k != "sandbox_preflight_fingerprint"})
    return payload


