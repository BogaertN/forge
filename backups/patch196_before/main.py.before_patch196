# ─── PATCH 150: LIVE APPLY ELIGIBILITY GATE V2 ─────────────────────────────
# Purpose:
#   Add one read-only eligibility surface for live apply readiness. This does
#   not apply patches, does not approve writes, and does not grant project-file
#   authority. It simply proves whether a proposed target has source grounding,
#   scope, tests, sandbox, rollback, snapshot, deferred-state, and human approval
#   evidence before any future apply path may proceed.
# Authority:
#   Forge-owned memory/report writes only. No project writes. No engine writes.
#   No patch apply authority. No shell execution.

FORGE_LIVE_ELIGIBILITY_V2_SCHEMA_VERSION = "forge_live_apply_eligibility_v2_patch150R"
FORGE_LIVE_ELIGIBILITY_V2_DIR = MEMORY_DIR / "forge_live_apply_eligibility_v2"
FORGE_LIVE_ELIGIBILITY_V2_STEM = "forge_live_apply_eligibility_v2"
FORGE_LIVE_ELIGIBILITY_V2_EXPORT_STEM = "forge_live_apply_eligibility_v2_export"

PATCH150_COMMANDS = [
    "forge-live-eligibility-v2-policy",
    "forge-live-eligibility-v2-check",
    "forge-live-eligibility-v2-show",
    "forge-live-eligibility-v2-list",
    "forge-live-eligibility-v2-next",
    "forge-live-eligibility-v2-export",
]

for _patch150_cmd in PATCH150_COMMANDS:
    if _patch150_cmd not in FORGE_EXPECTED_COMMANDS:
        FORGE_EXPECTED_COMMANDS.append(_patch150_cmd)


def _p150_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p150_stamp() -> str:
    return _p150_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p150_ensure_dir() -> None:
    FORGE_LIVE_ELIGIBILITY_V2_DIR.mkdir(parents=True, exist_ok=True)


def _p150_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p150_sha256(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p150_write(payload: dict, stem: str):
    _p150_ensure_dir()
    stamp = _p150_stamp()
    json_path = FORGE_LIVE_ELIGIBILITY_V2_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_LIVE_ELIGIBILITY_V2_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "target", "eligible_for_live_apply", "current_phase", "next_patch", "gate_pass_count", "gate_warn_count", "gate_fail_count"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("gates"):
        md.append("")
        md.append("## Eligibility Gates")
        for gate in payload.get("gates") or []:
            md.append(f"- **{gate.get('gate_id')}** — `{gate.get('status')}` — {gate.get('label')}: {gate.get('message')}")
    if payload.get("blocking_reasons"):
        md.append("")
        md.append("## Blocking Reasons")
        for item in payload.get("blocking_reasons") or []:
            md.append(f"- {item}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_LIVE_ELIGIBILITY_V2_DIR / f"latest_{stem}.json"
