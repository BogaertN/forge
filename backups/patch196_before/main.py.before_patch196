def _p163_write_json_md(payload: dict, stem: str):
    FORGE_RUNTIME_LIVE_APPROVAL_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p163_stamp()
    jp = FORGE_RUNTIME_LIVE_APPROVAL_DIR / f"{stamp}_{stem}.json"
    mp = FORGE_RUNTIME_LIVE_APPROVAL_DIR / f"{stamp}_{stem}.md"
    latest_jp = FORGE_RUNTIME_LIVE_APPROVAL_DIR / f"latest_{stem}.json"
    latest_mp = FORGE_RUNTIME_LIVE_APPROVAL_DIR / f"latest_{stem}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(text + "\n", encoding="utf-8")
    latest_jp.write_text(text + "\n", encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"- Status: {payload.get('status')}",
        f"- Candidate: {payload.get('candidate')}",
        f"- Planning ready: {payload.get('planning_ready')}",
        f"- Live build ready: {payload.get('live_build_ready')}",
        f"- Human approval present: {payload.get('human_approval_present')}",
        f"- Approval token status: {payload.get('approval_token_status')}",
        f"- Next patch: {payload.get('next_patch')}",
        "",
        "## Gates",
    ]
    for g in payload.get("gates") or []:
        lines.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')} — {g.get('detail')}")
    lines.extend(["", "## Planned live writes"])
    for f in payload.get("apply_plan", {}).get("planned_files") or []:
        lines.append(f"- {f.get('relative_path')} -> {f.get('planned_live_path')}")
    lines.extend(["", "## Roadmap law", str(payload.get("roadmap_mutation_policy", "APPEND_ONLY"))])
    md = "\n".join(lines) + "\n"
    mp.write_text(md, encoding="utf-8")
    latest_mp.write_text(md, encoding="utf-8")
    return jp, mp


