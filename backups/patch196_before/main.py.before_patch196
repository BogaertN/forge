    # Find scaffold — look for the installed function marker then replace to next def/anchor
    import re as _re
    header_pattern = r'# ── LLM-generated command: ' + re.escape(cmd_name) + r' ──\n'
    fn_pattern     = r'def ' + re.escape(fn_name) + r'\(session_id[^\)]*\):.*?(?=\n(?:def |class |if __name__|# ──))'
    full_pattern   = header_pattern + fn_pattern

    match = _re.search(full_pattern, main_content, _re.DOTALL)
    if not match:
        # Try without header comment
        match = _re.search(fn_pattern, main_content, _re.DOTALL)

    if not match:
