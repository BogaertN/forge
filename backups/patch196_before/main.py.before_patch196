def _patch97a_flatten_text(value, limit: int = 200000) -> str:
    try:
        text = json.dumps(value, sort_keys=True, ensure_ascii=False, default=str)
    except Exception:
        text = str(value)
    if len(text) > limit:
        text = text[:limit]
    return text.lower()


def _patch97a_keywords_for_row(row: dict) -> list[str]:
    raw = []
    raw.extend(str(row.get("source_key", "")).replace("_", " ").split())
    raw.extend(str(row.get("display_name", "")).replace("/", " ").replace("-", " ").split())
    raw.extend(str(row.get("source_role", "")).replace("_", " ").split())
    # stable aliases for project terms
    source_key = str(row.get("source_key", "")).lower()
    aliases = {
        "aiweb_forge_overview": ["forge", "audit", "hash", "manifest", "receipt"],
        "fbsc_core": ["fbsc", "frequency", "symbolic", "calculus"],
        "rsoc_or_resonant_runtime": ["rsoc", "resonant", "runtime", "architecture"],
        "gilligan_core": ["gilligan", "agent", "core", "recursive"],
        "rpmc_protocol": ["rpmc", "resonant", "phase", "memory", "calculus"],
        "christ_function": ["christ", "function", "correction", "operator"],
    }
    raw.extend(aliases.get(source_key, []))
    out = []
    for token in raw:
        t = re.sub(r"[^a-zA-Z0-9_]+", "", token.lower())
        if len(t) >= 3 and t not in out:
            out.append(t)
    return out[:18]


def _patch97a_guess_chunk_count(obj) -> int:
    """Best-effort chunk count extraction from heterogeneous receipts/manifests."""
    max_found = 0
    def walk(x):
        nonlocal max_found
        if isinstance(x, dict):
            for k, v in x.items():
                lk = str(k).lower()
                if any(term in lk for term in ["chunk_count", "chunks_written", "chunk_total", "total_chunks", "chunked_count"]):
                    if isinstance(v, int):
                        max_found = max(max_found, v)
                    elif isinstance(v, str) and v.isdigit():
                        max_found = max(max_found, int(v))
                if lk in {"chunks", "chunk_hashes", "chunk_ids"} and isinstance(v, list):
                    max_found = max(max_found, len(v))
                walk(v)
        elif isinstance(x, list):
            for item in x:
                walk(item)
    walk(obj)
    return max_found


def _patch97a_scan_json_dirs(row: dict) -> dict:
    """Scan Forge-owned context library metadata for source-specific chunk evidence."""
    keywords = _patch97a_keywords_for_row(row)
    dirs = [
        CONTEXT_LIBRARY_DIR / "receipts",
        CONTEXT_LIBRARY_DIR / "manifests",
        CONTEXT_LIBRARY_DIR / "indexes",
        CONTEXT_LIBRARY_DIR / "symbolic_maps",
        FORGE_ROOT / "ingestion_plans",
        FORGE_ROOT / "ingestion_manifests",
    ]
    matches = []
    chunk_evidence_count = 0
    files_scanned = 0
    for d in dirs:
        if not d.exists():
            continue
        for path in sorted(d.glob("**/*.json"))[:1200]:
            files_scanned += 1
            obj = _patch97a_read_json(path)
            if obj is None:
                continue
            text = _patch97a_flatten_text(obj)
            hits = [kw for kw in keywords if kw in text]
            if not hits:
                continue
            cc = _patch97a_guess_chunk_count(obj)
            if cc > 0:
                chunk_evidence_count += cc
            match = {
                "path": str(path),
                "path_sha256": _patch97a_sha256(path) if path.exists() and path.is_file() else "",
                "match_hits": hits[:10],
                "match_score": len(hits),
                "chunk_count_hint": cc,
                "report_type": obj.get("report_type", "") if isinstance(obj, dict) else "",
                "collection": obj.get("collection", "") if isinstance(obj, dict) else "",
            }
            matches.append(match)
    matches.sort(key=lambda m: (m.get("chunk_count_hint", 0), m.get("match_score", 0)), reverse=True)
    return {
        "files_scanned": files_scanned,
        "chunk_evidence_count": chunk_evidence_count,
        "matches": matches[:12],
    }


def _patch97a_scan_chroma_sqlite(row: dict) -> dict:
    """Read-only sqlite probe of local Chroma metadata/documents if present. No writes."""
    import sqlite3
    keywords = _patch97a_keywords_for_row(row)
    db_paths = []
    chroma_dir = CONTEXT_LIBRARY_DIR / "chroma_db"
    if chroma_dir.exists():
        for pat in ["*.sqlite3", "*.sqlite", "*.db"]:
            db_paths.extend(chroma_dir.glob(f"**/{pat}"))
    evidence = []
    errors = []
    for db in sorted(set(db_paths))[:6]:
        try:
            con = sqlite3.connect(str(db), timeout=2)
            cur = con.cursor()
            tables = [r[0] for r in cur.execute("select name from sqlite_master where type='table'").fetchall()]
            for table in tables:
                try:
                    cols = cur.execute(f"pragma table_info({table})").fetchall()
                    text_cols = [c[1] for c in cols if str(c[2]).lower() in ("text", "varchar", "") or "char" in str(c[2]).lower()]
                    for col in text_cols[:4]:
                        # Pull a limited sample. Chroma DBs are small enough here; stay bounded.
                        q = f"select {col} from {table} where {col} is not null limit 250"
                        for (val,) in cur.execute(q).fetchall():
                            sval = str(val).lower()
                            hits = [kw for kw in keywords if kw in sval]
                            if hits:
                                evidence.append({
                                    "db_path": str(db),
                                    "table": table,
                                    "column": col,
                                    "match_hits": hits[:10],
                                    "match_score": len(hits),
                                    "sample": str(val)[:280],
                                })
                                if len(evidence) >= 20:
                                    break
                        if len(evidence) >= 20:
                            break
                except Exception as e:
                    errors.append(f"{db}:{table}:{type(e).__name__}:{e}")
                if len(evidence) >= 20:
                    break
            con.close()
        except Exception as e:
            errors.append(f"{db}:{type(e).__name__}:{e}")
    evidence.sort(key=lambda m: m.get("match_score", 0), reverse=True)
    return {"sqlite_files_seen": len(db_paths), "evidence": evidence[:10], "errors": errors[:8]}


def _patch97a_classify(row: dict, json_scan: dict, sqlite_scan: dict) -> tuple[str, bool, str, list[str], list[str]]:
    warnings = []
    blockers = []
    chunk_count = int(json_scan.get("chunk_evidence_count", 0) or 0)
    sqlite_hits = len(sqlite_scan.get("evidence", []) or [])
    if chunk_count > 0 and sqlite_hits > 0:
        return "READY_RETRIEVABLE_WITH_CHUNKS", True, "PATCH98_LLM_REVIEW_GATE_AFTER_GATEWAY_INIT", warnings, blockers
    if chunk_count > 0:
        warnings.append("Chunk receipts were found, but Chroma/sqlite retrieval evidence was not proven by this probe.")
        return "CHUNK_RECEIPTS_FOUND_RETRIEVAL_UNPROVEN", False, "PATCH97D_RETRIEVAL_VALIDATION_OR_CONTEXT_SEARCH_BINDING_REQUIRED", warnings, blockers
    if sqlite_hits > 0:
        warnings.append("Retrieval-like sqlite evidence was found, but explicit source chunk receipt counts were not proven.")
        return "RETRIEVAL_HINT_FOUND_CHUNK_RECEIPTS_UNPROVEN", False, "PATCH97C_CHUNK_MANIFEST_DRY_RUN_REQUIRED", warnings, blockers
    if row.get("has_extraction_evidence") and row.get("has_context_evidence"):
        warnings.append("Source has extraction/context hints, but no concrete chunk/retrieval proof was found.")
        return "INGESTED_NOT_RETRIEVABLE_CHUNK_PROOF_MISSING", False, "PATCH97C_CHUNK_MANIFEST_DRY_RUN_REQUIRED", warnings, blockers
    if row.get("has_existing_source_file"):
        warnings.append("Source file exists, but extraction/chunk/retrieval proof is incomplete.")
        return "SOURCE_PRESENT_EXTRACTION_OR_CHUNK_PROOF_MISSING", False, "PATCH97A_D_REQUIRED", warnings, blockers
    blockers.append("No source file candidate was proven present in Patch 97 row.")
    return "SOURCE_LAW_MISSING", False, "REGISTER_SOURCE_LAW_BEFORE_LLM_REVIEW", warnings, blockers


def _patch97a_build_report() -> dict:
    source_report_path = _patch97a_source_law_report_path()
    now = _patch97a_now()
    rows = []
    if not source_report_path:
        return {
            "schema_version": SOURCE_LAW_CHUNK_PROBE_SCHEMA_VERSION,
            "report_type": "SOURCE_LAW_CHUNK_PROBE_V1_PATCH97A",
            "created_at": now,
