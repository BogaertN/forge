        {"id": "G05", "name": "Candidate risk is not high", "status": "PASS" if candidate.get("risk_level") in {"LOW", "MEDIUM"} else "FAIL", "detail": candidate.get("risk_level")},
        {"id": "G06", "name": "Live writes remain locked", "status": "PASS", "detail": "planning-only"},
