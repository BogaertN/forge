    for f in payload.get("planned_files", []):
        md.append(f"- {f.get('relative_path')} | live_write_now={f.get('live_write_planned_now')}")
    md_path.write_text("\n".join(md)+"\n", encoding="utf-8")
    _p172_shutil.copyfile(json_path, FORGE_RUNTIME_LIVE_APPLY_HOLD_DIR / "latest_forge_runtime_live_apply_hold_review_v1.json")
    _p172_shutil.copyfile(md_path, FORGE_RUNTIME_LIVE_APPLY_HOLD_DIR / "latest_forge_runtime_live_apply_hold_review_v1.md")
    return json_path, md_path


