def _p172_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19R" not in ids:
        rows.append({"id":"S19R","status":"ACTIVE","title":"Runtime Live Build Apply Hold Review / No-Write Receipt","patch":"Patch 172 — Runtime Live Build Apply Hold Review / No-Write Receipt","summary":"Review captured approval/hold evidence and write a no-write receipt before any future execution decision.","authority":"review/receipt gate only; no runtime writes"})
