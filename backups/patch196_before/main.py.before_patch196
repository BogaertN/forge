def _p142_json_load(path, default=None):
    import json
    from pathlib import Path
    if default is None:
        default = {}
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        pass
    return default


def _p142_write(payload: dict, stem: str):
    import json
    d = _p142_dir()
    ts = _p142_safe_ts()
    jp = d / f"{ts}_{stem}.json"
    mp = d / f"{ts}_{stem}.md"
    latest_j = d / f"latest_{stem}.json"
    latest_m = d / f"latest_{stem}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(text, encoding="utf-8")
    latest_j.write_text(text, encoding="utf-8")
    md = [f"# {payload.get('report_type', stem)}", "", f"Status: {payload.get('status')}", ""]
    for k in ("target", "recommendation", "candidate_action", "candidate_status", "recommended_next_patch"):
        if payload.get(k) is not None:
            md.append(f"- {k}: {payload.get(k)}")
    md.append("")
    md.append("```json")
    md.append(text[:16000])
    md.append("```")
    mdt = "\n".join(md)
    mp.write_text(mdt, encoding="utf-8")
    latest_m.write_text(mdt, encoding="utf-8")
    return str(jp), str(mp)


def _p142_sha_text(text: str) -> str:
    import hashlib
    return hashlib.sha256((text or "").encode("utf-8", errors="replace")).hexdigest()


def _p142_sha_file(path):
    import hashlib
    from pathlib import Path
    try:
        h = hashlib.sha256()
        with Path(path).open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p142_read_text(path, limit=None):
    from pathlib import Path
    try:
        txt = Path(path).read_text(encoding="utf-8", errors="replace")
        if limit and len(txt) > limit:
            return txt[:limit] + "\n...[TRUNCATED_BY_FORGE]..."
        return txt
    except Exception as exc:
        return f"<unreadable: {type(exc).__name__}: {exc}>"


