    md = []
    md.append("# Patch 172 — Runtime Live Build Apply Hold Review / No-Write Receipt")
    md.append("")
    for k in ["status","candidate","planning_ready","live_build_ready","human_approval_present","approval_token_entered","token_validation_status","execution_decision","runtime_writes","project_writes","engine_writes","next_patch"]:
        md.append(f"- **{k}**: `{payload.get(k)}`")
    md.append("")
    md.append("## No-Write Receipt")
    receipt = payload.get("no_write_receipt", {})
    for k in ["receipt_type","live_execution_performed","runtime_writes_performed","project_writes_performed","engine_writes_performed","no_write_reason"]:
        md.append(f"- **{k}**: `{receipt.get(k)}`")
    md.append("")
