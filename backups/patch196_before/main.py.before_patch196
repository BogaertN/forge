def _p136_scope_ok(path: str) -> bool:
    try:
        rp = Path(path).expanduser().resolve()
        allowed = [Path.home() / "aiweb", Path.home() / "forge_test_project"]
        return any(str(rp) == str(root.resolve()) or str(rp).startswith(str(root.resolve()) + os.sep) for root in allowed)
    except Exception:
        return False


def _p136_extract_target(evidence: dict, llm: dict) -> dict:
    snippets = evidence.get("code_context_snippets") or []
    stderr = ((evidence.get("import_probe") or {}).get("stderr_tail") or "")
    error_locations = evidence.get("error_locations") or []
    candidates = []
    for loc in error_locations:
        p = loc.get("path")
        if p and p.endswith(".py"):
            candidates.append({"path": p, "line": loc.get("line"), "source": "error_locations"})
    for sn in snippets:
        p = sn.get("path")
        if p and p.endswith(".py"):
            line = None
            candidates.append({"path": p, "line": line, "source": "code_context_snippets", "snippet_sha256": sn.get("sha256")})
    # Prefer non-test Python file with exact SyntaxError path from stderr.
    m = re.search(r'File "([^"]+\.py)", line (\d+)', stderr)
    if m:
        sp, ln = m.group(1), int(m.group(2))
        if not Path(sp).name.startswith("test_"):
            return {"path": sp, "line": ln, "source": "stderr_syntax_path"}
    for c in candidates:
        name = Path(c["path"]).name
        if not name.startswith("test_"):
            # Attach snippet sha for this exact path if available.
            for sn in snippets:
                if sn.get("path") == c["path"]:
                    c["snippet_sha256"] = sn.get("sha256")
            return c
    return candidates[0] if candidates else {}


def _p136_guess_syntax_line(stderr: str) -> tuple[str, int | None, str]:
    path = ""
    line = None
    msg = ""
    m = re.search(r'File "([^"]+\.py)", line (\d+)\n(?:.*\n)*?\s*\^\s*\nSyntaxError:\s*([^\n]+)', stderr)
    if m:
        path = m.group(1); line = int(m.group(2)); msg = m.group(3).strip()
    else:
        m = re.search(r'File "([^"]+\.py)", line (\d+)', stderr)
        if m:
            path = m.group(1); line = int(m.group(2))
        m2 = re.search(r'SyntaxError:\s*([^\n]+)', stderr)
        if m2:
            msg = m2.group(1).strip()
    return path, line, msg


def _p136_build_candidate_text(original: str, target_line: int | None, stderr: str, llm: dict) -> tuple[str, dict]:
    """Build a Forge-memory-only candidate repair.

    Patch 136R correction:
    The first Patch 136 candidate could close an unterminated string but leave the
    surrounding container open when the source file ended immediately after the
    broken line. This helper now performs a conservative syntax-structure repair:
    close the string line, then append a matching container closer only when the
    file tail is empty/whitespace and an obvious unmatched opening delimiter exists
    in the local context. It still does not write project files.
    """
    lines = original.splitlines(True)
    strategy = {
        "strategy": "none",
        "changed_lines": [],
        "confidence": "LOW",
        "notes": [],
    }
    _, stderr_line, syntax_msg = _p136_guess_syntax_line(stderr)
    line_no = target_line or stderr_line

    def _indent_of(line: str) -> str:
        m = re.match(r'^(\s*)', line or "")
        return m.group(1) if m else ""

    def _append_closers_if_file_tail_is_truncated(lines_list: list[str], anchor_idx: int) -> None:
        # Only auto-close when there is no meaningful source after the repaired line.
        tail = "".join(lines_list[anchor_idx + 1:]).strip()
        if tail:
            strategy["notes"].append("Source has non-empty tail after target line; no automatic container closer appended.")
            return

        # Look backward for the nearest unmatched opening container line.
        # This is intentionally conservative and local; it avoids broad code generation.
        stack: list[tuple[str, int, str]] = []
        pairs = {"{": "}", "[": "]", "(": ")"}
        closers = {"}", "]", ")"}
        for j, raw in enumerate(lines_list[:anchor_idx + 1]):
            # Strip simple quoted spans before delimiter counting to reduce false positives.
            rough = re.sub(r'"(?:\\.|[^"\\])*"', '""', raw)
            rough = re.sub(r"'(?:\\.|[^'\\])*'", "''", rough)
            for ch in rough:
                if ch in pairs:
                    stack.append((ch, j, _indent_of(raw)))
                elif ch in closers and stack:
                    expected = pairs.get(stack[-1][0])
                    if ch == expected:
                        stack.pop()
        if not stack:
            strategy["notes"].append("No obvious unmatched container found after string repair.")
            return

        # Append closers in reverse order. For the known class of issue this is usually a dict.
        appended = []
        for opener, opener_idx, indent in reversed(stack):
            closer = pairs[opener]
            line = f"{indent}{closer}\n"
            lines_list.append(line)
            appended.append({"line": len(lines_list), "after": line.rstrip("\n"), "reason": f"close_unmatched_{opener}"})
        if appended:
            strategy["changed_lines"].extend(appended)
            strategy["notes"].append("Appended conservative container closer(s) because target file tail was empty after syntax line.")
            if strategy.get("strategy") == "close_unterminated_double_quoted_string":
                strategy["strategy"] = "close_unterminated_string_and_trailing_container"
                strategy["confidence"] = "MEDIUM"

    if line_no and 1 <= line_no <= len(lines):
        idx = line_no - 1
        old = lines[idx]
        stripped_no_newline = old.rstrip("\r\n")
        newline = "\n" if old.endswith("\n") else ""
        lower_msg = (syntax_msg or stderr or "").lower()
        if "unterminated string literal" in lower_msg or "eol while scanning string" in lower_msg:
            # Generic minimal fix for a Python line with an odd number of unescaped double quotes.
            quote_count = len(re.findall(r'(?<!\\)"', stripped_no_newline))
            if quote_count % 2 == 1:
                suffix = '",'
                if stripped_no_newline.rstrip().endswith(","):
                    suffix = '"'
                # If the broken line is the physical end of file, force a newline so any
                # appended container closer is not joined onto the same line.
                tail_after = "".join(lines[idx + 1:]).strip()
                effective_newline = newline or ("\n" if not tail_after else "")
                new = stripped_no_newline + suffix + effective_newline
                lines[idx] = new
                strategy.update({
                    "strategy": "close_unterminated_double_quoted_string",
                    "changed_lines": [{"line": line_no, "before": old.rstrip("\n"), "after": new.rstrip("\n")}],
                    "confidence": "MEDIUM",
                })
                _append_closers_if_file_tail_is_truncated(lines, idx)
            else:
                strategy["notes"].append("Syntax message indicates unterminated string, but target line did not have odd unescaped double-quote count.")
        if strategy["strategy"] == "none":
            # Conservative fallback: no edit. Candidate can still report why it refused.
            strategy["notes"].append("No safe automatic candidate transformation matched the evidence.")
    else:
        strategy["notes"].append("No valid target line available for candidate transformation.")
    return "".join(lines), strategy

def _p136_compile_text_candidate(candidate_text: str, source_name: str) -> dict:
    P136_MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    temp_dir = P136_MEMORY_DIR / "compile_tmp"
    temp_dir.mkdir(parents=True, exist_ok=True)
    candidate_tmp = temp_dir / (Path(source_name).name + ".candidate_compile.py")
    candidate_tmp.write_text(candidate_text, encoding="utf-8", errors="replace")
    result = {"candidate_compile_path": str(candidate_tmp), "py_compile_status": "NOT_RUN", "returncode": None, "error": None}
    try:
        _p136_py_compile.compile(str(candidate_tmp), doraise=True)
        result["py_compile_status"] = "PASS"
        result["returncode"] = 0
    except Exception as exc:
        result["py_compile_status"] = "FAIL"
        result["returncode"] = 1
        result["error"] = str(exc)
    return result


