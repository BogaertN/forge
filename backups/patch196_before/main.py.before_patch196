def _p166_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19L" not in ids:
        rows.append({"id":"S19L","status":"ACTIVE","title":"Runtime Live Build Execution Plan / Receipt Gate","patch":"Patch 166 — Runtime Live Build Execution Plan / Receipt Gate","summary":"Prepare execution receipt structure for a future approved live runtime apply.","authority":"execution planning only; no live runtime writes"})
    if "S19M" not in ids:
        rows.append({"id":"S19M","status":"NEXT","title":"Runtime Live Build Approval Capture / Execution Gate","patch":"Patch 167 — Runtime Live Build Approval Capture / Execution Gate","summary":"Capture explicit human approval state and decide whether live execution can be unlocked.","authority":"approval capture and execution gate only"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K"}:
            row["status"] = "DONE"
        elif rid == "S19L":
            row["status"] = "ACTIVE"
        elif rid == "S19M":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


