    master_path, master = _patch127_latest_json(FORGE_ROOT / "memory" / "forge_master_status_v1", "latest_forge_master_status_report_v1.json")
    snapshot_path, snapshot = _patch127_latest_json(FORGE_ROOT / "memory" / "forge_self_snapshots_v1", "latest_forge_self_snapshot_v1.json")
    sandbox_path, sandbox = _patch127_latest_json(FORGE_ROOT / "memory" / "forge_self_sandboxes_v1", "latest_forge_self_sandbox_report_v1.json")

