def _p157_impact_rows() -> dict:
    data = _p157_latest_patch_impact()
    rows = data.get("rows")
    if not isinstance(rows, list):
        return {}
    out = {}
    for row in rows:
        if isinstance(row, dict):
            name = row.get("engine_base") or row.get("engine") or row.get("name")
            if name:
                out[str(name)] = row
    return out


def _p157_candidate_rows() -> list[dict]:
    impact = _p157_impact_rows()
    priority_order = {"P1_CORE": 0, "P2_SUPPORTING_CORE": 1, "P3_INTERFACE_OR_EXTENSION": 2}
    domain_order = {
        "SYSTEM_RUNTIME_AND_TOOLS": 0,
        "GOVERNANCE_AND_SAFETY": 1,
        "GENERAL_RUNTIME": 2,
        "MEMORY_AND_RESONANCE": 3,
        "DRIFT_AND_CORRECTION": 4,
        "AGENT_ORCHESTRATION": 5,
        "INTERFACE_AND_OPERATOR_SURFACE": 6,
    }
    candidates = []
    for row in _p157_runtime_rows():
        if not isinstance(row, dict):
            continue
        engine = row.get("engine")
        if not engine:
            continue
        imp = impact.get(str(engine), {})
        merged = dict(row)
        merged.update({
            "risk_level": imp.get("risk_level") or "UNKNOWN",
            "risk_score": imp.get("risk_score"),
            "test_status": imp.get("test_status") or "UNKNOWN",
            "relationship_count": imp.get("relationship_count", 0),
            "canonical_path": imp.get("canonical_path") or imp.get("resolved_path_guess"),
            "cautions": imp.get("cautions") or [],
            "required_human_checks": imp.get("required_human_checks") or [],
            "rollback_needs": imp.get("rollback_needs") or [],
        })
        eligible_for_plan = (
            merged.get("canonical_status") == "CANONICAL_INCLUDED"
            and merged.get("test_status") == "PASS"
            and merged.get("risk_level") in {"LOW", "MEDIUM"}
        )
        merged["eligible_for_planning"] = bool(eligible_for_plan)
        merged["live_build_ready"] = False
        merged["live_write_authority"] = False
        candidates.append(merged)

    def sort_key(item):
        return (
            0 if item.get("eligible_for_planning") else 1,
            0 if item.get("risk_level") == "LOW" else 1,
            0 if item.get("test_status") == "PASS" else 1,
            priority_order.get(item.get("priority"), 9),
            domain_order.get(item.get("runtime_domain"), 9),
            int(item.get("relationship_count") or 0),
            int(item.get("risk_score") if item.get("risk_score") is not None else 999),
            str(item.get("engine") or ""),
        )

    return sorted(candidates, key=sort_key)


def _p157_selected_candidate() -> dict:
    for row in _p157_candidate_rows():
        if row.get("eligible_for_planning"):
            return row
    return {}


def _p157_payload() -> dict:
    runtime_map = _p157_latest_runtime_map()
    rows = _p157_candidate_rows()
    candidate = _p157_selected_candidate()
    shortlisted = rows[:12]
    planning_ready = bool(candidate) and runtime_map.get("planning_ready") is True
    gates = [
        {"id": "G01", "name": "Runtime module map exists", "status": "PASS" if runtime_map else "FAIL", "detail": runtime_map.get("status") or "missing"},
        {"id": "G02", "name": "Canonical engines mapped", "status": "PASS" if runtime_map.get("canonical_engine_count") else "FAIL", "detail": runtime_map.get("canonical_engine_count")},
