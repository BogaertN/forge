    _p161_gate(gates, "S06", "No planned live runtime files exist yet", len(live_paths_existing) == 0, f"live_path_exists={len(live_paths_existing)}")
    _p161_gate(gates, "S07", "No live write authority", not (draft.get("runtime_file_write_authority") or (draft.get("authority") or {}).get("runtime_file_write_authority")), "runtime_file_write_authority=false")
    _p161_gate(gates, "S08", "Source authority finality is honest", source_status in {"FINAL", "BOUND", "CANDIDATE_OR_UNKNOWN", "UNKNOWN"}, source_status, warn=(source_status in {"CANDIDATE_OR_UNKNOWN", "UNKNOWN"}))
    _p161_gate(gates, "S09", "Live build gate remains locked", not bool(draft.get("live_build_ready") or draft_verify.get("live_build_ready")), "live_build_ready=false")
    for f in files:
        if not f.get("exists"):
            problems.append(f"Missing sandbox file: {f.get('relative_path')}")
        if not f.get("hash_match"):
            problems.append(f"Hash mismatch: {f.get('relative_path')}")
        if not f.get("static_ok"):
            problems.append(f"Static check failed: {f.get('relative_path')} — {f.get('static_detail')}")
        if f.get("live_path_exists"):
            problems.append(f"Planned live path already exists: {f.get('planned_live_path_not_created')}")
    fatal_fail = any(g.get("status") == "FAIL" for g in gates)
    payload = {
