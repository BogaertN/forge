def _patch126_norm(s: str) -> str:
    return (s or "").strip().lower().replace("\\", "/")


def _patch126_basename_no_py(s: str) -> str:
    s = _patch126_norm(s).rstrip("/")
    if "/" in s:
        s = s.split("/")[-1]
    if s.endswith(".py"):
        s = s[:-3]
    return s


def _patch126_entry_maps(sources: dict):
    entries = sources.get("lock", {}).get("canonical_entries") or []
    rel_rows = sources.get("relationship", {}).get("rows") or []
    tests = sources.get("test_run", {}).get("results") or []
    rel_by_engine = {r.get("engine_base"): r for r in rel_rows if r.get("engine_base")}
    tests_by_engine = {}
    for t in tests:
        eb = t.get("engine_base")
        if not eb:
            continue
        tests_by_engine.setdefault(eb, []).append(t)
    return entries, rel_by_engine, tests_by_engine


def _patch126_resolve_targets(target: str, sources: dict):
    entries, rel_by_engine, tests_by_engine = _patch126_entry_maps(sources)
    target_norm = _patch126_norm(target or "all")
    if target_norm in ("all", "latest", "*"):
        return entries
    base = _patch126_basename_no_py(target_norm)
    matches = []
    for e in entries:
        eb = _patch126_norm(e.get("engine_base"))
        cp = _patch126_norm(e.get("canonical_path"))
        if target_norm == eb or base == eb or target_norm in cp or cp.endswith(target_norm) or cp.endswith(base):
            matches.append(e)
    return matches


def _patch126_score(entry: dict, rel_row: dict, test_rows: list) -> dict:
    test_status = (rel_row or {}).get("test_status") or "NO_TEST_RESULT"
    relationship_count = int((rel_row or {}).get("relationship_count") or 0)
    neighbor_count = len((rel_row or {}).get("neighbors") or [])
    cautions = entry.get("cautions") or []
    required_checks = entry.get("required_human_checks") or []
    score = 10
    reasons = []
    if test_status == "PASS":
        score += 0
    elif test_status == "ISSUES":
        score += 35
        reasons.append("latest safe-test report has issues")
    elif test_status == "NO_TEST_RESULT":
        score += 25
        reasons.append("no latest safe-test result")
    else:
        score += 20
        reasons.append(f"test_status={test_status}")
    if relationship_count >= 5:
        score += 25
        reasons.append("many relationship neighbors")
    elif relationship_count >= 2:
        score += 15
        reasons.append("multiple relationship neighbors")
    elif relationship_count == 1:
        score += 8
        reasons.append("one relationship neighbor")
    if cautions:
        score += min(20, 5 * len(cautions))
        reasons.append("canonical lockfile cautions present")
    if required_checks:
        score += min(15, 5 * len(required_checks))
        reasons.append("required human checks present")
    score = min(score, 100)
    if score >= 70:
        level = "HIGH"
    elif score >= 35:
        level = "MEDIUM"
    else:
        level = "LOW"
    if not reasons:
        reasons.append("low relationship/test risk detected")
    return {
        "risk_score": score,
        "risk_level": level,
        "risk_reasons": reasons,
        "test_status": test_status,
        "relationship_count": relationship_count,
        "neighbor_count": neighbor_count,
    }


def _patch126_make_row(entry: dict, sources: dict) -> dict:
    entries, rel_by_engine, tests_by_engine = _patch126_entry_maps(sources)
    eb = entry.get("engine_base")
    rel_row = rel_by_engine.get(eb, {})
    test_rows = tests_by_engine.get(eb, [])
    score = _patch126_score(entry, rel_row, test_rows)
    resolved = None
    cp = entry.get("canonical_path") or ""
    if cp.startswith("aiweb/"):
        resolved = "/home/nic/" + cp
    elif cp.startswith("projects/"):
        resolved = "/home/nic/" + cp
    elif cp.startswith("/"):
        resolved = cp
    else:
        resolved = str(Path("/home/nic") / cp) if cp else None
    related_files = []
    for n in (rel_row or {}).get("neighbors") or []:
        related_files.append({
            "engine_base": n.get("engine_base"),
            "canonical_path": n.get("canonical_path"),
            "confidence": n.get("confidence"),
            "reason": n.get("reason"),
        })
    test_paths = [t.get("test_path") for t in test_rows if t.get("test_path")]
    latest_failures = []
    for t in test_rows:
        if t.get("status") != "PASS":
            latest_failures.append({
                "test_path": t.get("test_path"),
                "status": t.get("status"),
                "problem": t.get("problem"),
                "stderr_tail": t.get("stderr_tail"),
            })
    recommended = "READ_ONLY_ONLY"
    if score["risk_level"] == "LOW":
        recommended = "eligible_for_normal_patch_planning_after_source_trace"
    elif score["risk_level"] == "MEDIUM":
        recommended = "require_patch_impact_review_before_patch_proposal"
    else:
        recommended = "require_human_review_and_targeted_test_plan_before_patch_proposal"
    return {
        "engine_base": eb,
        "canonical_path": cp,
        "resolved_path_guess": resolved,
        "review_status": entry.get("review_status"),
        "decision_confidence": entry.get("decision_confidence"),
        "variant_count": entry.get("variant_count"),
        "cautions": entry.get("cautions") or [],
        "required_human_checks": entry.get("required_human_checks") or [],
        "review_note_excerpt": (entry.get("review_note") or "")[:600],
        "source_candidate_sha256": entry.get("source_candidate_sha256"),
        "risk_score": score["risk_score"],
        "risk_level": score["risk_level"],
        "risk_reasons": score["risk_reasons"],
        "test_status": score["test_status"],
        "test_paths": test_paths,
        "latest_failures": latest_failures,
        "relationship_count": score["relationship_count"],
        "related_files": related_files,
        "recommended_next_action": recommended,
        "rollback_needs": [
            "snapshot_or_file_backup_before_live_patch",
            "current_sha_readback_before_apply",
            "post_write_disk_verification",
        ],
        "authority": {
            "read_only_impact_analysis": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "ledger_mutation": False,
        },
    }


def _patch126_report(target: str, mode: str) -> dict:
    sources = _patch126_load_sources()
    matches = _patch126_resolve_targets(target, sources)
    rows = [_patch126_make_row(e, sources) for e in matches]
    summary = {
        "targets_requested": target or "all",
        "matches": len(rows),
        "high_risk": sum(1 for r in rows if r.get("risk_level") == "HIGH"),
        "medium_risk": sum(1 for r in rows if r.get("risk_level") == "MEDIUM"),
        "low_risk": sum(1 for r in rows if r.get("risk_level") == "LOW"),
        "test_issues": sum(1 for r in rows if r.get("test_status") == "ISSUES"),
        "no_test_result": sum(1 for r in rows if r.get("test_status") == "NO_TEST_RESULT"),
