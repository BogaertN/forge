            continue
        snap_path = Path(e.get("snapshot_path") or "")
        current_snapshot_sha = _patch121_sha256(snap_path) if snap_path.exists() else None
        ok = bool(current_snapshot_sha and current_snapshot_sha == e.get("snapshot_sha256") == e.get("source_sha256"))
