def cmd_forge_self_snapshot_create(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    import shutil
    _patch121_ensure_dirs()
    stamp = _patch121_slug_now()
    snapshot_id = f"FSS-{stamp}"
    snapshot_root = _PATCH121_SNAPSHOT_DIR / snapshot_id
    files_root = snapshot_root / "files"
    files_root.mkdir(parents=True, exist_ok=False)
    entries = []
    problems = []
    for src in _patch121_self_update_files():
        rel = _patch121_rel(src)
        entry = {
            "source_path": str(src),
            "relative_path": rel,
            "exists": src.exists(),
            "is_file": src.is_file() if src.exists() else False,
            "source_sha256": _patch121_sha256(src) if src.exists() and src.is_file() else None,
            "copied": False,
            "snapshot_path": None,
            "snapshot_sha256": None,
        }
        if src.exists() and src.is_file():
            dst = files_root / rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dst)
            entry["copied"] = True
            entry["snapshot_path"] = str(dst)
            entry["snapshot_sha256"] = _patch121_sha256(dst)
            if entry["source_sha256"] != entry["snapshot_sha256"]:
                problems.append(f"sha mismatch after copy: {rel}")
        entries.append(entry)
    manifest = {
        "schema_version": "forge_self_snapshot_manifest_v1_patch121",
        "report_type": "FORGE_SELF_SNAPSHOT_MANIFEST_V1",
        "created_at": _patch121_iso_now(),
        "status": "FORGE_SELF_SNAPSHOT_CREATED" if not problems else "FORGE_SELF_SNAPSHOT_CREATED_WITH_PROBLEMS",
        "snapshot_id": snapshot_id,
        "snapshot_root": str(snapshot_root),
        "files_root": str(files_root),
        "entries": entries,
        "copied_count": sum(1 for e in entries if e.get("copied")),
        "missing_optional_count": sum(1 for e in entries if not e.get("exists")),
        "problems": problems,
        "authority": {
            "writes_forge_memory_only": True,
            "live_self_write_authority": False,
            "project_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "audit_overwrite_authority": False,
        },
        "next_commands": ["forge-self-snapshot-show latest", "forge-self-snapshot-verify latest", "forge-self-snapshot-export", "forge-next"],
    }
    json_path, md_path = _patch121_write_json_and_md(manifest, _PATCH121_MANIFEST_PREFIX)
    # Also store a copy in the snapshot folder for forensic portability.
    (snapshot_root / "manifest.json").write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    print()
    print("── Forge Self-Snapshot Create — Patch 121 ──────────")
    print(f"  Status      : {manifest['status']}")
    print(f"  Snapshot ID : {snapshot_id}")
    print(f"  Copied      : {manifest['copied_count']}")
    print(f"  Missing opt : {manifest['missing_optional_count']}")
    print(f"  Problems    : {len(problems)}")
    print(f"  JSON        : {json_path}")
    print("  Authority   : Forge-owned snapshot only; no live write authority")
    print("──────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_SELF_SNAPSHOT_CREATED", str(json_path), f"snapshot={snapshot_id}", f"copied={manifest['copied_count']} problems={len(problems)}")


