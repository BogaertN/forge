def _patch74_candidate_markdown(candidate: dict) -> str:
    lines = []
    lines.append("# Human-Approved Engine Lockfile Candidate")
    lines.append("")
    lines.append(f"Policy version: `{candidate.get('policy_version')}`")
    lines.append(f"Created: `{candidate.get('created_at')}`")
    lines.append(f"Status: `{candidate.get('status')}`")
    lines.append(f"Canonical authority: `{candidate.get('canonical_authority')}`")
    lines.append(f"Included: `{candidate.get('included_count')}`")
    lines.append(f"Excluded: `{candidate.get('excluded_count')}`")
    lines.append("")
    lines.append("This file is a candidate artifact only. It does not move, delete, rename, quarantine, promote, or edit engine files.")
    lines.append("")
    lines.append("## Candidate entries")
    for row in candidate.get("candidate_entries", []):
        lines.append(f"- `{row.get('engine_base')}` → `{row.get('canonical_path_candidate')}` ({row.get('decision_confidence')})")
    lines.append("")
    lines.append("## Excluded entries")
    for row in candidate.get("excluded_entries", [])[:80]:
        lines.append(f"- `{row.get('engine_base')}` — `{row.get('reason')}` ({row.get('review_status')})")
    return "\n".join(lines) + "\n"


def _patch74_export_candidate(candidate: dict) -> tuple[Path, Path]:
    ts = _patch60_timestamp()
    json_path = CODE_MANIFESTS_DIR / f"{ts}_{_PATCH74_CANDIDATE_PREFIX}_export.json"
    md_path = CODE_MANIFESTS_DIR / f"{ts}_{_PATCH74_CANDIDATE_PREFIX}_export.md"
    json_path.write_text(json.dumps(candidate, indent=2, ensure_ascii=False), encoding="utf-8")
    md_path.write_text(_patch74_candidate_markdown(candidate), encoding="utf-8")
    return json_path, md_path


def _patch74_find_row(candidate: dict, engine_base: str) -> tuple[dict | None, str]:
    q = _code_engine_base_name((engine_base or "").strip().lower())
    for row in candidate.get("candidate_entries", []) or []:
        if str(row.get("engine_base", "")).lower() == q:
            return row, "candidate"
    for row in candidate.get("excluded_entries", []) or []:
        if str(row.get("engine_base", "")).lower() == q:
            return row, "excluded"
    return None, "missing"


