    static_ready = str(static.get("status", "")).startswith("FORGE_RUNTIME_CANDIDATE_STATIC") and static.get("problem_count", 0) == 0
    execution_decision = "HOLD_FOR_HUMAN_APPROVAL" if not human_approval_present else "APPROVAL_PRESENT_REQUIRES_SEPARATE_LIVE_APPLY_PATCH"
