def _patch124_targets_from_inventory(arg: str) -> tuple[list[dict], list[str], dict]:
    inv = _patch124_latest_inventory()
    problems = []
    targets = []
    if not inv:
        return [], ["canonical test inventory missing; run canonical-test-inventory first"], {}
    rows = inv.get("rows") or []
    requested = (arg or "all").strip()
    limit = None
    engine_filter = None
    parts = requested.split()
    if parts and parts[0] == "limit":
        try:
            limit = max(1, int(parts[1])) if len(parts) > 1 else 10
        except Exception:
            limit = 10
    elif requested not in ("all", "latest", ""):
        engine_filter = requested
    for row in rows:
        engine = row.get("engine_base")
        if engine_filter and engine != engine_filter:
            continue
        for tr in row.get("safe_test_candidates") or []:
            test_path = Path(tr.get("path") or "").expanduser()
            if not test_path.exists() or not test_path.is_file():
                problems.append(f"safe candidate disappeared: {engine} {test_path}")
                continue
            # Recheck SHA and banned-token state from current disk before planning.
            rescanned = _patch123_scan_test_file(test_path)
            if not rescanned.get("safe_candidate"):
                problems.append(f"candidate no longer safe by scan: {engine} {test_path}")
                continue
            if tr.get("sha256") and rescanned.get("sha256") != tr.get("sha256"):
                problems.append(f"candidate SHA changed since inventory: {engine} {test_path}")
                continue
            cwd = _patch124_engine_root_for_test(test_path, row.get("canonical_path") or "")
            targets.append({
                "engine_base": engine,
                "canonical_path": row.get("canonical_path"),
