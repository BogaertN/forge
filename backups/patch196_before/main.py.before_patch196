def _p177_extract_imports_from_text(text: str):
    imports = []
    for line in text.splitlines():
        s = line.strip()
        if s.startswith("import "):
            tail = s[len("import "):].split("#", 1)[0]
            for part in tail.split(","):
                name = part.strip().split(" as ", 1)[0].strip()
                if name:
                    imports.append(name)
        elif s.startswith("from ") and " import " in s:
            mod = s[len("from "):].split(" import ", 1)[0].strip()
            if mod:
                imports.append(mod)
    clean = []
    for item in imports:
        item = item.strip()
        if item and item not in clean:
            clean.append(item)
    return clean[:40]


def _p177_file_rows_from_scope(scope: dict):
    fs = scope.get("file_scope", {}) if isinstance(scope, dict) else {}
    rows = fs.get("files", []) if isinstance(fs, dict) else []
    if not isinstance(rows, list):
        return []
    return rows


def _p177_analyze_dependencies(scope: dict):
    files = _p177_file_rows_from_scope(scope)
    ext_counter = _p177_Counter()
    basename_counter = _p177_Counter()
    import_edges = []
    unreadable = []
    python_files = []
    config_files = []
    for row in files:
        path = str(row.get("path") or "")
        rel = str(row.get("relative_path") or path)
        suffix = _P177Path(path).suffix.lower()
        basename = _P177Path(path).name
        ext_counter[suffix or "<none>"] += 1
        basename_counter[basename] += 1
        if suffix == ".py":
            python_files.append(rel)
            try:
                txt = _P177Path(path).read_text(encoding="utf-8", errors="replace")
                imports = _p177_extract_imports_from_text(txt)
                import_edges.append({"file": rel, "import_count": len(imports), "imports": imports})
            except Exception as exc:
                unreadable.append({"file": rel, "path": path, "error": str(exc)})
        elif suffix in {".json", ".toml", ".yaml", ".yml", ".ini", ".cfg"}:
            config_files.append(rel)
    duplicates = []
    for name, count in basename_counter.items():
        if count > 1:
            duplicates.append({"basename": name, "count": count})
    local_import_hits = []
    basenames_without_suffix = {(_P177Path(str(r.get("path") or "")).stem) for r in files}
    for edge in import_edges:
        for imp in edge.get("imports", []):
            head = imp.split(".", 1)[0]
            if head in basenames_without_suffix:
                local_import_hits.append({"file": edge.get("file"), "import": imp, "local_name_match": head})
    return {
        "file_count": len(files),
        "python_file_count": len(python_files),
        "config_file_count": len(config_files),
        "extension_counts": dict(sorted(ext_counter.items())),
        "python_files_preview": python_files[:40],
        "config_files_preview": config_files[:40],
        "import_edges_preview": import_edges[:60],
        "local_import_name_hits": local_import_hits[:60],
        "duplicate_basenames": duplicates,
        "unreadable_files": unreadable[:40],
        "analysis_note": "Static read-only dependency scan. It does not execute imports, run tests, modify files, or infer live readiness.",
    }


def _p177_impact_notes(scope: dict, dep: dict):
    candidate = scope.get("selected_candidate") or "failsafe_manager"
    file_count = int(dep.get("file_count") or 0)
    py_count = int(dep.get("python_file_count") or 0)
    config_count = int(dep.get("config_file_count") or 0)
    duplicate_count = len(dep.get("duplicate_basenames") or [])
    warnings = []
    if not scope:
        warnings.append("Patch 176 scope receipt not found; dependency review is based on empty/fallback scope.")
    if file_count == 0:
        warnings.append("No candidate files were available from the Patch 176 scope receipt.")
    if duplicate_count:
        warnings.append("Duplicate basenames exist in the candidate file set; review before any future live apply.")
    if config_count:
        warnings.append("Configuration files are present; future patching must verify exact SHA and rollback files.")
    impact_level = "REVIEW_REQUIRED" if warnings else "LOW_NO_WRITE_REVIEW"
    return {
        "candidate": candidate,
        "impact_level": impact_level,
        "summary": "No live impact. This patch creates dependency/impact notes only. Any future real change still requires exact-read, SHA matching, sandbox, tests, rollback, and explicit approval.",
        "observed_file_count": file_count,
        "observed_python_file_count": py_count,
        "observed_config_file_count": config_count,
        "duplicate_basename_count": duplicate_count,
        "future_required_gates": [
            "exact-read target file from approved scope",
            "record current sha256",
            "build structured no-write plan",
            "sandbox apply on copied file set",
            "safe test runner / py_compile where applicable",
            "rollback artifact available",
            "fresh human approval token in a separate live execution patch",
            "post-write disk readback and audit verification",
        ],
        "warnings": warnings,
    }


