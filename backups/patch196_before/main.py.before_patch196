    json_path.write_text(_p174_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md = []
    md.append("# Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection")
    md.append("")
    for k in ["status","planning_ready","live_build_ready","human_approval_present","approval_token_entered","token_validation_status","execution_decision","runtime_writes","project_writes","engine_writes","next_patch"]:
        md.append(f"- **{k}**: `{payload.get(k)}`")
    md.append("")
    md.append("## Queue Decision")
    q = payload.get("queue_decision", {})
    for k in ["selected_candidate","selected_candidate_action","next_candidate_selection","live_execution_permitted","runtime_writes_performed","project_writes_performed","engine_writes_performed","reason"]:
        md.append(f"- **{k}**: `{q.get(k)}`")
    md.append("")
    md.append("## Candidate Queue Rows")
    for row in payload.get("candidate_queue_rows", []):
