def _p157_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default if default is not None else {}
    return default if default is not None else {}


def _p157_write_json_md(payload: dict, stem: str) -> tuple[Path, Path]:
    _p157_ensure_dir()
    stamp = _p157_stamp()
    jp = FORGE_RUNTIME_BUILD_PLAN_DIR / f"{stamp}_{stem}.json"
    mp = FORGE_RUNTIME_BUILD_PLAN_DIR / f"{stamp}_{stem}.md"
    latest_j = FORGE_RUNTIME_BUILD_PLAN_DIR / f"latest_{stem}.json"
    latest_m = FORGE_RUNTIME_BUILD_PLAN_DIR / f"latest_{stem}.md"
    jp.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md = _p157_markdown(payload)
    mp.write_text(md, encoding="utf-8")
    latest_j.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    latest_m.write_text(md, encoding="utf-8")
    return jp, mp


