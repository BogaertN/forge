FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_SCHEMA_VERSION = "forge_runtime_live_hold_continuation_v1_patch173"


def _p173_now() -> str:
    return _p173_datetime.now().strftime("%Y%m%d_%H%M%S")


def _p173_safe_read_json(path, default=None):
    try:
        p = _P173Path(path)
        if p.exists():
            return _p173_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p173_latest_json(rel_path: str, default=None):
    return _p173_safe_read_json(_P173Path.home() / "forge" / "memory" / rel_path, default)


def _p173_hash_payload(payload: dict) -> str:
    return _p173_hashlib.sha256(_p173_json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _p173_apply_hold_report():
    return _p173_latest_json("forge_runtime_live_apply_hold_review_v1/latest_forge_runtime_live_apply_hold_review_v1.json", {})


def _p173_explicit_approval_report():
    return _p173_latest_json("forge_runtime_live_explicit_approval_v1/latest_forge_runtime_live_explicit_approval_v1.json", {})


def _p173_planned_files():
    source = _p173_apply_hold_report() or _p173_explicit_approval_report()
    rows = []
    for item in source.get("planned_files", []) or []:
        if isinstance(item, dict):
            row = dict(item)
            row["live_write_planned_now"] = False
            row["queue_return_preserved"] = True
            rows.append(row)
    return rows


def _p173_source_report_summary():
    sources = [
        ("runtime_live_apply_hold_review", "forge_runtime_live_apply_hold_review_v1/latest_forge_runtime_live_apply_hold_review_v1.json"),
        ("runtime_live_explicit_approval", "forge_runtime_live_explicit_approval_v1/latest_forge_runtime_live_explicit_approval_v1.json"),
        ("runtime_live_token_validate", "forge_runtime_live_token_validate_v1/latest_forge_runtime_live_token_validate_v1.json"),
        ("runtime_live_token_entry", "forge_runtime_live_token_entry_v1/latest_forge_runtime_live_token_entry_v1.json"),
        ("runtime_live_execution_gate", "forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json"),
        ("runtime_live_final_gate", "forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json"),
        ("runtime_live_backup_dry_run", "forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_apply_dry_run_v1.json"),
        ("runtime_live_preflight", "forge_runtime_live_preflight_v1/latest_forge_runtime_live_preflight_v1.json"),
    ]
    rows = []
    for label, rel in sources:
        payload = _p173_latest_json(rel, {})
        rows.append({
            "label": label,
            "relative_path": rel,
            "found": bool(payload),
            "status": payload.get("status") if isinstance(payload, dict) else None,
            "candidate": payload.get("candidate") if isinstance(payload, dict) else None,
            "planning_ready": payload.get("planning_ready") if isinstance(payload, dict) else None,
            "live_build_ready": payload.get("live_build_ready") if isinstance(payload, dict) else None,
            "human_approval_present": payload.get("human_approval_present") if isinstance(payload, dict) else None,
            "runtime_writes": payload.get("runtime_writes") if isinstance(payload, dict) else None,
            "project_writes": payload.get("project_writes") if isinstance(payload, dict) else None,
            "engine_writes": payload.get("engine_writes") if isinstance(payload, dict) else None,
        })
    return rows


def _p173_payload() -> dict:
    hold = _p173_apply_hold_report()
    explicit = _p173_explicit_approval_report()
    files = _p173_planned_files()
    candidate = hold.get("candidate") or explicit.get("candidate") or "failsafe_manager"
    human_approval = bool(hold.get("human_approval_present") or explicit.get("human_approval_present") or False)
    token_entered = bool(hold.get("approval_token_entered") or explicit.get("approval_token_entered") or False)
    token_status = hold.get("token_validation_status") or explicit.get("token_validation_status") or "NOT_ENTERED"
    prior_runtime_writes = int(hold.get("runtime_writes") or 0)
    prior_project_writes = int(hold.get("project_writes") or 0)
    prior_engine_writes = int(hold.get("engine_writes") or 0)
    hold_status = hold.get("status") or "MISSING"
    no_write_receipt = hold.get("no_write_receipt") if isinstance(hold.get("no_write_receipt"), dict) else {}
    problems = []
    if not hold:
        problems.append("latest Patch 172 apply-hold review/no-write receipt is missing")
    if prior_runtime_writes or prior_project_writes or prior_engine_writes:
        problems.append("latest Patch 172 apply-hold review contains nonzero write counters")
    if not no_write_receipt:
        problems.append("Patch 172 no-write receipt block is missing")
    if not files:
        problems.append("planned runtime files could not be preserved for candidate queue return")

    gates = [
        {"id":"Q01","name":"Patch 172 apply-hold review exists","status":"PASS" if hold else "FAIL","detail": hold_status},
        {"id":"Q02","name":"Patch 172 no-write receipt exists","status":"PASS" if no_write_receipt else "FAIL","detail": no_write_receipt.get("receipt_type", "missing")},
        {"id":"Q03","name":"Patch 172 write counters are zero","status":"PASS" if (prior_runtime_writes == 0 and prior_project_writes == 0 and prior_engine_writes == 0) else "FAIL","detail": f"runtime={prior_runtime_writes} project={prior_project_writes} engine={prior_engine_writes}"},
        {"id":"Q04","name":"Human approval remains absent","status":"LOCKED" if not human_approval else "WARN","detail": f"human_approval_present={human_approval}"},
        {"id":"Q05","name":"Approval token remains non-executing","status":"LOCKED" if not token_entered else "WARN","detail": f"token_entered={token_entered} token_status={token_status}"},
        {"id":"Q06","name":"Live build remains not ready","status":"LOCKED","detail":"live_build_ready=False"},
        {"id":"Q07","name":"Candidate planned files preserved for queue return","status":"PASS" if files else "FAIL","detail": f"planned_files={len(files)}"},
        {"id":"Q08","name":"Queue return authority is no-write only","status":"PASS","detail":"Forge-owned memory report only; no runtime/project/engine writes"},
    ]
    summary = {"pass":0,"warn":0,"locked":0,"fail":0}
    for g in gates:
        key = str(g.get("status", "")).lower()
        if key in summary:
            summary[key] += 1

    queue_return = {
        "return_type": "RUNTIME_CANDIDATE_QUEUE_RETURN_HELD",
        "candidate": candidate,
        "queue_status": "HELD_PENDING_EXPLICIT_APPROVAL_OR_NEXT_CANDIDATE_REVIEW",
        "reason": "No explicit human approval token was entered and Patch 172 produced only a no-write receipt.",
        "approval_present": human_approval,
        "approval_token_entered": token_entered,
        "token_validation_status": token_status,
        "execution_decision": "RETURN_TO_RUNTIME_CANDIDATE_QUEUE_HELD",
        "live_execution_performed": False,
        "runtime_writes_performed": 0,
        "project_writes_performed": 0,
        "engine_writes_performed": 0,
        "required_before_any_future_live_apply": "a separate explicit approval token, a fresh execution patch, and disk rechecks of every runtime-live gate",
    }
    payload = {
        "report_type": "FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_QUEUE_RETURN_V1",
        "schema_version": FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_SCHEMA_VERSION,
        "created_at": _p173_now(),
        "active_patch": "Patch 173 — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return",
        "current_phase": "S19S — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return",
        "next_patch": "Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection",
        "recommended_next_patch": "Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection",
        "candidate": candidate,
        "status": "FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_READY_QUEUE_RETURN" if not problems else "FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_PROBLEMS_FOUND",
        "planning_ready": not problems,
        "live_build_ready": False,
        "human_approval_present": human_approval,
        "approval_token_entered": token_entered,
        "token_validation_status": token_status,
        "execution_decision": "RETURN_TO_RUNTIME_CANDIDATE_QUEUE_HELD",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "planned_file_count": len(files),
        "planned_files": files,
        "source_reports": _p173_source_report_summary(),
        "queue_return": queue_return,
        "queue_return_fingerprint": "",
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "runtime_file_write_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
            "live_execution_authority": False,
            "candidate_queue_mutation_authority": False,
        },
        "gates": gates,
        "gate_summary": summary,
        "problem_count": len(problems),
        "problems": problems,
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 173 continues the live-build hold, records that failsafe_manager returns to a held candidate-queue state, and performs zero live runtime, project, or engine writes.",
    }
    payload["queue_return_fingerprint"] = _p173_hash_payload(queue_return)
    return payload


def _p173_write_json_and_md(stem: str, payload: dict):
    FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_DIR.mkdir(parents=True, exist_ok=True)
    json_path = FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_DIR / f"{stem}.json"
    md_path = FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_DIR / f"{stem}.md"
    json_path.write_text(_p173_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md = []
    md.append("# Patch 173 — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return")
    md.append("")
    for k in ["status","candidate","planning_ready","live_build_ready","human_approval_present","approval_token_entered","token_validation_status","execution_decision","runtime_writes","project_writes","engine_writes","next_patch"]:
        md.append(f"- **{k}**: `{payload.get(k)}`")
    md.append("")
    md.append("## Queue Return")
    q = payload.get("queue_return", {})
    for k in ["return_type","queue_status","live_execution_performed","runtime_writes_performed","project_writes_performed","engine_writes_performed","reason"]:
        md.append(f"- **{k}**: `{q.get(k)}`")
    md.append("")
    md.append("## Gates")
    for g in payload.get("gates", []):
        md.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')} — {g.get('detail')}")
    md.append("")
    md.append("## Planned Files Preserved")
    for f in payload.get("planned_files", []):
        md.append(f"- {f.get('relative_path')} | live_write_now={f.get('live_write_planned_now')} | queue_return_preserved={f.get('queue_return_preserved')}")
    md_path.write_text("\n".join(md)+"\n", encoding="utf-8")
    _p173_shutil.copyfile(json_path, FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_DIR / "latest_forge_runtime_live_hold_continuation_v1.json")
    _p173_shutil.copyfile(md_path, FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_DIR / "latest_forge_runtime_live_hold_continuation_v1.md")
    return json_path, md_path


