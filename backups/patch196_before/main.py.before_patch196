        {"id":"D05","name":"Static candidate verification clean","status":"PASS" if static_ready else "WARN","detail": static.get("status") or "not found"},
        {"id":"D06","name":"Explicit human approval captured","status":"PASS" if human_approval_present else "LOCKED","detail": f"approval_token_status={approval_token_status}"},
        {"id":"D07","name":"Execution decision","status":"LOCKED" if not human_approval_present else "PASS","detail": execution_decision},
        {"id":"D08","name":"No live writes performed","status":"PASS","detail":"runtime_writes=0 project_writes=0 engine_writes=0"},
    ]
    problems = [g for g in gates if g.get("status") == "FAIL"]
    planning_ready = len(problems) == 0 and len(planned_files) > 0
    return {
        "schema_version": FORGE_RUNTIME_LIVE_DECISION_SCHEMA_VERSION,
