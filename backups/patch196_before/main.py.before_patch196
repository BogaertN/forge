def _p150_build_gates(target: str) -> tuple[list[dict], list[str]]:
    proposal = _p150_latest_llm_proposal()
    verify = _p150_latest_llm_verify()
    status_api = _p150_latest_status_api()
    dashboard = _p150_latest_dashboard()
    sequence = _p150_latest_build_sequence()
    gate = _p150_latest_gate()
    queue = _p150_latest_deferred_queue()
    impact = _p150_latest_patch_impact()
    tests = _p150_latest_tests()
    source = _p150_latest_source_hardening()

    gates: list[dict] = []
    blockers: list[str] = []

    def add(gate_id: str, label: str, status: str, message: str, evidence=None, blocks: bool = False):
        gates.append({"gate_id": gate_id, "label": label, "status": status, "message": message, "evidence": evidence})
        if blocks and status != "PASS":
            blockers.append(f"{gate_id}: {message}")

    add("G01", "LLM proposal exists", "PASS" if proposal else "FAIL", proposal.get("status") or "No latest LLM patch v2 proposal found.", {"path": str(MEMORY_DIR / "forge_llm_patch_proposal_v2")}, True)
    add("G02", "LLM proposal verified", "PASS" if verify.get("status") == "FORGE_LLM_PATCH_PROPOSAL_V2_VERIFIED_READ_ONLY" and not verify.get("problem_count") else "FAIL", verify.get("status") or "No verified proposal available.", {"problem_count": verify.get("problem_count"), "warning_count": verify.get("warning_count")}, True)
    add("G03", "Source authority visible", "PASS" if source.get("status") else "WARN", source.get("status") or "Source authority hardening report not found; do not claim authority.", {"gap_count": (source.get("summary") or {}).get("gap_count") or source.get("gap_count")}, False)
    test_counts = (tests.get("counts") or tests.get("summary") or {})
    test_fail = test_counts.get("fail")
    test_pass = test_counts.get("pass")
    add("G04", "Canonical tests clean", "PASS" if test_fail == 0 else "FAIL", f"pass={test_pass} fail={test_fail}", {"status": tests.get("status"), "counts_source": "counts_or_summary"}, True)
    add("G05", "Patch impact clean", "PASS" if ((impact.get("summary") or {}).get("high_risk") == 0 and (impact.get("summary") or {}).get("test_issues") == 0) else "FAIL", f"high={(impact.get('summary') or {}).get('high_risk')} test_issues={(impact.get('summary') or {}).get('test_issues')}", {"status": impact.get("status")}, True)
    add("G06", "Build phase gate clean", "PASS" if gate.get("gate_fail_count") == 0 else "FAIL", f"pass={gate.get('gate_pass_count')} warn={gate.get('gate_warn_count')} fail={gate.get('gate_fail_count')}", {"status": gate.get("status")}, True)
    status_next = status_api.get("recommended_next_patch") or status_api.get("next_patch")
    dashboard_next = dashboard.get("recommended_next_patch") or dashboard.get("next_patch") or ((dashboard.get("build_sequence") or {}).get("next_patch"))
    sequence_next = sequence.get("recommended_next_patch") or sequence.get("next_patch")
    status_dashboard_agree = bool(status_next and dashboard_next and sequence_next and status_next == dashboard_next == sequence_next)
    add("G07", "Status/dashboard/build sequence agree", "PASS" if status_dashboard_agree else "WARN", f"status_api={status_next} dashboard={dashboard_next} sequence={sequence_next}", {"sequence_next": sequence_next}, False)
    add("G08", "Deferred queue visible", "PASS" if queue.get("status") else "WARN", queue.get("status") or "Deferred queue report not found.", {"queue_total": queue.get("queue_total"), "repair_ready_count": queue.get("repair_ready_count")}, False)
    add("G09", "Snapshot freshness", "FAIL", "No Patch 150+ live apply may be eligible until snapshot/shadow-restore evidence exists.", {"expected_future_phase": "Patch 151 — Snapshot / Forensic Replay Plan"}, True)
    add("G10", "Sandbox/test binding for target", "FAIL", "No target-specific fresh sandbox pass is bound to this live-apply request.", {"target": target}, True)
    add("G11", "Rollback readiness", "FAIL", "No target-specific rollback artifact is bound to this live-apply request.", {"target": target}, True)
    add("G12", "Human approval", "FAIL", "No explicit human live-apply approval token is present. This is correct for read-only Patch 150.", {"required_future_token": "CONFIRM_LIVE_APPLY_ELIGIBLE_TARGET"}, True)
    return gates, blockers


def _p150_payload(target: str = "next") -> dict:
    target = (target or "next").strip() or "next"
    gates, blockers = _p150_build_gates(target)
    pass_count = sum(1 for g in gates if g.get("status") == "PASS")
    warn_count = sum(1 for g in gates if g.get("status") == "WARN")
    fail_count = sum(1 for g in gates if g.get("status") == "FAIL")
    eligible = fail_count == 0 and not blockers
    status = "FORGE_LIVE_APPLY_ELIGIBILITY_V2_READY_NOT_ELIGIBLE" if not eligible else "FORGE_LIVE_APPLY_ELIGIBILITY_V2_ELIGIBLE_PENDING_HUMAN_REVIEW"
    proposal = _p150_latest_llm_proposal()
    verify = _p150_latest_llm_verify()
    return {
        "schema_version": FORGE_LIVE_ELIGIBILITY_V2_SCHEMA_VERSION,
        "report_type": "FORGE_LIVE_APPLY_ELIGIBILITY_V2",
        "created_at": _p150_now(),
        "status": status,
        "active_patch": "Patch 150 — Live Apply Eligibility Gate v2",
        "current_phase": "S15 — Live apply eligibility gate v2",
        "target": target,
        "target_patch": proposal.get("target") or proposal.get("next_patch") or "Patch 150 — Live Apply Eligibility Gate v2",
        "eligible_for_live_apply": eligible,
        "gate_pass_count": pass_count,
        "gate_warn_count": warn_count,
        "gate_fail_count": fail_count,
        "gates": gates,
        "blocking_reasons": blockers,
        "llm_patch_proposal_v2": {"proposal_status": proposal.get("status"), "verification_status": verify.get("status"), "problem_count": verify.get("problem_count")},
        "plain_english": "Patch 150 creates the live-apply eligibility surface. It should usually say NOT ELIGIBLE until snapshot, sandbox, rollback, and human approval evidence exist.",
        "next_patch": "Patch 151 — Snapshot / Forensic Replay Plan",
        "recommended_next_patch": "Patch 151 — Snapshot / Forensic Replay Plan",
        "next_commands": ["forge-live-eligibility-v2-export", "forge-build-sequence", "forge-status-api-build", "forge-dashboard-build", "Install Patch 151 when ready"],
        "authority": {"read_only": True, "forge_memory_write_only": True, "proposal_only": True, "project_file_write_authority": False, "engine_file_write_authority": False, "patch_apply_authority": False, "shell_execution_authority": False, "network_or_server_start_authority": False, "human_approval_required": True},
    }


