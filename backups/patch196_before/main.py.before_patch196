def _p166_planned_files_from_sources():
    # Prefer final gate planned files, then backup dry-run files, then candidate draft files.
    final_gate = _p166_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    backup = _p166_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_apply_dry_run_v1.json", {}) or _p166_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_plan_v1.json", {})
    draft = _p166_latest_json("forge_runtime_candidate_drafts_v1/latest_forge_runtime_candidate_draft_v1.json", {})
    files = []
    for row in final_gate.get("planned_files", []) or []:
        if isinstance(row, dict):
            files.append(dict(row, source="final_gate"))
    if not files:
        for row in backup.get("planned_files", []) or backup.get("files", []) or []:
            if isinstance(row, dict):
                files.append(dict(row, source="backup_dry_run"))
    if not files:
        for row in draft.get("draft_files", []) or draft.get("files", []) or []:
            if isinstance(row, dict):
                files.append(dict(row, source="candidate_draft"))
    # Normalize common fields.
    normalized = []
    seen = set()
    for row in files:
        rel = row.get("relative_path") or row.get("target_relative_path") or row.get("runtime_relative_path") or row.get("path") or row.get("file")
        if not rel:
            rel = row.get("name") or "unknown"
        key = str(rel)
        if key in seen:
            continue
        seen.add(key)
        normalized.append({
            "relative_path": key,
            "target_relative_path": row.get("target_relative_path") or key,
            "sandbox_source": row.get("sandbox_source") or row.get("source_path") or row.get("source") or "candidate_sandbox",
            "source": row.get("source") or "runtime_evidence",
            "live_write_planned_now": False,
        })
    return normalized


