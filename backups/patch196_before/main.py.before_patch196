def _p184_now():
    return _p184_dt.datetime.now().strftime("%Y%m%d_%H%M%S")


def _p184_slug(text):
    slug = text.lower().strip()[:40]
    slug = "".join(c if (c.isalnum() or c == "_") else "_" for c in slug.replace(" ", "_").replace("-", "_"))
    while "__" in slug:
        slug = slug.replace("__", "_")
    return slug.strip("_")


def _p184_ensure_dirs():
    for sub in ("proposals", "approved", "installed"):
        (_P184_CMD_GEN_DIR / sub).mkdir(parents=True, exist_ok=True)
    return _P184_CMD_GEN_DIR


def cmd_forge_command_propose(description, session_id):
    """
    Propose a new Forge command. Forge generates Python code and saves a
    proposal. You then review it and install it through the normal patch
    workflow. No code is written to main.py until YOU run patch-apply.

    Usage  : forge-command-propose <description>
    Example: forge-command-propose "list all Python files in current scope"

    After this command:
      1. forge-command-show-proposal <slug>      — review the generated code
      2. forge-command-approve-proposal <slug>   — convert to a patch file
      3. patch-review <file>                     — see exactly what changes
      4. patch-preflight <file>                  — safety checks
      5. patch-apply <plan>                      — YOU install it
    """
    from agents.forge.memory import write_audit_entry
    description = description.strip().strip('"').strip("'")
    if not description:
        print()
        print("  Usage: forge-command-propose <description>")
        print('  Example: forge-command-propose "list all Python files"')
        print()
        return

    cmd_gen_dir = _p184_ensure_dirs()
    ts          = _p184_now()
    slug        = _p184_slug(description)
    proposal_id = f"{ts}_cmd_{slug}"
    fn_name     = f"cmd_{slug}"
    cmd_name    = slug.replace("_", "-")

    fn_code = (
        f"def {fn_name}(session_id: str):\n"
        f'    """\n'
        f"    {description}\n\n"
        f"    Generated by forge-command-propose on {ts}\n"
        f"    Install via: forge-command-approve-proposal {slug}\n"
        f"    then patch-review, patch-preflight, patch-apply\n"
        f'    """\n'
        f"    from agents.forge.memory import write_audit_entry\n"
        f"    print()\n"
        f"    _title = {repr(description[:50])}\n"
        f"    print(f'── {{_title}} ──')\n"
        f'    print("  Status: EXECUTED")\n'
        f'    print("  TODO: Replace this with real implementation")\n'
        f'    print("─" * 60)\n'
        f"    print()\n"
        f"    write_audit_entry(\n"
        f"        session_id=session_id,\n"
        f'        tool="{fn_name.upper()}_EXECUTED",\n'
        f'        path="-", lines="-",\n'
        f'        reason="llm-generated command executed"\n'
        f"    )\n"
    )

    reg_entry = {
        "description":    description,
        "executes":       False,
        "trust_level":    5.0,
        "writes":         False,
        "generated_by":   "forge-command-propose",
        "generated_at":   ts,
    }

    proposal = {
        "proposal_id":           proposal_id,
        "created_at":            ts,
        "description":           description,
        "slug":                  slug,
        "function_name":         fn_name,
        "command_name":          cmd_name,
        "function_code":         fn_code,
        "tool_registry_entry":   reg_entry,
        "status":                "PROPOSAL_READY_FOR_REVIEW",
        "approved":              False,
        "patch_proposal_created": False,
    }

    proposals_dir = cmd_gen_dir / "proposals"
    json_path = proposals_dir / f"{proposal_id}_proposal.json"
    md_path   = proposals_dir / f"{proposal_id}_proposal.md"
    json_path.write_text(_p184_json.dumps(proposal, indent=2), encoding="utf-8")
    md_path.write_text(
        f"# Command Proposal: {cmd_name}\n\n"
        f"**Description:** {description}\n"
        f"**Slug:** {slug}\n"
        f"**Status:** PROPOSAL_READY_FOR_REVIEW\n\n"
        f"## Generated Code\n\n```python\n{fn_code}\n```\n\n"
        f"## Next Steps\n\n"
        f"1. Review : `forge-command-show-proposal {slug}`\n"
        f"2. Approve: `forge-command-approve-proposal {slug}`\n"
        f"3. Then use normal patch workflow to install\n",
        encoding="utf-8"
    )

    print()
    print("── Forge Command Proposal Created — Patch 184 ──────────────────────")
    print(f"  Proposal ID : {proposal_id}")
    print(f"  Command     : {cmd_name}")
    print(f"  Function    : {fn_name}")
    print(f"  Description : {description}")
    print(f"  Status      : PROPOSAL_READY_FOR_REVIEW")
    print()
    print("  What to do next — copy and run each step in order:")
    print(f"    Step 1 — Review  : forge-command-show-proposal {slug}")
    print(f"    Step 2 — Approve : forge-command-approve-proposal {slug}")
    print( "    Step 3 — Review patch  : patch-review <filename shown>")
    print( "    Step 4 — Preflight     : patch-preflight <filename shown>")
    print( "    Step 5 — Apply (yours) : patch-apply <plan shown>")
    print("────────────────────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "FORGE_COMMAND_PROPOSAL_CREATED",
                      str(json_path), proposal_id, f"command proposal: {description}")


