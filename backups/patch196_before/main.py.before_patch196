def _p142_extract_kv(raw: str, key: str):
    import re
    m = re.search(rf"^\s*{re.escape(key)}\s*:\s*(.+?)\s*$", raw or "", re.I | re.M)
    return m.group(1).strip() if m else None


def _p142_build_class_wrapper_candidate(base_text: str, module: str, missing_symbol: str, alias: str, class_name: str, method_name: str):
    import re
    problems = []
    if not all([module, missing_symbol, alias, class_name, method_name]):
        problems.append("missing_transformation_inputs")
        return base_text, {"changed": False, "problems": problems}
    pattern = re.compile(rf"^(\s*)from\s+{re.escape(module)}\s+import\s+{re.escape(missing_symbol)}(?:\s+as\s+{re.escape(alias)})?\s*$", re.M)
    replacement = f"from {module} import {class_name}"
    new_text, count = pattern.subn(replacement, base_text, count=1)
    if count != 1:
        problems.append("target_import_line_not_found")
        return base_text, {"changed": False, "problems": problems}
    instance_name = "_" + alias.replace("_breathe", "_breather") + "_instance"
    if instance_name in new_text or f"def {alias}" in new_text:
        return new_text, {"changed": new_text != base_text, "problems": problems, "note": "wrapper_already_present_or_partially_present"}
    lines = new_text.splitlines()
    insert_idx = 0
    for i, line in enumerate(lines):
        if line.startswith("import ") or line.startswith("from "):
            insert_idx = i + 1
    wrapper = ["", f"{instance_name} = {class_name}()", f"def {alias}(phase=None):", f"    return {instance_name}.{method_name}()", ""]
    lines[insert_idx:insert_idx] = wrapper
    new_text = "\n".join(lines) + ("\n" if base_text.endswith("\n") else "")
    return new_text, {"changed": new_text != base_text, "problems": problems, "module": module, "missing_symbol": missing_symbol, "alias": alias, "class_name": class_name, "method_name": method_name, "instance_name": instance_name}


def _p142_compile_text(text: str, filename="candidate.py"):
    import tempfile, subprocess, sys
    from pathlib import Path
    with tempfile.TemporaryDirectory(prefix="forge_p142_compile_") as td:
        p = Path(td) / filename
        p.write_text(text or "", encoding="utf-8", errors="replace")
        try:
            cp = subprocess.run([sys.executable, "-m", "py_compile", str(p)], cwd=td, text=True, capture_output=True, timeout=45, shell=False)
            return {"py_compile_status": "PASS" if cp.returncode == 0 else "FAIL", "returncode": cp.returncode, "stdout": cp.stdout, "stderr": cp.stderr, "shell": False}
        except Exception as exc:
            return {"py_compile_status": "ERROR", "returncode": 127, "stdout": "", "stderr": repr(exc), "shell": False}


