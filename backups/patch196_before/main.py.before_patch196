def _patch130_iso_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _patch130_ensure_dir() -> None:
    FORGE_MODE_ENFORCEMENT_DIR.mkdir(parents=True, exist_ok=True)


def _patch130_write_json_md(payload: dict, stem: str) -> tuple[Path, Path]:
    _patch130_ensure_dir()
    ts = _patch130_iso_now().replace("-", "_").replace(":", "").replace("T", "_")
    json_path = FORGE_MODE_ENFORCEMENT_DIR / f"{ts}_{stem}.json"
    md_path = FORGE_MODE_ENFORCEMENT_DIR / f"{ts}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md_lines = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "mode", "current_mode", "command", "recommended_next_patch"):
        if key in payload:
            md_lines.append(f"- **{key}**: `{payload.get(key)}`")
    if "summary" in payload and isinstance(payload.get("summary"), dict):
        md_lines.append("")
        md_lines.append("## Summary")
        for k, v in payload.get("summary", {}).items():
            md_lines.append(f"- **{k}**: `{v}`")
    if "allowed_modes" in payload:
        md_lines.append("")
        md_lines.append("## Allowed modes")
        for item in payload.get("allowed_modes") or []:
            md_lines.append(f"- `{item}`")
    if "problems" in payload:
        md_lines.append("")
        md_lines.append("## Problems")
        for item in payload.get("problems") or []:
            md_lines.append(f"- {item}")
    md_path.write_text("\n".join(md_lines) + "\n", encoding="utf-8")
    latest_json = FORGE_MODE_ENFORCEMENT_DIR / f"latest_{stem}.json"
    latest_md = FORGE_MODE_ENFORCEMENT_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


def _patch130_load_json(path: Path) -> dict:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return {}


