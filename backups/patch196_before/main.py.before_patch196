def _snapshot_manifest_safe_to_hash(path: Path) -> tuple[bool, str]:
    p = Path(path)
    low_parts = [part.lower() for part in p.parts]
    name_low = p.name.lower()
    if any(part in SNAPSHOT_IGNORED_NAMES for part in low_parts):
        return False, "ignored_name"
    if any(marker in name_low for marker in SNAPSHOT_SECRET_MARKERS):
        return False, "secret_marker"
    if any(marker in str(p).lower() for marker in SNAPSHOT_SECRET_MARKERS):
        return False, "secret_path_marker"
    if p.suffix.lower() in SNAPSHOT_IGNORED_SUFFIXES:
        return False, "ignored_suffix"
    try:
        if not p.exists():
            return False, "missing"
        if not p.is_file():
            return False, "not_file"
        size = p.stat().st_size
        if size > SNAPSHOT_MANIFEST_MAX_FILE_BYTES:
            return False, "too_large"
    except Exception:
        return False, "stat_error"
    return True, "ok"


def _snapshot_manifest_hash_row(path: Path, label: str, root_label: str = "direct") -> dict:
    p = Path(path)
    row = {
        "label": label,
        "root_label": root_label,
        "path": str(p),
        "exists": p.exists(),
        "is_file": p.is_file() if p.exists() else False,
        "size_bytes": None,
        "sha256": None,
        "sha256_16": None,
        "included": False,
        "skip_reason": None,
        "content_copied": False,
        "note": "hash metadata only; file content was not copied",
    }
    ok, reason = _snapshot_manifest_safe_to_hash(p)
    if not ok:
        row["skip_reason"] = reason
        return row
    try:
        size = p.stat().st_size
        import hashlib as _hashlib
        h = _hashlib.sha256()
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        digest = h.hexdigest()
        row.update({
            "size_bytes": size,
            "sha256": digest,
            "sha256_16": digest[:16],
            "included": True,
        })
    except Exception as e:
        row["skip_reason"] = f"hash_error:{e}"
    return row


def _snapshot_manifest_scan_root(root: Path, root_label: str, limit: int = SNAPSHOT_MANIFEST_MAX_FILES_PER_ROOT) -> dict:
    root = Path(root)
    result = {
        "root_label": root_label,
        "root": str(root),
        "exists": root.exists(),
        "is_dir": root.is_dir() if root.exists() else False,
        "files": [],
        "counts": {"included": 0, "skipped": 0, "truncated": 0},
        "content_copied": False,
    }
    if not root.exists() or not root.is_dir():
        return result
    visited = 0
    try:
        for p in sorted(root.rglob("*")):
            if not p.is_file():
                continue
            if visited >= limit:
                result["counts"]["truncated"] += 1
                continue
            visited += 1
            try:
                rel = str(p.relative_to(root))
            except Exception:
                rel = p.name
            row = _snapshot_manifest_hash_row(p, rel, root_label=root_label)
            if row.get("included"):
                result["counts"]["included"] += 1
                result["files"].append(row)
            else:
                result["counts"]["skipped"] += 1
    except Exception as e:
        result["error"] = str(e)
    return result


