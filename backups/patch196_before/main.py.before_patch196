def _p155_write(payload: dict, stem: str):
    _p155_ensure_dir()
    stamp = _p155_stamp()
    jp = FORGE_AIWEB_RUNTIME_READINESS_DIR / f"{stamp}_{stem}.json"
    mp = FORGE_AIWEB_RUNTIME_READINESS_DIR / f"{stamp}_{stem}.md"
    jp.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"- **status**: `{payload.get('status')}`",
        f"- **active_patch**: `{payload.get('active_patch')}`",
        f"- **current_phase**: `{payload.get('current_phase')}`",
        f"- **next_patch**: `{payload.get('next_patch')}`",
        f"- **planning_ready**: `{payload.get('planning_ready')}`",
        f"- **live_build_ready**: `{payload.get('live_build_ready')}`",
        "",
        "## Domain Rows",
        "",
    ]
    for row in payload.get("domain_rows") or []:
        lines.append(f"- `{row.get('domain_id')}` `{row.get('status')}` — {row.get('domain')}: {row.get('summary')}")
    if payload.get("live_build_blockers"):
        lines += ["", "## Live Build Blockers", ""]
        for row in payload.get("live_build_blockers") or []:
            lines.append(f"- `{row.get('domain_id')}` — {row.get('domain')}")
    lines += ["", "## Authority", ""]
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- `{k}`: `{v}`")
    mp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    (FORGE_AIWEB_RUNTIME_READINESS_DIR / f"latest_{stem}.json").write_text(jp.read_text(encoding="utf-8"), encoding="utf-8")
    (FORGE_AIWEB_RUNTIME_READINESS_DIR / f"latest_{stem}.md").write_text(mp.read_text(encoding="utf-8"), encoding="utf-8")
    return jp, mp


def _p155_append_rows(existing_rows: list) -> list:
    rows = [dict(r) for r in (existing_rows or [])]
    known = {r.get("id") for r in rows}
    additions = [
        {"id": "S19A", "title": "AI.Web Runtime Build Readiness Map", "status": "ACTIVE", "purpose": "Map whether Forge is ready to plan the AI.Web runtime build through canonical engines, tests, source authority, snapshots, shadow evidence, and live-apply gates."},
        {"id": "S19B", "title": "Runtime Module Dependency Map", "status": "NEXT", "purpose": "Map AI.Web runtime modules, dependencies, wrappers, tests, and deferred edges before any runtime build patch is proposed."},
        {"id": "S19C", "title": "Runtime Build Sandbox Planner", "status": "FUTURE", "purpose": "Plan a Forge-owned runtime build sandbox before any AI.Web live runtime writes are eligible."},
    ]
    for row in additions:
        if row["id"] not in known:
            rows.append(row)
            known.add(row["id"])
    for row in rows:
        rid = row.get("id")
        if rid in {"S17", "S17A", "S17B", "S17C", "S18", "S18A"}:
            row["status"] = "DONE"
        elif rid in {"S18B", "S18C"}:
            row["status"] = row.get("status") or "FUTURE"
        elif rid == "S19":
            row["status"] = "ACTIVE"
        elif rid == "S19A":
            row["status"] = "ACTIVE"
        elif rid == "S19B":
            row["status"] = "NEXT"
        elif rid == "S19C":
            row["status"] = "FUTURE"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


