def _snapshot_shadow_copy_full_sha(path: Path) -> str | None:
    try:
        import hashlib as _hashlib
        h = _hashlib.sha256()
        with Path(path).open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _snapshot_shadow_copy_safe_rel(rel: str) -> bool:
