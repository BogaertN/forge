# ─── PATCH 149: LLM PATCH PROPOSAL V2 ─────────────────────────────────────
# Purpose:
#   Build a stricter, current-roadmap-aware LLM patch proposal packet. This does
#   not call an LLM, edit code, apply patches, run shell commands, or claim source
#   authority. It prepares the verified structure that a local LLM may later fill
#   under Forge validation.
# Authority:
#   Forge-owned memory/report writes only. No project writes. No engine writes.
#   No patch apply authority. No shell execution. Human approval still required.

FORGE_LLM_PATCH_V2_SCHEMA_VERSION = "forge_llm_patch_proposal_v2_patch149"
FORGE_LLM_PATCH_V2_DIR = MEMORY_DIR / "forge_llm_patch_proposal_v2"
FORGE_LLM_PATCH_V2_STEM = "forge_llm_patch_proposal_v2"
FORGE_LLM_PATCH_V2_VERIFY_STEM = "forge_llm_patch_proposal_v2_verify"
FORGE_LLM_PATCH_V2_EXPORT_STEM = "forge_llm_patch_proposal_v2_export"

PATCH149_COMMANDS = [
    "forge-llm-patch-v2-policy",
    "forge-llm-patch-v2-draft",
    "forge-llm-patch-v2-show",
    "forge-llm-patch-v2-verify",
