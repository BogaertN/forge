def _patch96_allowed_code_file(path: Path) -> bool:
    parts = {p.lower() for p in path.parts}
    if "__pycache__" in parts or ".venv" in parts or "node_modules" in parts or ".git" in parts:
        return False
    if path.suffix.lower() in {".pyc", ".pyo", ".sqlite", ".db", ".png", ".jpg", ".jpeg", ".gif", ".webp", ".pdf", ".zip", ".tar", ".gz"}:
        return False
    if path.suffix.lower() in {".py", ".json", ".md", ".txt", ".yaml", ".yml", ".toml", ".sh", ".js", ".jsx", ".ts", ".tsx", ".css", ".html"}:
        return True
    return path.name.lower() in {"readme", "dockerfile", "makefile"}


def _patch96_extract_symbols(text: str, suffix: str) -> dict:
    imports: list[str] = []
    functions: list[str] = []
    classes: list[str] = []
    if suffix == ".py":
        for line in (text or "").splitlines():
            s = line.strip()
            if s.startswith("import ") or s.startswith("from "):
                imports.append(s[:240])
            if s.startswith("def "):
                functions.append(s.split("(", 1)[0].replace("def ", "").strip()[:120])
            if s.startswith("class "):
                classes.append(s.split("(", 1)[0].replace("class ", "").replace(":", "").strip()[:120])
    else:
        # Lightweight generic hints, not semantic authority.
        for m in re.finditer(r"\b([A-Za-z_][A-Za-z0-9_]{2,})\b", text or ""):
            val = m.group(1)
            if val not in functions and len(functions) < 25:
                functions.append(val[:120])
    return {"imports": imports[:30], "functions": functions[:50], "classes": classes[:30]}


def _patch96_collect_files_from_row(row: dict) -> list[Path]:
    files: list[Path] = []
    for raw in row.get("readable_file_samples") or []:
        p = Path(str(raw))
        if p.exists() and p.is_file() and _patch96_allowed_code_file(p):
            files.append(p)
    cand = Path(str(row.get("candidate_path_resolved") or ""))
    if cand.exists():
        if cand.is_file() and _patch96_allowed_code_file(cand):
            files.append(cand)
        elif cand.is_dir():
            preferred = []
            for p in cand.rglob("*"):
                if p.is_file() and _patch96_allowed_code_file(p):
                    preferred.append(p)
            preferred = sorted(preferred, key=lambda p: (0 if p.name in {"run.py", "main.py", "engine.py", "__init__.py", "README.md"} else 1, str(p)))
            files.extend(preferred[:10])
    # de-duplicate and limit
    out: list[Path] = []
    seen: set[str] = set()
    for p in files:
        rp = str(p.resolve())
        if rp not in seen:
            out.append(p.resolve())
            seen.add(rp)
        if len(out) >= 12:
            break
    return out


def _patch96_file_evidence(path: Path, candidate_root: Path | None) -> dict:
    raw = path.read_bytes()
    text = raw.decode("utf-8", errors="replace")
    rel = ""
    try:
        if candidate_root and candidate_root.exists():
            rel = str(path.relative_to(candidate_root if candidate_root.is_dir() else candidate_root.parent))
    except Exception:
        rel = path.name
    syms = _patch96_extract_symbols(text, path.suffix.lower())
    return {
        "path": str(path),
        "relative_to_candidate": rel or path.name,
        "size_bytes": len(raw),
        "sha256": _patch96_sha256_file(path),
        "suffix": path.suffix.lower(),
        "line_count": text.count("\n") + 1 if text else 0,
        "imports_sample": syms.get("imports", []),
        "functions_sample": syms.get("functions", []),
        "classes_sample": syms.get("classes", []),
        "excerpt_start": text[:2400],
        "excerpt_sha256": _patch96_sha256_text(text[:2400]),
    }


def _patch96_make_binder(engine_family: str) -> tuple[dict, Path, Path]:
    report_path, report, row = _patch96_engine_row(engine_family)
    if not row:
        raise ValueError(f"engine family not found in latest Patch 95 report: {engine_family}")
    if not row.get("ready_for_llm_review"):
        raise ValueError(f"engine family is not ready for evidence binding: {engine_family} ({row.get('readiness_state')})")
    if row.get("blockers"):
        raise ValueError(f"engine family has blockers: {engine_family}")
    candidate = Path(str(row.get("candidate_path_resolved") or ""))
    if not candidate.exists():
        raise ValueError(f"candidate path no longer exists: {candidate}")
    files = _patch96_collect_files_from_row(row)
    if not files:
        raise ValueError(f"no readable source files found for: {engine_family}")
    file_evidence = [_patch96_file_evidence(p, candidate) for p in files]
    primary_hash = file_evidence[0].get("sha256", "") if file_evidence else ""
    evidence_seed = f"{engine_family}|{candidate}|{primary_hash}|{len(file_evidence)}"
    evidence_id = "EEB-" + _patch96_sha256_text(evidence_seed)[:16]
    now = _patch96_now()
    safe = _patch96_safe_name(engine_family.lower())
    binder = {
        "schema_version": ENGINE_EVIDENCE_SCHEMA_VERSION,
        "report_type": "ENGINE_SOURCE_EVIDENCE_BINDER_V1_PATCH96",
        "created_at": now,
        "evidence_id": evidence_id,
        "engine_family": row.get("engine_family"),
        "review_status": row.get("review_status"),
        "readiness_state": row.get("readiness_state"),
        "ready_for_llm_brief": True,
        "source_readiness_report_path": str(report_path) if report_path else "",
        "source_readiness_report_sha256": _patch96_sha256_file(report_path) if report_path and report_path.exists() else "",
        "candidate_path_recorded": row.get("candidate_path_recorded"),
        "candidate_path_resolved": str(candidate),
        "candidate_path_is_dir": candidate.is_dir(),
        "candidate_path_exists_at_bind_time": True,
        "candidate_path_sha_basis": "file_evidence_hashes",
        "relationship_report_found": row.get("relationship_report_found"),
        "relationship_report_path": row.get("relationship_report_path"),
        "relationship_category_counts": row.get("relationship_category_counts", {}),
        "manifest_hits": row.get("manifest_hits", [])[:30],
        "symbols_from_readiness_sample": row.get("symbols_sample", []),
        "file_count": len(file_evidence),
        "file_evidence": file_evidence,
        "blockers": [],
        "warnings": list(row.get("warnings") or []),
        "authority": _patch96_authority(),
        "next_allowed_step": "Patch 97 source-law context readiness or Patch 98 LLM draft only after source-law context is proven",
        "stale_evidence_rule": "Patch 100 must re-verify candidate path and file SHA(s) against this binder before committing any canonical decision.",
    }
    ENGINE_EVIDENCE_BINDERS_DIR.mkdir(parents=True, exist_ok=True)
    json_path = ENGINE_EVIDENCE_BINDERS_DIR / f"{now}_{safe}_{ENGINE_EVIDENCE_REPORT_PREFIX}.json"
    md_path = ENGINE_EVIDENCE_BINDERS_DIR / f"{now}_{safe}_{ENGINE_EVIDENCE_REPORT_PREFIX}.md"
    _patch96_write_json(json_path, binder)
    latest_path = ENGINE_EVIDENCE_BINDERS_DIR / f"latest_{safe}_engine_evidence_binder.json"
    _patch96_write_json(latest_path, binder)
    lines = [
        f"# Patch 96 Engine Source Evidence Binder — {row.get('engine_family')}",
        "",
        f"Evidence ID: `{evidence_id}`",
        f"Created: `{now}`",
        f"Candidate: `{candidate}`",
        f"Review status: `{row.get('review_status')}`",
        f"Readiness: `{row.get('readiness_state')}`",
        f"Files bound: `{len(file_evidence)}`",
        "",
        "## Authority",
        "No engine writes. No canonical decision. No review ledger mutation. No Chroma writes. No shell execution.",
        "",
        "## Files",
    ]
    for f in file_evidence[:20]:
        lines.append(f"- `{f.get('path')}` sha256=`{f.get('sha256')}` functions=`{len(f.get('functions_sample') or [])}` classes=`{len(f.get('classes_sample') or [])}`")
    lines.extend(["", "## Stale Evidence Rule", binder["stale_evidence_rule"], ""])
    md_path.write_text("\n".join(lines), encoding="utf-8")
    return binder, json_path, md_path


