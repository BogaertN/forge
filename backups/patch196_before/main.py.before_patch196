    from agents.forge.memory import write_audit_entry
    arg = (arg or "latest").strip()
    parts = arg.split()
    token_ok = P136_CONFIRM in parts
    if not token_ok:
        payload = {
            "schema_version": "generic_repair_candidate_refusal_v1_patch136",
            "report_type": "GENERIC_REPAIR_CANDIDATE_REFUSAL_V1",
            "created_at": _p136_now(),
            "status": "GENERIC_REPAIR_CANDIDATE_BUILD_REFUSED_CONFIRM_TOKEN_REQUIRED",
            "required_token": P136_CONFIRM,
            "example": f"generic-repair-candidate-build latest {P136_CONFIRM}",
            "authority": {"project_file_write_authority": False, "patch_apply_authority": False},
        }
        jp, _ = _p136_write(payload, "generic_repair_candidate_refusal_v1")
        print("\n[refused] Missing confirmation token.")
        print("Run:", payload["example"])
        write_audit_entry(session_id, "GENERIC_REPAIR_CANDIDATE_BUILD_REFUSED", str(jp), "missing_confirm_token", P136_CONFIRM)
        return

    evidence = _p136_load_json(_p136_latest_evidence_path())
    llm = _p136_load_json(_p136_latest_llm_path())
    problems = []
    if not evidence:
        problems.append("missing_latest_generic_repair_evidence_packet")
    if not llm or not llm.get("model_generation_called"):
        problems.append("missing_or_unverified_latest_generic_repair_llm_proposal")

    target = _p136_extract_target(evidence, llm)
    target_file = target.get("path")
    target_line = target.get("line")
    if not target_file:
        problems.append("target_file_not_resolved")
    if target_file and not _p136_scope_ok(target_file):
        problems.append("target_file_out_of_scope")
    target_path = Path(target_file).expanduser().resolve() if target_file else None
    if target_path and not target_path.exists():
        problems.append("target_file_missing_on_disk")

    expected_sha = target.get("snippet_sha256")
    # Search snippets for expected sha if not already attached.
    for sn in evidence.get("code_context_snippets") or []:
        if sn.get("path") == target_file:
            expected_sha = expected_sha or sn.get("sha256")

    original_text = ""
    current_sha = None
    if target_path and target_path.exists() and target_path.is_file():
        try:
            original_text = target_path.read_text(encoding="utf-8", errors="replace")
            current_sha = _p136_sha_text(original_text)
        except Exception as exc:
            problems.append(f"target_file_read_failed:{exc}")

    if expected_sha and current_sha and expected_sha != current_sha:
        problems.append("current_target_sha_mismatch_against_evidence")

    stderr = ((evidence.get("import_probe") or {}).get("stderr_tail") or "")
    candidate_text = original_text
    strategy = {"strategy": "not_attempted", "changed_lines": [], "confidence": "LOW", "notes": []}
    diff_text = ""
    compile_result = {"py_compile_status": "NOT_RUN"}
    candidate_file_path = ""
    diff_path = ""

    if not problems and original_text:
        candidate_text, strategy = _p136_build_candidate_text(original_text, target_line, stderr, llm)
        if candidate_text == original_text:
            problems.append("no_candidate_change_generated")
        else:
            P136_MEMORY_DIR.mkdir(parents=True, exist_ok=True)
            safe_name = Path(target_file).name.replace("/", "_")
            candidate_path = P136_MEMORY_DIR / f"{_p136_stamp()}_candidate_{safe_name}"
            latest_candidate_path = P136_MEMORY_DIR / f"latest_candidate_{safe_name}"
            candidate_path.write_text(candidate_text, encoding="utf-8", errors="replace")
            latest_candidate_path.write_text(candidate_text, encoding="utf-8", errors="replace")
            candidate_file_path = str(candidate_path)
            diff_lines = list(_p136_difflib.unified_diff(
                original_text.splitlines(True),
                candidate_text.splitlines(True),
                fromfile=f"a/{target_file}",
                tofile=f"b/{target_file} (candidate only)",
            ))
            diff_text = "".join(diff_lines)
            dp = P136_MEMORY_DIR / f"{_p136_stamp()}_candidate.diff"
            latest_dp = P136_MEMORY_DIR / "latest_candidate.diff"
            dp.write_text(diff_text, encoding="utf-8", errors="replace")
            latest_dp.write_text(diff_text, encoding="utf-8", errors="replace")
            diff_path = str(dp)
            compile_result = _p136_compile_text_candidate(candidate_text, target_file)

    status = "GENERIC_REPAIR_CANDIDATE_READY_NO_LIVE_WRITE"
    if problems:
        status = "GENERIC_REPAIR_CANDIDATE_NOT_READY"
    elif compile_result.get("py_compile_status") != "PASS":
        status = "GENERIC_REPAIR_CANDIDATE_BUILT_WITH_COMPILE_ISSUES"

    payload = {
        "schema_version": "generic_repair_candidate_v1_patch136",
        "report_type": "GENERIC_REPAIR_CANDIDATE_V1",
        "created_at": _p136_now(),
        "status": status,
        "target": evidence.get("target") or target.get("engine_name") or target_file,
        "target_file": target_file,
        "target_line": target_line,
        "target_resolution_source": target.get("source"),
        "expected_evidence_sha256": expected_sha,
        "current_target_sha256": current_sha,
        "candidate_sha256": _p136_sha_text(candidate_text) if candidate_text and candidate_text != original_text else None,
        "candidate_file_path": candidate_file_path,
        "diff_path": diff_path,
        "diff_preview": diff_text[:4000],
        "repair_strategy": strategy,
        "candidate_compile": compile_result,
        "llm_proposal_status": llm.get("status"),
        "llm_model_generation_called": bool(llm.get("model_generation_called")),
        "problems": problems,
        "candidate_status": "ready_for_sandbox_candidate" if status == "GENERIC_REPAIR_CANDIDATE_READY_NO_LIVE_WRITE" else "not_ready_for_sandbox_candidate",
        "next_commands": ["generic-repair-candidate-show diff", "generic-repair-candidate-verify latest", "generic-repair-candidate-export"],
        "recommended_next_patch": "Patch 137 — Generic Repair Sandbox Candidate" if status == "GENERIC_REPAIR_CANDIDATE_READY_NO_LIVE_WRITE" else "Fix candidate builder inputs before sandboxing",
