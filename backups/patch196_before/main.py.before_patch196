def _grounding_default_filters(mode: str = "balanced", limit: int = 5) -> dict:
    """Build a context-search compatible filter dictionary for internal grounding."""
    return {
        "show_metadata": False,
        "mode": mode,
        "corpus_id": "",
        "phase": "",
        "operator": "",
        "memory_role": "",
        "limit": limit,
        "diversity": True,
        "debug_scores": False,
    }


def _grounding_context_results(
    query: str,
    *,
    mode: str = "balanced",
    limit: int = 5,
    preferred_folder: str = "",
) -> tuple[list[dict], str, str | None]:
    """Return scored context results without printing or writing to Chroma.

    This deliberately reuses the Patch 53 scoring helpers so Phase D grounding is
    based on the same evidence model as context-search.
    """
    filters = _grounding_default_filters(mode=mode, limit=max(1, min(10, int(limit or 5))))
    broad = True
    raw, ef_name, error = _context_query_all(query, broad=broad)
    if error:
        return [], ef_name, error

    manifest_lookup = _manifest_by_corpus_id()
    ranked: list[dict] = []
    for r in raw:
        meta = r.get("meta", {}) or {}
        if preferred_folder and str(meta.get("corpus_folder", "")) != preferred_folder:
            continue
        ok, reasons = _context_search_filter_match(meta, filters)
        if not ok:
            continue
        vector_semantic = _clamp01(1.0 - float(r.get("distance") or 0.0))
        lexical, term_hits = _lexical_score(r.get("doc", ""), query)
        semantic = _semantic_signal(vector_semantic, lexical, filters)
        provenance = _provenance_score(meta)
        symbolic = _symbolic_score(meta, filters, query)
        authority_weight, authority_tier, authority_reason = _authority_for_meta(meta, manifest_lookup)
        mode_bonus = _source_mode_bonus(meta, filters)
        weights = _mode_weights(filters)
        folder_bonus = 0.04 if preferred_folder and str(meta.get("corpus_folder", "")) == preferred_folder else 0.0
        final = _clamp01(
            weights["semantic"] * semantic +
            weights["provenance"] * provenance +
            weights["symbolic"] * symbolic +
            weights["authority"] * authority_weight +
            weights["mode_bonus"] * mode_bonus +
            folder_bonus
        )
        ranked.append({
            **r,
            "semantic_score": round(semantic, 4),
            "vector_score": round(vector_semantic, 4),
            "lexical_score": round(lexical, 4),
            "term_hits": term_hits,
            "provenance_score": round(provenance, 4),
            "symbolic_score": round(symbolic, 4),
            "authority_weight": round(float(authority_weight), 4),
            "authority_tier": authority_tier,
            "authority_reason": authority_reason,
            "mode_bonus": round(mode_bonus, 4),
            "filter_reasons": reasons,
            "final_score": round(final, 4),
        })
    ranked.sort(key=lambda x: (-x["final_score"], -x["semantic_score"], -x.get("lexical_score", 0.0), str((x.get("meta") or {}).get("chunk_id", ""))))
    shown, _dup, _deferred = _diverse_result_slice(ranked, int(filters.get("limit", limit)), True)
    return shown, ef_name, None


def _grounding_read_target(target_file: str) -> tuple[dict, str | None]:
    """Resolve, permission-check, and read a target file for read-only grounding."""
    import hashlib
    from agents.forge.permissions import is_path_blocked, is_path_allowed

    raw = (target_file or "").strip()
    if not raw:
        return {"ok": False, "reason": "missing target file"}, None
    path = Path(os.path.realpath(os.path.abspath(os.path.expanduser(raw))))
    blocked, reason = is_path_blocked(str(path))
    if blocked:
        return {"ok": False, "path": str(path), "reason": f"blocked: {reason}"}, None
    allowed, reason = is_path_allowed(str(path))
    if not allowed:
        return {"ok": False, "path": str(path), "reason": f"out of scope: {reason}"}, None
    if not path.exists():
        return {"ok": False, "path": str(path), "reason": "target file does not exist"}, None
    if not path.is_file():
        return {"ok": False, "path": str(path), "reason": "target path is not a regular file"}, None
    try:
        raw_bytes = path.read_bytes()
    except Exception as e:
        return {"ok": False, "path": str(path), "reason": f"read failed: {e}"}, None
    if b"\x00" in raw_bytes[:4096]:
        return {"ok": False, "path": str(path), "reason": "target appears binary; grounded patch preflight is text-only"}, None
    try:
        text = raw_bytes.decode("utf-8")
    except UnicodeDecodeError:
        text = raw_bytes.decode("utf-8", errors="replace")
    profile = {
        "ok": True,
        "path": str(path),
        "name": path.name,
        "suffix": path.suffix,
        "size_bytes": len(raw_bytes),
        "line_count": text.count("\n") + (1 if text else 0),
        "sha256_16": hashlib.sha256(raw_bytes).hexdigest()[:16],
        "read_chars": min(len(text), 120000),
        "truncated": len(text) > 120000,
    }
    return profile, text[:120000]


def _grounding_target_terms(path: str, text: str | None) -> list[str]:
    """Extract stable target terms from filename and code/document content."""
    terms: list[str] = []
    seen: set[str] = set()

    def add(value: str):
        v = (value or "").strip()
        if not v:
            return
        for token in re.findall(r"[A-Za-z_][A-Za-z0-9_]{2,}|χ\(t\)|Φ\d+", v):
            low = token.lower()
            if low in {"the", "and", "for", "from", "with", "this", "that", "into", "main", "file", "python"}:
                continue
            if low not in seen:
                seen.add(low)
                terms.append(token)

    p = Path(path or "")
    add(p.stem.replace("_", " ").replace("-", " "))
    for part in p.parts[-4:]:
        add(part.replace("_", " ").replace("-", " "))

    body = text or ""
    for m in re.findall(r"^\s*(?:def|class)\s+([A-Za-z_][A-Za-z0-9_]*)", body, flags=re.M):
        add(m)
    for m in re.findall(r"^\s*(?:from\s+([A-Za-z_][A-Za-z0-9_\.]*?)\s+import|import\s+([A-Za-z_][A-Za-z0-9_\.]*))", body, flags=re.M):
        add(" ".join(x for x in m if x))
    for keyword in [
        "patch", "proposal", "preflight", "apply", "rollback", "audit", "ledger",
        "context", "search", "corpus", "receipt", "ingest", "chroma", "vector",
        "permission", "scope", "command", "surface", "verification", "test",
    ]:
        if re.search(rf"\b{re.escape(keyword)}\b", body, flags=re.I):
            add(keyword)
    return terms[:18]


def _grounding_artifact_matches(target_path: str, terms: list[str], limit: int = 5) -> list[dict]:
    """Search Forge-owned patch lifecycle artifacts for similar prior work.

    This is read-only and intentionally limited to Forge-owned lifecycle folders.
    """
    roots = [
        FORGE_ROOT / "proposed_patches",
        FORGE_ROOT / "apply_plans",
        FORGE_ROOT / "rollback_registry",
    ]
    target_name = Path(target_path).name.lower()
    needles = [t.lower() for t in terms if len(t) >= 4][:12]
    matches: list[dict] = []
    for root in roots:
        if not root.exists():
            continue
        for p in sorted(root.rglob("*")):
            if not p.is_file():
                continue
            if p.suffix.lower() not in {".txt", ".md", ".json", ".diff"}:
                continue
            try:
                if p.stat().st_size > 1_200_000:
                    continue
                txt = p.read_text(encoding="utf-8", errors="replace")
            except Exception:
                continue
            low = txt.lower()
            score = 0
            if target_name and target_name in low:
                score += 6
            if target_name and target_name in p.name.lower():
                score += 3
            score += sum(1 for n in needles if n in low)
            if score <= 0:
                continue
            snippet = " ".join(txt.split())[:240]
            try:
                rel = str(p.relative_to(FORGE_ROOT))
            except Exception:
                rel = str(p)
            matches.append({"path": rel, "score": score, "snippet": snippet})
    matches.sort(key=lambda x: (-x["score"], x["path"]))
    return matches[:limit]


def _print_grounding_results(title: str, query: str, results: list[dict], min_score: float) -> bool:
    """Print a compact grounding result group. Returns whether group passed."""
    top = results[0]["final_score"] if results else 0.0
    passed = bool(results and top >= min_score)
    print(f"  {title}")
    print(f"    query       : {query}")
    print(f"    threshold   : {min_score:.2f}")
    print(f"    status      : {'PASS' if passed else 'WEAK'}")
    print(f"    results     : {len(results)}")
    for idx, r in enumerate(results[:3], 1):
        meta = r.get("meta", {}) or {}
        print(f"    {idx}. score={r.get('final_score')} semantic={r.get('semantic_score')} lexical={r.get('lexical_score')} authority={r.get('authority_weight')} ({r.get('authority_tier')})")
        print(f"       citation : {_source_citation(meta)}")
        print(f"       role     : {meta.get('memory_role','?')} | folder={meta.get('corpus_folder','?')} | phases={meta.get('rpmc_phase_tags','') or '(none)'} | ops={meta.get('symbolic_operators','') or '(none)'}")
        print(f"       evidence : {_evidence_snippet(r.get('doc',''), query, width=220)}")
    if not results:
        print("       evidence : none")
    print()
    return passed


def cmd_patch_propose_grounded(target_file: str, session_id: str) -> None:
    """Read-only grounded patch preflight. It does not write a patch proposal.

    Usage: patch-propose-grounded <target_file>
    Purpose: prove source-law, engineering, implementation, and prior-art context
    before Nic creates a serious patch proposal.
    """
    from agents.forge.memory import write_audit_entry

    profile, text = _grounding_read_target(target_file)
    print()
    print("── Grounded Patch Proposal Preflight ────────────────")
    print("  Phase      : D — Retrieval Before Coding")
    print("  Command    : patch-propose-grounded")
    print("  Writes     : NO patch proposal, NO project modification, NO Chroma write")
    print()

    if not profile.get("ok"):
        reason = str(profile.get("reason", "unknown"))
        print(f"[forge] PATCH_PROPOSE_GROUNDED_REFUSED")
        print(f"  Target : {profile.get('path', target_file)}")
        print(f"  Reason : {reason}")
        write_audit_entry(session_id, "PATCH_PROPOSE_GROUNDED_REFUSED", str(profile.get("path", target_file)), "-", reason[:160])
        print("──────────────────────────────────────────────────────")
        print()
        return

    terms = _grounding_target_terms(str(profile["path"]), text or "")
    target_query = " ".join(terms[:10]) or str(profile["name"])
    source_query = f"{target_query} source law patch safety audit rollback scope authority"
    engineering_query = f"{target_query} engineering standard verification protocol test rollback"
    implementation_query = f"{target_query} implementation blueprint handler route command preflight apply"
    prior_query = f"{target_query} patch proposal preflight rollback audit ledger"

    print("  Target file:")
    print(f"    path       : {profile['path']}")
    print(f"    size       : {profile['size_bytes']} bytes")
    print(f"    lines      : {profile['line_count']}")
    print(f"    sha256_16  : {profile['sha256_16']}")
    print(f"    read_chars : {profile['read_chars']}{' (truncated for grounding)' if profile.get('truncated') else ''}")
    print()
    print("  Target signals:")
    print(f"    {', '.join(terms[:18]) if terms else '(none extracted)'}")
    print()

    source_results, ef_name, source_error = _grounding_context_results(source_query, mode="source_law", limit=5)
    engineering_results, _, engineering_error = _grounding_context_results(engineering_query, mode="balanced", limit=5, preferred_folder="05_ENGINEERING_STANDARDS")
    implementation_results, _, implementation_error = _grounding_context_results(implementation_query, mode="implementation", limit=5)
    prior_context_results, _, prior_error = _grounding_context_results(prior_query, mode="balanced", limit=5)
    artifact_matches = _grounding_artifact_matches(str(profile["path"]), terms, limit=5)

    if source_error or engineering_error or implementation_error or prior_error:
        print("  Search warnings:")
        for label, err in [
            ("source-law", source_error),
            ("engineering", engineering_error),
            ("implementation", implementation_error),
            ("prior-context", prior_error),
        ]:
            if err:
                print(f"    {label}: {err}")
        print()

    print(f"  Embedding  : {ef_name or 'unknown'}")
    print(f"  Collection : {CONTEXT_COLLECTION}")
    print()

    source_ok = _print_grounding_results("1. Source-law grounding", source_query, source_results, 0.55)
    engineering_ok = _print_grounding_results("2. Engineering-standard grounding", engineering_query, engineering_results, 0.50)
    implementation_ok = _print_grounding_results("3. Implementation grounding", implementation_query, implementation_results, 0.45)
    prior_context_ok = _print_grounding_results("4. Similar context / prior patch doctrine", prior_query, prior_context_results, 0.45)

    print("  5. Forge patch lifecycle artifact scan")
    print("    roots       : proposed_patches, apply_plans, rollback_registry")
    print(f"    results     : {len(artifact_matches)}")
    for idx, m in enumerate(artifact_matches[:5], 1):
        print(f"    {idx}. score={m['score']} path={m['path']}")
        print(f"       snippet : {m['snippet']}")
    if not artifact_matches:
        print("       evidence : no matching local lifecycle artifacts found")
    print()

    prior_ok = prior_context_ok or bool(artifact_matches)
    pass_count = sum(1 for x in [source_ok, engineering_ok, implementation_ok, prior_ok] if x)
    if source_ok and engineering_ok and implementation_ok and prior_ok:
        verdict = "GROUNDING_PASS"
        audit_tool = "PATCH_PROPOSE_GROUNDED_PASS"
        next_step = "Grounding is strong enough to support a manual patch proposal. Use patch-propose only with the rationale above."
    elif source_ok and engineering_ok and pass_count >= 3:
        verdict = "GROUNDING_WARN"
        audit_tool = "PATCH_PROPOSE_GROUNDED_WARN"
        next_step = "Grounding is partial. Safe for low-risk/manual review only; strengthen missing evidence before a serious patch."
    else:
        verdict = "GROUNDING_FAIL"
        audit_tool = "PATCH_PROPOSE_GROUNDED_REFUSED"
        next_step = "No source-grounded rationale. Do not create a serious patch until grounding is improved."

    receipt_path = None
    receipt_md_path = None
    receipt_error = ""
    queries = {
        "source_law": source_query,
        "engineering_standard": engineering_query,
        "implementation": implementation_query,
        "prior_context": prior_query,
    }
    if verdict in ("GROUNDING_PASS", "GROUNDING_WARN"):
        receipt_path, receipt_md_path, receipt_error = _write_grounding_receipt(
            session_id,
            profile,
            verdict,
            pass_count,
            source_ok,
            engineering_ok,
            implementation_ok,
            prior_ok,
            queries,
            source_results,
            engineering_results,
            implementation_results,
            prior_context_results,
            artifact_matches,
        )

    print("── Grounded Rationale Summary ────────────────────────")
    print(f"  Verdict                   : {verdict}")
    print(f"  Source-law evidence        : {'PASS' if source_ok else 'WEAK'}")
    print(f"  Engineering evidence       : {'PASS' if engineering_ok else 'WEAK'}")
    print(f"  Implementation evidence    : {'PASS' if implementation_ok else 'WEAK'}")
    print(f"  Prior/similar evidence     : {'PASS' if prior_ok else 'WEAK'}")
    print(f"  Grounding receipt          : {receipt_path if receipt_path else '(not created)'}")
    if receipt_error:
        print(f"  Receipt warning            : {receipt_error}")
    print(f"  Rule                       : No source-grounded rationale, no major patch.")
    print(f"  Next                       : {next_step}")
    print()
    print("  [Read-only. No proposal written. No files modified. Context library unchanged.]")
    print("──────────────────────────────────────────────────────")
    print()

    write_audit_entry(
        session_id,
        audit_tool,
        str(profile["path"]),
        f"source={len(source_results)} engineering={len(engineering_results)} implementation={len(implementation_results)} prior={len(prior_context_results)} artifacts={len(artifact_matches)}",
        f"verdict={verdict} sha={profile['sha256_16']} pass_count={pass_count}/4",
    )
    if receipt_path:
        write_audit_entry(
            session_id,
            "PATCH_GROUNDING_RECEIPT_CREATED",
            str(receipt_path),
            "read-only receipt",
            f"target={profile['path']} sha={profile['sha256_16']} verdict={verdict}",
        )


def _grounding_safe_slug(value: str, max_len: int = 72) -> str:
    """Create a filesystem-safe short slug for grounding receipts."""
    stem = Path(value or "target").name or "target"
    slug = re.sub(r"[^A-Za-z0-9_.-]+", "_", stem).strip("._-") or "target"
    return slug[:max_len]


def _grounding_receipt_result_summary(results: list[dict], limit: int = 3) -> list[dict]:
    out = []
    for r in (results or [])[:limit]:
        meta = r.get("meta", {}) or {}
        out.append({
            "final_score": r.get("final_score"),
            "semantic_score": r.get("semantic_score"),
            "lexical_score": r.get("lexical_score"),
            "authority_weight": r.get("authority_weight"),
            "authority_tier": r.get("authority_tier"),
            "source_citation": _source_citation(meta),
            "corpus_id": meta.get("corpus_id"),
            "chunk_id": meta.get("chunk_id"),
            "corpus_folder": meta.get("corpus_folder"),
            "memory_role": meta.get("memory_role"),
        })
    return out


def _write_grounding_receipt(
    session_id: str,
    profile: dict,
    verdict: str,
    pass_count: int,
    source_ok: bool,
    engineering_ok: bool,
    implementation_ok: bool,
    prior_ok: bool,
    queries: dict,
    source_results: list[dict],
    engineering_results: list[dict],
    implementation_results: list[dict],
    prior_context_results: list[dict],
    artifact_matches: list[dict],
) -> tuple[Path | None, Path | None, str]:
    """Persist a read-only grounding receipt for patch-propose guard checks."""
    try:
        GROUNDING_RECEIPTS_DIR.mkdir(parents=True, exist_ok=True)
        ts = datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")
        receipt_id = f"{ts}_grounding_{_grounding_safe_slug(str(profile.get('path','target')))}_{profile.get('sha256_16','unknown')}"
        json_path = GROUNDING_RECEIPTS_DIR / f"{receipt_id}.json"
        md_path = GROUNDING_RECEIPTS_DIR / f"{receipt_id}.md"
        data = {
            "receipt_id": receipt_id,
            "created_at": datetime.datetime.now().isoformat(timespec="seconds"),
            "session_id": session_id,
            "command": "patch-propose-grounded",
            "verdict": verdict,
            "accepted_for_patch_propose": verdict == "GROUNDING_PASS",
            "pass_count": pass_count,
            "target_path": str(profile.get("path", "")),
            "target_name": str(profile.get("name", "")),
            "target_sha256_16": profile.get("sha256_16"),
            "target_size_bytes": profile.get("size_bytes"),
            "target_line_count": profile.get("line_count"),
            "evidence_status": {
                "source_law": bool(source_ok),
                "engineering_standard": bool(engineering_ok),
                "implementation": bool(implementation_ok),
                "prior_or_similar": bool(prior_ok),
            },
            "queries": queries,
            "evidence_counts": {
                "source_law": len(source_results or []),
                "engineering_standard": len(engineering_results or []),
                "implementation": len(implementation_results or []),
                "prior_context": len(prior_context_results or []),
                "artifact_matches": len(artifact_matches or []),
            },
            "top_evidence": {
                "source_law": _grounding_receipt_result_summary(source_results),
                "engineering_standard": _grounding_receipt_result_summary(engineering_results),
                "implementation": _grounding_receipt_result_summary(implementation_results),
                "prior_context": _grounding_receipt_result_summary(prior_context_results),
                "artifact_matches": artifact_matches[:5],
            },
        }
        json_path.write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8")
        md_lines = [
            f"# Grounding Receipt — {receipt_id}",
            "",
            f"**Verdict:** {verdict}",
            f"**Accepted for patch-propose:** {data['accepted_for_patch_propose']}",
            f"**Target:** `{data['target_path']}`",
