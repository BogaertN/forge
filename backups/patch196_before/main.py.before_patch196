def _p163_approval_template(candidate: str, preflight: dict, static: dict) -> dict:
    seed = json.dumps({
        "candidate": candidate,
        "preflight_status": preflight.get("status"),
        "static_status": static.get("status"),
        "created_for_patch": "Patch 163",
        "approval_required_phrase": "CONFIRM_RUNTIME_LIVE_BUILD_APPROVAL_FOR_FAILSAFE_MANAGER",
    }, sort_keys=True)
    token_id = hashlib.sha256(seed.encode("utf-8")).hexdigest()[:24]
    return {
        "token_id": f"runtime_approval_template_{token_id}",
        "approval_status": "TEMPLATE_READY_NOT_APPROVED",
        "human_approval_present": False,
        "approval_required_phrase": "CONFIRM_RUNTIME_LIVE_BUILD_APPROVAL_FOR_FAILSAFE_MANAGER",
        "meaning": "This is a Forge-owned approval template only. It is not a live-build approval and cannot authorize writes.",
    }


def _p163_payload() -> dict:
    preflight = _p163_latest_preflight()
    static = _p163_latest_static()
    draft = _p163_latest_draft()
    sandbox_verify = _p163_latest_sandbox_verify()
    snapshot = _p163_latest_snapshot()
    shadow = _p163_latest_shadow_diff()

    selected = preflight.get("selected_candidate") or static.get("selected_candidate") or draft.get("selected_candidate") or {}
    candidate = preflight.get("candidate") or static.get("candidate") or selected.get("engine") or "UNKNOWN"
    files = static.get("files") or []
    file_count = len(files)
    files_verified = sum(1 for f in files if f.get("exists") and f.get("hash_match") and f.get("static_ok"))
    token = _p163_approval_template(candidate, preflight, static)

    planned_files = []
    for f in files:
        planned_files.append({
            "relative_path": f.get("relative_path"),
            "sandbox_path": f.get("sandbox_path"),
            "planned_live_path": f.get("planned_live_path_not_created") or f.get("live_path") or "",
            "sha256": f.get("sha256_now") or f.get("sha256_expected"),
            "purpose": f.get("purpose"),
            "live_path_exists": bool(f.get("live_path_exists")),
        })

    shadow_summary = shadow.get("summary") or {}
    shadow_match = shadow_summary.get("shadow_matches_snapshot")
    if shadow_match is None:
        shadow_match = shadow.get("shadow_matches_snapshot")
    shadow_problem_count = shadow_summary.get("problem_count")
    if shadow_problem_count is None:
        shadow_problem_count = shadow.get("problem_count", 0)

    snapshot_status = snapshot.get("status") or snapshot.get("verification_status") or "UNKNOWN"
    preflight_ok = preflight.get("status") == "FORGE_RUNTIME_LIVE_PREFLIGHT_READY_GATE_LOCKED" and preflight.get("planning_ready") is True
    static_ok = static.get("status") == "FORGE_RUNTIME_CANDIDATE_STATIC_VERIFICATION_READY_GATE_LOCKED" and static.get("problem_count", 0) == 0
    files_ok = file_count > 0 and files_verified == file_count
    sandbox_ok = (sandbox_verify.get("planning_ready") is True) or (sandbox_verify.get("status") in {"FORGE_RUNTIME_BUILD_SANDBOX_VERIFICATION_READY_PLANNING_ONLY"})
    snapshot_ok = ("PASS" in str(snapshot_status)) or snapshot.get("problems") == [] or snapshot.get("problem_count") == 0
    shadow_ok = bool(shadow_match) and int(shadow_problem_count or 0) == 0

    gates = []
    _p163_gate(gates, "A01", "Preflight report exists and is planning-ready", "PASS" if preflight_ok else "FAIL", preflight.get("status") or "missing", not preflight_ok)
    _p163_gate(gates, "A02", "Static sandbox candidate verification clean", "PASS" if static_ok else "FAIL", static.get("status") or "missing", not static_ok)
    _p163_gate(gates, "A03", "Candidate files statically verified", "PASS" if files_ok else "FAIL", f"files_verified={files_verified}/{file_count}", not files_ok)
    _p163_gate(gates, "A04", "Runtime sandbox verification evidence exists", "PASS" if sandbox_ok else "WARN", sandbox_verify.get("status") or "candidate_or_missing", False)
    _p163_gate(gates, "A05", "Snapshot evidence exists", "PASS" if snapshot_ok else "WARN", str(snapshot_status), False)
    _p163_gate(gates, "A06", "Shadow forensic diff clean", "PASS" if shadow_ok else "WARN", f"shadow_matches_snapshot={shadow_match} problems={shadow_problem_count}", False)
    _p163_gate(gates, "A07", "Approval token template generated", "PASS", token.get("token_id"), False)
    _p163_gate(gates, "A08", "Human approval present", "LOCKED", "No approval command in Patch 163 grants write authority", True)
    _p163_gate(gates, "A09", "Live apply authority", "LOCKED", "Patch 163 builds an apply plan only; no live write authority", True)

    blocking = [g for g in gates if g.get("blocks_live_build") and g.get("status") in {"FAIL", "LOCKED"}]
    planning_ready = all(g.get("status") in {"PASS", "WARN", "LOCKED"} for g in gates[:7])
    live_build_ready = False

    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_APPROVAL_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_APPROVAL_V1",
        "active_patch": "Patch 163 — Runtime Live Build Approval Token / Apply Plan",
        "current_phase": "S19I — Runtime Live Build Approval Token / Apply Plan",
        "created_at": _p163_now(),
        "status": "FORGE_RUNTIME_LIVE_APPROVAL_PLAN_READY_GATE_LOCKED",
        "candidate": candidate,
        "planning_ready": planning_ready,
        "live_build_ready": live_build_ready,
        "human_approval_present": False,
        "approval_token_status": token.get("approval_status"),
        "approval_token_template": token,
        "file_count": file_count,
        "files_verified": files_verified,
        "selected_candidate": selected,
        "apply_plan": {
            "status": "FORGE_RUNTIME_APPLY_PLAN_DRAFT_READY_NO_LIVE_WRITE",
            "target_root": "/home/nic/aiweb/runtime",
            "planned_file_count": len(planned_files),
            "planned_files": planned_files,
            "forbidden_in_patch_163": ["write_live_runtime_files", "patch_apply", "engine_write", "live_restore"],
            "requires_before_live_build": [
                "explicit human approval token",
                "live target backup plan",
                "live apply dry-run",
                "rollback plan",
                "final confirmation gate",
            ],
        },
        "gates": gates,
        "gate_summary": {
            "pass": sum(1 for g in gates if g.get("status") == "PASS"),
            "warn": sum(1 for g in gates if g.get("status") == "WARN"),
            "locked": sum(1 for g in gates if g.get("status") == "LOCKED"),
            "fail": sum(1 for g in gates if g.get("status") == "FAIL"),
        },
        "problem_count": 0,
        "problems": [],
        "authority": {
            "forge_owned_report_write_authority": True,
            "approval_template_authority": True,
            "human_approval_authority": False,
            "runtime_file_write_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "live_restore_authority": False,
        },
        "plain_english": "Patch 163 creates a Forge-owned approval token template and live apply plan draft, but does not approve or execute the runtime build.",
        "next_patch": "Patch 164 — Runtime Live Build Backup / Apply Dry Run",
        "recommended_next_patch": "Patch 164 — Runtime Live Build Backup / Apply Dry Run",
        "roadmap_mutation_policy": "APPEND_ONLY",
    }
    return payload


