def _patch109_build_plan() -> dict:
    progress = _patch109_latest_progress()
    crosschecks = _patch109_crosscheck_map()
    queue = _patch109_queue_decision_map()
    ledger = _patch109_ledger_status_map()
    progress_gaps = progress.get("gaps") or {}
    progress_crosschecked_not_decided = set(_patch109_slug(x) for x in progress_gaps.get("crosschecked_not_decided") or [])
    rows = []
    for fam, cc in sorted(crosschecks.items()):
        q = queue.get(fam, {})
        l = ledger.get(fam, {})
        ledger_status = l.get("review_status") or "UNKNOWN"
        queue_decision = q.get("queue_decision") or "UNDECIDED"
        blockers = []
        warnings = []
        if cc.get("crosscheck_status") != "EVIDENCE_CROSSCHECK_READY_NO_AUTHORITY":
            blockers.append(f"crosscheck_status_not_ready:{cc.get('crosscheck_status')}")
        if cc.get("crosscheck_blockers"):
            blockers.extend([f"crosscheck_blocker:{b}" for b in cc.get("crosscheck_blockers")])
        if ledger_status != "PENDING_REVIEW":
            warnings.append(f"ledger_status_is_{ledger_status}; decision may already be committed/deferred")
        if queue_decision != "UNDECIDED":
            warnings.append(f"queue_decision_already_{queue_decision}")
        ready = (not blockers) and ledger_status == "PENDING_REVIEW" and queue_decision == "UNDECIDED"
        priority = 1 if fam in progress_crosschecked_not_decided else 5
        rows.append({
            "engine_family": fam,
            "ready_for_triage_decision": ready,
            "priority": priority,
            "ledger_status": ledger_status,
            "queue_decision": queue_decision,
            "crosscheck_status": cc.get("crosscheck_status"),
            "llm_called": cc.get("llm_called"),
            "llm_status": cc.get("llm_status"),
            "evidence_id": cc.get("evidence_id"),
            "candidate_path": cc.get("candidate_path"),
            "likely_system_role": cc.get("likely_system_role"),
            "recommendation_draft": cc.get("recommendation_draft"),
            "crosscheck_path": cc.get("crosscheck_path"),
            "crosscheck_sha256": cc.get("crosscheck_sha256"),
            "blockers": blockers,
            "warnings": warnings,
            "commands": {
                "read_evidence": f"engine-review-evidence-show {fam}",
                "show_triage": f"engine-review-triage-show {fam}",
                "approve": f"engine-review-triage-approve {fam}",
                "defer": f"engine-review-triage-defer {fam}",
                "reject": f"engine-review-triage-reject {fam}",
            },
        })
    ready_rows = [r for r in rows if r.get("ready_for_triage_decision")]
    decided_or_committed = [r for r in rows if not r.get("ready_for_triage_decision")]
    rows = sorted(rows, key=lambda r: (r.get("priority", 9), not r.get("ready_for_triage_decision"), r.get("engine_family") or ""))
    now = _patch109_now()
    return {
        "schema_version": ENGINE_REVIEW_TRIAGE_SCHEMA_VERSION,
        "report_type": "ENGINE_REVIEW_TRIAGE_PLAN_V1_PATCH109",
        "created_at": now,
        "status": "ENGINE_REVIEW_TRIAGE_READY_NO_LEDGER_AUTHORITY",
        "counts": {
            "crosschecked_engines": len(rows),
            "ready_for_triage_decision": len(ready_rows),
            "not_ready_or_already_decided": len(decided_or_committed),
            "progress_crosschecked_not_decided": len(progress_crosschecked_not_decided),
        },
        "rows": rows,
        "recommended_next_engine": ready_rows[0].get("engine_family") if ready_rows else None,
        "next_step": "Run engine-review-triage-show <engine>, read the full evidence display, then approve/defer/reject explicitly. No ledger mutation occurs until the commit gate.",
        "manual_rule": "Never approve from summary alone. Read engine-review-evidence-show <engine> first.",
        "authority": _patch109_authority(decision_write_authority=False),
    }


