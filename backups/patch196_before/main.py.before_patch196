# Patch 132R — Visible Local LLM Invocation Proof
# ---------------------------------------------------------------------------
# Patch 132 created an LLM-ready source-grounded proposal packet, but it did
# not call the local model. Patch 132R adds a visible, fixed Ollama call path.
# It writes prompt/response evidence only under Forge memory. It cannot edit
# project files, engine files, ledgers, Chroma, or apply patches.
import json as _p132r_json
import hashlib as _p132r_hashlib
import shutil as _p132r_shutil
