def _p180_candidate_from_reports(scope, dependency, validation, sandbox):
    for report in (sandbox, validation, scope, dependency):
        if isinstance(report, dict):
            cand = report.get("selected_candidate") or report.get("candidate")
            if cand:
                return cand
    return "failsafe_manager"


def _p180_file_summary(rows):
    name_counter = _p180_Counter()
    ext_counter = _p180_Counter()
    py = js = cfg = 0
    unique_sha = set()
    for row in rows:
        p = _P180Path(str(row.get("path") or row.get("relative_path") or ""))
        suffix = p.suffix.lower()
        name_counter[p.name] += 1
        ext_counter[suffix or "<none>"] += 1
        if suffix == ".py":
            py += 1
        if suffix == ".json":
            js += 1
        if suffix in {".json", ".toml", ".yaml", ".yml", ".ini", ".cfg"}:
            cfg += 1
        if row.get("sha256"):
            unique_sha.add(str(row.get("sha256")))
    return {
        "file_count": len(rows),
        "python_file_count": py,
        "json_file_count": js,
        "config_file_count": cfg,
        "extension_counts": dict(sorted(ext_counter.items())),
        "duplicate_basenames": [{"basename": n, "count": c} for n, c in sorted(name_counter.items()) if c > 1],
        "exact_sha_rows_present": bool(rows) and all(bool(r.get("sha256")) for r in rows),
        "unique_sha_count": len(unique_sha),
        "rows_preview": rows[:40],
    }


def _p180_restore_rows(rows):
    restore_rows = []
    for idx, row in enumerate(rows, start=1):
        path = str(row.get("path") or "")
        sha = str(row.get("sha256") or "")
        size = row.get("size")
        rel = str(row.get("relative_path") or _P180Path(path).name)
        restore_rows.append({
            "index": idx,
            "path": path,
            "relative_path": rel,
            "current_sha256_required_before_any_future_copy": sha,
            "size": size,
            "restore_strategy_future_only": "copy original bytes from future sandbox/backup manifest only if path and current SHA match",
            "rollback_allowed_now": False,
            "writes_now": False,
        })
    return restore_rows


def _p180_rollback_matrix(candidate: str, rows: list, summary: dict):
    proposed_backup_root = str(_P180Path.home() / "forge" / "memory" / "forge_runtime_candidate_backups_v1" / f"{candidate}_PENDING_NO_WRITE")
    return {
        "matrix_type": "NO_WRITE_ROLLBACK_RESTORE_PLAN",
        "candidate": candidate,
        "source_file_count": summary.get("file_count"),
        "exact_sha_rows_available": summary.get("exact_sha_rows_present"),
        "duplicate_basename_guard_required": len(summary.get("duplicate_basenames") or []) > 0,
        "creates_backup_now": False,
        "copies_files_now": False,
        "restores_files_now": False,
        "deletes_files_now": False,
        "runs_tests_now": False,
        "shell_allowed": False,
        "approval_token_requested": False,
        "live_apply_allowed": False,
        "proposed_backup_root_future": proposed_backup_root,
        "restore_rows_preview": _p180_restore_rows(rows)[:40],
        "future_backup_manifest_required_fields": [
            "candidate",
            "created_at",
            "source_path",
            "backup_path",
            "relative_path",
            "size",
            "sha256_before",
            "sha256_after_backup_copy",
            "scope_receipt_id",
            "sandbox_receipt_id",
        ],
        "future_restore_preconditions": [
            "load latest scope receipt and verify candidate is unchanged",
            "verify every target path is still inside approved scope",
            "verify every target current SHA matches expected pre-restore SHA or refuse as stale",
            "verify backup manifest exists and backup bytes hash to sha256_before",
            "refuse duplicate basename targeting unless exact absolute path and SHA are present",
            "restore only from Forge-owned backup/sandbox manifest generated by a prior gated patch",
            "run post-restore exact-read and SHA verification from disk",
            "write restore receipt and audit entry; never silently mutate files",
        ],
        "future_refusal_conditions": [
            "missing scope receipt",
            "missing sandbox readiness receipt",
            "candidate mismatch",
            "missing exact SHA row",
            "stale current SHA",
            "missing backup manifest",
            "backup hash mismatch",
            "path outside approved scope",
            "attempt to touch .env, keys, secrets, ~/.ssh, Chroma files, node_modules, .venv, __pycache__",
            "approval token supplied during this no-write planning phase",
        ],
    }


def _p180_payload() -> dict:
    scope = _p180_scope_report()
    dependency = _p180_dependency_report()
    validation = _p180_validation_report()
    sandbox = _p180_sandbox_report()
    candidate = _p180_candidate_from_reports(scope, dependency, validation, sandbox)
    rows = _p180_file_rows(scope)
    summary = _p180_file_summary(rows)
    matrix = _p180_rollback_matrix(candidate, rows, summary)
    warnings = []
    problems = []
    if not scope:
        warnings.append("Latest Patch 176 scope receipt is missing; rollback matrix is informational only.")
    if not sandbox:
        warnings.append("Latest Patch 179 sandbox readiness receipt is missing; rollback matrix should be reviewed before future sandbox execution.")
    if summary.get("duplicate_basenames"):
        warnings.append("Duplicate basenames remain present; future backup/restore must use exact path + SHA only.")
    if not summary.get("exact_sha_rows_present"):
        warnings.append("Exact SHA rows are incomplete; future restore must refuse until hashes are available.")
    for label, report in [("scope", scope), ("validation", validation), ("sandbox", sandbox), ("dependency", dependency)]:
        if isinstance(report, dict) and report.get("live_apply_allowed") is True:
            problems.append(f"{label} receipt unexpectedly permits live apply; rollback matrix blocks advancement.")
    gates = [
        {"id":"P180-G1","name":"Patch 176 scope receipt loaded","status":"OK" if scope else "WARN","detail":scope.get("status", "missing") if isinstance(scope, dict) else "missing"},
        {"id":"P180-G2","name":"Patch 179 sandbox readiness receipt loaded","status":"OK" if sandbox else "WARN","detail":sandbox.get("status", "missing") if isinstance(sandbox, dict) else "missing"},
        {"id":"P180-G3","name":"Candidate preserved","status":"OK","detail":candidate},
        {"id":"P180-G4","name":"Exact SHA restore rows available","status":"OK" if summary.get("exact_sha_rows_present") else "WARN","detail":f"exact_sha_rows_present={summary.get('exact_sha_rows_present')}"},
        {"id":"P180-G5","name":"Rollback/restore execution deferred","status":"OK","detail":"creates_backup_now=False restores_files_now=False deletes_files_now=False"},
        {"id":"P180-G6","name":"Live apply remains forbidden","status":"OK","detail":"approval token not requested; runtime/project/engine writes remain zero"},
    ]
    payload = {
        "schema_version": FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_SCHEMA_VERSION,
        "patch": "Patch 180 — Runtime Candidate Dry-Plan Rollback Matrix / No-Write Restore Plan",
        "status": "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_READY_NO_WRITE_RESTORE_PLAN" if not problems else "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_BLOCKED_REVIEW_REQUIRED",
        "created_at": _p180_now(),
        "selected_candidate": candidate,
        "rollback_matrix_ready": not problems,
        "rollback_execution_allowed": False,
        "restore_execution_allowed": False,
        "backup_creation_allowed": False,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "token_validation_status": "NOT_REQUESTED",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_receipt_writes_only": True,
        "candidate_file_summary": summary,
        "rollback_matrix": matrix,
        "source_report": {
            "scope_latest": str(_P180Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_scope_v1" / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
            "scope_status": scope.get("status") if isinstance(scope, dict) else None,
            "dependency_latest": str(_P180Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_dependency_v1" / "latest_forge_runtime_candidate_dry_plan_dependency_v1.json"),
            "dependency_status": dependency.get("status") if isinstance(dependency, dict) else None,
            "validation_latest": str(_P180Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_validation_v1" / "latest_forge_runtime_candidate_dry_plan_validation_v1.json"),
            "validation_status": validation.get("status") if isinstance(validation, dict) else None,
            "sandbox_latest": str(_P180Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_sandbox_v1" / "latest_forge_runtime_candidate_dry_plan_sandbox_v1.json"),
            "sandbox_status": sandbox.get("status") if isinstance(sandbox, dict) else None,
        },
        "any_file_boundary": {
            "future_generalization_allowed": True,
            "current_patch_accepts_arbitrary_path": False,
            "current_patch_uses_selected_candidate_only": True,
            "required_for_any_file": [
                "approved scope",
                "exact-list/exact-read",
                "sha256 current-state record",
                "no-write rollback matrix",
                "Forge-owned backup manifest",
                "sandbox rehearsal/pass receipt",
                "safe tests",
                "explicit human approval token in separate live patch",
                "post-write disk verification",
            ],
        },
        "gates": gates,
        "warnings": warnings,
        "problems": problems,
        "next_patch": "Patch 181 — Runtime Candidate Sandbox Execution Preflight / No-Write Gate",
        "recommended_next_patch": "Patch 181 — Runtime Candidate Sandbox Execution Preflight / No-Write Gate",
    }
    payload["rollback_matrix_fingerprint"] = _p180_hash_payload({k:v for k,v in payload.items() if k != "rollback_matrix_fingerprint"})
    return payload


