def _p169_short_hash(text: str) -> str:
    return _p169_hashlib.sha256((text or "").encode("utf-8")).hexdigest()[:16]


def _p169_planned_files_from_sources():
    decision = _p169_latest_json("forge_runtime_live_decision_v1/latest_forge_runtime_live_decision_v1.json", {})
    execution = _p169_latest_json("forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json", {})
    final_gate = _p169_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    files = []
    for src_name, payload in [("decision_gate", decision), ("execution_plan", execution), ("final_gate", final_gate)]:
        for row in payload.get("planned_files", []) or []:
            if isinstance(row, dict):
                r = dict(row)
                r["source"] = r.get("source") or src_name
                files.append(r)
        if files:
            break
    normalized = []
    seen = set()
    for row in files:
        rel = row.get("relative_path") or row.get("target_relative_path") or row.get("runtime_relative_path") or row.get("path") or row.get("file")
        if not rel:
            continue
        rel = str(rel)
        if rel in seen:
            continue
        seen.add(rel)
        normalized.append({
            "relative_path": rel,
            "target_relative_path": row.get("target_relative_path") or rel,
            "source": row.get("source") or "runtime_live_token_entry",
            "sandbox_source": row.get("sandbox_source") or row.get("source_path") or row.get("source") or "candidate_sandbox",
            "live_write_planned_now": False,
        })
    return normalized


def _p169_required_token(candidate: str, planned_files) -> dict:
    file_list = "|".join(sorted([str(f.get("relative_path") or f.get("target_relative_path") or "") for f in planned_files]))
    seed = f"AIWEB_RUNTIME_LIVE_BUILD_APPROVAL::{candidate}::{file_list}"
    digest = _p169_short_hash(seed)
    phrase = f"APPROVE_RUNTIME_LIVE_BUILD_{candidate.upper()}_{digest}"
    return {
        "token_type": "HUMAN_APPROVAL_TOKEN_TEMPLATE",
        "candidate": candidate,
        "required_phrase": phrase,
        "required_phrase_hash": _p169_hashlib.sha256(phrase.encode("utf-8")).hexdigest(),
        "status": "TEMPLATE_READY_NOT_ENTERED",
        "entry_captured": False,
        "approval_present": False,
        "instructions": "Do not type this token unless Nic intentionally approves a future live runtime write in a separate approval step.",
    }


def _p169_payload() -> dict:
    decision = _p169_latest_json("forge_runtime_live_decision_v1/latest_forge_runtime_live_decision_v1.json", {})
    capture = _p169_latest_json("forge_runtime_live_approval_capture_v1/latest_forge_runtime_live_approval_capture_v1.json", {})
    execution = _p169_latest_json("forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json", {})
    final_gate = _p169_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    candidate = decision.get("candidate") or capture.get("candidate") or execution.get("candidate") or final_gate.get("candidate") or "failsafe_manager"
    planned_files = _p169_planned_files_from_sources()
    token = _p169_required_token(candidate, planned_files)
    prior_approval = bool(decision.get("human_approval_present") or capture.get("human_approval_present") or execution.get("human_approval_present") or final_gate.get("human_approval_present"))
    approval_token_status = decision.get("approval_token_status") or capture.get("approval_token_status") or execution.get("approval_token_status") or final_gate.get("approval_token_status") or "TEMPLATE_READY_NOT_APPROVED"
    problems = []
    if not planned_files:
        problems.append("No planned runtime files found from prior live decision/execution evidence.")
    gates = [
        {"id": "T01", "name": "Approval decision report exists", "status": "PASS" if decision else "FAIL", "detail": decision.get("status", "missing")},
        {"id": "T02", "name": "Execution plan report exists", "status": "PASS" if execution else "FAIL", "detail": execution.get("status", "missing")},
        {"id": "T03", "name": "Final approval gate exists", "status": "PASS" if final_gate else "FAIL", "detail": final_gate.get("status", "missing")},
        {"id": "T04", "name": "Candidate known", "status": "PASS" if candidate else "FAIL", "detail": candidate},
        {"id": "T05", "name": "Planned files available", "status": "PASS" if planned_files else "FAIL", "detail": f"planned_files={len(planned_files)}"},
        {"id": "T06", "name": "Human approval token entry captured", "status": "LOCKED", "detail": token.get("status")},
        {"id": "T07", "name": "Live runtime write authority", "status": "LOCKED", "detail": "runtime writes remain disabled"},
        {"id": "T08", "name": "No live writes performed", "status": "PASS", "detail": "runtime_writes=0 project_writes=0 engine_writes=0"},
    ]
    planning_ready = len([g for g in gates if g.get("status") == "FAIL"]) == 0 and len(problems) == 0
    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_TOKEN_ENTRY_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_HUMAN_APPROVAL_TOKEN_ENTRY_GATE_V1",
        "created_at": _p169_now(),
        "active_patch": "Patch 169 — Runtime Live Build Human Approval Token Entry Gate",
        "current_phase": "S19O — Runtime Live Build Human Approval Token Entry Gate",
        "next_patch": "Patch 170 — Runtime Live Build Approval Token Validation / Final Execution Preflight",
        "recommended_next_patch": "Patch 170 — Runtime Live Build Approval Token Validation / Final Execution Preflight",
        "status": "FORGE_RUNTIME_LIVE_TOKEN_ENTRY_READY_GATE_LOCKED" if planning_ready else "FORGE_RUNTIME_LIVE_TOKEN_ENTRY_HAS_BLOCKERS",
        "candidate": candidate,
        "planning_ready": planning_ready,
        "live_build_ready": False,
        "human_approval_present": False,
        "prior_human_approval_detected": prior_approval,
        "approval_token_status": approval_token_status,
        "approval_entry_status": token.get("status"),
        "approval_token_template": token,
        "execution_decision": "HOLD_FOR_HUMAN_APPROVAL",
        "planned_file_count": len(planned_files),
        "planned_files": planned_files,
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "problem_count": len(problems),
        "problems": problems,
        "gates": gates,
        "gate_summary": {
            "pass": sum(1 for g in gates if g.get("status") == "PASS"),
            "warn": sum(1 for g in gates if g.get("status") == "WARN"),
            "locked": sum(1 for g in gates if g.get("status") == "LOCKED"),
            "fail": sum(1 for g in gates if g.get("status") == "FAIL"),
        },
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "runtime_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
        },
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 169 creates a separate human approval token entry gate. It generates the required token template but does not treat it as entered and performs zero live writes.",
    }
    return payload


def _p169_markdown(payload: dict) -> str:
    lines = []
    lines.append(f"# {payload.get('active_patch','Patch 169')} — Human Approval Token Entry Gate")
    lines.append("")
    lines.append(f"Status: {payload.get('status')}")
    lines.append(f"Candidate: {payload.get('candidate')}")
    lines.append(f"Planning ready: {payload.get('planning_ready')}")
