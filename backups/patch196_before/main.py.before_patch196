        "ledger_deferred": counts.get("ledger_deferred"),
        "ledger_pending": counts.get("ledger_pending"),
        "future_lockfile_eligible": counts.get("future_lockfile_eligible"),
        "source_ledger_path": (final or {}).get("source_ledger_path"),
