def _p178_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19X" not in ids:
        rows.append({"id":"S19X","status":"ACTIVE","title":"Runtime Candidate Dry-Plan Validation Matrix / No-Write Test Plan","patch":"Patch 178 — Runtime Candidate Dry-Plan Validation Matrix / No-Write Test Plan","summary":"Create a no-write validation/test matrix before any future sandbox or live apply.","authority":"validation planning only; no runtime writes"})
    if "S19Y" not in ids:
        rows.append({"id":"S19Y","status":"NEXT","title":"Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan","patch":"Patch 179 — Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan","summary":"Plan the Forge-owned sandbox rehearsal for the selected runtime candidate without executing or applying it.","authority":"sandbox planning only; no runtime writes"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R","S19S","S19T","S19U","S19V","S19W"}:
            row["status"] = "DONE"
        elif rid == "S19X":
            row["status"] = "ACTIVE"
        elif rid == "S19Y":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


