def _p156_engine_name(entry) -> str:
    if isinstance(entry, str):
        return entry
    if isinstance(entry, dict):
        # Patch 156R: canonical lockfile rows use `engine_base`.
        # Keep older accepted keys too, but prefer real engine identity fields
        # over generic row IDs so the runtime dependency map can read the
        # 54-engine canonical lockfile correctly.
        for k in ("engine", "engine_name", "engine_base", "canonical_engine", "name"):
            if entry.get(k):
                return str(entry.get(k))
        p = entry.get("canonical_path") or entry.get("path") or entry.get("engine_path") or entry.get("recommended_keep_path")
        if p:
            return Path(str(p)).name
        if entry.get("id"):
            return str(entry.get("id"))
    return ""


def _p156_canonical_engine_entries(lock: dict) -> list[dict]:
    raw = lock.get("canonical_entries") or lock.get("included_entries") or lock.get("engines") or []
    entries = []
    if isinstance(raw, dict):
        raw = list(raw.values())
    for item in raw:
        name = _p156_engine_name(item)
        if not name:
            continue
        if isinstance(item, dict):
            row = dict(item)
        else:
            row = {"engine": name}
        row["engine"] = name
        entries.append(row)
    return entries


def _p156_runtime_domain(engine: str) -> str:
    e = (engine or "").lower()
    if any(x in e for x in ["memory", "archive", "resurrection", "capacitor", "fluid", "spc", "state"]):
        return "MEMORY_AND_RESONANCE"
    if any(x in e for x in ["christ", "drift", "guard", "trust", "confusion", "breather", "recursive_field", "collapse"]):
        return "DRIFT_AND_CORRECTION"
    if any(x in e for x in ["agent", "athena", "neo", "gilligan", "reflection", "kernel", "naming", "goal"]):
        return "AGENT_ORCHESTRATION"
    if any(x in e for x in ["dashboard", "ui", "visual", "formatter", "onboarding", "control_panel"]):
        return "INTERFACE_AND_OPERATOR_SURFACE"
    if any(x in e for x in ["policy", "failsafe", "tier", "contribution", "ledger", "token"]):
        return "GOVERNANCE_AND_SAFETY"
    if any(x in e for x in ["plugin", "system", "os", "peer", "compute", "install", "project", "log"]):
        return "SYSTEM_RUNTIME_AND_TOOLS"
    return "GENERAL_RUNTIME"


def _p156_priority(engine: str, domain: str) -> str:
    e = (engine or "").lower()
    if any(x in e for x in ["aiweb_os", "phase", "memory_stack", "christping", "drift", "symbolic_capacitor", "loop_resurrection", "failsafe", "system_log"]):
        return "P1_CORE"
    if domain in {"MEMORY_AND_RESONANCE", "DRIFT_AND_CORRECTION", "SYSTEM_RUNTIME_AND_TOOLS"}:
        return "P2_SUPPORTING_CORE"
    return "P3_INTERFACE_OR_EXTENSION"


def _p156_engine_dependency_rows(inputs: dict) -> list[dict]:
    lock = inputs.get("canonical_lockfile") or {}
    canonical = _p156_canonical_engine_entries(lock)
    source = inputs.get("source_authority") or {}
    source_rows = source.get("engine_rows") or source.get("rows") or source.get("candidate_rows") or []
    source_lookup = {}
    if isinstance(source_rows, list):
        for row in source_rows:
            if isinstance(row, dict):
                name = _p156_engine_name(row)
                if name:
                    source_lookup[name] = row
    rows = []
    for entry in canonical:
        engine = entry.get("engine")
        domain = _p156_runtime_domain(engine)
        srow = source_lookup.get(engine) or {}
        source_status = srow.get("status") or srow.get("source_status") or ("CANDIDATE_OR_UNKNOWN")
        rows.append({
            "engine": engine,
            "runtime_domain": domain,
            "priority": _p156_priority(engine, domain),
            "canonical_status": "CANONICAL_INCLUDED",
            "source_authority_status": source_status,
            "dependency_kind": "canonical_runtime_module",
            "live_write_ready": False,
            "notes": "Planning row only. No runtime write authority granted by Patch 156.",
        })
    rows.sort(key=lambda r: (r.get("priority"), r.get("runtime_domain"), r.get("engine")))
    return rows


def _p156_domain_summary(rows: list[dict]) -> list[dict]:
    counts = {}
    for row in rows:
        d = row.get("runtime_domain") or "UNKNOWN"
        counts.setdefault(d, {"domain": d, "total": 0, "p1_core": 0, "p2_supporting_core": 0, "p3_interface_or_extension": 0})
        counts[d]["total"] += 1
        if row.get("priority") == "P1_CORE":
            counts[d]["p1_core"] += 1
        elif row.get("priority") == "P2_SUPPORTING_CORE":
            counts[d]["p2_supporting_core"] += 1
        else:
            counts[d]["p3_interface_or_extension"] += 1
    return [counts[k] for k in sorted(counts)]


def _p156_blockers(inputs: dict) -> list[dict]:
    blockers = []
    runtime = inputs.get("runtime_readiness") or {}
    live = inputs.get("live_eligibility") or {}
    source = inputs.get("source_authority") or {}
    source_summary = source.get("summary") or {}
    if runtime.get("planning_ready") is not True:
        blockers.append({"id": "B01", "type": "planning", "summary": "AI.Web runtime readiness is not planning-ready."})
    if live.get("eligible_for_live_apply") is not True:
        blockers.append({"id": "B02", "type": "live_write", "summary": "Live apply remains locked. This is expected before runtime build writes."})
    gap_count = source_summary.get("engines_with_source_authority_gaps")
    if isinstance(gap_count, int) and gap_count > 0:
        blockers.append({"id": "B03", "type": "source_authority", "summary": f"{gap_count} canonical engines still have source authority gaps."})
    if (inputs.get("shadow_diff") or {}).get("summary", {}).get("shadow_matches_snapshot") is not True:
        blockers.append({"id": "B04", "type": "forensic", "summary": "Latest shadow restore proof is missing or not matching snapshot."})
    return blockers


def _p156_payload() -> dict:
    inputs = _p156_latest_inputs()
    tool = _p156_live_tool_state()
    rows = _p156_engine_dependency_rows(inputs)
    domains = _p156_domain_summary(rows)
    blockers = _p156_blockers(inputs)
    runtime = inputs.get("runtime_readiness") or {}
    tests = inputs.get("canonical_tests") or {}
    test_counts = tests.get("counts") or {}
    planning_ready = bool(rows) and runtime.get("planning_ready") is True
