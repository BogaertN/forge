    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q"}:
            row["status"] = "DONE"
        elif rid == "S19R":
            row["status"] = "ACTIVE"
        elif rid == "S19S":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


