                print(f"    - {field}")
    print("──────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "LLM_PLAN_SHOW", str(path), "read-only", f"arg={arg}")


def cmd_llm_plan_validate(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    arg = (arg or "latest").strip()
    if arg.lower() in {"latest", "template", ""}:
        source_path = _patch119_latest_template_path()
        source_payload = _patch119_load_json(source_path)
        packet = source_payload.get("template") if source_payload.get("template") else source_payload
        if not packet:
            packet = _patch119_template_object()
    else:
        # Patch 119 intentionally does not read arbitrary system paths. It only reads files
        # inside the Forge-owned llm_plans_v1 directory by filename.
        safe_name = re.sub(r"[^a-zA-Z0-9_.\-]+", "_", arg).strip("._")
        source_path = _PATCH119_ROOT / safe_name
        source_payload = _patch119_load_json(source_path)
        packet = source_payload.get("template") if source_payload.get("template") else source_payload
    validation = _patch119_validate_packet(packet or {})
    payload = {
        "schema_version": _PATCH119_SCHEMA_VERSION,
        "report_type": "LLM_PLAN_VALIDATION_V1",
        "created_at": _patch119_iso_now(),
        "status": validation.get("status"),
        "source_path": str(source_path),
        "source_sha256": _patch119_sha256(source_path),
        "validation": validation,
        "authority": {
            "mode": "SCHEMA_VALIDATION_ONLY",
            "project_file_write_authority": False,
            "forge_self_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "chroma_write_authority": False,
            "ledger_mutation_authority": False,
            "llm_autonomous_decision_authority": False,
        },
        "plain_english": "The LLM planning packet shape was checked. This does not make any patch eligible for live apply.",
        "next_commands": ["llm-plan-show validation", "llm-plan-export", "forge-next"],
    }
    json_path, md_path = _patch119_write_json_and_md(payload, _PATCH119_VALIDATION_PREFIX)
    print()
    print("── LLM Plan Validate — Patch 119 ────────────────────")
    print(f"  Status        : {validation.get('status')}")
    print(f"  Schema valid  : {validation.get('schema_valid')}")
    print(f"  Concrete plan : {validation.get('concrete_plan')}")
    print(f"  Live eligible : {validation.get('live_apply_eligible')}")
    print(f"  Problems      : {len(validation.get('problems') or [])}")
    print(f"  Warnings      : {len(validation.get('warnings') or [])}")
    print(f"  JSON          : {json_path}")
    print("──────────────────────────────────────────────────────")
    print()
    write_audit_entry(session_id, "LLM_PLAN_VALIDATION_WRITTEN", str(json_path), f"status={validation.get('status')}", "schema_only_no_apply")


