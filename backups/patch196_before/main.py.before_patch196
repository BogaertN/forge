FORGE_GROUNDING_ATTACHMENT_BEGIN = "BEGIN_FORGE_GROUNDING_ATTACHMENT_PATCH_56"
FORGE_GROUNDING_ATTACHMENT_END = "END_FORGE_GROUNDING_ATTACHMENT_PATCH_56"

def _proposal_grounding_attachment_text(receipt: dict) -> str:
    """Build a deterministic grounding attachment block for proposal files."""
    receipt = receipt or {}
    evidence_status = receipt.get("evidence_status", {}) or {}
    evidence_counts = receipt.get("evidence_counts", {}) or {}
    top_evidence = receipt.get("top_evidence", {}) or {}

    def _yes(value) -> str:
        return "PASS" if bool(value) else "WEAK"

    def _count(name: str) -> str:
        value = evidence_counts.get(name, 0)
        try:
            return str(int(value))
        except Exception:
            return str(value)

    def _evidence_lines(label: str, key: str, limit: int = 3) -> list[str]:
        rows = top_evidence.get(key, []) or []
        out: list[str] = []
        out.append(f"{label}:")
        if not rows:
            out.append("  - none recorded")
            return out
        for idx, item in enumerate(rows[:limit], 1):
            if key == "artifact_matches":
                out.append(f"  {idx}. score={item.get('score')} path={item.get('path')}")
                snippet = str(item.get("snippet", "")).replace("\n", " ")[:220]
                if snippet:
                    out.append(f"     snippet={snippet}")
                continue
            citation = item.get("source_citation") or f"{item.get('corpus_id')}::{item.get('chunk_id')}"
            score = item.get("final_score")
            role = item.get("memory_role") or "(none)"
            folder = item.get("corpus_folder") or "(unknown)"
            out.append(f"  {idx}. score={score} citation={citation}")
            out.append(f"     role={role} folder={folder}")
        return out

    lines = [
        "",
        FORGE_GROUNDING_ATTACHMENT_BEGIN,
        "GROUNDING ATTACHMENT — PATCH 56",
        "Exact block verification: Patch 56C requires full-line BEGIN/END sentinels plus required fields; random user text is ignored.",
        "═" * 66,
        "This proposal was created after source-grounded preflight.",
        "Forge rule: ground first, propose second, carry proof forward.",
        "",
        f"Grounding receipt ID        : {receipt.get('receipt_id')}",
        f"Grounding receipt path      : {receipt.get('_path')}",
        f"Grounding created at        : {receipt.get('created_at')}",
        f"Grounding verdict           : {receipt.get('verdict')}",
        f"Accepted for patch-propose  : {receipt.get('accepted_for_patch_propose')}",
        f"Pass count                  : {receipt.get('pass_count')}/4",
        f"Target path                 : {receipt.get('target_path')}",
        f"Target SHA-256/16           : {receipt.get('target_sha256_16')}",
        "",
        "Evidence status:",
        f"  source_law            : {_yes(evidence_status.get('source_law'))} ({_count('source_law')} results)",
        f"  engineering_standard  : {_yes(evidence_status.get('engineering_standard'))} ({_count('engineering_standard')} results)",
        f"  implementation        : {_yes(evidence_status.get('implementation'))} ({_count('implementation')} results)",
        f"  prior_or_similar      : {_yes(evidence_status.get('prior_or_similar'))} ({_count('prior_context')} context results, {_count('artifact_matches')} artifacts)",
        "",
        "Top grounding evidence carried forward:",
    ]
    lines.extend(_evidence_lines("Source-law", "source_law"))
    lines.extend(_evidence_lines("Engineering-standard", "engineering_standard"))
    lines.extend(_evidence_lines("Implementation", "implementation"))
    lines.extend(_evidence_lines("Prior/similar context", "prior_context"))
    lines.extend(_evidence_lines("Patch lifecycle artifacts", "artifact_matches"))
    lines.extend([
        "",
        "Proposal review instruction:",
        "  Review this grounding attachment together with the proposed change.",
        "  If the attachment is missing, stale, or for a different SHA, do not apply the patch.",
        "═" * 66,
        FORGE_GROUNDING_ATTACHMENT_END,
        "",
    ])
    return "\n".join(lines)



def _proposal_grounding_attachment_state(text: str) -> dict:
    """Strictly verify whether a proposal contains a real Forge grounding attachment block.

    Patch 56 and 56B used substring checks. That was too loose because a normal
    proposal field could mention the marker phrase or sentinel names. Patch 56C
    treats the attachment as present only when the BEGIN and END sentinels are on
    their own lines and the block between them contains the required grounding
    proof fields.
    """
    text = text or ""
    lines = text.splitlines()
    begin_lines = [i for i, line in enumerate(lines) if line.strip() == FORGE_GROUNDING_ATTACHMENT_BEGIN]
    end_lines = [i for i, line in enumerate(lines) if line.strip() == FORGE_GROUNDING_ATTACHMENT_END]
    marker_mentions = (
        FORGE_GROUNDING_ATTACHMENT_BEGIN in text
        or FORGE_GROUNDING_ATTACHMENT_END in text
        or "GROUNDING ATTACHMENT — PATCH 56" in text
    )
    required_fields = [
        "GROUNDING ATTACHMENT — PATCH 56",
        "Grounding receipt ID",
        "Grounding receipt path",
        "Target SHA-256/16",
        "Grounding verdict",
        "Evidence status:",
        "Top grounding evidence carried forward:",
    ]

    checked_blocks = []
    for b in begin_lines:
        for e in end_lines:
            if e <= b:
                continue
            block = "\n".join(lines[b:e + 1])
            missing = [field for field in required_fields if field not in block]
            checked_blocks.append({"begin_line": b + 1, "end_line": e + 1, "missing": missing})
            if not missing:
                return {
                    "valid": True,
                    "reason": "valid exact grounding attachment block found",
                    "begin_line": b + 1,
                    "end_line": e + 1,
                    "marker_mentions": marker_mentions,
                    "begin_line_count": len(begin_lines),
                    "end_line_count": len(end_lines),
                    "checked_blocks": checked_blocks,
                    "missing": [],
                }

    reason = "no full-line BEGIN/END grounding block found"
    if begin_lines and not end_lines:
        reason = "BEGIN sentinel exists without END sentinel"
    elif end_lines and not begin_lines:
        reason = "END sentinel exists without BEGIN sentinel"
    elif begin_lines and end_lines:
        reason = "BEGIN/END sentinels exist but required grounding fields are missing"
    elif marker_mentions:
        reason = "marker text mentioned only inside normal proposal text"

    missing = required_fields
    if checked_blocks:
        missing = checked_blocks[0].get("missing", required_fields)
    return {
        "valid": False,
        "reason": reason,
        "marker_mentions": marker_mentions,
        "begin_line_count": len(begin_lines),
        "end_line_count": len(end_lines),
        "checked_blocks": checked_blocks,
        "missing": missing,
    }


def _append_grounding_attachment_to_proposal(proposal_path: str | Path, receipt: dict, session_id: str) -> bool:
    """Append and self-verify the active grounding receipt summary to a Forge proposal file."""
    from agents.forge.memory import write_audit_entry
    try:
        path = Path(proposal_path).expanduser().resolve()
        if not str(path).startswith(str(FORGE_ROOT / "proposed_patches")):
            write_audit_entry(
                session_id=session_id,
                tool="PATCH_PROPOSAL_GROUNDING_ATTACH_REFUSED",
                path=str(path),
                lines="-",
                reason="proposal path outside Forge proposed_patches",
            )
            return False

        current = path.read_text(encoding="utf-8") if path.exists() else ""
        state = _proposal_grounding_attachment_state(current)
        if state.get("valid"):
            write_audit_entry(
                session_id=session_id,
                tool="PATCH_PROPOSAL_GROUNDING_ALREADY_ATTACHED",
                path=str(path),
                lines=f"exact block lines {state.get('begin_line')}-{state.get('end_line')}",
                reason=f"receipt={receipt.get('receipt_id')}",
            )
            return True

        if state.get("marker_mentions") or state.get("begin_line_count") or state.get("end_line_count"):
            write_audit_entry(
                session_id=session_id,
                tool="PATCH_PROPOSAL_GROUNDING_MARKER_REPAIRED",
                path=str(path),
                lines="invalid marker text ignored; appending verified attachment",
                reason=f"{state.get('reason')} begin_lines={state.get('begin_line_count')} end_lines={state.get('end_line_count')}",
            )

        attachment = _proposal_grounding_attachment_text(receipt)
        with path.open("a", encoding="utf-8") as f:
            f.write("\n")
            f.write(attachment)

        verified_text = path.read_text(encoding="utf-8")
        verified_state = _proposal_grounding_attachment_state(verified_text)
        if not verified_state.get("valid"):
            write_audit_entry(
                session_id=session_id,
                tool="PATCH_PROPOSAL_GROUNDING_ATTACHMENT_FAILED",
                path=str(path),
                lines="self-verification failed",
                reason=f"{verified_state.get('reason')} missing={verified_state.get('missing')}",
            )
            return False

        write_audit_entry(
            session_id=session_id,
            tool="PATCH_PROPOSAL_GROUNDING_ATTACHED",
            path=str(path),
            lines=f"exact block lines {verified_state.get('begin_line')}-{verified_state.get('end_line')}",
            reason=f"receipt={receipt.get('receipt_id')} sha={receipt.get('target_sha256_16')} verdict={receipt.get('verdict')}",
        )
        return True
    except Exception as e:
        write_audit_entry(
            session_id=session_id,
            tool="PATCH_PROPOSAL_GROUNDING_ATTACH_WARN",
            path=str(proposal_path),
            lines="-",
            reason=str(e)[:160],
        )
        return False


