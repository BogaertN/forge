def _p158_markdown(payload: dict) -> str:
    cand = payload.get("selected_candidate") or {}
    lines = [
        "# Forge Runtime Build Sandbox Plan — Patch 158",
        "",
        f"Status: {payload.get('status')}",
        f"Current: {payload.get('current_phase')}",
        f"Next: {payload.get('next_patch')}",
        f"Planning ready: {payload.get('planning_ready')}",
        f"Dry-run ready: {payload.get('dry_run_ready')}",
        f"Live build ready: {payload.get('live_build_ready')}",
        "",
        "## Selected Candidate",
        f"- Engine: {cand.get('engine') or 'NONE'}",
        f"- Domain: {cand.get('runtime_domain') or '-'}",
        f"- Canonical path: {cand.get('canonical_path') or '-'}",
        f"- Risk: {cand.get('risk_level') or '-'} ({cand.get('risk_score') or '-'})",
        "",
        "## Future paths not created",
    ]
    for row in payload.get("future_paths_not_created") or []:
        lines.append(f"- {row.get('kind')}: {row.get('path')} ({row.get('authority')})")
    lines += ["", "## Gates"]
    for gate in payload.get("gates") or []:
        lines.append(f"- {gate.get('id')} [{gate.get('status')}] {gate.get('name')}: {gate.get('detail')}")
    lines += ["", "## Blockers / locks"]
    for blocker in payload.get("blockers") or []:
        lines.append(f"- {blocker.get('id')} [{blocker.get('type')}] {blocker.get('summary')}")
    return "\n".join(lines) + "\n"


def _p158_dry_run_payload(plan: dict) -> dict:
    candidate = plan.get("selected_candidate") or {}
    sandbox_id = _p158_sandbox_id(candidate)
    sandbox_dir = FORGE_RUNTIME_BUILD_SANDBOX_ROOT / sandbox_id
    sandbox_dir.mkdir(parents=True, exist_ok=True)
    candidate_manifest = {
        "sandbox_id": sandbox_id,
        "created_at": _p158_now(),
        "candidate": candidate,
        "future_paths_not_created": plan.get("future_paths_not_created") or [],
        "authority": "Forge-owned dry-run preview only. No AI.Web runtime/project/engine files were created.",
    }
    (sandbox_dir / "candidate_plan.json").write_text(json.dumps(candidate_manifest, indent=2, sort_keys=True), encoding="utf-8")
    (sandbox_dir / "README.md").write_text(
        "\n".join([
            "# Forge Runtime Build Sandbox Dry Run",
            "",
            "This directory is Forge-owned dry-run evidence only.",
            "No AI.Web runtime files were created.",
            "No engine files were written.",
            "No patch was applied.",
