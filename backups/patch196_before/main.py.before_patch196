def _p148_now() -> str:
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _p148_stamp() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p148_load_json(path) -> dict:
    try:
        p = Path(path)
        if not p.exists():
            return {}
        return json.loads(p.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        return {}


def _p148_sha256(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        h = hashlib.sha256()
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p148_write(payload: dict, stem: str):
    FORGE_SOURCE_AUTHORITY_HARDENING_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p148_stamp()
