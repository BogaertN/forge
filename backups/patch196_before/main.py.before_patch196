def cmd_forge_tool_install(package: str, session_id: str):
    """
    Install a PyPI package into Forge's Python environment.
    Requires typing INSTALL to confirm.

    Usage: forge-tool-install <package-name>
    Example: forge-tool-install rich

    What this does:
      1. Fetches package info from PyPI (confirms it exists)
      2. Shows you what will be installed
      3. Asks you to type INSTALL to confirm
      4. Runs pip install using Forge's own Python
      5. Records the install in Forge memory
      6. Audits every step
    What this does NOT do:
      - Does NOT modify AI.Web project files
      - Does NOT install system-wide — only into Forge's venv
    """
    from agents.forge.memory import write_audit_entry

    package = package.strip()
    if not package:
        print("\n  Usage: forge-tool-install <package-name>\n")
        return

    _p194_ensure_dirs()

    print()
    print("── Forge Tool Install — Patch 194 ───────────────────────────────────")
    print(f"  Package : {package}")
    print(f"  Fetching info from PyPI...")
    print()

    data = _p194_pypi_json(package)
    if "_error" in data:
        print(f"  ERROR: Cannot reach PyPI: {data['_error']}")
        print()
        return

    info    = data.get("info", {})
    name    = info.get("name", package)
    version = info.get("version", "?")
    summary = info.get("summary", "(no summary)")

    installed = _p194_pip_list()
    if name.lower() in installed:
        print(f"  Already installed: {name} {installed[name.lower()]}")
        print(f"  To wrap: forge-tool-wrap {name}")
        print()
        return

    print(f"  Name   : {name}")
    print(f"  Version: {version}")
    print(f"  Summary: {summary[:70]}")
    print()
    print(f"  Will install into: {_p194_sys.executable}")
    print()
    print("  ╔══════════════════════════════════════════════════════════════╗")
    print("  ║  Type  INSTALL  and press Enter to proceed.                 ║")
    print("  ║  Type anything else to cancel.                              ║")
    print("  ╚══════════════════════════════════════════════════════════════╝")
    print()

    try:
        confirm = input("  Your input: ").strip()
    except EOFError:
        confirm = ""

    if confirm != "INSTALL":
        print("\n  Cancelled. Nothing installed.\n")
        write_audit_entry(session_id, "FORGE_TOOL_INSTALL_CANCELLED",
                          name, version, "user did not type INSTALL")
        return

    write_audit_entry(session_id, "FORGE_TOOL_INSTALL_APPROVED",
                      name, version, "user typed INSTALL")

    print(f"\n  Installing {name}=={version} ...")
    try:
        result = _p194_sub.run(
            [_p194_sys.executable, "-m", "pip", "install", name],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode != 0:
            err = result.stderr.strip()[-300:]
            print(f"  ✗ pip install failed:\n  {err}")
            write_audit_entry(session_id, "FORGE_TOOL_INSTALL_FAILED",
                              name, version, f"pip error: {err.replace(chr(10),' ')}")
            return

        # Verify it installed
        installed_after = _p194_pip_list()
        actual_ver = installed_after.get(name.lower(), version)

        # Record
        ts = _p184_now()
        record = {
            "package": name, "version": actual_ver,
            "summary": summary, "installed_at": ts,
            "python": _p194_sys.executable,
        }
        (_P194_TOOLS_DIR / "installed" / f"{name.lower()}_install.json"
         ).write_text(_p194_json.dumps(record, indent=2))

        print(f"  ✓ Installed: {name} {actual_ver}")
        print()
        print(f"  Next: forge-tool-wrap {name.lower()}")
        print("────────────────────────────────────────────────────────────────────")
        print()
        write_audit_entry(session_id, "FORGE_TOOL_INSTALL_COMPLETE",
                          name, actual_ver, f"installed via pip")
    except _p194_sub.TimeoutExpired:
        print("  ✗ pip install timed out after 120s")
        write_audit_entry(session_id, "FORGE_TOOL_INSTALL_TIMEOUT",
                          name, version, "pip timed out")


