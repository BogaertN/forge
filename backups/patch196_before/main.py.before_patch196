            f"- Engineering-standard: {engineering_ok}",
            f"- Implementation: {implementation_ok}",
            f"- Prior/similar: {prior_ok}",
            "",
            "## Rule",
            "No source-grounded rationale, no major patch.",
        ]
        md_path.write_text("\n".join(md_lines), encoding="utf-8")
        return json_path, md_path, ""
    except Exception as e:
        return None, None, str(e)


def _read_grounding_receipts() -> list[dict]:
    receipts: list[dict] = []
    if not GROUNDING_RECEIPTS_DIR.exists():
        return receipts
    for p in sorted(GROUNDING_RECEIPTS_DIR.glob("*.json"), reverse=True):
        try:
            data = json.loads(p.read_text(encoding="utf-8"))
            data["_path"] = str(p)
            receipts.append(data)
        except Exception:
            continue
    return receipts


def _grounding_guard_status(target_file: str) -> dict:
    """Return whether a target has a fresh PASS grounding receipt for its current SHA."""
    profile, _ = _grounding_read_target(target_file)
    if not profile.get("ok"):
        return {"ok": False, "state": "TARGET_INVALID", "reason": profile.get("reason", "target invalid"), "profile": profile}
    target_path = str(profile.get("path"))
    target_sha = profile.get("sha256_16")
    path_receipts = [r for r in _read_grounding_receipts() if str(r.get("target_path")) == target_path]
    exact = [r for r in path_receipts if r.get("target_sha256_16") == target_sha and r.get("verdict") == "GROUNDING_PASS" and r.get("accepted_for_patch_propose") is True]
    if exact:
        exact.sort(key=lambda r: str(r.get("created_at", "")), reverse=True)
        return {"ok": True, "state": "GROUNDING_PASS", "reason": "fresh grounding receipt found", "profile": profile, "receipt": exact[0]}
    if path_receipts:
        path_receipts.sort(key=lambda r: str(r.get("created_at", "")), reverse=True)
        newest = path_receipts[0]
        if newest.get("target_sha256_16") != target_sha:
            return {"ok": False, "state": "GROUNDING_STALE", "reason": f"target SHA changed: receipt={newest.get('target_sha256_16')} current={target_sha}", "profile": profile, "receipt": newest}
        return {"ok": False, "state": "GROUNDING_NOT_PASSING", "reason": f"latest grounding verdict is {newest.get('verdict')}", "profile": profile, "receipt": newest}
    return {"ok": False, "state": "GROUNDING_MISSING", "reason": "no grounding receipt for this target", "profile": profile}


