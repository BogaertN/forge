    mp = FORGE_SOURCE_AUTHORITY_HARDENING_DIR / f"{stamp}_{stem}.md"
    jp.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"- **status**: `{payload.get('status')}`",
        f"- **active_patch**: `{payload.get('active_patch')}`",
        f"- **next_patch**: `{payload.get('next_patch') or payload.get('recommended_next_patch')}`",
    ]
    s = payload.get("summary") or {}
    if s:
        lines.append("")
        lines.append("## Summary")
        for k, v in s.items():
            lines.append(f"- **{k}**: `{v}`")
    gaps = payload.get("gap_rows") or []
    if gaps:
        lines.append("")
        lines.append("## Source Authority Gaps")
        for row in gaps[:50]:
            lines.append(f"- `{row.get('engine_base')}` — {', '.join(row.get('required_source_domains') or [])}")
        if len(gaps) > 50:
            lines.append(f"- ... {len(gaps) - 50} more in JSON")
    mp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    (FORGE_SOURCE_AUTHORITY_HARDENING_DIR / f"latest_{stem}.json").write_text(jp.read_text(encoding="utf-8"), encoding="utf-8")
    (FORGE_SOURCE_AUTHORITY_HARDENING_DIR / f"latest_{stem}.md").write_text(mp.read_text(encoding="utf-8"), encoding="utf-8")
    return jp, mp


