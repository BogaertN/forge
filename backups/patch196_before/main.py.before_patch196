def _patch126_iso_now() -> str:
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _patch126_sha256_path(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch126_read_json(path: Path):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    return None


def _patch126_write_json_md(payload: dict, prefix: str):
    PATCH126_IMPACT_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")
    json_path = PATCH126_IMPACT_DIR / f"{ts}_{prefix}.json"
    md_path = PATCH126_IMPACT_DIR / f"{ts}_{prefix}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    latest_json = PATCH126_IMPACT_DIR / f"latest_{prefix}.json"
    latest_md = PATCH126_IMPACT_DIR / f"latest_{prefix}.md"
    latest_json.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [f"# {payload.get('report_type', prefix)}", "", f"Status: {payload.get('status')}", f"Created: {payload.get('created_at')}", ""]
    if payload.get("target"):
        lines.append(f"Target: {payload.get('target')}")
    if payload.get("summary"):
        lines += ["", "## Summary", ""]
        for k, v in (payload.get("summary") or {}).items():
            lines.append(f"- {k}: {v}")
    if payload.get("plain_english"):
        lines += ["", "## Plain English", "", str(payload.get("plain_english"))]
    if payload.get("rows"):
        lines += ["", "## Rows", ""]
        for row in payload.get("rows") or []:
            lines.append(f"- {row.get('engine_base') or row.get('target')}: risk={row.get('risk_level')} score={row.get('risk_score')} tests={row.get('test_status')}")
    if payload.get("impact"):
        lines += ["", "## Impact", ""]
        imp = payload.get("impact") or {}
        for k in ["engine_base", "canonical_path", "risk_level", "risk_score", "test_status", "relationship_count", "recommended_next_action"]:
            if k in imp:
                lines.append(f"- {k}: {imp.get(k)}")
    if payload.get("authority"):
        lines += ["", "## Authority", ""]
        for k, v in (payload.get("authority") or {}).items():
            lines.append(f"- {k}: {v}")
    md_text = "\n".join(lines) + "\n"
    md_path.write_text(md_text, encoding="utf-8")
    latest_md.write_text(md_text, encoding="utf-8")
    return json_path, md_path


