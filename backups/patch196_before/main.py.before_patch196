def _p160_verify_payload() -> dict:
    import ast
    draft = _p160_latest_draft()
    files = draft.get("draft_files") or []
    gates = []
    problems = []
    def add(gid, name, status, detail):
        gates.append({"id": gid, "name": name, "status": status, "detail": detail})
    add("D01", "Draft report exists", "PASS" if draft else "FAIL", draft.get("status") or "missing")
    add("D02", "Draft status sandbox-only ready", "PASS" if draft.get("status") == "FORGE_RUNTIME_CANDIDATE_DRAFT_READY_SANDBOX_ONLY" else "FAIL", draft.get("status") or "missing")
    expected = int(draft.get("expected_draft_file_count") or 0)
    actual = len(files)
    add("D03", "Draft file count matches plan", "PASS" if expected == actual and actual == 4 else "FAIL", f"expected={expected} actual={actual}")
    zero = draft.get("project_files_written") == 0 and draft.get("engine_files_written") == 0 and draft.get("runtime_files_written") == 0
    add("D04", "No live AI.Web writes", "PASS" if zero else "FAIL", f"project={draft.get('project_files_written')} engine={draft.get('engine_files_written')} runtime={draft.get('runtime_files_written')}")
    verified_files = []
    manifest_ok = False
    adapter_ok = False
    for row in files:
        p = Path(row.get("sandbox_path") or "")
        entry = dict(row)
        entry["exists"] = p.exists() and p.is_file()
        entry["hash_match"] = False
        if entry["exists"]:
            entry["sha256_now"] = hashlib.sha256(p.read_bytes()).hexdigest()
            entry["hash_match"] = entry["sha256_now"] == row.get("sha256")
            if p.name == "runtime_manifest.json":
                try:
                    payload = json.loads(p.read_text(encoding="utf-8"))
                    manifest_ok = payload.get("manifest_type") == "AIWEB_RUNTIME_CANDIDATE_SANDBOX_MANIFEST" and payload.get("authority", {}).get("runtime_file_write_authority") is False
                except Exception as exc:
                    problems.append(f"manifest parse failed: {exc}")
            if p.name.endswith("_runtime_adapter.py"):
                try:
                    ast.parse(p.read_text(encoding="utf-8"))
                    adapter_ok = True
                except Exception as exc:
                    problems.append(f"adapter syntax failed: {exc}")
        if not entry["exists"] or not entry["hash_match"]:
            problems.append(f"file verify failed: {p}")
        verified_files.append(entry)
    add("D05", "Draft files verify from disk", "PASS" if actual > 0 and all(r.get("exists") and r.get("hash_match") for r in verified_files) else "FAIL", f"verified={sum(1 for r in verified_files if r.get('hash_match'))}/{len(verified_files)}")
    add("D06", "Runtime manifest parses and remains sandbox-only", "PASS" if manifest_ok else "FAIL", f"manifest_ok={manifest_ok}")
    add("D07", "Runtime adapter syntax parses", "PASS" if adapter_ok else "FAIL", f"adapter_syntax_ok={adapter_ok}")
    warnings = []
    source_status = str((draft.get("selected_candidate") or {}).get("source_authority_status") or "CANDIDATE_OR_UNKNOWN")
    if source_status in {"CANDIDATE_OR_UNKNOWN", "UNKNOWN", ""}:
        warnings.append("Source authority remains candidate/unknown; acceptable for sandbox-only draft, not live build.")
    failed = [g for g in gates if g.get("status") == "FAIL"]
    status = "FORGE_RUNTIME_CANDIDATE_DRAFT_VERIFY_PASS_SANDBOX_ONLY" if not failed and not problems else "FORGE_RUNTIME_CANDIDATE_DRAFT_VERIFY_HAS_PROBLEMS"
    return {
        "schema_version": FORGE_RUNTIME_CANDIDATE_DRAFT_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_CANDIDATE_DRAFT_VERIFICATION_V1",
        "created_at": _p160_now(),
        "status": status,
        "active_patch": "Patch 160 — Runtime Candidate File Draft / Sandbox Candidate",
        "current_phase": "S19F — Runtime Candidate File Draft / Sandbox Candidate",
        "next_patch": "Patch 161 — Runtime Candidate Static Verification / Live Build Gate",
        "planning_ready": status.endswith("SANDBOX_ONLY"),
        "live_build_ready": False,
        "selected_candidate": draft.get("selected_candidate") or {},
        "draft_status": draft.get("status"),
        "draft_files_verified": sum(1 for r in verified_files if r.get("exists") and r.get("hash_match")),
        "draft_file_count": len(verified_files),
        "verified_files": verified_files,
        "gates": gates,
        "warnings": warnings,
        "problems": problems,
        "problem_count": len(problems) + len(failed),
        "authority": {"project_file_write_authority": False, "engine_file_write_authority": False, "runtime_file_write_authority": False, "patch_apply_authority": False, "forge_owned_report_write_authority": True},
