def _patch109_slug(value: str) -> str:
    if "_patch106_slug" in globals():
        return _patch106_slug(value)
    return re.sub(r"[^a-zA-Z0-9_.-]+", "_", (value or "").strip()).strip("_").lower()


def _patch109_read_json(path) -> dict:
    return json.loads(Path(path).read_text(encoding="utf-8"))


def _patch109_write_json(path, data: dict) -> None:
    p = Path(path)
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def _patch109_sha256(path) -> str | None:
    try:
        h = hashlib.sha256()
        p = Path(path)
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


