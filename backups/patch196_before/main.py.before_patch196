        "deferred_items": deferred,
        "blocked_items": blocked,
        "next_commands": ["forge-build-sequence-export", "Install Patch 145 when ready"] if clean else ["forge-command-surface", "engine-final-lockfile-show latest", "canonical-test-run-show latest", "patch-impact-map all"],
        "authority": {"read_only": True, "server_started": False, "network_opened": False, "project_file_write_authority": False, "engine_file_write_authority": False, "patch_apply_authority": False, "shell_execution_authority": False, "ledger_mutation": False, "chroma_write_authority": False},
    }
    return payload


