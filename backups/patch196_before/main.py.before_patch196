    queue = inputs.get("deferred_queue") or {}
    live = inputs.get("live_eligibility") or {}
    dash2 = inputs.get("dashboard_v2") or {}
    seq = inputs.get("build_sequence") or {}

    rows = []
    rows.append({
        "domain_id": "D01",
        "domain": "Forge command surface and trust",
        "status": _p155_status(tool.get("tools") == 504 and tool.get("expected_commands") == len(FORGE_EXPECTED_COMMANDS) and tool.get("trust_level") == 5.0),
        "summary": f"tools={tool.get('tools')} expected_commands={tool.get('expected_commands')} trust={tool.get('trust_level')}",
