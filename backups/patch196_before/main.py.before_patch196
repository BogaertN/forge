# Purpose: require a fresh Forge-owned self-snapshot before any future Forge
# self-update can advance toward sandbox/apply. This patch has no live self-write
# authority, no project write authority, no shell execution authority, and never
# overwrites the audit log.

_PATCH121_DIR = FORGE_ROOT / "memory" / "forge_self_snapshots_v1"
_PATCH121_SNAPSHOT_DIR = _PATCH121_DIR / "snapshots"
_PATCH121_POLICY_PREFIX = "forge_self_snapshot_policy_v1"
_PATCH121_MANIFEST_PREFIX = "forge_self_snapshot_manifest_v1"
_PATCH121_VERIFY_PREFIX = "forge_self_snapshot_verification_v1"
_PATCH121_EXPORT_PREFIX = "forge_self_snapshot_export_v1"


def _patch121_iso_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _patch121_slug_now() -> str:
    from datetime import datetime
    return datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch121_ensure_dirs() -> None:
    _PATCH121_DIR.mkdir(parents=True, exist_ok=True)
    _PATCH121_SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)


def _patch121_sha256(path: Path) -> str | None:
    import hashlib
    try:
        h = hashlib.sha256()
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _patch121_write_json_and_md(payload: dict, prefix: str) -> tuple[Path, Path]:
    import json
    _patch121_ensure_dirs()
    stamp = _patch121_slug_now()
    json_path = _PATCH121_DIR / f"{stamp}_{prefix}.json"
    md_path = _PATCH121_DIR / f"{stamp}_{prefix}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = [f"# {payload.get('report_type', prefix)}", ""]
    for key, value in payload.items():
        if isinstance(value, (str, int, float, bool)) or value is None:
            lines.append(f"- **{key}:** {value}")
        elif isinstance(value, list):
            lines.append(f"- **{key}:** {len(value)} item(s)")
            for item in value[:30]:
                lines.append(f"  - `{item}`" if not isinstance(item, dict) else f"  - `{item.get('path') or item.get('name') or item}`")
        elif isinstance(value, dict):
            lines.append(f"- **{key}:**")
            for k, v in value.items():
                lines.append(f"  - `{k}`: `{v}`")
    md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    latest_json = _PATCH121_DIR / f"latest_{prefix}.json"
    latest_md = _PATCH121_DIR / f"latest_{prefix}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


