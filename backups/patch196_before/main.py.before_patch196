def _p137_find_test_for_target(target: str, target_file: str) -> str | None:
    # Prefer import probe test target if present.
    probe = _p137_latest_import_probe()
    for key in ("test_file", "test_path", "resolved_test_path"):
        val = probe.get(key)
        if val and Path(str(val)).exists():
            return str(val)
    # Search canonical safe test report for matching engine.
    report = _p137_latest_safe_test_report()
    rows = []
    for key in ("targets", "results", "test_results", "rows"):
        if isinstance(report.get(key), list):
            rows.extend(report.get(key))
    for row in rows:
        if not isinstance(row, dict):
            continue
        engine = str(row.get("engine") or row.get("target") or "")
        path = row.get("test_path") or row.get("path") or row.get("file")
        if engine == target and path and Path(str(path)).exists():
            return str(path)
    # Fallback: test_*.py in target file parent.
    parent = Path(target_file).parent if target_file else None
    if parent and parent.exists():
        tests = sorted(parent.glob("test*.py")) + sorted(parent.glob("*_test.py"))
        if tests:
            return str(tests[0])
    return None


def _p137_run_cmd(argv, cwd: Path, env=None, timeout=60):
    import subprocess, os
    merged = os.environ.copy()
    if env:
        merged.update(env)
    started = _p137_now()
    try:
        r = subprocess.run(argv, cwd=str(cwd), env=merged, shell=False, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout)
        return {"argv": argv, "cwd": str(cwd), "returncode": r.returncode, "stdout": r.stdout[-8000:], "stderr": r.stderr[-8000:], "started_at": started, "ended_at": _p137_now(), "timeout": False, "shell": False}
    except subprocess.TimeoutExpired as e:
        return {"argv": argv, "cwd": str(cwd), "returncode": None, "stdout": (e.stdout or "")[-8000:] if isinstance(e.stdout, str) else "", "stderr": (e.stderr or "")[-8000:] if isinstance(e.stderr, str) else "", "started_at": started, "ended_at": _p137_now(), "timeout": True, "shell": False}
    except Exception as e:
        return {"argv": argv, "cwd": str(cwd), "returncode": -999, "stdout": "", "stderr": repr(e), "started_at": started, "ended_at": _p137_now(), "timeout": False, "shell": False}


def _p137_call_llm(prompt: str, target: str, session_id: str) -> dict:
    import subprocess, shutil, hashlib
    from agents.forge.memory import write_audit_entry
    P137_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _p137_safe_stamp()
    prompt_path = P137_DIR / f"{stamp}_prompt_sandbox_review_{target}.txt"
    raw_path = P137_DIR / f"{stamp}_response_raw_sandbox_review_{target}.txt"
    err_path = P137_DIR / f"{stamp}_response_stderr_sandbox_review_{target}.txt"
    prompt_path.write_text(prompt, encoding="utf-8")
    model = "qwen3:8b"
    ollama = shutil.which("ollama")
    if not ollama:
        raw_path.write_text("", encoding="utf-8")
        err_path.write_text("ollama executable not found", encoding="utf-8")
        return {"model_generation_called": False, "provider": "ollama", "model": model, "returncode": None, "prompt_path": str(prompt_path), "raw_response_path": str(raw_path), "stderr_path": str(err_path), "error": "ollama_not_found"}
    write_audit_entry(session_id, "GENERIC_REPAIR_SANDBOX_LLM_CALL_STARTED", str(prompt_path), f"model={model}", "shell_false=true")
    try:
        r = subprocess.run([ollama, "run", model, prompt], shell=False, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=180)
        raw_path.write_text(r.stdout or "", encoding="utf-8")
        err_path.write_text(r.stderr or "", encoding="utf-8")
        recommendation = "REVISE_OR_REJECT"
        upper = (r.stdout or "").upper()
        if "APPROVE_SANDBOX_RESULT" in upper or "APPROVE_CANDIDATE" in upper or "SANDBOX_PASS" in upper:
            recommendation = "APPROVE_SANDBOX_RESULT"
        elif "REVISE" in upper:
            recommendation = "REVISE_CANDIDATE"
        elif "REJECT" in upper:
            recommendation = "REJECT_CANDIDATE"
        result = {"model_generation_called": True, "provider": "ollama", "model": model, "returncode": r.returncode, "prompt_path": str(prompt_path), "prompt_sha256": _p137_sha(prompt_path), "raw_response_path": str(raw_path), "raw_response_sha256": _p137_sha(raw_path), "stderr_path": str(err_path), "stderr_sha256": _p137_sha(err_path), "preview": (r.stdout or "")[:2500], "llm_recommendation": recommendation, "subprocess_shell_false": True}
        write_audit_entry(session_id, "GENERIC_REPAIR_SANDBOX_LLM_CALL_COMPLETED", str(raw_path), recommendation, f"model_generation_called=true returncode={r.returncode}")
        return result
    except subprocess.TimeoutExpired:
        raw_path.write_text("", encoding="utf-8")
        err_path.write_text("timeout", encoding="utf-8")
        write_audit_entry(session_id, "GENERIC_REPAIR_SANDBOX_LLM_CALL_TIMEOUT", str(prompt_path), "timeout", "model_generation_called=true")
        return {"model_generation_called": True, "provider": "ollama", "model": model, "returncode": None, "prompt_path": str(prompt_path), "raw_response_path": str(raw_path), "stderr_path": str(err_path), "error": "timeout", "llm_recommendation": "REVISE_CANDIDATE"}


