def _p164_root():
    from pathlib import Path
    root = Path.home() / "forge" / "memory" / "forge_runtime_live_backup_v1"
    root.mkdir(parents=True, exist_ok=True)
    return root

def _p164_json_load(path, default=None):
    import json
    from pathlib import Path
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default

def _p164_write_json_md(payload: dict, stem: str):
    import json
    root = _p164_root()
    ts = _p164_now().replace("-", "").replace(":", "").replace("T", "_")
    jp = root / f"{ts}_{stem}.json"
    mp = root / f"{ts}_{stem}.md"
    latest_j = root / f"latest_{stem}.json"
    latest_m = root / f"latest_{stem}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(text + "\n", encoding="utf-8")
    latest_j.write_text(text + "\n", encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', stem)}",
        "",
        f"- Status: {payload.get('status')}",
        f"- Candidate: {payload.get('candidate')}",
        f"- Planning ready: {payload.get('planning_ready')}",
        f"- Live build ready: {payload.get('live_build_ready')}",
        f"- Next patch: {payload.get('next_patch')}",
        "",
        "This report is Forge-owned evidence only. It does not authorize or perform live runtime writes.",
    ]
    mp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    latest_m.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return jp, mp

