def _p160_slug(value: str) -> str:
    raw = str(value or "runtime_candidate").strip().lower()
    out = []
    for ch in raw:
        out.append(ch if ch.isalnum() else "_")
    slug = "".join(out).strip("_")
    while "__" in slug:
        slug = slug.replace("__", "_")
    return slug or "runtime_candidate"


