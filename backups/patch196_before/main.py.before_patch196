def _boot_banner_tests(status: dict) -> dict:
    tests = status.get("latest_test_run", {}) if isinstance(status, dict) else {}
    summary = tests.get("summary", {}) if isinstance(tests, dict) else {}
    if summary:
        return {
            "status": tests.get("status", "?"),
            "pass": summary.get("pass", "?"),
            "fail": summary.get("fail", "?"),
        }
    latest_test = _boot_banner_load_json(MEMORY_DIR / "canonical_engine_test_runs_v1" / "latest_canonical_engine_test_run_report_v1.json")
    summary = latest_test.get("summary", {}) if isinstance(latest_test, dict) else {}
    return {
        "status": latest_test.get("status", "?"),
        "pass": summary.get("pass", "?"),
        "fail": summary.get("fail", "?"),
    }


def _boot_banner_mode_state() -> dict:
    matrix = _boot_banner_load_json(MEMORY_DIR / "forge_mode_enforcement_v1" / "latest_forge_mode_permission_matrix_v1.json")
    authority = matrix.get("authority", {}) if isinstance(matrix, dict) else {}
    if matrix:
        return {
            "status": matrix.get("status") or "MATRIX_READY",
            "hard_blocking": authority.get("hard_blocking_active", False),
            "commands": matrix.get("command_count", "?"),
        }
    registry = _boot_banner_load_json(MEMORY_DIR / "forge_modes_v1" / "latest_forge_mode_registry_v1.json")
    if registry:
        return {
            "status": registry.get("status") or "REGISTRY_READY",
            "hard_blocking": False,
            "commands": "?",
        }
    return {"status": "not built", "hard_blocking": False, "commands": "?"}


def _boot_banner_line(text: str, width: int = 53) -> str:
    clean = str(text)
    if len(clean) > width:
        clean = clean[: width - 1] + "…"
    return "│ " + clean.ljust(width) + " │"


