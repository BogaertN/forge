def cmd_import_probe_run(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    raw = (arg or "latest").strip()
    parts = raw.split()
    target_arg = parts[0] if parts else "latest"
    confirm = parts[1] if len(parts) > 1 else ""
    if confirm != IMPORT_PROBE_CONFIRM:
        print("\nIMPORT_PROBE_RUN_REFUSED")
        print("Missing confirmation token.")
        print("Run: import-probe-run", target_arg, IMPORT_PROBE_CONFIRM)
        print()
        write_audit_entry(session_id, "IMPORT_PROBE_RUN_REFUSED", target_arg, "missing_confirm_token", "no_subprocess")
        return
    plan = _p134_load(_p134_latest_plan_path()) if target_arg in {"latest", "plan", "run"} else _p134_plan_payload(target_arg)
    if target_arg not in {"latest", "plan", "run"}:
        _p134_write(plan, "import_probe_plan_v1")
    resolved = plan.get("resolved_target") or _p134_resolve_target(target_arg)
    problems = list(plan.get("problems") or [])
    aiweb_root = Path("/home/nic/aiweb")
    engines_root = aiweb_root / "engines"
    target_path = Path(resolved.get("target_path") or "")
    test_candidates = [Path(x) for x in (resolved.get("test_candidates") or [])]
    command_kind = "none"
    argv = []
    cwd = target_path if target_path.is_dir() else target_path.parent
    if not problems:
        if resolved.get("target_kind") == "python_file" and target_path.suffix == ".py" and target_path.exists():
            if target_path.name.startswith("test_") or target_path.name.endswith("_test.py"):
                argv = [sys.executable, str(target_path)]
                command_kind = "python_test_file"
            else:
                argv = [sys.executable, "-m", "py_compile", str(target_path)]
                command_kind = "py_compile_file"
        elif test_candidates:
            test_path = test_candidates[0]
            argv = [sys.executable, str(test_path)]
            cwd = test_path.parent
            command_kind = "engine_test_file"
        else:
            problems.append("no runnable Python target selected")
    env = os.environ.copy()
    prefix_items = []
    try:
        if cwd.exists(): prefix_items.append(str(cwd.resolve()))
        if target_path.exists(): prefix_items.append(str((target_path if target_path.is_dir() else target_path.parent).resolve()))
    except Exception:
        pass
    prefix_items += [str(engines_root), str(aiweb_root)]
    existing = env.get("PYTHONPATH", "")
    prefix = os.pathsep.join([x for x in dict.fromkeys(prefix_items) if x])
    env["PYTHONPATH"] = prefix + (os.pathsep + existing if existing else "")
    started = datetime.datetime.now()
    result = {
        "schema_version": "import_probe_run_v1_patch134",
        "report_type": "IMPORT_PROBE_RUN_V1",
        "created_at": _p134_iso(),
        "status": "IMPORT_PROBE_RUN_BLOCKED" if problems else "IMPORT_PROBE_RUN_STARTED",
        "target": resolved.get("target"),
        "target_engine": resolved.get("engine_name"),
        "resolved_target": resolved,
        "command_kind": command_kind,
        "argv": argv,
        "cwd": str(cwd),
        "env_additions": {"PYTHONPATH_prefix": prefix},
        "problems": problems,
        "plain_english": "Generic import/path probe result. A passing probe means this target can run under the scoped diagnostic environment. A failing probe means the target needs either test-runner path adjustment or file/package repair review.",
        "authority": {
            "read_only": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "ledger_mutation_authority": False,
            "writes_forge_memory_only": True,
            "subprocess_shell_false": True,
        },
    }
    if not problems:
        try:
            cp = subprocess.run(argv, cwd=str(cwd), env=env, shell=False, capture_output=True, text=True, timeout=30)
            duration = (datetime.datetime.now() - started).total_seconds()
            passed = cp.returncode == 0
            result.update({
                "returncode": cp.returncode,
                "duration_seconds": round(duration, 3),
                "stdout_tail": _p134_tail(cp.stdout),
                "stderr_tail": _p134_tail(cp.stderr),
                "status": "IMPORT_PROBE_PASS" if passed else "IMPORT_PROBE_FAIL",
                "probe_passed": passed,
                "recommendation": "Treat this as environment-compatible; if a previous safe test failed, investigate test-runner cwd/PYTHONPATH behavior." if passed else "Do not alter live files yet; inspect package structure, imports, and test assumptions through a separate repair proposal.",
            })
        except subprocess.TimeoutExpired as exc:
            result.update({"status": "IMPORT_PROBE_TIMEOUT", "timeout_seconds": 30, "stdout_tail": _p134_tail(exc.stdout or ""), "stderr_tail": _p134_tail(exc.stderr or ""), "probe_passed": False})
        except Exception as exc:
            result.update({"status": "IMPORT_PROBE_ERROR", "error": str(exc), "probe_passed": False})
    jp, mp = _p134_write(result, "import_probe_run_v1")
    print("\n── Import / Path Probe Run — Patch 134 ─────────────")
    print("  Status   :", result.get("status"))
    print("  Target   :", result.get("target"))
    print("  Kind     :", result.get("command_kind"))
    print("  Return   :", result.get("returncode"))
    print("  Passed   :", result.get("probe_passed"))
    print("  JSON     :", jp)
    if result.get("stderr_tail"):
        print("  Stderr tail:")
        print(_p134_tail(result.get("stderr_tail"), 1200))
    print("──────────────────────────────────────────────────────\n")
    write_audit_entry(session_id, "IMPORT_PROBE_RUN_WRITTEN", str(jp), result.get("status"), f"target={result.get('target')} returncode={result.get('returncode')}")


