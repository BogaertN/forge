def _patch127_iso_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _patch127_sha256_path(path: Path) -> str:
    import hashlib
    try:
        return hashlib.sha256(path.read_bytes()).hexdigest()
    except Exception:
        return ""


def _patch127_read_json(path: Path) -> dict:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return {}


def _patch127_latest_json(directory: Path, pattern: str) -> tuple[Path | None, dict]:
    try:
        files = sorted(directory.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    except Exception:
        files = []
    for p in files:
        data = _patch127_read_json(p)
        if data:
            return p, data
    return None, {}


def _patch127_write_json_md(payload: dict, prefix: str) -> tuple[Path, Path]:
    PATCH127_STATUS_API_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch127_iso_now().replace(":", "").replace("-", "_").replace("T", "_")
    json_path = PATCH127_STATUS_API_DIR / f"{stamp}_{prefix}.json"
    md_path = PATCH127_STATUS_API_DIR / f"{stamp}_{prefix}.md"
    latest_json = PATCH127_STATUS_API_DIR / f"latest_{prefix}.json"
    latest_md = PATCH127_STATUS_API_DIR / f"latest_{prefix}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    json_path.write_text(text + "\n", encoding="utf-8")
    latest_json.write_text(text + "\n", encoding="utf-8")
    md_lines = [f"# {payload.get('report_type', prefix)}", ""]
    md_lines.append(f"Status: `{payload.get('status')}`")
    if payload.get("plain_english"):
        md_lines.extend(["", payload.get("plain_english")])
    if payload.get("summary"):
        md_lines.extend(["", "## Summary"])
        for k, v in payload.get("summary", {}).items():
            md_lines.append(f"- **{k}**: `{v}`")
    if payload.get("recommended_next_patch"):
        md_lines.extend(["", f"Recommended next patch: `{payload.get('recommended_next_patch')}`"])
    md_text = "\n".join(md_lines) + "\n"
    md_path.write_text(md_text, encoding="utf-8")
    latest_md.write_text(md_text, encoding="utf-8")
    return json_path, md_path


def _patch127_audit_tail_status(max_lines: int = 2500) -> dict:
    audit_path = FORGE_ROOT / "logs" / "forge_audit.log"
    if not audit_path.exists():
        return {"exists": False, "entries_checked": 0, "chain_breaks": None, "latest_entry_hash": None}
    try:
        lines = audit_path.read_text(encoding="utf-8", errors="replace").splitlines()[-max_lines:]
    except Exception as exc:
        return {"exists": True, "entries_checked": 0, "chain_breaks": None, "error": str(exc), "latest_entry_hash": None}
    import re
    pat = re.compile(r"PREV_HASH:\s*([0-9a-f]+)\s*\|\s*ENTRY_HASH:\s*([0-9a-f]+)")
    prev = None
    breaks = 0
    checked = 0
    latest = None
    for line in lines:
        m = pat.search(line)
        if not m:
            continue
        ph, eh = m.group(1), m.group(2)
        checked += 1
        if prev is not None and ph != prev:
            breaks += 1
        prev = eh
        latest = eh
    return {"exists": True, "entries_checked": checked, "chain_breaks": breaks, "latest_entry_hash": latest}


