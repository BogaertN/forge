def _p151_append_only_roadmap_rows(existing_rows: list) -> list:
    """Patch 151R: Preserve the previously published roadmap rows and append new detail rows.

    Rule: roadmap rows are append-only. Existing stage IDs are not deleted, renumbered,
    or repurposed by later patches. Later patches may only mark status forward and add
    child/detail rows.
    """
    prior_canonical = [
        {"id": "S01", "title": "Patch law, audit, and exact truth", "status": "DONE", "purpose": "Initial patch/audit/exact-read foundations."},
        {"id": "S02", "title": "Corpus and source authority foundations", "status": "DONE", "purpose": "Corpus intake, source authority, and context memory foundations."},
        {"id": "S03", "title": "Codebase index and symbolic runtime map", "status": "DONE", "purpose": "Code index, symbol map, engine inventory, and runtime role mapping."},
        {"id": "S04", "title": "Sandbox and safe test harness", "status": "DONE", "purpose": "Sandbox/test safety layers and safe canonical test execution."},
        {"id": "S05", "title": "Canonical engine authority", "status": "DONE", "purpose": "Human-reviewed canonical lockfile and deferred/excluded authority."},
        {"id": "S06", "title": "Relationship and impact intelligence", "status": "DONE", "purpose": "Canonical relationships, neighbors, impact map, and risk surfaces."},
        {"id": "S07", "title": "Status API and read-only dashboard", "status": "DONE", "purpose": "Read-only status API and dashboard surfaces."},
        {"id": "S08", "title": "Mode registry and permission matrix", "status": "DONE", "purpose": "Mode registry, check-only matrix, and permission visibility."},
        {"id": "S09", "title": "Roadmap V2 realignment", "status": "DONE", "purpose": "Repair roadmap away from stale single-task routing."},
        {"id": "S10", "title": "Roadmap-Grounded Build Sequencer", "status": "DONE", "purpose": "Create build sequence brain without replacing the historical roadmap."},
        {"id": "S11", "title": "Deferred Engine Repair Queue", "status": "DONE", "purpose": "Keep deferred engines visible without blocking the main path."},
        {"id": "S12", "title": "Build Phase Gate Checker", "status": "DONE", "purpose": "Check build phase readiness from verified reports."},
        {"id": "S13", "title": "Dashboard Roadmap Panel", "status": "DONE", "purpose": "Expose roadmap/deferred/gate status to dashboard surfaces."},
        {"id": "S14", "title": "Source Authority Runtime Binder Hardening", "status": "DONE", "purpose": "Strengthen source-authority binder without claiming fake final authority."},
        {"id": "S15", "title": "LLM Patch Proposal v2", "status": "DONE", "purpose": "Read-only LLM patch proposal structure with verified fields."},
        {"id": "S16", "title": "Live Apply Eligibility Gate v2", "status": "DONE", "purpose": "Create read-only live-apply go/no-go gate; no write authority."},
        {"id": "S17", "title": "Snapshot and forensic replay expansion", "status": "ACTIVE", "purpose": "Parent roadmap stage for snapshot planning, creation, shadow replay, and forensic diff."},
        {"id": "S18", "title": "Dashboard v2 / operator control panel", "status": "FUTURE", "purpose": "Future operator-facing dashboard expansion after snapshot foundations."},
        {"id": "S19", "title": "AI.Web runtime build through Forge", "status": "FUTURE", "purpose": "Use Forge to build AI.Web runtime modules after gates are mature."},
        {"id": "S20", "title": "Freeze, release, and recovery package", "status": "FUTURE", "purpose": "Package stable Forge with install, recovery, audit, and release artifacts."},
    ]

    appended_detail = [
        {"id": "S17A", "title": "Snapshot / Forensic Replay Plan", "status": "ACTIVE", "purpose": "Patch 151 defines the snapshot and forensic replay plan. It creates no snapshot and restores nothing."},
        {"id": "S17B", "title": "Snapshot Create / Verify", "status": "NEXT", "purpose": "Patch 152 should create Forge-owned snapshot artifacts and verify hashes."},
        {"id": "S17C", "title": "Shadow Restore / Forensic Diff", "status": "FUTURE", "purpose": "Future patch should rehearse restore into a shadow directory and produce forensic diff evidence."},
    ]

    # Preserve any unknown historical rows from disk as extra rows, but never let
    # later patches repurpose the canonical prior IDs or erase the future parent stages.
    result = []
    seen = set()
    for row in prior_canonical + appended_detail:
        result.append(dict(row))
        seen.add(row["id"])

    for row in existing_rows or []:
        rid = row.get("id")
        if not rid or rid in seen:
            continue
        preserved = dict(row)
        preserved.setdefault("status", "PRESERVED")
        preserved.setdefault("purpose", "Preserved historical roadmap row from earlier disk state.")
        result.append(preserved)
        seen.add(rid)

    return result


