        print("── Patch Apply Refused — Test Gate ──────────────────")
        print("  Rule       : no real patch-apply without matching TEST_BOUND safe test receipt")
        print(f"  Apply plan : {candidate}")
        print(f"  Target     : {target_file}")
        print(f"  Original   : {str(original_sha)[:16]}")
        print(f"  Future     : {str(future_sha)[:16]}")
        print(f"  Reason     : {test_gate.get('reason')}")
