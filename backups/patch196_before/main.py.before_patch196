def _p173_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19S" not in ids:
        rows.append({"id":"S19S","status":"ACTIVE","title":"Runtime Live Build Hold Continuation / Runtime Candidate Queue Return","patch":"Patch 173 — Runtime Live Build Hold Continuation / Runtime Candidate Queue Return","summary":"Continue holding the live build when approval is absent and return the candidate to a held queue state without writes.","authority":"hold-continuation queue-return gate only; no runtime writes"})
    if "S19T" not in ids:
        rows.append({"id":"S19T","status":"NEXT","title":"Runtime Candidate Queue Review / Next Candidate Selection","patch":"Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection","summary":"Review the held candidate queue and decide whether to keep failsafe_manager held, request explicit approval, or select the next runtime candidate for dry planning.","authority":"queue review only; no live writes"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R"}:
            row["status"] = "DONE"
        elif rid == "S19S":
            row["status"] = "ACTIVE"
        elif rid == "S19T":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


def _p144_sequence_payload() -> dict:
    payload = _patch173_previous_p144_sequence_payload()
    hold_return = _p173_load_latest()
