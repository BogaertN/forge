    impact_path, impact = _patch127_latest_json(FORGE_ROOT / "memory" / "patch_impact_v1", "latest_patch_impact_map_v1.json")
    tests_path, tests = _patch127_latest_json(FORGE_ROOT / "memory" / "canonical_engine_test_runs_v1", "latest_canonical_engine_test_run_report_v1.json")
