    rows = _p179_file_rows(scope)
    return {
        "plan_type": "NO_WRITE_SANDBOX_REHEARSAL_PLAN",
        "executes_now": False,
        "creates_sandbox_now": False,
        "copies_files_now": False,
        "runs_tests_now": False,
        "shell_allowed": False,
        "approval_token_requested": False,
        "proposed_sandbox_root_future": proposed_root,
        "candidate": candidate,
        "source_file_count": summary.get("file_count"),
        "exact_sha_rows_available": bool(rows) and all(bool(r.get("sha256")) for r in rows),
        "future_rehearsal_steps": [
            "Load latest Patch 176 scope receipt and Patch 178 validation matrix.",
            "Refuse if selected candidate changed or current source SHA no longer matches receipt.",
            "Create a Forge-owned sandbox directory only in a future sandbox-execution patch.",
            "Copy exact scoped files by absolute path into the sandbox with manifest rows: source path, relative path, size, sha256.",
            "Run allowlisted checks inside sandbox only: py_compile for scoped Python files and JSON parse for scoped JSON/config files.",
            "Write sandbox manifest, test report, and diff/no-diff report as Forge-owned receipts.",
            "Keep live_apply_allowed false until rollback matrix, sandbox pass, human approval, and post-write verification exist.",
        ],
        "future_refusal_conditions": [
            "missing validation receipt",
            "missing scope receipt",
            "candidate mismatch",
            "missing source SHA rows",
            "stale source SHA",
            "duplicate basename target without exact path + SHA",
            "attempt to run arbitrary shell command",
            "attempt to touch .env, keys, secrets, ~/.ssh, Chroma files, node_modules, .venv, __pycache__",
            "approval token supplied during no-write planning phase",
        ],
    }


def _p179_payload() -> dict:
    validation = _p179_validation_report()
    dependency = _p179_dependency_report()
    scope = _p179_scope_report()
    candidate = (validation.get("selected_candidate") if isinstance(validation, dict) else None) or (scope.get("selected_candidate") if isinstance(scope, dict) else None) or (dependency.get("selected_candidate") if isinstance(dependency, dict) else None) or "failsafe_manager"
    summary = _p179_candidate_summary(validation, scope, dependency)
    rehearsal = _p179_rehearsal_plan(candidate, summary, scope)
    warnings = []
    problems = []
    if not validation:
        warnings.append("Latest Patch 178 validation receipt is missing; sandbox readiness is informational only.")
    if validation and validation.get("status") != "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_READY_NO_WRITE_TEST_PLAN":
        warnings.append(f"Patch 178 validation status is {validation.get('status')}; review before sandbox execution.")
    if not scope:
        warnings.append("Latest Patch 176 scope receipt is missing; exact file-set replay is not ready.")
    if len(summary.get("duplicate_basenames") or []) > 0:
        warnings.append("Duplicate basenames remain present; future sandbox/apply must target exact path + SHA only.")
    if validation and validation.get("live_apply_allowed") is True:
        problems.append("Validation receipt unexpectedly permits live apply; sandbox readiness blocks advancement.")
    if scope and scope.get("live_apply_allowed") is True:
        problems.append("Scope receipt unexpectedly permits live apply; sandbox readiness blocks advancement.")
    gates = [
        {"id":"P179-G1","name":"Patch 178 validation receipt loaded","status":"OK" if validation else "WARN","detail":validation.get("status", "missing") if isinstance(validation, dict) else "missing"},
        {"id":"P179-G2","name":"Patch 176 scope receipt available","status":"OK" if scope else "WARN","detail":scope.get("status", "missing") if isinstance(scope, dict) else "missing"},
        {"id":"P179-G3","name":"Candidate preserved","status":"OK","detail":candidate},
        {"id":"P179-G4","name":"Sandbox execution deferred","status":"OK","detail":"creates_sandbox_now=False copies_files_now=False runs_tests_now=False"},
        {"id":"P179-G5","name":"Exact SHA rows checked for future rehearsal","status":"OK" if rehearsal.get("exact_sha_rows_available") else "WARN","detail":f"exact_sha_rows_available={rehearsal.get('exact_sha_rows_available')}"},
        {"id":"P179-G6","name":"Live apply remains forbidden","status":"OK","detail":"approval token not requested; runtime/project/engine writes remain zero"},
    ]
    payload = {
        "schema_version": FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SANDBOX_SCHEMA_VERSION,
        "patch": "Patch 179 — Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan",
        "status": "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SANDBOX_READY_NO_WRITE_REHEARSAL_PLAN" if not problems else "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SANDBOX_BLOCKED_REVIEW_REQUIRED",
        "created_at": _p179_now(),
        "selected_candidate": candidate,
        "sandbox_readiness_ready": not problems,
        "sandbox_execution_allowed": False,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "token_validation_status": "NOT_REQUESTED",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_receipt_writes_only": True,
        "candidate_file_summary": summary,
        "sandbox_rehearsal_plan": rehearsal,
        "source_report": {
            "validation_latest": str(_P179Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_validation_v1" / "latest_forge_runtime_candidate_dry_plan_validation_v1.json"),
            "validation_status": validation.get("status") if isinstance(validation, dict) else None,
            "scope_latest": str(_P179Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_scope_v1" / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
            "scope_status": scope.get("status") if isinstance(scope, dict) else None,
            "dependency_latest": str(_P179Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_dependency_v1" / "latest_forge_runtime_candidate_dry_plan_dependency_v1.json"),
            "dependency_status": dependency.get("status") if isinstance(dependency, dict) else None,
        },
        "any_file_boundary": {
            "future_generalization_allowed": True,
            "current_patch_accepts_arbitrary_path": False,
            "current_patch_uses_selected_candidate_only": True,
            "required_for_any_file": [
                "approved scope",
                "exact-list/exact-read",
                "sha256 current-state record",
                "no-write plan",
                "sandbox rehearsal",
                "safe tests",
                "rollback matrix",
                "explicit human approval token in separate live patch",
                "post-write disk verification",
            ],
        },
        "gates": gates,
        "warnings": warnings,
        "problems": problems,
        "next_patch": "Patch 180 — Runtime Candidate Dry-Plan Rollback Matrix / No-Write Restore Plan",
        "recommended_next_patch": "Patch 180 — Runtime Candidate Dry-Plan Rollback Matrix / No-Write Restore Plan",
    }
    payload["sandbox_readiness_fingerprint"] = _p179_hash_payload({k:v for k,v in payload.items() if k != "sandbox_readiness_fingerprint"})
    return payload


def _p179_write_json_and_md(stem: str, payload: dict):
    FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SANDBOX_DIR.mkdir(parents=True, exist_ok=True)
