        "relationship_map": str(MEMORY_DIR / "canonical_engine_relationships_v1" / "latest_canonical_engine_relationship_map_v1.json"),
        "revision_candidate": str(MEMORY_DIR / "generic_revision_loop_v1" / "latest_generic_revision_loop_candidate_v1.json"),
        "revision_sandbox_run": str(MEMORY_DIR / "generic_revision_sandboxes_v1" / "latest_generic_revision_sandbox_run_v1.json"),
    }
    source_sha256 = {k: _p145_sha256_path(v) for k, v in source_paths.items()}

    queue = []
    for row in disposition.get("rows") or []:
        if row.get("review_status") == "DEFERRED" or row.get("future_lockfile_eligible") is False:
            priority, priority_reason = _p145_priority(row)
            qstatus, blockers, action = _p145_repair_readiness(row, revision_candidate, revision_run)
            evidence = []
            if row.get("review_note_summary"):
                evidence.append("engine disposition review note present")
            if row.get("recommended_keep_path"):
                evidence.append(f"recommended path: {row.get('recommended_keep_path')}")
            if row.get("engine_base") == "stack_linker_breather" and revision_candidate:
                evidence.append(f"preserved revision candidate status: {revision_candidate.get('status')}")
                evidence.append(f"preserved revision candidate sha: {revision_candidate.get('candidate_sha256') or revision_candidate.get('candidate_file_sha256')}")
                if revision_run:
                    evidence.append(f"latest revision sandbox status: {revision_run.get('status')}")
            queue.append({
                "engine_base": row.get("engine_base"),
                "recommended_keep_path": row.get("recommended_keep_path"),
                "review_status": row.get("review_status"),
                "disposition_bucket": row.get("disposition_bucket"),
                "priority": priority,
                "priority_reason": priority_reason,
                "queue_status": qstatus,
                "blockers": blockers,
                "recommended_next_action": action,
                "safe_current_action": "queue/report only; no engine write, no promotion, no deletion, no quarantine",
                "evidence_notes": evidence,
                "required_human_checks": row.get("required_human_checks") or [],
                "variant_count": row.get("variant_count"),
                "decision_confidence": row.get("decision_confidence"),
            })

    queue = sorted(queue, key=lambda r: (r.get("priority", 999), r.get("engine_base") or ""))
    next_target = None
    for row in queue:
        if row.get("engine_base") == "stack_linker_breather":
            next_target = {
                "engine_base": row.get("engine_base"),
                "queue_status": row.get("queue_status"),
                "safe_next_action": row.get("recommended_next_action"),
                "note": "Visible repair target only. Main build sequence still advances to Patch 146 before reopening repair work.",
            }
            break
    if next_target is None and queue:
        row = queue[0]
        next_target = {
            "engine_base": row.get("engine_base"),
            "queue_status": row.get("queue_status"),
            "safe_next_action": row.get("recommended_next_action"),
            "note": "Visible repair target only. Build phase gates decide when repair work may resume.",
        }

    repair_ready = sum(1 for r in queue if r.get("queue_status") == "REPAIR_EVIDENCE_PRESERVED_SANDBOX_REQUIRED")
    repair_blocked = sum(1 for r in queue if r.get("blockers"))

    clean_state = (
        lock_counts.get("included") == 54
        and lock_counts.get("excluded") == 26
        and (test.get("status") == "CANONICAL_TEST_RUN_COMPLETED_ALL_PASS")
        and test_counts.get("fail") in (0, None)
        and impact_summary.get("test_issues") in (0, None)
    )

    return {
        "schema_version": FORGE_DEFERRED_ENGINE_QUEUE_SCHEMA_VERSION,
        "report_type": "FORGE_DEFERRED_ENGINE_REPAIR_QUEUE_V1",
        "created_at": _p145_now(),
        "status": "FORGE_DEFERRED_ENGINE_REPAIR_QUEUE_READY" if clean_state else "FORGE_DEFERRED_ENGINE_REPAIR_QUEUE_READY_WITH_STATE_WARNINGS",
        "active_patch": "Patch 145 — Deferred Engine Repair Queue",
        "next_patch": "Patch 146 — Build Phase Gate Checker",
        "queue_total": len(queue),
        "repair_ready_count": repair_ready,
        "repair_blocked_count": repair_blocked,
        "verified_state": {
            "tools": 444,
            "expected_commands": 520,
            "canonical_included": lock_counts.get("included"),
            "canonical_excluded": lock_counts.get("excluded"),
            "ledger_approved": lock_counts.get("ledger_approved"),
            "ledger_deferred": lock_counts.get("ledger_deferred"),
            "ledger_pending": lock_counts.get("ledger_pending"),
            "latest_test_status": test.get("status"),
            "latest_test_pass": test_counts.get("pass"),
            "latest_test_fail": test_counts.get("fail"),
            "patch_impact_matches": impact_summary.get("matches"),
            "patch_impact_high_risk": impact_summary.get("high_risk"),
            "patch_impact_test_issues": impact_summary.get("test_issues"),
            "relationship_engines": (relationship.get("summary") or {}).get("canonical_engines"),
            "disposition_deferred_total": disp_counts.get("deferred_total"),
            "disposition_excluded_total": disp_counts.get("excluded_total"),
            "previous_build_sequence_status": sequence.get("status"),
            "previous_build_sequence_next_patch": sequence.get("next_patch"),
        },
        "source_paths": source_paths,
        "source_sha256": source_sha256,
        "queue": queue,
        "next_repair_target": next_target,
        "plain_english": "Deferred engines are now tracked in a repair queue. This does not repair them or promote them; it keeps their evidence visible so the main Forge roadmap can continue without losing the deferred work.",
        "next_commands": ["forge-build-sequence", "forge-status-api-build", "forge-dashboard-build", "Install Patch 146 when ready"],
        "authority": {"read_only": True, "forge_memory_write_only": True, "patch_apply_authority": False, "project_file_write_authority": False, "engine_file_write_authority": False, "shell_execution_authority": False},
