def _p162_payload() -> dict:
    static = _p162_latest_static()
    selected = static.get("selected_candidate") or {}
    candidate = static.get("candidate") or selected.get("engine") or "UNKNOWN"
    files = static.get("files") or []
    file_count = static.get("file_count")
    files_verified = static.get("files_verified")
    live_path_exists_count = sum(1 for f in files if f.get("live_path_exists"))
    all_hash_match = all(bool(f.get("hash_match")) for f in files) if files else False
    all_static_ok = all(bool(f.get("static_ok")) for f in files) if files else False
    source_status = selected.get("source_authority_status") or static.get("source_authority_status") or "CANDIDATE_OR_UNKNOWN"
    tool = _p162_live_tool_state()

    gates = []
    _p162_gate(gates, "P01", "Static verification report exists", "PASS" if static else "FAIL", static.get("status") or "missing", not bool(static))
    _p162_gate(gates, "P02", "Static candidate status is gate-locked", "PASS" if static.get("status") == "FORGE_RUNTIME_CANDIDATE_STATIC_VERIFICATION_READY_GATE_LOCKED" else "FAIL", static.get("status") or "missing", static.get("status") != "FORGE_RUNTIME_CANDIDATE_STATIC_VERIFICATION_READY_GATE_LOCKED")
    _p162_gate(gates, "P03", "Candidate files verified in sandbox", "PASS" if file_count and files_verified == file_count and all_hash_match and all_static_ok else "FAIL", f"files_verified={files_verified}/{file_count} hash_match={all_hash_match} static_ok={all_static_ok}", not (file_count and files_verified == file_count and all_hash_match and all_static_ok))
    _p162_gate(gates, "P04", "No planned live runtime files exist yet", "PASS" if live_path_exists_count == 0 else "FAIL", f"live_path_exists={live_path_exists_count}", live_path_exists_count != 0)
    _p162_gate(gates, "P05", "Live runtime write authority is absent", "PASS", "runtime_file_write_authority=false", False)
    _p162_gate(gates, "P06", "Project/engine/patch write authority is absent", "PASS", "project=false engine=false patch_apply=false", False)
    _p162_gate(gates, "P07", "Source authority finality is honest", "PASS", source_status, False)
    _p162_gate(gates, "P08", "Human approval token present", "LOCKED", "human approval token not created by Patch 162", True)
    _p162_gate(gates, "P09", "Live build remains locked", "LOCKED", "preflight evidence exists but live build is not authorized", True)

    blocking_failures = [g for g in gates if g.get("status") == "FAIL" and g.get("blocks_live")]
    locked_gates = [g for g in gates if g.get("status") == "LOCKED"]

    planning_ready = not blocking_failures and bool(static)
    live_build_ready = False
    status = "FORGE_RUNTIME_LIVE_PREFLIGHT_READY_GATE_LOCKED" if planning_ready else "FORGE_RUNTIME_LIVE_PREFLIGHT_HAS_BLOCKERS"

    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_PREFLIGHT_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_PREFLIGHT_V1",
        "active_patch": "Patch 162 — Runtime Live Build Preflight / Human Approval Gate",
        "current_phase": "S19H — Runtime Live Build Preflight / Human Approval Gate",
        "created_at": _p162_now(),
        "status": status,
        "candidate": candidate,
        "selected_candidate": selected,
        "static_status": static.get("status") or "MISSING",
        "file_count": file_count,
        "files_verified": files_verified,
        "live_path_exists_count": live_path_exists_count,
        "planning_ready": planning_ready,
        "live_build_ready": live_build_ready,
        "human_approval_present": False,
        "source_authority_status": source_status,
        "gates": gates,
        "gate_summary": {
            "pass": sum(1 for g in gates if g.get("status") == "PASS"),
            "locked": len(locked_gates),
            "fail": sum(1 for g in gates if g.get("status") == "FAIL"),
        },
        "problem_count": len(blocking_failures),
        "problems": blocking_failures,
        "authority": {
            "forge_owned_report_write_authority": True,
            "runtime_file_write_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "live_restore_authority": False,
            "human_approval_authority": False,
        },
        "tool_state": tool,
        "plain_english": "Patch 162 proves the sandbox candidate has enough evidence for preflight review, but keeps live runtime writes locked until explicit human approval and a later apply plan exist.",
        "next_patch": "Patch 163 — Runtime Live Build Approval Token / Apply Plan",
        "recommended_next_patch": "Patch 163 — Runtime Live Build Approval Token / Apply Plan",
        "roadmap_mutation_policy": "APPEND_ONLY",
    }
    return payload


