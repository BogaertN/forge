def _p171_now() -> str:
    return _p171_datetime.now().strftime("%Y%m%d_%H%M%S")


def _p171_safe_read_json(path, default=None):
    try:
        p = _P171Path(path)
        if p.exists():
            return _p171_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p171_latest_json(rel_path: str, default=None):
    return _p171_safe_read_json(_P171Path.home() / "forge" / "memory" / rel_path, default)


def _p171_hash_text(text: str) -> str:
    return _p171_hashlib.sha256((text or "").encode("utf-8")).hexdigest()


def _p171_planned_files_from_sources():
    for rel in [
        "forge_runtime_live_token_validate_v1/latest_forge_runtime_live_token_validate_v1.json",
        "forge_runtime_live_token_entry_v1/latest_forge_runtime_live_token_entry_v1.json",
        "forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json",
        "forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_v1.json",
        "forge_runtime_candidate_static_verify_v1/latest_forge_runtime_candidate_static_verify_v1.json",
    ]:
        payload = _p171_latest_json(rel, {})
        rows = payload.get("planned_files", []) or payload.get("files", []) or []
        if rows:
            normalized = []
            seen = set()
            for row in rows:
                if not isinstance(row, dict):
                    continue
                r = dict(row)
                relp = r.get("relative_path") or r.get("target_relative_path") or r.get("runtime_relative_path") or r.get("path") or r.get("file")
                if not relp:
                    continue
                relp = str(relp)
                if relp in seen:
                    continue
                seen.add(relp)
                normalized.append({
                    "relative_path": relp,
                    "target_relative_path": r.get("target_relative_path") or relp,
                    "source": r.get("source") or "runtime_live_explicit_approval",
                    "sandbox_source": r.get("sandbox_source") or r.get("source_path") or "candidate_sandbox",
                    "live_write_planned_now": False,
                })
            return normalized
    return []


def _p171_payload(entered_token: str = "") -> dict:
    token_validation = _p171_latest_json("forge_runtime_live_token_validate_v1/latest_forge_runtime_live_token_validate_v1.json", {})
    token_entry = _p171_latest_json("forge_runtime_live_token_entry_v1/latest_forge_runtime_live_token_entry_v1.json", {})
    decision = _p171_latest_json("forge_runtime_live_decision_v1/latest_forge_runtime_live_decision_v1.json", {})
    static_verify = _p171_latest_json("forge_runtime_candidate_static_verify_v1/latest_forge_runtime_candidate_static_verify_v1.json", {})
    backup = _p171_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_v1.json", {})
    candidate = (
        token_validation.get("candidate")
        or token_entry.get("candidate")
        or decision.get("candidate")
        or "failsafe_manager"
    )
    token_template = token_validation.get("approval_token_template") or token_entry.get("approval_token_template") or {}
    required_phrase = token_template.get("required_phrase") or ""
    required_hash = token_template.get("required_phrase_hash") or ""
    entered_token = (entered_token or "").strip()
    entered_hash = _p171_hash_text(entered_token) if entered_token else ""
    token_entered = bool(entered_token)
    token_hash_matches = bool(entered_hash and required_hash and entered_hash == required_hash)
    explicit_approval_present = bool(token_entered and token_hash_matches)
    planned_files = _p171_planned_files_from_sources()
    problems = []
    if not token_validation:
        problems.append("Missing Patch 170 token-validation report.")
    if not required_phrase or not required_hash:
        problems.append("Missing approval token template phrase/hash.")
    if not planned_files:
        problems.append("No planned runtime files found from prior evidence.")
    gates = [
        {"id": "A01", "name": "Patch 170 token-validation report exists", "status": "PASS" if token_validation else "FAIL", "detail": token_validation.get("status", "missing")},
        {"id": "A02", "name": "Approval template exists", "status": "PASS" if required_phrase and required_hash else "FAIL", "detail": token_template.get("status", "missing")},
        {"id": "A03", "name": "Explicit approval token entered", "status": "LOCKED" if not token_entered else "PASS", "detail": "not_entered" if not token_entered else "entered"},
        {"id": "A04", "name": "Entered token hash validates", "status": "LOCKED" if not token_entered else ("PASS" if token_hash_matches else "FAIL"), "detail": "not_entered" if not token_entered else ("hash_match" if token_hash_matches else "hash_mismatch")},
        {"id": "A05", "name": "Candidate known", "status": "PASS" if candidate else "FAIL", "detail": candidate},
        {"id": "A06", "name": "Candidate static verification exists", "status": "PASS" if static_verify else "WARN", "detail": static_verify.get("status", "missing_or_not_bundled")},
        {"id": "A07", "name": "Backup/apply dry-run exists", "status": "PASS" if backup else "WARN", "detail": backup.get("status", "missing_or_not_bundled")},
        {"id": "A08", "name": "Planned files available", "status": "PASS" if planned_files else "FAIL", "detail": f"planned_files={len(planned_files)}"},
        {"id": "A09", "name": "Apply hold remains active", "status": "LOCKED" if not explicit_approval_present else "PASS", "detail": "HOLD_FOR_HUMAN_APPROVAL" if not explicit_approval_present else "APPROVAL_CAPTURED_NO_EXECUTION"},
        {"id": "A10", "name": "No live writes performed", "status": "PASS", "detail": "runtime_writes=0 project_writes=0 engine_writes=0"},
    ]
    hard_fails = [g for g in gates if g.get("status") == "FAIL"]
    planning_ready = len(hard_fails) == 0 and len(problems) == 0
    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_EXPLICIT_APPROVAL_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_EXPLICIT_APPROVAL_CAPTURE_APPLY_HOLD_V1",
        "created_at": _p171_now(),
        "active_patch": "Patch 171 — Runtime Live Build Explicit Approval Capture / Apply Hold",
        "current_phase": "S19Q — Runtime Live Build Explicit Approval Capture / Apply Hold",
        "next_patch": "Patch 172 — Runtime Live Build Apply Hold Review / No-Write Receipt",
        "recommended_next_patch": "Patch 172 — Runtime Live Build Apply Hold Review / No-Write Receipt",
        "status": "FORGE_RUNTIME_LIVE_EXPLICIT_APPROVAL_READY_APPLY_HOLD" if planning_ready else "FORGE_RUNTIME_LIVE_EXPLICIT_APPROVAL_HAS_BLOCKERS",
        "candidate": candidate,
        "planning_ready": planning_ready,
        "live_build_ready": False,
        "human_approval_present": explicit_approval_present,
        "approval_capture_status": "APPROVAL_CAPTURED_NO_EXECUTION" if explicit_approval_present else "TEMPLATE_READY_NOT_APPROVED",
        "approval_token_entered": token_entered,
        "token_validation_status": "NOT_ENTERED" if not token_entered else ("VALID" if token_hash_matches else "INVALID_HASH"),
        "execution_decision": "HOLD_FOR_HUMAN_APPROVAL" if not explicit_approval_present else "APPROVAL_CAPTURED_APPLY_STILL_HELD",
        "approval_token_template": token_template,
        "entered_token_hash": entered_hash,
        "required_token_hash": required_hash,
        "planned_file_count": len(planned_files),
        "planned_files": planned_files,
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "problem_count": len(problems),
        "problems": problems,
        "gates": gates,
        "gate_summary": {
            "pass": sum(1 for g in gates if g.get("status") == "PASS"),
            "warn": sum(1 for g in gates if g.get("status") == "WARN"),
            "locked": sum(1 for g in gates if g.get("status") == "LOCKED"),
            "fail": sum(1 for g in gates if g.get("status") == "FAIL"),
        },
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "runtime_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
        },
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 171 captures explicit approval state and keeps apply held. Even a valid approval token does not execute runtime writes in this patch.",
    }
    return payload


