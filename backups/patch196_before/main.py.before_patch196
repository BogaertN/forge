def _p142_find_file(root, name):
    from pathlib import Path
    try:
        r = Path(root)
        if r.exists():
            matches = [p for p in r.rglob(name) if "__pycache__" not in p.parts]
            matches.sort(key=lambda p: (len(str(p)), str(p)))
            return str(matches[0]) if matches else None
    except Exception:
        return None
    return None


def _p142_parse_failure(stderr: str):
    import re
    data = {"missing_symbol": None, "module": None}
    m = re.search(r"cannot import name ['\"]([^'\"]+)['\"] from ['\"]([^'\"]+)['\"]", stderr or "")
    if m:
        data["missing_symbol"] = m.group(1)
        data["module"] = m.group(2)
    return data


def _p142_find_import_alias(code: str, module: str, missing_symbol: str):
    import re
    if not module or not missing_symbol:
        return None
    mod = re.escape(module)
    sym = re.escape(missing_symbol)
    pat = re.compile(rf"^\s*from\s+{mod}\s+import\s+{sym}(?:\s+as\s+([A-Za-z_][A-Za-z0-9_]*))?\s*$", re.M)
    m = pat.search(code or "")
    if m:
        return m.group(1) or missing_symbol
    return None


def _p142_find_breather_class(dep_code: str):
    import re
    classes = re.findall(r"^class\s+([A-Za-z_][A-Za-z0-9_]*)\s*[:(]", dep_code or "", re.M)
    with_breathe = []
    for cls in classes:
        # rough but bounded: if there is a def breathe anywhere, prefer class names containing Breather
        if re.search(r"^\s+def\s+breathe\s*\(", dep_code or "", re.M):
            with_breathe.append(cls)
    if with_breathe:
        with_breathe.sort(key=lambda c: (0 if "Breather" in c else 1, len(c), c))
        return with_breathe[0]
    return classes[0] if classes else None


