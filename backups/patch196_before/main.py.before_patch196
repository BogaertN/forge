def _p138_parse_missing_module(stderr_text):
    import re
    if not stderr_text:
        return None
    patterns = [
        r"ModuleNotFoundError:\s+No module named ['\"]([^'\"]+)['\"]",
        r"ImportError:\s+No module named ['\"]([^'\"]+)['\"]",
    ]
    for pat in patterns:
        m = re.search(pat, stderr_text)
        if m:
            return m.group(1)
    return None

