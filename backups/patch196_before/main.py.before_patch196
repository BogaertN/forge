P140_DIR = Path.home() / "forge" / "memory" / "generic_revision_candidates_v1"
P140_CONFIRM = "CONFIRM_BUILD_GENERIC_REVISION_CANDIDATE"


def _p140_now() -> str:
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _p140_stamp() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p140_safe_name(value) -> str:
    import re
    s = str(value or "target").replace("/", "_").replace("\\", "_")
    return re.sub(r"[^A-Za-z0-9_.-]+", "_", s).strip("_") or "target"


def _p140_sha_text(text: str) -> str:
    return hashlib.sha256((text or "").encode("utf-8", errors="replace")).hexdigest()


def _p140_sha_file(path) -> str | None:
    try:
        return hashlib.sha256(Path(path).read_bytes()).hexdigest()
    except Exception:
        return None


def _p140_read_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        pass
    return {} if default is None else default


def _p140_write(payload: dict, stem: str):
    P140_DIR.mkdir(parents=True, exist_ok=True)
    ts = _p140_stamp()
    jp = P140_DIR / f"{ts}_{stem}.json"
    mp = P140_DIR / f"{ts}_{stem}.md"
    latest_j = P140_DIR / f"latest_{stem}.json"
    latest_m = P140_DIR / f"latest_{stem}.md"
    txt = json.dumps(payload, indent=2, ensure_ascii=False, sort_keys=True)
    jp.write_text(txt, encoding="utf-8")
    latest_j.write_text(txt, encoding="utf-8")
    md = "# " + str(payload.get("report_type", stem)) + "\n\n```json\n" + txt + "\n```\n"
    mp.write_text(md, encoding="utf-8")
    latest_m.write_text(md, encoding="utf-8")
    return jp, mp


