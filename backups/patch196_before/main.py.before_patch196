            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "live_restore_authority": False,
            "shell_execution_authority": False,
            "roadmap_append_only": True,
        },
        "plain_english": "Forge selected the first safe runtime module build candidate for planning only. No runtime files are written.",
        "next_commands": [
            "forge-runtime-build-plan-export",
            "forge-build-sequence",
            "forge-dashboard-roadmap-build",
            "forge-status-api-build",
            "forge-dashboard-build",
            "Install Patch 158 when ready",
        ],
    }


def _p157_markdown(payload: dict) -> str:
    cand = payload.get("selected_candidate") or {}
    lines = [
        "# Forge Runtime Build Plan — Patch 157",
        "",
        f"Status: {payload.get('status')}",
        f"Current: {payload.get('current_phase')}",
        f"Next: {payload.get('next_patch')}",
        f"Planning ready: {payload.get('planning_ready')}",
        f"Live build ready: {payload.get('live_build_ready')}",
        "",
        "## Selected Candidate",
    ]
    if cand:
        lines += [
            f"- Engine: {cand.get('engine')}",
            f"- Domain: {cand.get('runtime_domain')}",
            f"- Priority: {cand.get('priority')}",
            f"- Risk: {cand.get('risk_level')} ({cand.get('risk_score')})",
            f"- Test status: {cand.get('test_status')}",
            f"- Canonical path: {cand.get('canonical_path')}",
        ]
    else:
        lines.append("- No candidate selected.")
    lines += ["", "## Gates"]
    for gate in payload.get("gates") or []:
        lines.append(f"- {gate.get('id')} [{gate.get('status')}] {gate.get('name')}: {gate.get('detail')}")
    lines += ["", "## Blockers / Locks"]
    for blocker in payload.get("blockers") or []:
        lines.append(f"- {blocker.get('id')} [{blocker.get('type')}] {blocker.get('summary')}")
    lines += ["", "## Shortlist"]
    for row in (payload.get("candidate_shortlist") or [])[:20]:
        lines.append(f"- {row.get('engine')} | {row.get('runtime_domain')} | {row.get('priority')} | risk={row.get('risk_level')} | test={row.get('test_status')}")
    return "\n".join(lines) + "\n"


