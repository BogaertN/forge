def _patch131_required_domains(engine: str) -> list[str]:
    e = (engine or "").lower()
    domains = []
    def add(name):
        if name not in domains:
            domains.append(name)
    if any(x in e for x in ["christ", "ping", "correction"]):
        add("CHRISTPING_CORRECTION_LAYER")
    if any(x in e for x in ["drift", "confusion", "failsafe", "trust", "tier", "guard"]):
        add("SAFETY_GOVERNANCE_AND_DRIFT_CONTROL")
    if any(x in e for x in ["memory", "archive", "spc", "stack", "activity", "project_memory"]):
        add("MEMORY_STATE_AND_SPC_AUTHORITY")
    if any(x in e for x in ["recursive", "recursion", "field", "phase", "symbolic", "glyph", "resonance", "breather", "tone"]):
        add("FBSC_RPMC_SYMBOLIC_RUNTIME")
    if any(x in e for x in ["dashboard", "visual", "display"]):
        add("DASHBOARD_AND_OBSERVABILITY")
    if any(x in e for x in ["plugin", "external", "peer", "feed", "communication"]):
        add("EXTERNAL_BOUNDARY_AND_PLUGIN_TRUST")
    if any(x in e for x in ["agent", "athena", "neo", "gilligan", "reflection"]):
        add("AGENT_IDENTITY_AND_GOVERNANCE")
    if any(x in e for x in ["snapshot", "ledger", "log", "audit"]):
        add("AUDIT_LEDGER_AND_PROVENANCE")
    if not domains:
        add("GENERAL_AIWEB_RUNTIME")
    return domains


def _patch131_domain_keywords(domain: str) -> list[str]:
    d = domain.upper()
    mapping = {
        "CHRISTPING_CORRECTION_LAYER": ["christ", "ping", "correction", "drift", "recursive correction"],
        "SAFETY_GOVERNANCE_AND_DRIFT_CONTROL": ["safety", "trust", "guard", "drift", "governance", "tier", "failsafe"],
        "MEMORY_STATE_AND_SPC_AUTHORITY": ["memory", "spc", "capacitor", "archive", "stack", "state"],
        "FBSC_RPMC_SYMBOLIC_RUNTIME": ["fbsc", "rpmc", "symbolic", "recursive", "phase", "resonance", "glyph", "field"],
        "DASHBOARD_AND_OBSERVABILITY": ["dashboard", "visual", "display", "status", "observability"],
        "EXTERNAL_BOUNDARY_AND_PLUGIN_TRUST": ["plugin", "external", "boundary", "peer", "feed", "communication"],
        "AGENT_IDENTITY_AND_GOVERNANCE": ["agent", "athena", "neo", "gilligan", "identity", "reflection"],
        "AUDIT_LEDGER_AND_PROVENANCE": ["audit", "ledger", "provenance", "snapshot", "receipt", "log"],
        "GENERAL_AIWEB_RUNTIME": ["ai.web", "aiweb", "runtime", "forge", "system"],
    }
    return mapping.get(d, [d.lower()])


def _patch131_discover_source_candidates(limit: int = 240) -> list[dict]:
    """Discover candidate source documents without claiming authority automatically."""
    roots = [
        MEMORY_DIR / "context_library_v1",
        MEMORY_DIR / "source_gap_reports",
        MEMORY_DIR / "source_law_chunk_probe_v1",
        MEMORY_DIR / "corpus_registration_reports",
        CODE_MANIFESTS_DIR,
        Path.home() / "forge_corpus",
        FORGE_ROOT,
    ]
    suffixes = {".json", ".md", ".txt", ".pdf"}
    important = ["source", "law", "official", "ai.web", "aiweb", "runtime", "codex", "protoforge", "christ", "memory", "dashboard", "forge", "system", "rpmc", "fbsc", "symbolic"]
    rows = []
    seen = set()
    for root in roots:
        try:
            if not root.exists():
                continue
            for p in root.rglob("*"):
                if len(rows) >= limit:
                    return rows
                try:
                    if not p.is_file() or p.suffix.lower() not in suffixes:
                        continue
                    sp = str(p)
                    if sp in seen:
                        continue
                    seen.add(sp)
                    low = p.name.lower() + " " + str(p.parent).lower()
                    if not any(k in low for k in important):
                        continue
                    size = p.stat().st_size
                    rows.append({
                        "path": sp,
                        "name": p.name,
                        "suffix": p.suffix.lower(),
                        "size_bytes": size,
                        "sha256": _patch131_sha256(p) if size <= 5_000_000 else None,
                        "authority_claimed": False,
                        "candidate_only": True,
                    })
                except Exception:
                    continue
        except Exception:
            continue
    return rows


def _patch131_match_sources_for_domains(domains: list[str], candidates: list[dict], max_per_domain: int = 3) -> dict:
    result = {}
    for domain in domains:
        kws = _patch131_domain_keywords(domain)
        matches = []
        for c in candidates:
            hay = (c.get("name", "") + " " + c.get("path", "")).lower()
            if any(k.lower() in hay for k in kws):
                matches.append(c)
            if len(matches) >= max_per_domain:
                break
        result[domain] = matches
    return result


def _patch131_engine_test_status(engine: str, tests_payload: dict) -> str:
    rows = tests_payload.get("results") or tests_payload.get("test_results") or tests_payload.get("rows") or []
    statuses = []
    for row in rows if isinstance(rows, list) else []:
        if str(row.get("engine") or row.get("engine_base") or "") == engine:
            statuses.append(str(row.get("status") or row.get("result") or "UNKNOWN"))
    if any(s.upper() in {"FAIL", "FAILED", "ISSUES", "ERROR", "TIMEOUT"} for s in statuses):
        return "ISSUES"
    if statuses:
        return "PASS_OR_RECORDED"
    return "NO_TEST_RESULT"


def _patch131_engine_risk(engine: str, impact_payload: dict) -> dict:
    rows = impact_payload.get("rows") or impact_payload.get("impact_rows") or impact_payload.get("matches") or []
    for row in rows if isinstance(rows, list) else []:
        name = row.get("engine") or row.get("engine_base") or row.get("target")
        if str(name) == engine:
            return {
                "risk_level": row.get("risk_level") or row.get("risk") or "UNKNOWN",
                "risk_score": row.get("risk_score"),
                "test_status": row.get("test_status"),
            }
    return {"risk_level": "UNKNOWN", "risk_score": None, "test_status": None}


def _patch131_payload() -> dict:
    lock_path = _patch131_lockfile_path()
    lock = _patch131_load_json(lock_path)
    canonical = lock.get("canonical_entries") or []
    source_candidates = _patch131_discover_source_candidates()
    impact = _patch131_latest_impact()
    tests = _patch131_latest_tests()
    rows = []
    domain_counts = {}
    gap_count = 0
    candidate_match_count = 0
    for entry in canonical:
        engine = entry.get("engine_base") or entry.get("engine") or entry.get("name") or "UNKNOWN_ENGINE"
        domains = _patch131_required_domains(engine)
        for d in domains:
            domain_counts[d] = domain_counts.get(d, 0) + 1
        matches_by_domain = _patch131_match_sources_for_domains(domains, source_candidates)
        flat_matches = []
        for d, matches in matches_by_domain.items():
            for m in matches:
                flat_matches.append({"domain": d, **m})
        if flat_matches:
            candidate_match_count += 1
        else:
            gap_count += 1
        risk = _patch131_engine_risk(engine, impact)
        test_status = _patch131_engine_test_status(engine, tests)
        rows.append({
            "engine_base": engine,
            "canonical_path": entry.get("canonical_path"),
            "review_status": entry.get("review_status"),
            "required_source_domains": domains,
            "candidate_source_documents": flat_matches[:8],
            "source_authority_status": "CANDIDATE_DOCUMENTS_FOUND_REQUIRES_HUMAN_CONFIRMATION" if flat_matches else "SOURCE_AUTHORITY_GAP_RECORDED",
            "authority_claimed": False,
            "risk_level": risk.get("risk_level"),
            "risk_score": risk.get("risk_score"),
            "test_status": test_status,
            "next_required_action": "human_confirm_source_binding" if flat_matches else "provide_or_ingest_authoritative_source_document",
        })
    payload = {
        "schema_version": "engine_source_law_map_v1_patch131",
        "report_type": "ENGINE_SOURCE_LAW_MAP_V1",
        "created_at": _patch131_iso_now(),
        "status": "ENGINE_SOURCE_AUTHORITY_RUNTIME_MAP_READY" if canonical else "ENGINE_SOURCE_AUTHORITY_RUNTIME_MAP_NOT_READY",
        "mode": "READ_ONLY_SOURCE_AUTHORITY_BINDING",
        "source_lockfile_path": str(lock_path),
        "source_lockfile_sha256": _patch131_sha256(lock_path),
        "summary": {
            "canonical_engines": len(canonical),
            "source_candidate_files_seen": len(source_candidates),
            "engines_with_candidate_source_documents": candidate_match_count,
            "engines_with_source_authority_gaps": gap_count,
            "domain_count": len(domain_counts),
            "engine_file_writes": 0,
            "patch_apply_authority": False,
            "llm_decision_authority": False,
        },
        "domain_counts": dict(sorted(domain_counts.items())),
        "source_candidates_sample": source_candidates[:40],
        "rows": rows,
        "authority": {
            "read_only": True,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "chroma_write_authority": False,
            "source_authority_claimed_automatically": False,
            "requires_human_confirmation": True,
        },
        "plain_english": "This report binds each canonical engine to required source-authority domains and candidate evidence files where available. It does not claim final source authority automatically.",
        "recommended_next_patch": "Patch 132 — LLM Source-Grounded Patch Proposal",
    }
    return payload


