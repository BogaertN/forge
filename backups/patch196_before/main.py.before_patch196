def _p159_file_sha(path) -> str | None:
    try:
        import hashlib
        p = Path(path)
        h = hashlib.sha256()
        with p.open("rb") as fh:
            for chunk in iter(lambda: fh.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p159_verified_files(dry: dict) -> list[dict]:
    out = []
    for row in dry.get("created_files") or []:
        p = Path(row.get("path") or "")
        actual = _p159_file_sha(p) if p.exists() else None
        expected = row.get("sha256")
        out.append({
            "name": row.get("name"),
            "path": str(p),
            "exists": p.exists(),
            "expected_sha256": expected,
            "actual_sha256": actual,
            "hash_match": bool(actual and expected and actual == expected),
            "size_expected": row.get("size"),
            "size_actual": p.stat().st_size if p.exists() else None,
        })
    return out


