import shutil as _p136l_shutil
import time as _p136l_time

P136L_MEMORY_DIR = Path.home() / "forge" / "memory" / "generic_repair_candidate_reviews_v1"
P136L_CONFIRM = "CONFIRM_CALL_LLM_CANDIDATE_REVIEW"


def _p136l_now() -> str:
    return datetime.datetime.now().replace(microsecond=0).isoformat()


def _p136l_stamp() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p136l_sha_text(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8", errors="replace")).hexdigest()


def _p136l_sha_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _p136l_load(path: Path) -> dict:
    try:
        if path and path.exists():
            return json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        return {}
    return {}


def _p136l_write(payload: dict, stem: str) -> tuple[Path, Path]:
    P136L_MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    jp = P136L_MEMORY_DIR / f"{_p136l_stamp()}_{stem}.json"
    mp = P136L_MEMORY_DIR / f"{_p136l_stamp()}_{stem}.md"
    latest_jp = P136L_MEMORY_DIR / f"latest_{stem}.json"
    latest_mp = P136L_MEMORY_DIR / f"latest_{stem}.md"
    txt = json.dumps(payload, indent=2, sort_keys=True)
    jp.write_text(txt, encoding="utf-8")
    latest_jp.write_text(txt, encoding="utf-8")
    md = [f"# {payload.get('report_type', stem)}", "", f"status: {payload.get('status')}", f"created_at: {payload.get('created_at')}"]
    for key in ("target", "target_file", "candidate_status", "review_recommendation", "recommended_next_patch"):
        if payload.get(key) is not None:
            md.append(f"{key}: {payload.get(key)}")
    mp.write_text("\n".join(md) + "\n", encoding="utf-8")
    latest_mp.write_text("\n".join(md) + "\n", encoding="utf-8")
    return jp, mp


