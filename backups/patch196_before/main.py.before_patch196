    return report.get("status") if isinstance(report, dict) else None


def _p181_live_or_write_violation(report):
    if not isinstance(report, dict):
        return False
    return bool(report.get("live_apply_allowed") is True or report.get("runtime_writes", 0) != 0 or report.get("project_writes", 0) != 0 or report.get("engine_writes", 0) != 0)


def _p181_payload() -> dict:
    scope = _p181_scope_report()
    dependency = _p181_dependency_report()
    validation = _p181_validation_report()
    sandbox = _p181_sandbox_readiness_report()
    rollback = _p181_rollback_report()
    candidate = _p181_candidate_from_reports(rollback, sandbox, validation, dependency, scope)
    summary = _p181_file_summary(scope, rollback)
    exact_sha_ready = bool(summary.get("exact_sha_rows_present") or (rollback.get("rollback_matrix", {}) if isinstance(rollback, dict) else {}).get("exact_sha_rows_available"))
    blockers = []
    warnings = []
    if not scope:
        blockers.append("Missing Patch 176 scope receipt.")
    if not dependency:
        warnings.append("Missing Patch 177 dependency receipt; dependency impact should be reviewed before sandbox execution.")
    if not validation:
        blockers.append("Missing Patch 178 validation matrix receipt.")
    if not sandbox:
        blockers.append("Missing Patch 179 sandbox readiness receipt.")
    if not rollback:
        blockers.append("Missing Patch 180 rollback matrix receipt.")
    if summary.get("duplicate_basenames"):
        warnings.append("Duplicate basenames remain present; future sandbox and restore logic must use exact path + SHA only.")
    if not exact_sha_ready:
        blockers.append("Exact SHA rows are not available; sandbox staging must refuse.")
    for label, report in [("scope", scope), ("dependency", dependency), ("validation", validation), ("sandbox", sandbox), ("rollback", rollback)]:
        if _p181_live_or_write_violation(report):
            blockers.append(f"{label} receipt contains a live-apply or write violation.")
    if isinstance(rollback, dict) and rollback.get("restore_execution_allowed") is True:
        blockers.append("Rollback receipt unexpectedly permits restore execution.")
    if isinstance(sandbox, dict) and sandbox.get("sandbox_execution_allowed") is True:
        blockers.append("Sandbox readiness receipt unexpectedly permits sandbox execution.")
    preflight_rows = [
        {"name": "scope_receipt", "status": _p181_status(scope) or "missing", "required": True},
        {"name": "dependency_receipt", "status": _p181_status(dependency) or "missing", "required": False},
        {"name": "validation_receipt", "status": _p181_status(validation) or "missing", "required": True},
        {"name": "sandbox_readiness_receipt", "status": _p181_status(sandbox) or "missing", "required": True},
        {"name": "rollback_matrix_receipt", "status": _p181_status(rollback) or "missing", "required": True},
    ]
    gates = [
        {"id":"P181-G1","name":"Patch 176 scope receipt loaded","status":"OK" if scope else "BLOCK","detail":_p181_status(scope) or "missing"},
        {"id":"P181-G2","name":"Patch 178 validation receipt loaded","status":"OK" if validation else "BLOCK","detail":_p181_status(validation) or "missing"},
        {"id":"P181-G3","name":"Patch 179 sandbox readiness receipt loaded","status":"OK" if sandbox else "BLOCK","detail":_p181_status(sandbox) or "missing"},
        {"id":"P181-G4","name":"Patch 180 rollback matrix receipt loaded","status":"OK" if rollback else "BLOCK","detail":_p181_status(rollback) or "missing"},
        {"id":"P181-G5","name":"Exact path + SHA rows available","status":"OK" if exact_sha_ready else "BLOCK","detail":f"exact_sha_ready={exact_sha_ready}"},
        {"id":"P181-G6","name":"No execution allowed in Patch 181","status":"OK","detail":"sandbox_creation=False sandbox_execution=False tests=False live_apply=False"},
    ]
    payload = {
        "schema_version": FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_SCHEMA_VERSION,
        "patch": "Patch 181 — Runtime Candidate Sandbox Execution Preflight / No-Write Gate",
        "status": "FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_READY_NO_WRITE_GATE" if not blockers else "FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_BLOCKED_REVIEW_REQUIRED",
        "created_at": _p181_now(),
        "selected_candidate": candidate,
        "sandbox_preflight_ready": not blockers,
        "future_sandbox_stage_candidate": not blockers,
        "sandbox_creation_allowed": False,
        "sandbox_execution_allowed": False,
        "test_execution_allowed": False,
        "backup_creation_allowed": False,
        "restore_execution_allowed": False,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "token_validation_status": "NOT_REQUESTED",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_receipt_writes_only": True,
        "candidate_file_summary": summary,
        "preflight": {
            "candidate": candidate,
            "rows": preflight_rows,
            "required_receipts_loaded": all(bool(x) for x in [scope, validation, sandbox, rollback]),
            "optional_dependency_receipt_loaded": bool(dependency),
            "exact_sha_ready": exact_sha_ready,
            "duplicate_basename_count": len(summary.get("duplicate_basenames") or []),
            "future_sandbox_stage_must_be_forge_owned": True,
            "future_sandbox_stage_must_copy_by_exact_path_and_verify_sha": True,
            "future_sandbox_stage_must_not_touch_project_files": True,
        },
        "source_report": {
            "scope_latest": str(_P181Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_scope_v1" / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
            "scope_status": _p181_status(scope),
            "dependency_latest": str(_P181Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_dependency_v1" / "latest_forge_runtime_candidate_dry_plan_dependency_v1.json"),
            "dependency_status": _p181_status(dependency),
            "validation_latest": str(_P181Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_validation_v1" / "latest_forge_runtime_candidate_dry_plan_validation_v1.json"),
            "validation_status": _p181_status(validation),
            "sandbox_latest": str(_P181Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_sandbox_v1" / "latest_forge_runtime_candidate_dry_plan_sandbox_v1.json"),
            "sandbox_status": _p181_status(sandbox),
            "rollback_latest": str(_P181Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_rollback_v1" / "latest_forge_runtime_candidate_dry_plan_rollback_v1.json"),
            "rollback_status": _p181_status(rollback),
        },
        "any_file_boundary": {
            "future_generalization_allowed": True,
            "current_patch_accepts_arbitrary_path": False,
            "current_patch_uses_selected_candidate_only": True,
            "required_for_any_file": [
                "approved scope",
