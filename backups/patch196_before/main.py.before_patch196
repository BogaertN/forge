    """
    Approve a proposal and create a patch proposal file in
    ~/forge/proposed_patches/. After this, use the normal patch
    workflow to actually install the command.

    Usage: forge-command-approve-proposal <slug>

    What this does step by step:
      1. Marks the proposal as approved
      2. Creates a patch file in proposed_patches/ showing exactly
         what needs to be added to main.py and tool_registry.json
      3. Tells you which commands to run next
    What this does NOT do:
      - Does NOT edit main.py
      - Does NOT edit tool_registry.json
      - Does NOT run any code
      - YOU stay in control through patch-apply
    """
    from agents.forge.memory import write_audit_entry
    slug = slug.strip()
    if not slug:
        print()
        print("  Usage: forge-command-approve-proposal <slug>")
        print()
