def _p167_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19M" not in ids:
        rows.append({"id":"S19M","status":"ACTIVE","title":"Runtime Live Build Approval Capture / Execution Gate","patch":"Patch 167 — Runtime Live Build Approval Capture / Execution Gate","summary":"Capture approval state for the future live runtime build path and keep execution locked without explicit approval.","authority":"approval capture only; no live runtime writes"})
    if "S19N" not in ids:
        rows.append({"id":"S19N","status":"NEXT","title":"Runtime Live Build Approval Receipt / Execution Decision Gate","patch":"Patch 168 — Runtime Live Build Approval Receipt / Execution Decision Gate","summary":"Verify approval receipt state and decide whether live build can remain locked or advance toward a separately approved execution.","authority":"decision gate only; no implicit approval"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L"}:
            row["status"] = "DONE"
        elif rid == "S19M":
            row["status"] = "ACTIVE"
        elif rid == "S19N":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


