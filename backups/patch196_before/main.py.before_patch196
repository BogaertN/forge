    verified = _p144_verified_state()
    clean = _p144_is_state_clean(verified)
    deferred = list(base.get("deferred_items") or [])
    if not any((item.get("name") == "stack_linker_breather") for item in deferred if isinstance(item, dict)):
        deferred.append({"name": "stack_linker_breather", "reason": "Deferred and excluded from canonical lockfile after import/dependency repair loop did not close cleanly."})
    blocked = [] if clean else [{"name": "build_sequence_progression", "reason": "Final lockfile, tests, patch impact, or stack_linker_breather deferral state is not clean."}]
    next_patch = "Patch 145 — Deferred Engine Repair Queue" if clean else "Repair current Forge state before Patch 145"
    status = "FORGE_BUILD_SEQUENCE_READY" if clean else "FORGE_BUILD_SEQUENCE_BLOCKED_STATE_REPAIR_REQUIRED"
    payload = {
        "schema_version": FORGE_BUILD_SEQUENCE_SCHEMA_VERSION,
