# Purpose:
#   Create a Forge-owned sandbox lane for future Forge self-updates.
#   This patch does not apply live changes to main.py or tool_registry.json.
#   It copies a verified self-snapshot into a sandbox directory and runs safe,
#   deterministic checks against the sandbox files only.

_PATCH122_SCHEMA_VERSION = "forge_self_update_sandbox_v1_patch122"
_PATCH122_ROOT = FORGE_ROOT / "memory" / "forge_self_sandboxes_v1"
_PATCH122_PLAN_PREFIX = "forge_self_sandbox_plan_v1"
_PATCH122_REPORT_PREFIX = "forge_self_sandbox_report_v1"
_PATCH122_CLEAN_PREFIX = "forge_self_sandbox_clean_v1"
_PATCH122_EXPORT_PREFIX = "forge_self_sandbox_export_v1"
_PATCH122_MAX_SANDBOXES_TO_KEEP = 5


def _patch122_now_id() -> str:
    import datetime
    return datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch122_iso_now() -> str:
    import datetime
    return datetime.datetime.now().isoformat(timespec="seconds")


def _patch122_ensure_root() -> None:
    _PATCH122_ROOT.mkdir(parents=True, exist_ok=True)


def _patch122_sha256(path: Path) -> str | None:
    import hashlib
    try:
        if not path.exists() or not path.is_file():
            return None
        h = hashlib.sha256()
        with path.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _patch122_load_json(path: Path, default=None):
    import json
    if default is None:
        default = {}
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        pass
    return default


def _patch122_write_json_and_md(payload: dict, prefix: str) -> tuple[Path, Path]:
    import json
    _patch122_ensure_root()
    stamp = _patch122_now_id()
    json_path = _PATCH122_ROOT / f"{stamp}_{prefix}.json"
    md_path = _PATCH122_ROOT / f"{stamp}_{prefix}.md"
    latest_json = _PATCH122_ROOT / f"latest_{prefix}.json"
    latest_md = _PATCH122_ROOT / f"latest_{prefix}.md"
    text = json.dumps(payload, indent=2, sort_keys=True)
    json_path.write_text(text + "\n", encoding="utf-8")
    latest_json.write_text(text + "\n", encoding="utf-8")

    lines = [
        f"# {payload.get('report_type', prefix)}",
        "",
        f"- Status: `{payload.get('status')}`",
        f"- Created: `{payload.get('created_at')}`",
        f"- Authority: `{(payload.get('authority') or {}).get('mode', 'SANDBOX_ONLY')}`",
        "",
    ]
    if payload.get("plain_english"):
        lines.extend(["## Plain English", "", str(payload.get("plain_english")), ""])
    if payload.get("sandbox_id"):
        lines.append(f"- Sandbox ID: `{payload.get('sandbox_id')}`")
    if payload.get("sandbox_root"):
        lines.append(f"- Sandbox root: `{payload.get('sandbox_root')}`")
    if payload.get("problems"):
        lines.extend(["", "## Problems", ""])
        for problem in payload.get("problems") or []:
            lines.append(f"- {problem}")
    if payload.get("warnings"):
        lines.extend(["", "## Warnings", ""])
        for warning in payload.get("warnings") or []:
            lines.append(f"- {warning}")
    if payload.get("checks"):
        lines.extend(["", "## Checks", ""])
        for check in payload.get("checks") or []:
            if isinstance(check, dict):
                lines.append(f"- `{check.get('name')}` → `{check.get('status')}`")
    if payload.get("next_commands"):
        lines.extend(["", "## Next Commands", ""])
        for cmd in payload.get("next_commands") or []:
            lines.append(f"- `{cmd}`")
    md_text = "\n".join(lines).rstrip() + "\n"
    md_path.write_text(md_text, encoding="utf-8")
    latest_md.write_text(md_text, encoding="utf-8")
    return json_path, md_path


