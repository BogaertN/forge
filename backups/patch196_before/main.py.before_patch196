def _p178_payload() -> dict:
    dependency = _p178_dependency_report()
    scope = _p178_scope_report()
    selector = _p178_selector_report()
    candidate = (dependency.get("selected_candidate") if isinstance(dependency, dict) else None) or (scope.get("selected_candidate") if isinstance(scope, dict) else None) or (selector.get("selected_candidate") if isinstance(selector, dict) else None) or "failsafe_manager"
    matrix, summary = _p178_validation_matrix(scope, dependency)
    test_plan = _p178_test_plan(summary)
    warnings = []
    problems = []
    if not dependency:
        warnings.append("Latest Patch 177 dependency receipt is missing; run/build dependency review before relying on this validation matrix.")
    if dependency and dependency.get("status") != "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_DEPENDENCY_READY_NO_WRITE_IMPACT_NOTES":
        warnings.append(f"Patch 177 dependency status is {dependency.get('status')}; review before advancing.")
    if scope and scope.get("live_apply_allowed") is True:
        problems.append("Scope receipt unexpectedly permits live apply; validation matrix blocks advancement.")
    if dependency and dependency.get("live_apply_allowed") is True:
        problems.append("Dependency receipt unexpectedly permits live apply; validation matrix blocks advancement.")
    duplicate_count = len(summary.get("duplicate_basenames") or [])
    if duplicate_count:
        warnings.append("Duplicate basenames remain present; future file targeting must be exact path + SHA based.")
    gates = [
        {"id":"P178-G1","name":"Patch 177 dependency receipt loaded or safe warning recorded","status":"OK" if dependency else "WARN","detail":dependency.get("status", "missing") if isinstance(dependency, dict) else "missing"},
        {"id":"P178-G2","name":"Selected candidate preserved","status":"OK","detail":candidate},
        {"id":"P178-G3","name":"Validation matrix built without execution","status":"OK","detail":f"checks={len(matrix)}"},
        {"id":"P178-G4","name":"Safe-test plan is no-write/no-shell","status":"OK","detail":"executes_now=False shell_allowed=False"},
        {"id":"P178-G5","name":"Rollback and sandbox remain future gates","status":"OK","detail":"required before any live apply"},
        {"id":"P178-G6","name":"Live apply remains forbidden","status":"OK","detail":"approval token not requested; runtime/project/engine writes remain zero"},
    ]
    payload = {
        "schema_version": FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_SCHEMA_VERSION,
        "patch": "Patch 178 — Runtime Candidate Dry-Plan Validation Matrix / No-Write Test Plan",
        "status": "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_READY_NO_WRITE_TEST_PLAN" if not problems else "FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_BLOCKED_REVIEW_REQUIRED",
        "created_at": _p178_now(),
        "selected_candidate": candidate,
        "validation_matrix_ready": not problems,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "token_validation_status": "NOT_REQUESTED",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_receipt_writes_only": True,
        "candidate_file_summary": summary,
        "validation_matrix": matrix,
        "test_plan": test_plan,
        "source_report": {
            "dependency_latest": str(_P178Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_dependency_v1" / "latest_forge_runtime_candidate_dry_plan_dependency_v1.json"),
            "dependency_status": dependency.get("status") if isinstance(dependency, dict) else None,
            "scope_latest": str(_P178Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_scope_v1" / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
            "scope_status": scope.get("status") if isinstance(scope, dict) else None,
            "selector_latest": str(_P178Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_selector_v1" / "latest_forge_runtime_candidate_dry_plan_selector_v1.json"),
            "selector_status": selector.get("status") if isinstance(selector, dict) else None,
        },
        "any_file_boundary": {
            "future_generalization_allowed": True,
            "current_patch_accepts_arbitrary_path": False,
            "required_for_any_file": [
                "approved scope",
                "exact-read",
                "sha256 current-state record",
                "no-write plan",
                "sandbox rehearsal",
                "safe tests",
                "rollback copy",
                "explicit human approval token in separate live patch",
                "post-write disk verification",
            ],
        },
        "gates": gates,
        "warnings": warnings,
        "problems": problems,
        "next_patch": "Patch 179 — Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan",
        "recommended_next_patch": "Patch 179 — Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan",
    }
    payload["validation_fingerprint"] = _p178_hash_payload({k:v for k,v in payload.items() if k != "validation_fingerprint"})
    return payload


def _p178_write_json_and_md(stem: str, payload: dict):
    FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR.mkdir(parents=True, exist_ok=True)
    json_path = FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / f"{stem}.json"
    md_path = FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / f"{stem}.md"
    json_path.write_text(_p178_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines = ["# Patch 178 — Runtime Candidate Dry-Plan Validation Matrix", "", "No runtime, project, engine, shell, or test execution occurred.", ""]
    for k in ["status","selected_candidate","validation_matrix_ready","live_apply_allowed","runtime_writes","project_writes","engine_writes","next_patch"]:
        lines.append(f"- **{k}**: `{payload.get(k)}`")
    summary = payload.get("candidate_file_summary", {})
    lines.extend(["", "## Candidate File Summary", f"- files: `{summary.get('file_count')}`", f"- python files: `{summary.get('python_file_count')}`", f"- config files: `{summary.get('config_file_count')}`", f"- duplicate basenames: `{len(summary.get('duplicate_basenames') or [])}`"])
    lines.append("")
    lines.append("## Validation Matrix")
    for item in payload.get("validation_matrix", []):
        lines.append(f"- {item.get('id')} [{item.get('status')}] {item.get('name')} — {item.get('future_check')}")
    lines.append("")
    lines.append("## Gates")
    for g in payload.get("gates", []):
        lines.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')} — {g.get('detail')}")
    md_path.write_text("\n".join(lines)+"\n", encoding="utf-8")
    _p178_shutil.copyfile(json_path, FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / "latest_forge_runtime_candidate_dry_plan_validation_v1.json")
    _p178_shutil.copyfile(md_path, FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / "latest_forge_runtime_candidate_dry_plan_validation_v1.md")
    return json_path, md_path


