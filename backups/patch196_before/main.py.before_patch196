def _p145_priority(row: dict) -> tuple[int, str]:
    engine = row.get("engine_base") or ""
    bucket = row.get("disposition_bucket") or ""
    reason = "normal deferred review"
    score = 50
    if engine == "stack_linker_breather":
        return 10, "known failed canonical test removed from lockfile; repair evidence exists"
    if "runtime_wrapper" in bucket or "stack" in bucket:
        score = 30
        reason = "wrapper/stack dependency layer may affect runtime ordering"
    elif "authority" in bucket or "external" in bucket:
        score = 35
        reason = "authority/control surface requires stricter boundary review"
    elif row.get("is_hold_family"):
        score = 80
        reason = "hold family; keep archived until explicit human review"
    return score, reason


def _p145_repair_readiness(row: dict, revision_candidate: dict, revision_run: dict) -> tuple[str, list[str], str]:
    engine = row.get("engine_base") or ""
    blockers = []
    if row.get("future_lockfile_eligible"):
        blockers.append("row unexpectedly marked future_lockfile_eligible; review ledger before repair queue use")
    if row.get("review_status") != "DEFERRED":
        blockers.append("not DEFERRED; treat as excluded hold/approved hold rather than repair queue target")
    if engine == "stack_linker_breather":
        if revision_candidate and revision_candidate.get("target") == "stack_linker_breather":
            status = "REPAIR_EVIDENCE_PRESERVED_SANDBOX_REQUIRED"
            action = "Use deferred repair queue later to reopen the preserved candidate, run dependency probe, sandbox, safe tests, then human approval before any live write."
        else:
            blockers.append("no latest preserved revision candidate found")
            status = "NEEDS_REPAIR_PLAN"
            action = "Create a fresh repair plan from current disk state before any sandbox attempt."
        return status, blockers, action
    status = "NEEDS_DEPENDENCY_AND_ROLE_REVIEW"
    action = row.get("recommended_next_action") or "Map dependencies, source law, tests, and runtime role before any promotion or repair."
    return status, blockers, action


def _p145_queue_payload() -> dict:
    lock = _p145_lockfile()
    disposition = _p145_disposition()
    test = _p145_test_run()
    impact = _p145_patch_impact()
    relationship = _p145_relationship_map()
    revision_candidate = _p145_latest_revision_candidate()
    revision_run = _p145_latest_revision_run()
    sequence = _p145_latest_sequence()

    lock_counts = lock.get("counts") or {}
    test_counts = test.get("counts") or {}
    impact_summary = impact.get("summary") or {}
    disp_counts = disposition.get("counts") or {}

    source_paths = {
        "canonical_lockfile": str(MEMORY_DIR / "code_library_v1" / "manifests" / "engine_canonical_lockfile_v1.json"),
        "engine_disposition": str(MEMORY_DIR / "engine_disposition_v1" / "latest_engine_disposition_report_v1.json"),
