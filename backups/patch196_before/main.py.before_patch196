def _p178_file_rows_from_scope(scope: dict):
    fs = scope.get("file_scope", {}) if isinstance(scope, dict) else {}
    rows = fs.get("files", []) if isinstance(fs, dict) else []
    return rows if isinstance(rows, list) else []


def _p178_candidate_file_summary(scope: dict, dependency: dict):
    rows = _p178_file_rows_from_scope(scope)
    ext_counter = _p178_Counter()
    python_files = []
    json_files = []
    config_files = []
    duplicate_names = []
    name_counter = _p178_Counter()
    for row in rows:
        path = str(row.get("path") or "")
        rel = str(row.get("relative_path") or path)
        p = _P178Path(path)
        suffix = p.suffix.lower()
        name_counter[p.name] += 1
        ext_counter[suffix or "<none>"] += 1
        if suffix == ".py":
            python_files.append(rel)
        if suffix == ".json":
            json_files.append(rel)
        if suffix in {".json", ".toml", ".yaml", ".yml", ".ini", ".cfg"}:
            config_files.append(rel)
    for name, count in name_counter.items():
        if count > 1:
            duplicate_names.append({"basename": name, "count": count})
    dep_scan = dependency.get("dependency_scan", {}) if isinstance(dependency, dict) else {}
    if not rows and dep_scan:
        # Fallback summary from Patch 177 dependency scan only. This remains no-write.
        python_files = list(dep_scan.get("python_files_preview") or [])
        config_files = list(dep_scan.get("config_files_preview") or [])
        json_files = [f for f in config_files if str(f).endswith(".json")]
        duplicate_names = list(dep_scan.get("duplicate_basenames") or [])
        ext_counter.update(dep_scan.get("extension_counts") or {})
    return {
        "file_count": len(rows) if rows else int((dependency.get("dependency_scan") or {}).get("file_count") or 0),
        "python_file_count": len(python_files),
        "json_file_count": len(json_files),
        "config_file_count": len(config_files),
        "extension_counts": dict(sorted(ext_counter.items())),
        "python_files_preview": python_files[:60],
        "json_files_preview": json_files[:60],
        "config_files_preview": config_files[:60],
        "duplicate_basenames": duplicate_names,
    }


def _p178_validation_matrix(scope: dict, dependency: dict):
    summary = _p178_candidate_file_summary(scope, dependency)
    py_count = int(summary.get("python_file_count") or 0)
    json_count = int(summary.get("json_file_count") or 0)
    config_count = int(summary.get("config_file_count") or 0)
    duplicate_count = len(summary.get("duplicate_basenames") or [])
    matrix = [
        {
            "id": "VAL-001",
            "name": "scope receipt present",
            "kind": "receipt_gate",
            "future_check": "Load latest Patch 176 scope receipt before any sandbox or live apply.",
            "status": "PASS" if scope else "WARN",
            "no_write": True,
            "notes": (scope.get("status") if isinstance(scope, dict) else "missing"),
        },
        {
            "id": "VAL-002",
            "name": "dependency receipt present",
            "kind": "receipt_gate",
            "future_check": "Load latest Patch 177 dependency receipt before any sandbox or live apply.",
            "status": "PASS" if dependency else "WARN",
            "no_write": True,
            "notes": (dependency.get("status") if isinstance(dependency, dict) else "missing"),
        },
        {
            "id": "VAL-003",
            "name": "python syntax plan",
            "kind": "safe_test_plan",
            "future_check": "Use safe test runner or explicit py_compile plan for scoped Python files only; shell=False; no arbitrary command strings.",
            "status": "PLANNED" if py_count else "SKIP_NO_PYTHON_FILES",
            "no_write": True,
            "targets": summary.get("python_files_preview")[:40],
        },
        {
            "id": "VAL-004",
            "name": "json/config parse plan",
            "kind": "safe_test_plan",
            "future_check": "Parse scoped JSON/config files without modifying them; report parse failures before sandbox.",
            "status": "PLANNED" if config_count else "SKIP_NO_CONFIG_FILES",
            "no_write": True,
            "targets": summary.get("config_files_preview")[:40],
        },
        {
            "id": "VAL-005",
            "name": "duplicate basename review",
            "kind": "human_review_gate",
            "future_check": "Confirm duplicate basenames are intentional before any patch target selection.",
            "status": "WARN" if duplicate_count else "PASS",
            "no_write": True,
            "duplicate_count": duplicate_count,
            "duplicates": summary.get("duplicate_basenames")[:40],
        },
        {
            "id": "VAL-006",
            "name": "rollback matrix required",
            "kind": "rollback_gate",
            "future_check": "For every target file, capture current SHA and rollback copy before sandbox/apply.",
            "status": "REQUIRED_FUTURE_GATE",
            "no_write": True,
        },
        {
            "id": "VAL-007",
            "name": "sandbox rehearsal required",
            "kind": "sandbox_gate",
            "future_check": "Copy scoped file set into Forge-owned sandbox and run planned checks there before any live write.",
            "status": "REQUIRED_FUTURE_GATE",
            "no_write": True,
        },
        {
            "id": "VAL-008",
            "name": "live approval forbidden in this patch",
            "kind": "approval_gate",
            "future_check": "Approval token is not accepted in Patch 178; live apply remains false.",
            "status": "PASS",
            "no_write": True,
        },
    ]
    return matrix, summary


def _p178_test_plan(summary: dict):
    return {
        "plan_type": "NO_WRITE_VALIDATION_TEST_PLAN",
        "executes_now": False,
        "shell_allowed": False,
        "arbitrary_commands_allowed": False,
        "future_allowed_patterns": [
            "python3 -m py_compile <scoped_python_file> via safe runner shell=False",
            "json parse of <scoped_json_file> with Python json.load/read_text",
            "static import/dependency scan already produced by Patch 177",
