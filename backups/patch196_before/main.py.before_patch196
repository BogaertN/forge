def _p156_append_rows(rows: list[dict]) -> list[dict]:
    rows = [dict(r) for r in (rows or [])]
    known = {r.get("id") for r in rows}
    additions = [
        {
            "id": "S19B",
            "status": "ACTIVE",
            "title": "Runtime Module Dependency Map",
            "patch": "Patch 156 — Runtime Module Dependency Map",
            "summary": "Map canonical AI.Web engines into runtime dependency domains for planning only.",
            "authority": "read-only; Forge-owned reports only; no runtime writes",
        },
        {
            "id": "S19C",
            "status": "NEXT",
            "title": "Runtime Build Plan / First Safe Module Candidate",
            "patch": "Patch 157 — Runtime Build Plan / First Safe Module Candidate",
            "summary": "Select and plan the first safe AI.Web runtime module build candidate without live writes.",
            "authority": "planning only until live-apply evidence gates pass",
        },
    ]
    for row in additions:
        if row["id"] not in known:
            rows.append(row)
            known.add(row["id"])
    for row in rows:
        rid = row.get("id")
        if rid in {"S17", "S17A", "S17B", "S17C", "S18", "S18A", "S19A"}:
            row["status"] = "DONE"
        elif rid == "S19":
            row["status"] = "ACTIVE"
        elif rid == "S19B":
            row["status"] = "ACTIVE"
        elif rid == "S19C":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


