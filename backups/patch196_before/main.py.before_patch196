def _p159_markdown(payload: dict) -> str:
    lines = [f"# {payload.get('report_type', 'Patch 159 Report')}", ""]
    for key in ["status", "current_phase", "active_patch", "next_patch", "planning_ready", "live_build_ready"]:
        if key in payload:
            lines.append(f"- **{key}**: {payload.get(key)}")
    cand = payload.get("selected_candidate") or {}
    if cand:
        lines.append(f"- **candidate**: {cand.get('engine')} ({cand.get('runtime_domain')})")
    if payload.get("gates"):
        lines += ["", "## Gates"]
        for g in payload.get("gates") or []:
            lines.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')}: {g.get('detail')}")
    if payload.get("verified_files"):
        lines += ["", "## Verified dry-run files"]
        for row in payload.get("verified_files") or []:
            lines.append(f"- {row.get('name')} exists={row.get('exists')} hash_match={row.get('hash_match')} path={row.get('path')}")
    if payload.get("candidate_files"):
        lines += ["", "## Candidate future files — not created"]
        for row in payload.get("candidate_files") or []:
            lines.append(f"- {row.get('path')} action={row.get('planned_action')} created={row.get('created_by_patch_159')}")
    if payload.get("blockers"):
        lines += ["", "## Blockers"] + [f"- {x}" for x in payload.get("blockers") or []]
    if payload.get("warnings"):
        lines += ["", "## Warnings"] + [f"- {x}" for x in payload.get("warnings") or []]
    return "\n".join(lines) + "\n"


