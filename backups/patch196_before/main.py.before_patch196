def _p183_safe_candidate_name(name: str) -> str:
    clean = "".join(ch if ch.isalnum() or ch in {"_", "-"} else "_" for ch in str(name or "candidate"))
    return clean.strip("_") or "candidate"


def _p183_stage_filename(row: dict) -> str:
    planned = row.get("planned_stage_path") or ""
    expected_sha = str(row.get("source_sha256") or "")
    source_path = str(row.get("source_path") or "")
    if planned:
        name = _P183Path(planned).name
        if name:
            return name
    basename = _P183Path(source_path).name or "file"
    prefix = expected_sha[:12] if expected_sha else _p183_hashlib.sha256(source_path.encode("utf-8")).hexdigest()[:12]
    return f"{prefix}__{basename}"


def _p183_under_forge_memory(path: _P183Path) -> bool:
    try:
        root = (_P183Path.home() / "forge" / "memory").resolve()
        target = path.resolve()
        return str(target).startswith(str(root) + "/") or target == root
    except Exception:
        return False


def _p183_payload(materialize: bool = False) -> dict:
    created_at = _p183_now()
    stage_plan = _p183_load_stage_plan()
    candidate = _p183_safe_candidate_name(stage_plan.get("selected_candidate") or "failsafe_manager")
    rows = stage_plan.get("stage_manifest") if isinstance(stage_plan.get("stage_manifest"), list) else []
    stage_root = FORGE_RUNTIME_CANDIDATE_SANDBOXES_DIR / f"{candidate}_stage_{created_at}"
    blockers = []
    warnings = list(stage_plan.get("warnings") or []) if isinstance(stage_plan.get("warnings"), list) else []

    if not stage_plan:
        blockers.append("Missing latest Patch 182 sandbox-stage manifest receipt.")
    if not bool(stage_plan.get("stage_manifest_ready")):
        blockers.append("Patch 182 sandbox-stage manifest is not marked ready.")
    if not rows:
        blockers.append("Patch 182 stage manifest has no file rows.")
    if not _p183_under_forge_memory(stage_root):
        blockers.append("Planned sandbox root is not under ~/forge/memory; refusing materialization.")

    copy_results = []
    copied_count = 0
    verified_count = 0
    refused_count = 0
    sandbox_created = False

    if materialize and not blockers:
        stage_root.mkdir(parents=True, exist_ok=True)
        sandbox_created = True
        for row in rows:
            source_path = _P183Path(str(row.get("source_path") or ""))
            expected_sha = str(row.get("source_sha256") or "")
            stage_path = stage_root / _p183_stage_filename(row)
            result = {
                "source_path": str(source_path),
                "expected_source_sha256": expected_sha,
                "stage_path": str(stage_path),
                "source_sha_verified": False,
                "staged_sha_verified": False,
                "status": "REFUSED",
                "reason": "unprocessed",
            }
            try:
                if not str(source_path).startswith(str(_P183Path.home() / "aiweb") + "/"):
                    result["reason"] = "source path is outside ~/aiweb approved project root"
                    refused_count += 1
                elif not source_path.exists() or not source_path.is_file():
                    result["reason"] = "source file missing or not a regular file"
                    refused_count += 1
                else:
                    actual_source_sha = _p183_hash_file(source_path)
                    result["actual_source_sha256"] = actual_source_sha
                    result["source_size"] = source_path.stat().st_size
                    if expected_sha and actual_source_sha != expected_sha:
                        result["reason"] = "source SHA mismatch before copy; refusing"
                        refused_count += 1
                    else:
                        result["source_sha_verified"] = True
                        if not _p183_under_forge_memory(stage_path):
                            result["reason"] = "stage path is outside Forge memory; refusing"
                            refused_count += 1
                        else:
                            stage_path.parent.mkdir(parents=True, exist_ok=True)
                            _p183_shutil.copy2(source_path, stage_path)
                            staged_sha = _p183_hash_file(stage_path)
                            result["staged_sha256"] = staged_sha
                            result["staged_size"] = stage_path.stat().st_size
                            if staged_sha == actual_source_sha:
                                result["staged_sha_verified"] = True
                                result["status"] = "COPIED_AND_VERIFIED"
                                result["reason"] = "source SHA precheck and staged SHA readback passed"
                                copied_count += 1
                                verified_count += 1
                            else:
                                result["status"] = "COPIED_BUT_FAILED_VERIFY"
                                result["reason"] = "staged SHA did not match source SHA after copy"
                                refused_count += 1
            except Exception as exc:
                result["status"] = "ERROR"
                result["reason"] = f"{type(exc).__name__}: {exc}"
                refused_count += 1
            copy_results.append(result)
    else:
        for row in rows:
            copy_results.append({
                "source_path": row.get("source_path"),
                "expected_source_sha256": row.get("source_sha256"),
                "stage_path": str(stage_root / _p183_stage_filename(row)),
                "status": "PLANNED_ONLY" if not blockers else "BLOCKED",
                "source_sha_verified": False,
                "staged_sha_verified": False,
                "reason": "materialize=False" if not blockers else "; ".join(blockers),
            })

    all_copied = bool(rows) and copied_count == len(rows) and verified_count == len(rows) and refused_count == 0
    if materialize and not all_copied and not blockers:
        blockers.append("One or more sandbox copy rows failed exact SHA copy/readback verification.")

    status = "FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_CREATE_READY_FORGE_OWNED_COPY_VERIFIED" if all_copied else "FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_CREATE_BLOCKED_OR_INCOMPLETE"
    gates = [
        {"id": "P183-G1", "name": "Patch 182 stage manifest loaded", "status": "PASS" if stage_plan else "BLOCKED", "detail": str(FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_PLAN_DIR / "latest_forge_runtime_candidate_sandbox_stage_v1.json")},
        {"id": "P183-G2", "name": "Stage manifest ready", "status": "PASS" if bool(stage_plan.get("stage_manifest_ready")) else "BLOCKED", "detail": str(stage_plan.get("status"))},
        {"id": "P183-G3", "name": "Exact path/SHA rows available", "status": "PASS" if bool(rows) else "BLOCKED", "detail": f"rows={len(rows)}"},
        {"id": "P183-G4", "name": "Sandbox root is Forge-owned", "status": "PASS" if _p183_under_forge_memory(stage_root) else "BLOCKED", "detail": str(stage_root)},
        {"id": "P183-G5", "name": "Source SHA precheck passed for every copied row", "status": "PASS" if all_copied else "PENDING_OR_BLOCKED", "detail": f"copied={copied_count} verified={verified_count} refused={refused_count}"},
        {"id": "P183-G6", "name": "No live/project/engine writes", "status": "PASS", "detail": "runtime_writes=0 project_writes=0 engine_writes=0"},
    ]
    payload = {
        "schema_version": "forge_runtime_candidate_sandbox_stage_create_v1.patch183",
        "patch": "Patch 183 — Runtime Candidate Sandbox Stage Create/Verify / Forge-Owned Copy Only",
        "created_at": created_at,
        "status": status,
        "selected_candidate": candidate,
        "source_stage_status": stage_plan.get("status"),
        "sandbox_root": str(stage_root),
        "sandbox_created": sandbox_created,
        "sandbox_copy_allowed_now": True,
        "sandbox_copy_executed": bool(materialize and sandbox_created),
        "sandbox_execution_allowed": False,
        "test_execution_allowed": False,
        "backup_creation_allowed": False,
        "restore_execution_allowed": False,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_sandbox_writes_only": bool(materialize and sandbox_created),
        "sandbox_file_writes": copied_count,
        "receipt_writes": 2 if materialize else 0,
        "file_count": len(rows),
        "copied_count": copied_count,
        "verified_count": verified_count,
        "refused_count": refused_count,
        "copy_results": copy_results,
        "copy_integrity_ready": all_copied,
        "stage_manifest_fingerprint": stage_plan.get("stage_manifest_fingerprint"),
        "source_report": {
            "stage_plan_latest": str(FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_PLAN_DIR / "latest_forge_runtime_candidate_sandbox_stage_v1.json"),
            "stage_plan_status": stage_plan.get("status"),
            "stage_plan_file_count": len(rows),
        },
        "any_file_boundary": {
            "general_any_file_support": "future_only",
            "allowed_now": False,
            "selected_candidate_only": True,
            "rule": "This command materializes only the selected runtime candidate from a prior exact-path/SHA stage manifest. General file support requires approved scope, current SHA, sandbox, tests, rollback, explicit approval, and post-write verification.",
        },
        "gates": gates,
        "warnings": warnings,
        "blockers": blockers,
        "next_patch": "Patch 184 — Runtime Candidate Sandbox Copy Integrity Review / No-Write Readback Receipt",
        "recommended_next_patch": "Patch 184 — Runtime Candidate Sandbox Copy Integrity Review / No-Write Readback Receipt",
    }
    payload["payload_fingerprint"] = _p183_hashlib.sha256(_p183_json.dumps({k: v for k, v in payload.items() if k != "payload_fingerprint"}, sort_keys=True, default=str).encode("utf-8")).hexdigest()
