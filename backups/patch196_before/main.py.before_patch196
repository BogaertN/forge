FORGE_DEFERRED_ENGINE_QUEUE_SCHEMA_VERSION = "forge_deferred_engine_repair_queue_v1_patch145"
FORGE_DEFERRED_ENGINE_QUEUE_DIR = MEMORY_DIR / "forge_deferred_engine_repair_queue_v1"
FORGE_DEFERRED_ENGINE_QUEUE_STEM = "forge_deferred_engine_repair_queue_v1"
FORGE_DEFERRED_ENGINE_QUEUE_EXPORT_STEM = "forge_deferred_engine_repair_queue_export_v1"

PATCH145_COMMANDS = [
    "forge-deferred-engine-queue-policy",
    "forge-deferred-engine-queue-build",
    "forge-deferred-engine-queue-show",
    "forge-deferred-engine-queue-list",
    "forge-deferred-engine-queue-next",
    "forge-deferred-engine-queue-export",
]

for _patch145_cmd in PATCH145_COMMANDS:
    if _patch145_cmd not in FORGE_EXPECTED_COMMANDS:
        FORGE_EXPECTED_COMMANDS.append(_patch145_cmd)


def _p145_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p145_stamp() -> str:
    return _p145_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p145_ensure_dir() -> None:
    FORGE_DEFERRED_ENGINE_QUEUE_DIR.mkdir(parents=True, exist_ok=True)


def _p145_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p145_sha256_path(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p145_write(payload: dict, stem: str):
    _p145_ensure_dir()
    stamp = _p145_stamp()
    json_path = FORGE_DEFERRED_ENGINE_QUEUE_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_DEFERRED_ENGINE_QUEUE_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "next_patch", "queue_total", "repair_ready_count", "repair_blocked_count"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("verified_state"):
        md.append("")
        md.append("## Verified State")
        for k, v in (payload.get("verified_state") or {}).items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("queue"):
        md.append("")
        md.append("## Deferred Engine Queue")
        for row in payload.get("queue") or []:
            md.append(f"- **{row.get('engine_base')}** — `{row.get('queue_status')}` — priority `{row.get('priority')}` — {row.get('recommended_next_action')}")
    if payload.get("next_repair_target"):
        md.append("")
        md.append("## Next Repair Target")
        target = payload.get("next_repair_target") or {}
        md.append(f"- **engine_base**: `{target.get('engine_base')}`")
        md.append(f"- **safe_next_action**: {target.get('safe_next_action')}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_DEFERRED_ENGINE_QUEUE_DIR / f"latest_{stem}.json"
    latest_md = FORGE_DEFERRED_ENGINE_QUEUE_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


