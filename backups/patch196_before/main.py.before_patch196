def _p149_verify_payload(payload: dict) -> dict:
    problems = []
    warnings = []
    if not payload:
        problems.append("missing proposal payload")
    authority = payload.get("authority") or {}
    false_flags = [
        "project_file_write_authority",
        "engine_file_write_authority",
        "forge_self_write_authority",
        "patch_apply_authority",
        "shell_execution_authority",
        "ledger_mutation_authority",
        "chroma_write_authority",
        "network_or_server_start_authority",
        "source_authority_claimed_automatically",
    ]
    for key in false_flags:
        if authority.get(key) is not False:
            problems.append(f"authority flag must be false: {key}")
    if authority.get("requires_human_approval") is not True:
        problems.append("requires_human_approval must be true")
    if (payload.get("source_evidence") or {}).get("source_authority_claimed") is not False:
        problems.append("source authority must remain candidate-only")
    for row in payload.get("target_files") or []:
        if row.get("under_forge_root") is not True:
            problems.append(f"target file outside Forge root: {row.get('path')}")
        if row.get("exists") is not True:
            warnings.append(f"target file missing: {row.get('path')}")
        if row.get("sha256") is None:
            warnings.append(f"target sha missing: {row.get('path')}")
    ev = ((payload.get("source_evidence") or {}).get("evidence_summary") or {})
    if ev.get("canonical_included") != 54:
        problems.append("canonical included count must be 54 before Patch 150 planning")
    if ev.get("latest_test_fail") not in (0, None):
        problems.append("canonical test failures must be zero")
    if ev.get("build_gate_fail") not in (0, None):
        problems.append("build phase gate failures must be zero")
    if ev.get("source_authority_status") != "FORGE_SOURCE_AUTHORITY_HARDENING_READY":
        warnings.append("source authority hardening is not fresh/ready")
    if ev.get("source_authority_gaps"):
        warnings.append(f"source-authority gaps remain candidate-only: {ev.get('source_authority_gaps')}")
    if ev.get("repair_ready"):
        warnings.append(f"deferred repair targets remain visible: {ev.get('repair_ready')}")
    status = "FORGE_LLM_PATCH_PROPOSAL_V2_VERIFIED_READ_ONLY" if not problems else "FORGE_LLM_PATCH_PROPOSAL_V2_VERIFICATION_FAILED"
    return {
        "schema_version": "forge_llm_patch_proposal_v2_verify_patch149",
        "report_type": "FORGE_LLM_PATCH_PROPOSAL_V2_VERIFY",
        "created_at": _p149_now(),
        "status": status,
        "active_patch": "Patch 149 — LLM Patch Proposal v2",
        "target": payload.get("target"),
        "proposal_status": payload.get("status"),
        "proposal_sha256": _p149_sha256(_p149_latest_proposal_path()) if _p149_latest_proposal_path() else None,
        "problems": problems,
        "warnings": warnings,
        "problem_count": len(problems),
        "warning_count": len(warnings),
        "next_patch": "Patch 150 — Live Apply Eligibility Gate v2",
        "recommended_next_patch": "Patch 150 — Live Apply Eligibility Gate v2",
        "authority": {"verification_only": True, "project_file_write_authority": False, "engine_file_write_authority": False, "patch_apply_authority": False, "shell_execution_authority": False},
        "summary": {"problems": len(problems), "warnings": len(warnings), "write_authority": False, "target": payload.get("target")},
    }


