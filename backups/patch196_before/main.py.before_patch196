def _patch123_now() -> str:
    return datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch123_iso_now() -> str:
    return datetime.datetime.now().isoformat(timespec="seconds")


def _patch123_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch123_write_json_md(payload: dict, prefix: str):
    CANONICAL_TESTS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch123_now()
    json_path = CANONICAL_TESTS_DIR / f"{stamp}_{prefix}.json"
    md_path = CANONICAL_TESTS_DIR / f"{stamp}_{prefix}.md"
    text = json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False)
    json_path.write_text(text + "\n", encoding="utf-8")
    md = _patch123_markdown(payload)
    md_path.write_text(md, encoding="utf-8")
    (CANONICAL_TESTS_DIR / f"latest_{prefix}.json").write_text(text + "\n", encoding="utf-8")
    (CANONICAL_TESTS_DIR / f"latest_{prefix}.md").write_text(md, encoding="utf-8")
    return json_path, md_path


def _patch123_markdown(payload: dict) -> str:
    lines = []
    lines.append(f"# {payload.get('report_type', 'CANONICAL_ENGINE_TESTS')}\n")
    lines.append(f"Status: `{payload.get('status', 'UNKNOWN')}`\n")
    if payload.get("plain_english"):
        lines.append(payload.get("plain_english") + "\n")
    counts = payload.get("counts") or {}
    if counts:
        lines.append("## Counts")
        for k, v in counts.items():
            lines.append(f"- {k}: {v}")
        lines.append("")
    if payload.get("rows"):
        lines.append("## Rows")
        for row in payload.get("rows", []):
            lines.append(f"### {row.get('engine_base')}")
            lines.append(f"- canonical_path: `{row.get('canonical_path')}`")
            lines.append(f"- resolved_path: `{row.get('resolved_path')}`")
            lines.append(f"- path_exists: {row.get('path_exists')}")
            lines.append(f"- test_files_found: {len(row.get('test_files') or [])}")
            lines.append(f"- safe_test_candidates: {len(row.get('safe_test_candidates') or [])}")
            lines.append(f"- status: `{row.get('test_inventory_status')}`")
            if row.get("warnings"):
                lines.append("- warnings:")
                for w in row.get("warnings") or []:
                    lines.append(f"  - {w}")
            lines.append("")
    if payload.get("gaps"):
        lines.append("## Gaps")
        for gap in payload.get("gaps", []):
            lines.append(f"- {gap.get('engine_base')}: {gap.get('reason')}")
        lines.append("")
    lines.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- {k}: {v}")
    lines.append("")
    return "\n".join(lines)


def _patch123_load_final_lockfile() -> dict:
    path = CODE_MANIFESTS_DIR / "engine_canonical_lockfile_v1.json"
    if not path.exists():
        return {"_missing": True, "_path": str(path)}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        data["_path"] = str(path)
        data["_sha256"] = _patch123_sha256(path)
        return data
    except Exception as exc:
        return {"_error": str(exc), "_path": str(path)}


def _patch123_resolve_canonical_path(canonical_path: str) -> Path | None:
    if not canonical_path:
        return None
    raw = canonical_path.strip()
    candidates = []
    p = Path(raw).expanduser()
    if p.is_absolute():
        candidates.append(p)
    home = FORGE_ROOT.parent
    if raw.startswith("aiweb/"):
        candidates.append(home / raw)
        candidates.append(home / "aiweb" / raw[len("aiweb/"):])
    else:
        candidates.append(home / raw)
        candidates.append(home / "aiweb" / raw)
    # Remove duplicates while preserving order.
    seen = set()
    unique = []
    for c in candidates:
        s = str(c)
        if s not in seen:
            unique.append(c)
            seen.add(s)
    for c in unique:
        if c.exists():
            return c
    return unique[0] if unique else None


def _patch123_is_probable_test(path: Path) -> bool:
    name = path.name.lower()
    if not name.endswith(".py"):
        return False
    return name.startswith("test_") or name.endswith("_test.py") or "test" in name


def _patch123_scan_test_file(path: Path) -> dict:
    row = {
        "path": str(path),
        "relative_name": path.name,
        "exists": path.exists(),
        "readable": False,
        "sha256": None,
        "banned_tokens": [],
        "safe_candidate": False,
        "reason": None,
    }
    if not path.exists() or not path.is_file():
        row["reason"] = "missing_or_not_file"
        return row
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
        row["readable"] = True
        row["sha256"] = _patch123_sha256(path)
        hits = [tok for tok in _PATCH123_BANNED_TEST_TOKENS if tok in text]
        row["banned_tokens"] = hits
        if hits:
            row["safe_candidate"] = False
            row["reason"] = "contains_disallowed_or_high_risk_tokens"
        else:
            row["safe_candidate"] = True
            row["reason"] = "python_test_file_no_banned_tokens_detected"
    except Exception as exc:
        row["reason"] = f"read_failed: {exc}"
    return row


def _patch123_inventory_rows() -> dict:
    lock = _patch123_load_final_lockfile()
    problems = []
    if lock.get("_missing"):
        problems.append("engine_canonical_lockfile_v1.json missing")
    if lock.get("_error"):
        problems.append(f"engine_canonical_lockfile_v1.json unreadable: {lock.get('_error')}")
    rows = []
    gaps = []
    entries = lock.get("canonical_entries") or []
    for entry in entries:
        engine = entry.get("engine_base") or "UNKNOWN"
        canonical_path = entry.get("canonical_path") or ""
        resolved = _patch123_resolve_canonical_path(canonical_path)
        warnings = []
        test_rows = []
        safe = []
        py_files = []
        if resolved and resolved.exists() and resolved.is_dir():
            try:
                for p in sorted(resolved.rglob("*.py")):
                    rel_parts = set(p.relative_to(resolved).parts)
                    if "__pycache__" in rel_parts or ".venv" in rel_parts or "node_modules" in rel_parts:
                        continue
                    py_files.append(str(p))
                    if _patch123_is_probable_test(p):
                        tr = _patch123_scan_test_file(p)
                        test_rows.append(tr)
                        if tr.get("safe_candidate"):
                            safe.append(tr)
            except Exception as exc:
                warnings.append(f"scan_failed: {exc}")
        elif resolved and resolved.exists() and resolved.is_file():
            if resolved.suffix == ".py":
                py_files.append(str(resolved))
                if _patch123_is_probable_test(resolved):
                    tr = _patch123_scan_test_file(resolved)
                    test_rows.append(tr)
                    if tr.get("safe_candidate"):
                        safe.append(tr)
        else:
            warnings.append("canonical_path_did_not_resolve_on_disk")
        if not test_rows:
            status = "NO_TEST_FILES_FOUND"
            gaps.append({"engine_base": engine, "reason": "no test-like Python files found", "canonical_path": canonical_path, "resolved_path": str(resolved) if resolved else None})
        elif not safe:
            status = "TEST_FILES_FOUND_BUT_NONE_MARKED_SAFE"
            gaps.append({"engine_base": engine, "reason": "test files found but banned/high-risk tokens or read failures were detected", "canonical_path": canonical_path, "resolved_path": str(resolved) if resolved else None})
        else:
            status = "SAFE_TEST_CANDIDATE_FOUND"
        rows.append({
            "engine_base": engine,
            "canonical_path": canonical_path,
            "resolved_path": str(resolved) if resolved else None,
            "path_exists": bool(resolved and resolved.exists()),
            "is_dir": bool(resolved and resolved.exists() and resolved.is_dir()),
            "python_file_count": len(py_files),
            "test_files": test_rows,
            "safe_test_candidates": safe,
            "test_inventory_status": status,
            "warnings": warnings,
            "lockfile_index": entry.get("index"),
            "review_status": entry.get("review_status"),
        })
    counts = {
        "canonical_entries": len(entries),
        "rows": len(rows),
        "paths_resolved": sum(1 for r in rows if r.get("path_exists")),
        "engines_with_test_files": sum(1 for r in rows if r.get("test_files")),
        "engines_with_safe_test_candidates": sum(1 for r in rows if r.get("safe_test_candidates")),
        "engines_without_test_files": sum(1 for r in rows if r.get("test_inventory_status") == "NO_TEST_FILES_FOUND"),
        "engines_with_tests_but_no_safe_candidate": sum(1 for r in rows if r.get("test_inventory_status") == "TEST_FILES_FOUND_BUT_NONE_MARKED_SAFE"),
        "gaps": len(gaps),
    }
    return {"lockfile": lock, "rows": rows, "gaps": gaps, "counts": counts, "problems": problems}


