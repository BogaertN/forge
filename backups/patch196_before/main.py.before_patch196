def _p168_planned_files_from_sources():
    capture = _p168_latest_json("forge_runtime_live_approval_capture_v1/latest_forge_runtime_live_approval_capture_v1.json", {})
    execution = _p168_latest_json("forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json", {})
    final_gate = _p168_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    files = []
    for src_name, payload in [("approval_capture", capture), ("execution_plan", execution), ("final_gate", final_gate)]:
        for row in payload.get("planned_files", []) or []:
            if isinstance(row, dict):
                r = dict(row)
                r["source"] = r.get("source") or src_name
                files.append(r)
        if files:
            break
    normalized = []
    seen = set()
    for row in files:
        rel = row.get("relative_path") or row.get("target_relative_path") or row.get("runtime_relative_path") or row.get("path") or row.get("file")
        if not rel:
            continue
        rel = str(rel)
        if rel in seen:
            continue
        seen.add(rel)
        normalized.append({
            "relative_path": rel,
            "target_relative_path": row.get("target_relative_path") or rel,
            "source": row.get("source") or "runtime_live_decision",
            "sandbox_source": row.get("sandbox_source") or row.get("source_path") or row.get("source") or "candidate_sandbox",
            "live_write_planned_now": False,
        })
    return normalized


def _p168_payload() -> dict:
    capture = _p168_latest_json("forge_runtime_live_approval_capture_v1/latest_forge_runtime_live_approval_capture_v1.json", {})
