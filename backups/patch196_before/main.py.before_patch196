        })
    ready_count = sum(1 for r in rows if r.get("source_law_chunk_ready"))
    blocker_count = sum(len(r.get("blockers", [])) for r in rows)
    not_ready = len(rows) - ready_count
    if rows and ready_count == len(rows):
        overall = "SOURCE_LAW_CHUNKS_RETRIEVABLE_READY_FOR_LLM_REVIEW"
        route = "PATCH98_LLM_ENGINE_REVIEW_DRAFT_GENERATOR_WITH_GATEWAY_INIT"
    elif blocker_count:
