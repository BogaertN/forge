    for k in ["status","selected_candidate","sandbox_preflight_ready","future_sandbox_stage_candidate","sandbox_creation_allowed","sandbox_execution_allowed","test_execution_allowed","live_apply_allowed","runtime_writes","project_writes","engine_writes","next_patch"]:
