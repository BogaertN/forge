def _p153_write_report(payload: dict, stem: str):
    _p153_ensure_dirs()
    stamp = _p153_stamp()
    json_path = FORGE_SHADOW_RESTORE_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_SHADOW_RESTORE_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "snapshot_id", "shadow_id", "snapshot_root", "shadow_root", "file_count", "copied_file_count", "verified_file_count", "problem_count", "live_restore_authority"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("summary"):
        md.append("")
        md.append("## Summary")
        for k, v in (payload.get("summary") or {}).items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("domains"):
        md.append("")
        md.append("## Domains")
        for domain in payload.get("domains") or []:
            md.append(f"- **{domain.get('domain_id')}** — {domain.get('title')}: files=`{domain.get('file_count')}` problems=`{len(domain.get('problems') or [])}`")
    if payload.get("problems"):
        md.append("")
        md.append("## Problems")
        for problem in payload.get("problems") or []:
            md.append(f"- `{problem}`")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_SHADOW_RESTORE_DIR / f"latest_{stem}.json"
    latest_md = FORGE_SHADOW_RESTORE_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


