def _p144_sequence_payload() -> dict:
    queue = _p145_latest_queue()
    base_verified = {}
    if queue:
        base_verified = dict(queue.get("verified_state") or {})
    else:
        # Build a transient queue state for display without forcing a write.
        base_verified = dict((_p145_queue_payload().get("verified_state") or {}))

    queue_status = queue.get("status") if queue else "NOT_BUILT_YET"
    queue_total = queue.get("queue_total") if queue else None
    repair_ready = queue.get("repair_ready_count") if queue else None
    next_repair_target = (queue.get("next_repair_target") or {}).get("engine_base") if queue else None

