            row["status"] = "NEXT"
            row["title"] = "Snapshot / forensic replay"
            row["purpose"] = "Project-state snapshots, shadow restore, diffs, and replay before multi-file writes."
        elif rid in {"S17", "S18", "S19", "S20"} and row.get("status") == "NEXT":
            row["status"] = "READY"
