def _p156_markdown(payload: dict) -> str:
    lines = [
        "# Forge Runtime Module Dependency Map v1",
        "",
        f"- Status: {payload.get('status')}",
        f"- Current phase: {payload.get('current_phase')}",
        f"- Next patch: {payload.get('next_patch')}",
        f"- Planning ready: {payload.get('planning_ready')}",
        f"- Live build ready: {payload.get('live_build_ready')}",
        f"- Canonical engines mapped: {payload.get('canonical_engine_count')}",
        f"- Runtime domains: {payload.get('domain_count')}",
        "",
        "## Domain Summary",
    ]
    for row in payload.get("domain_summary") or []:
        lines.append(f"- {row.get('domain')}: total={row.get('total')} p1={row.get('p1_core')} p2={row.get('p2_supporting_core')} p3={row.get('p3_interface_or_extension')}")
    lines.append("")
    lines.append("## Blockers / Locks")
    blockers = payload.get("blockers") or []
    if not blockers:
        lines.append("- No planning blockers recorded.")
    else:
        for b in blockers:
            lines.append(f"- {b.get('id')} [{b.get('type')}] {b.get('summary')}")
    lines.append("")
    lines.append("## Dependency Rows")
    for row in (payload.get("dependency_rows") or [])[:80]:
        lines.append(f"- {row.get('engine')} | {row.get('runtime_domain')} | {row.get('priority')} | {row.get('source_authority_status')}")
    return "\n".join(lines) + "\n"


