def _p179_file_rows(scope: dict):
    fs = scope.get("file_scope", {}) if isinstance(scope, dict) else {}
    rows = fs.get("files", []) if isinstance(fs, dict) else []
    return rows if isinstance(rows, list) else []


def _p179_candidate_summary(validation: dict, scope: dict, dependency: dict):
    from collections import Counter as _p179_Counter
    rows = _p179_file_rows(scope)
    validation_summary = validation.get("candidate_file_summary", {}) if isinstance(validation, dict) else {}
    dep_scan = dependency.get("dependency_scan", {}) if isinstance(dependency, dict) else {}
    base = validation_summary or dep_scan or {}
    ext_counter = _p179_Counter()
    duplicate_basenames = list(base.get("duplicate_basenames") or [])
    if rows:
        name_counter = _p179_Counter()
        py = 0
        cfg = 0
        js = 0
        for row in rows:
            p = _P179Path(str(row.get("path") or row.get("relative_path") or ""))
            suffix = p.suffix.lower()
            name_counter[p.name] += 1
            ext_counter[suffix or "<none>"] += 1
            if suffix == ".py":
                py += 1
            if suffix == ".json":
                js += 1
            if suffix in {".json", ".toml", ".yaml", ".yml", ".ini", ".cfg"}:
                cfg += 1
        duplicate_basenames = [{"basename": n, "count": c} for n, c in name_counter.items() if c > 1]
        return {
            "file_count": len(rows),
            "python_file_count": py,
            "json_file_count": js,
            "config_file_count": cfg,
            "extension_counts": dict(sorted(ext_counter.items())),
            "duplicate_basenames": duplicate_basenames,
            "exact_sha_rows_present": all(bool(r.get("sha256")) for r in rows),
            "rows_preview": rows[:40],
        }
    return {
        "file_count": int(base.get("file_count") or 0),
        "python_file_count": int(base.get("python_file_count") or 0),
        "json_file_count": int(base.get("json_file_count") or 0),
        "config_file_count": int(base.get("config_file_count") or 0),
        "extension_counts": dict(base.get("extension_counts") or {}),
        "duplicate_basenames": duplicate_basenames,
        "exact_sha_rows_present": False,
        "rows_preview": [],
    }


