def _patch124_now() -> str:
    return datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch124_iso_now() -> str:
    return datetime.datetime.now().isoformat(timespec="seconds")


def _patch124_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _patch124_write_json_md(payload: dict, prefix: str):
    CANONICAL_TEST_RUNS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = _patch124_now()
    json_path = CANONICAL_TEST_RUNS_DIR / f"{stamp}_{prefix}.json"
    md_path = CANONICAL_TEST_RUNS_DIR / f"{stamp}_{prefix}.md"
    text = json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False)
    json_path.write_text(text + "\n", encoding="utf-8")
    md = _patch124_markdown(payload)
    md_path.write_text(md, encoding="utf-8")
    (CANONICAL_TEST_RUNS_DIR / f"latest_{prefix}.json").write_text(text + "\n", encoding="utf-8")
    (CANONICAL_TEST_RUNS_DIR / f"latest_{prefix}.md").write_text(md, encoding="utf-8")
    return json_path, md_path


def _patch124_markdown(payload: dict) -> str:
    lines = [f"# {payload.get('report_type', 'CANONICAL_ENGINE_TEST_RUNS')}\n"]
    lines.append(f"Status: `{payload.get('status', 'UNKNOWN')}`\n")
    if payload.get("plain_english"):
        lines.append(payload.get("plain_english") + "\n")
    counts = payload.get("counts") or {}
    if counts:
        lines.append("## Counts")
        for k, v in counts.items():
            lines.append(f"- {k}: {v}")
        lines.append("")
    if payload.get("targets"):
        lines.append("## Targets")
        for t in payload.get("targets", []):
            lines.append(f"- {t.get('engine_base')} :: `{t.get('test_path')}` :: {t.get('planned_command')}")
        lines.append("")
    if payload.get("results"):
        lines.append("## Results")
        for r in payload.get("results", []):
            lines.append(f"- {r.get('engine_base')} :: {r.get('status')} :: rc={r.get('returncode')} :: `{r.get('test_path')}`")
        lines.append("")
    if payload.get("problems"):
        lines.append("## Problems")
        for p in payload.get("problems", []):
            lines.append(f"- {p}")
        lines.append("")
    lines.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- {k}: {v}")
    lines.append("")
    return "\n".join(lines)


