def _p174_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19T" not in ids:
        rows.append({"id":"S19T","status":"ACTIVE","title":"Runtime Candidate Queue Review / Next Candidate Selection","patch":"Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection","summary":"Review the held runtime candidate queue and defer any next live selection into dry planning only.","authority":"queue review only; no live writes"})
    if "S19U" not in ids:
        rows.append({"id":"S19U","status":"NEXT","title":"Runtime Candidate Dry-Plan Selector / No-Write Planning Gate","patch":"Patch 175 — Runtime Candidate Dry-Plan Selector / No-Write Planning Gate","summary":"Select or preserve the next runtime candidate for dry planning only, with no approval, execution, or live writes.","authority":"dry-plan selector only; no runtime writes"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R","S19S"}:
            row["status"] = "DONE"
        elif rid == "S19T":
            row["status"] = "ACTIVE"
        elif rid == "S19U":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


