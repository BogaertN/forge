        rows.append({"id":"S19Y","status":"ACTIVE","title":"Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan","patch":"Patch 179 — Runtime Candidate Dry-Plan Sandbox Readiness / No-Write Rehearsal Plan","summary":"Plan a Forge-owned sandbox rehearsal for the selected runtime candidate without creating a sandbox or executing tests.","authority":"sandbox planning only; no runtime writes"})
