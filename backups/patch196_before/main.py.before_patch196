def _p135_find_row(report: dict, target: str) -> dict:
    rows = report.get("rows") or []
    target_s = str(target or "").lower()
    for row in rows:
        hay = " ".join(str(row.get(k, "")) for k in ("engine_base", "engine", "engine_name", "canonical_path", "target", "resolved_path_guess")).lower()
        if target_s and target_s in hay:
            return row
    return {}


def _p135_parse_error_locations(stderr_tail: str) -> list[dict]:
    locations = []
    text = stderr_tail or ""
    for m in _p135_re.finditer(r'File "([^"]+)", line (\d+)', text):
        locations.append({"path": m.group(1), "line": int(m.group(2))})
    return locations


def _p135_snippet(path, line: int | None = None, radius: int = 12, max_chars: int = 6000) -> dict:
    p = _P135Path(path)
    info = {"path": str(p), "exists": p.exists(), "scope_ok": False, "sha256": None, "line_start": None, "line_end": None, "text": ""}
    if not p.exists() or not p.is_file():
        return info
    # Code snippets may come from AI.Web source or Forge memory evidence only.
    scope_ok = _p135_under(p, _P135Path("/home/nic/aiweb")) or _p135_under(p, FORGE_ROOT / "memory")
    info["scope_ok"] = bool(scope_ok)
    if not scope_ok:
        return info
    info["sha256"] = _p135_sha(p)
    try:
        lines = p.read_text(encoding="utf-8", errors="replace").splitlines()
        if line is None:
            start, end = 1, min(len(lines), 80)
        else:
            start = max(1, int(line) - radius)
            end = min(len(lines), int(line) + radius)
        body = []
        for i in range(start, end + 1):
            body.append(f"{i:04d}: {lines[i-1]}")
        text = "\n".join(body)
        if len(text) > max_chars:
            text = text[:max_chars] + "\n...TRUNCATED_BY_FORGE..."
        info.update({"line_start": start, "line_end": end, "text": text})
    except Exception as exc:
        info["text"] = f"SNIPPET_READ_ERROR: {exc}"
    return info


def _p135_source_doc_samples(row: dict, limit: int = 3) -> list[dict]:
    samples = []
    for doc in (row.get("candidate_source_documents") or [])[:limit]:
        p = _P135Path(str(doc.get("path") or ""))
        sample = {"metadata": doc, "snippet": "", "snippet_scope_ok": False}
        if p.exists() and p.is_file() and _p135_under(p, FORGE_ROOT / "memory"):
            sample["snippet_scope_ok"] = True
            try:
                text = p.read_text(encoding="utf-8", errors="replace")[:2500]
                sample["snippet"] = text
            except Exception as exc:
                sample["snippet"] = f"SOURCE_SNIPPET_READ_ERROR: {exc}"
        samples.append(sample)
    return samples


def _p135_build_evidence_packet(arg: str) -> dict:
    probe = _p135_latest_import_probe()
    target = (arg or "latest").strip()
    if target == "latest":
        target = probe.get("target") or probe.get("target_engine") or "unknown"
    resolved = probe.get("resolved_target") or {}
    target_path = resolved.get("target_path")
    stderr_tail = probe.get("stderr_tail") or ""
    error_locations = _p135_parse_error_locations(stderr_tail)
    snippets = []
    for loc in error_locations[:3]:
        snippets.append(_p135_snippet(loc.get("path"), loc.get("line")))
    for test_path in (resolved.get("test_candidates") or [])[:3]:
        if not any(s.get("path") == test_path for s in snippets):
            snippets.append(_p135_snippet(test_path, None, max_chars=5000))
    if target_path and _P135Path(target_path).is_dir():
        # Include a small directory listing and obvious core files if they exist.
        for name in ("stack_linker_core.py", "__init__.py", "main.py"):
            p = _P135Path(target_path) / name
            if p.exists() and not any(s.get("path") == str(p) for s in snippets):
                snippets.append(_p135_snippet(p, None, max_chars=5000))
    source_map = _p135_latest_json_from("engine_source_authority_v1", "latest_engine_source_law_map_v1.json")
    impact_map = _p135_latest_json_from("patch_impact_v1", "latest_patch_impact_map_v1.json")
    relationship_map = _p135_latest_json_from("canonical_engine_relationships_v1", "latest_canonical_engine_relationship_map_v1.json")
    test_report = _p135_latest_json_from("canonical_engine_test_runs_v1", "latest_canonical_engine_test_run_report_v1.json")
    source_row = _p135_find_row(source_map, target)
    impact_row = _p135_find_row(impact_map, target)
    relationship_row = _p135_find_row(relationship_map, target)
    inferred_issue = "UNKNOWN"
    if "SyntaxError" in stderr_tail:
        inferred_issue = "PYTHON_SYNTAX_ERROR"
    elif "ModuleNotFoundError" in stderr_tail:
        inferred_issue = "PYTHON_IMPORT_PATH_OR_PACKAGE_ERROR"
    elif probe.get("probe_passed") is True:
        inferred_issue = "NO_CURRENT_IMPORT_PROBE_FAILURE"
    problems = []
    if not probe:
        problems.append("latest import probe result is missing")
    if probe and probe.get("probe_passed") is True:
        problems.append("latest import probe passed; repair may not be needed")
    if target == "unknown":
        problems.append("target could not be inferred")
    payload = {
        "schema_version": "generic_repair_evidence_packet_v1_patch135",
        "report_type": "GENERIC_REPAIR_EVIDENCE_PACKET_V1",
        "created_at": _p135_now(),
        "status": "GENERIC_REPAIR_EVIDENCE_PACKET_READY" if not problems else "GENERIC_REPAIR_EVIDENCE_PACKET_READY_WITH_WARNINGS",
        "target": target,
        "inferred_issue": inferred_issue,
        "plain_english": "Generic repair evidence packet compiled from the latest import probe, code snippets, source-authority candidates, impact/risk map, relationship map, and test run data. This does not edit files or apply patches.",
        "import_probe": probe,
        "error_locations": error_locations,
        "code_context_snippets": snippets[:8],
        "source_authority_row": source_row,
        "source_document_samples": _p135_source_doc_samples(source_row),
        "patch_impact_row": impact_row,
        "relationship_row": relationship_row,
        "latest_test_report_summary": test_report.get("summary", {}),
        "problems": problems,
        "authority": {
            "read_only": True,
            "llm_call_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "ledger_mutation_authority": False,
            "shell_execution_authority": False,
            "writes_forge_memory_only": True,
        },
        "next_commands": [f"generic-repair-llm latest {GENERIC_REPAIR_CONFIRM}", "generic-repair-show llm", "generic-repair-export"],
        "recommendation": "Call the local LLM with the confirm token to draft a repair proposal from this compiled evidence. Do not apply any repair yet.",
    }
    return payload


def _p135_prompt(packet: dict) -> str:
    """Build a focused, repair-first prompt for the local LLM.

    Patch 135S correction:
    The first Patch 135 prompt serialized the whole evidence packet. That proved the
    LLM plumbing worked, but it let the model over-focus on source/corpus metadata.
    This prompt keeps source authority present but makes the actual failing code,
    stderr, and minimal repair task the center of gravity.
    """
    target = packet.get("target") or "unknown"
    inferred_issue = packet.get("inferred_issue") or "UNKNOWN"
    probe = packet.get("import_probe") or {}
    stderr_tail = probe.get("stderr_tail") or ""
    error_locations = packet.get("error_locations") or []
    snippets = packet.get("code_context_snippets") or []
    impact = packet.get("patch_impact_row") or {}
    relationship = packet.get("relationship_row") or {}
    source_row = packet.get("source_authority_row") or {}
    source_samples = packet.get("source_document_samples") or []

    def _clip(value, limit=5000):
        text = str(value or "")
        return text[:limit] + ("\n...CLIPPED_BY_FORGE..." if len(text) > limit else "")

    focused_snippets = []
    for snip in snippets[:5]:
        focused_snippets.append({
            "path": snip.get("path"),
            "line_start": snip.get("line_start"),
            "line_end": snip.get("line_end"),
            "sha256": snip.get("sha256"),
            "text": _clip(snip.get("text"), 7000),
        })

    source_summary = {
        "source_authority_status": source_row.get("source_authority_status"),
        "required_source_domains": source_row.get("required_source_domains"),
        "candidate_source_document_count": len(source_row.get("candidate_source_documents") or []),
        "candidate_source_samples": [
            {
                "title": s.get("title") or s.get("filename") or s.get("source") or s.get("path"),
                "authority": s.get("authority") or s.get("authority_class") or s.get("document_authority"),
            }
            for s in (source_samples or [])[:5]
        ],
    }

    focused = {
        "task": "Produce a minimal repair proposal for the probed Python failure. Do not apply it.",
        "target": target,
        "inferred_issue": inferred_issue,
        "direct_failure_stderr": _clip(stderr_tail, 5000),
        "error_locations": error_locations[:5],
        "code_context_snippets": focused_snippets,
        "impact_summary": {
            "risk_level": impact.get("risk_level"),
            "risk_score": impact.get("risk_score"),
            "test_status": impact.get("test_status"),
            "latest_failures": impact.get("latest_failures"),
            "rollback_needs": impact.get("rollback_needs"),
            "related_files": impact.get("related_files"),
        },
        "relationship_summary": {
            "risk_level": relationship.get("risk_level"),
            "test_status": relationship.get("test_status"),
            "neighbors": relationship.get("neighbors"),
            "python_files": relationship.get("python_files"),
        },
        "source_authority_summary": source_summary,
        "hard_constraints": {
            "do_not_edit_files": True,
            "do_not_claim_applied": True,
            "do_not_broaden_scope": True,
            "do_not_discuss_chroma_or_ingestion_unless_directly_relevant_to_the_code_failure": True,
            "prefer_smallest_syntax_or_import_fix": True,
            "must_name_exact_file_and_line_region": True,
            "must_include_tests_to_rerun": True,
            "must_include_uncertainties": True,
        },
    }

    raw = _p135_json.dumps(focused, indent=2, ensure_ascii=False, sort_keys=True)
    if len(raw) > 18000:
        raw = raw[:18000] + "\n...TRUNCATED_BY_FORGE_FOR_PROMPT_BOUND..."

    return (
        "You are Forge's local code repair proposal LLM.\n"
        "CRITICAL: Respond with JSON only. No markdown. No prose introduction. No hidden thinking transcript.\n"
        "You are NOT applying a patch. You are proposing the smallest safe repair.\n"
        "Focus on the direct Python failure, stderr, and code snippets below.\n"
        "Do NOT explain Chroma, ingestion receipts, corpus chunks, or unrelated metadata unless it directly affects the failing code.\n"
        "Use only the evidence below. Do not invent files, functions, source authority, or test results.\n\n"
        "Return exactly this JSON object shape:\n"
        "{\n"
        "  \"diagnosis\": \"\",\n"
        "  \"root_cause\": \"\",\n"
        "  \"minimal_repair_strategy\": \"\",\n"
        "  \"proposed_file_changes\": [\n"
        "    {\"path\": \"\", \"exact_region\": \"\", \"reason\": \"\", \"proposed_edit_summary\": \"\"}\n"
        "  ],\n"
        "  \"files_to_inspect_before_apply\": [],\n"
        "  \"tests_to_run_after_change\": [],\n"
        "  \"rollback_plan\": [],\n"
        "  \"risk_level\": \"LOW|MEDIUM|HIGH\",\n"
        "  \"uncertainties\": [],\n"
        "  \"evidence_used\": [],\n"
        "  \"human_approval_questions\": [],\n"
        "  \"forbidden_actions\": []\n"
        "}\n\n"
        "FOCUSED_EVIDENCE:\n" + raw
    )

