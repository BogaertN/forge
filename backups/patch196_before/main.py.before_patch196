def _patch116_now() -> str:
    return datetime.datetime.now().strftime("%Y-%m-%d_%H%M%S")


def _patch116_iso_now() -> str:
    return datetime.datetime.now().isoformat(timespec="seconds")


def _patch116_sha256(path: Path | str | None) -> str | None:
    if not path:
        return None
    try:
        p = Path(path)
        h = hashlib.sha256()
        with p.open("rb") as f:
            for block in iter(lambda: f.read(1024 * 1024), b""):
                h.update(block)
        return h.hexdigest()
    except Exception:
        return None


def _patch116_load_json(path: Path | str | None) -> dict | None:
    if not path:
        return None
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
