def _p169_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19O" not in ids:
        rows.append({"id":"S19O","status":"ACTIVE","title":"Runtime Live Build Human Approval Token Entry Gate","patch":"Patch 169 — Runtime Live Build Human Approval Token Entry Gate","summary":"Prepare the explicit human approval token-entry gate while performing zero live writes.","authority":"approval template only; no runtime writes"})
    if "S19P" not in ids:
        rows.append({"id":"S19P","status":"NEXT","title":"Runtime Live Build Approval Token Validation / Final Execution Preflight","patch":"Patch 170 — Runtime Live Build Approval Token Validation / Final Execution Preflight","summary":"Validate whether any explicit approval token has been captured before live execution can proceed.","authority":"validation gate only; no implicit approval"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N"}:
            row["status"] = "DONE"
