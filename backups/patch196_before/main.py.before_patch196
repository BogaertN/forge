def _patch98_infer_role(engine_family: str, binder: dict) -> tuple[str, str]:
    fam = (engine_family or "").lower()
    role_map = [
        ("phase", "phase_logic"),
        ("christping", "christping_correction"),
        ("drift", "drift_collapse"),
        ("memory", "memory_persistence"),
        ("cold", "spc_cold_storage"),
        ("capacitor", "spc_cold_storage"),
        ("resurrection", "loop_resurrection"),
        ("loop", "loop_resurrection"),
        ("policy", "policy_failsafe"),
        ("failsafe", "policy_failsafe"),
        ("log", "ledger_provenance"),
        ("ledger", "ledger_provenance"),
        ("control", "ui_control_panel"),
        ("dashboard", "ui_control_panel"),
        ("agent", "agent_kernel"),
        ("kernel", "agent_kernel"),
        ("tone", "agent_interface"),
        ("plugin", "plugin_runtime"),
    ]
    for key, role in role_map:
        if key in fam:
            return role, f"Inferred from engine family keyword `{key}` plus bound code evidence."
    rel = binder.get("relationship_category_counts") or {}
    if rel:
        top = sorted(rel.items(), key=lambda kv: kv[1], reverse=True)[0]
        return f"relationship:{top[0]}", "Inferred from Patch 79 relationship category counts."
    return "unclassified_runtime_component", "No strong role keyword found; requires human/LLM review."



def _patch98_strip_model_thinking(raw: str) -> tuple[str, bool]:
    """
    Remove model reasoning wrappers from local model output.

    Qwen/Ollama may emit visible scratchpad text in one of two forms:
      - <think>...</think>
      - Thinking... ...done thinking.

    Forge must not store that reasoning. It keeps only the visible review beginning
    at the required public headings when present.
    """
    import re
    text = str(raw or "")
    had_think = False

    # Strip XML-style reasoning blocks.
    if re.search(r"<think>.*?</think>", text, flags=re.I | re.S):
        had_think = True
        text = re.sub(r"<think>.*?</think>", "\n", text, flags=re.I | re.S)

    # Strip Qwen visible scratchpad form: Thinking... ...done thinking.
    if re.search(r"(^|\n)\s*Thinking\.\.\.", text, flags=re.I):
        had_think = True
        text = re.sub(
            r"(^|\n)\s*Thinking\.\.\..*?\.\.\.done thinking\.\s*",
            "\n",
            text,
            flags=re.I | re.S,
        )

    # If the model still included analysis before the required public section,
    # keep only the public review from the first required heading onward.
    heading_match = re.search(r"(?im)^\s*Plain-English Purpose\s*:", text)
    if heading_match:
        if heading_match.start() > 0 and text[:heading_match.start()].strip():
            had_think = True
        text = text[heading_match.start():]

    visible = text.strip()
    return visible[:12000], had_think


def _patch98_engine_review_prompt(engine_family: str, binder: dict, source_report: dict) -> str:
    """Build the bounded prompt for the local Ollama model from already-bound evidence only."""
    files = binder.get("file_evidence") or []
    file_blocks = []
    for f in files[:6]:
        file_blocks.append({
            "path": f.get("path") or f.get("file_path") or f.get("resolved_path"),
            "sha256": f.get("sha256") or f.get("file_sha256"),
            "functions_sample": (f.get("functions_sample") or [])[:20],
            "classes_sample": (f.get("classes_sample") or [])[:20],
            "imports_sample": (f.get("imports_sample") or [])[:20],
            "excerpt_start": (f.get("excerpt_start") or "")[:1200],
        })
    payload = {
        "engine_family": engine_family,
        "candidate_path": binder.get("candidate_path_resolved"),
        "review_status": binder.get("review_status"),
        "evidence_id": binder.get("evidence_id"),
        "evidence_binder_sha256": binder.get("_sha256"),
        "file_count": binder.get("file_count"),
        "source_law_status": source_report.get("overall_status"),
        "source_law_counts": source_report.get("counts"),
        "file_evidence_samples": file_blocks,
    }
    import json
    evidence_json = json.dumps(payload, indent=2, sort_keys=True)
    return (
        "You are Forge's local LLM review layer for AI.Web engine canonical review.\\n"
        "Use ONLY the bound evidence below. Do not invent files, source authority, or runtime facts.\\n"
        "Do not claim canonical authority. Nic must approve later.\\n"
        "Do not include hidden chain-of-thought. Give a concise but useful review.\\n\\n"
        "Return plain text with these exact section headings:\\n"
        "Plain-English Purpose:\\n"
        "Likely System Role:\\n"
        "Evidence Used:\\n"
        "Risks / Uncertainties:\\n"
        "Recommendation Draft:\\n"
        "Suggested Nic Action:\\n\\n"
        "Bound evidence JSON:\\n"
        f"{evidence_json}\\n"
    )


def _patch98_call_local_llm_for_review(engine_family: str, binder: dict, source_report: dict) -> dict:
    """Call local Ollama for the review text. Falls back safely if unavailable; never grants authority."""
    import subprocess, time, hashlib
    prompt = _patch98_engine_review_prompt(engine_family, binder, source_report)
    prompt_sha = hashlib.sha256(prompt.encode("utf-8")).hexdigest()
    started = time.time()
    result = {
        "provider": "ollama",
        "model": LLM_ENGINE_REVIEW_MODEL_NAME,
        "timeout_seconds": LLM_ENGINE_REVIEW_MODEL_TIMEOUT_SECONDS,
        "prompt_sha256": prompt_sha,
        "called": False,
        "status": "NOT_CALLED",
        "elapsed_seconds": None,
        "raw_contains_think_block": False,
        "hidden_reasoning_stored": False,
        "visible_response": "",
        "error": None,
    }
    try:
        completed = subprocess.run(
            ["ollama", "run", LLM_ENGINE_REVIEW_MODEL_NAME, prompt],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=LLM_ENGINE_REVIEW_MODEL_TIMEOUT_SECONDS,
        )
        result["called"] = True
        result["elapsed_seconds"] = round(time.time() - started, 3)
        if completed.returncode != 0:
            result["status"] = "OLLAMA_RETURNED_ERROR_FALLBACK_USED"
            result["error"] = (completed.stderr or completed.stdout or "").strip()[:2000]
            return result
        visible, had_think = _patch98_strip_model_thinking(completed.stdout)
        result["raw_contains_think_block"] = had_think
        result["visible_response"] = visible
        result["status"] = "OLLAMA_VISIBLE_REVIEW_READY" if visible else "OLLAMA_EMPTY_RESPONSE_FALLBACK_USED"
        return result
    except FileNotFoundError as exc:
        result["elapsed_seconds"] = round(time.time() - started, 3)
        result["status"] = "OLLAMA_NOT_FOUND_FALLBACK_USED"
        result["error"] = str(exc)
        return result
    except subprocess.TimeoutExpired:
        result["called"] = True
        result["elapsed_seconds"] = round(time.time() - started, 3)
        result["status"] = "OLLAMA_TIMEOUT_FALLBACK_USED"
        result["error"] = f"Timed out after {LLM_ENGINE_REVIEW_MODEL_TIMEOUT_SECONDS}s"
        return result
    except Exception as exc:
        result["elapsed_seconds"] = round(time.time() - started, 3)
        result["status"] = "OLLAMA_EXCEPTION_FALLBACK_USED"
        result["error"] = repr(exc)[:2000]
        return result


def _patch98_fallback_review_text(engine_family: str, brief: dict, binder: dict) -> str:
    """Deterministic fallback text when local LLM is unavailable."""
    funcs = ", ".join(brief.get("functions_sample") or []) or "none recorded"
    imports = ", ".join(brief.get("imports_sample") or []) or "none recorded"
    return (
        "Plain-English Purpose:\\n"
        f"{brief.get('plain_english_purpose')}\\n\\n"
        "Likely System Role:\\n"
        f"{brief.get('likely_system_role')} — {brief.get('role_reason')}\\n\\n"
        "Evidence Used:\\n"
        f"Evidence ID {binder.get('evidence_id')} at {binder.get('candidate_path_resolved')}. "
        f"Function samples: {funcs}. Import samples: {imports}.\\n\\n"
        "Risks / Uncertainties:\\n"
        "This is deterministic fallback text because the local LLM did not return a usable review. "
        "Do not treat it as a true model-authored recommendation.\\n\\n"
        "Recommendation Draft:\\n"
        f"{brief.get('recommendation')} with confidence {brief.get('confidence')}.\\n\\n"
        "Suggested Nic Action:\\n"
        f"{brief.get('suggested_nic_action')}\\n"
    )


def _patch98_build_plain_brief(engine_family: str, binder: dict, source_report: dict) -> dict:
    files = binder.get("file_evidence") or []
    funcs = []
    imports = []
    classes = []
    excerpts = []
    for f in files[:8]:
        funcs.extend(f.get("functions_sample") or [])
        imports.extend(f.get("imports_sample") or [])
        classes.extend(f.get("classes_sample") or [])
        ex = (f.get("excerpt_start") or "").strip().splitlines()
        if ex:
            excerpts.append(" ".join(ex[:2])[:300])
    role, role_reason = _patch98_infer_role(engine_family, binder)
    status = binder.get("review_status") or "UNKNOWN"
    blockers = list(binder.get("blockers") or [])
    warnings = list(binder.get("warnings") or [])
    if not files:
        blockers.append("Evidence binder contains no file evidence.")
    recommendation = "DEFER_FOR_HUMAN_REVIEW"
    confidence = "MEDIUM" if files and not blockers else "LOW"
    if status in {"approved", "APPROVED", "HUMAN_APPROVED"}:
        recommendation = "KEEP_APPROVED_REVIEW_STATUS"
    elif status and "defer" in status.lower():
        recommendation = "DEFER_PENDING_COMPARISON"
    elif files and len(files) >= 1 and not blockers:
        recommendation = "DRAFT_APPROVE_CANDIDATE_AFTER_HUMAN_REVIEW"
    return {
        "plain_english_purpose": f"`{engine_family}` appears to be a local AI.Web engine/component. The bound source evidence includes {len(files)} readable file(s), with samples of functions/imports that should be reviewed against source-law context before any canonical decision.",
        "likely_system_role": role,
        "role_reason": role_reason,
        "functions_sample": sorted(set(funcs))[:20],
        "classes_sample": sorted(set(classes))[:20],
        "imports_sample": sorted(set(imports))[:20],
        "source_excerpt_samples": excerpts[:4],
        "recommendation": recommendation,
        "confidence": confidence,
        "risk_notes": warnings[:10] + blockers[:10],
        "suggested_nic_action": "Read this brief, compare with the evidence ID, then later approve/defer/reject through the human review queue. Do not treat this draft as canonical authority.",
        "source_law_basis": {
            "status": source_report.get("overall_status"),
            "ready_targets": (source_report.get("counts") or {}).get("ready_retrievable_with_chunks"),
            "total_targets": (source_report.get("counts") or {}).get("targets"),
            "report_path": source_report.get("_path"),
            "report_sha256": source_report.get("_sha256"),
        },
    }


def _patch98_make_draft(engine_family: str) -> dict:
    gateway_ok, gateway_msg = _patch98_gateway_ready()
    source_ok, source_report, source_blockers = _patch98_source_law_ready()
    binder, binder_err = _patch98_find_evidence_binder(engine_family)
    blockers = []
    if not gateway_ok:
        blockers.append(gateway_msg)
    if not source_ok:
        blockers.extend(source_blockers)
    if not binder:
        blockers.append(binder_err)
    elif not binder.get("ready_for_llm_brief"):
        blockers.append("Evidence binder is not marked ready_for_llm_brief.")
    now = _patch98_now()
    draft_id = f"LER-{_patch98_slug(engine_family, 32)}-{now}"
    if blockers:
        return {
            "schema_version": LLM_ENGINE_REVIEW_SCHEMA_VERSION,
            "report_type": "LLM_ENGINE_REVIEW_DRAFT_REFUSED_V1_PATCH98",
            "created_at": now,
            "draft_id": draft_id,
            "engine_family": engine_family,
            "status": "REFUSED_NOT_READY_FOR_LLM_ENGINE_REVIEW_DRAFT",
            "blockers": blockers,
            "warnings": [],
            "authority": _patch98_authority(),
        }
    brief = _patch98_build_plain_brief(engine_family, binder, source_report)
    print()
    print(f"[forge] LLM inference requested for {engine_family}.")
    print(f"[forge] Local model: {LLM_ENGINE_REVIEW_MODEL_NAME} via Ollama.")
    print("[forge] Thinking locally now. Hidden model reasoning will be stripped; only the visible review is stored.")
    llm_invocation = _patch98_call_local_llm_for_review(engine_family, binder, source_report)
    if llm_invocation.get("visible_response"):
        llm_review_text = llm_invocation.get("visible_response")
    else:
        llm_review_text = _patch98_fallback_review_text(engine_family, brief, binder)
    return {
        "schema_version": LLM_ENGINE_REVIEW_SCHEMA_VERSION,
        "report_type": "LLM_ENGINE_REVIEW_DRAFT_V1_PATCH98_2_REAL_LOCAL_LLM_ATTEMPT",
        "created_at": now,
        "draft_id": draft_id,
        "engine_family": engine_family,
        "status": "LLM_ENGINE_REVIEW_DRAFT_READY_FOR_HUMAN_REVIEW_NO_AUTHORITY",
        "gateway_policy_path": str(LLM_ENGINE_REVIEW_GATEWAY_POLICY_PATH),
        "gateway_policy_sha256": _patch98_sha256(LLM_ENGINE_REVIEW_GATEWAY_POLICY_PATH),
        "evidence_id": binder.get("evidence_id"),
        "evidence_binder_path": binder.get("_path"),
        "evidence_binder_sha256": binder.get("_sha256"),
        "candidate_path_resolved": binder.get("candidate_path_resolved"),
        "candidate_path_recorded": binder.get("candidate_path_recorded"),
        "candidate_path_sha_basis": binder.get("candidate_path_sha_basis"),
        "file_count": binder.get("file_count"),
        "review_status_at_draft_time": binder.get("review_status"),
        "plain_english_brief": brief,
        "llm_invocation": llm_invocation,
        "llm_visible_review_text": llm_review_text,
        "stale_evidence_rule": "Patch 100 must re-read candidate path and re-verify current SHA against this evidence binder before committing any canonical decision. If changed: REFUSED_STALE_ENGINE_EVIDENCE.",
        "blockers": [],
        "warnings": binder.get("warnings", []),
        "authority": _patch98_authority(),
    }


def _patch98_write_draft(draft: dict) -> tuple[Path, Path]:
    LLM_ENGINE_REVIEW_DIR.mkdir(parents=True, exist_ok=True)
    engine = draft.get("engine_family") or "unknown"
    safe = _patch98_slug(engine)
    now = draft.get("created_at") or _patch98_now()
    json_path = LLM_ENGINE_REVIEW_DIR / f"{now}_{safe}_{LLM_ENGINE_REVIEW_DRAFT_PREFIX}.json"
    md_path = LLM_ENGINE_REVIEW_DIR / f"{now}_{safe}_{LLM_ENGINE_REVIEW_DRAFT_PREFIX}.md"
    _patch98_write_json(json_path, draft)
    lines = [
        "# Patch 98 LLM Engine Review Draft",
        "",
        f"Engine: `{engine}`",
        f"Status: `{draft.get('status')}`",
        f"Draft ID: `{draft.get('draft_id')}`",
        "",
    ]
    if draft.get("blockers"):
        lines.append("## Blockers")
        for b in draft.get("blockers", []):
            lines.append(f"- {b}")
    else:
        brief = draft.get("plain_english_brief") or {}
        llm_info = draft.get("llm_invocation") or {}
        lines.extend([
            "## Local LLM Invocation",
            f"Provider: `{llm_info.get('provider', 'unknown')}`",
            f"Model: `{llm_info.get('model', 'unknown')}`",
            f"Status: `{llm_info.get('status', 'unknown')}`",
            f"Called: `{llm_info.get('called')}`",
            f"Elapsed seconds: `{llm_info.get('elapsed_seconds')}`",
            f"Hidden model reasoning stored: `{llm_info.get('hidden_reasoning_stored')}`",
            "",
            "## Local LLM Visible Review",
            draft.get("llm_visible_review_text", ""),
            "",
            "## Deterministic Evidence Summary",
            "### Plain-English Purpose",
            brief.get("plain_english_purpose", ""),
            "",
            "### Likely System Role",
            f"`{brief.get('likely_system_role')}` — {brief.get('role_reason')}",
            "",
            "### Recommendation",
            f"`{brief.get('recommendation')}` with confidence `{brief.get('confidence')}`",
            "",
            "### Evidence",
            f"Evidence ID: `{draft.get('evidence_id')}`",
            f"Evidence binder SHA: `{draft.get('evidence_binder_sha256')}`",
            f"Candidate path: `{draft.get('candidate_path_resolved')}`",
            "",
            "### Function Samples",
        ])
        for fn in brief.get("functions_sample", [])[:15]:
            lines.append(f"- `{fn}`")
        lines.extend(["", "## Suggested Nic Action", brief.get("suggested_nic_action", "")])
    md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    latest = LLM_ENGINE_REVIEW_DIR / f"latest_{safe}_llm_engine_review_draft.json"
    latest_md = LLM_ENGINE_REVIEW_DIR / f"latest_{safe}_llm_engine_review_draft.md"
    latest.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    (LLM_ENGINE_REVIEW_DIR / "latest_llm_engine_review_draft.json").write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


