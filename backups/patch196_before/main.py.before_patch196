def _p133_now():
    return _p133_datetime.datetime.now().replace(microsecond=0).isoformat()


def _p133_stamp():
    return _p133_datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p133_load(path):
    try:
        p=_p133_Path(path)
        if p.exists():
            return _p133_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return {}


def _p133_sha(path):
    try:
        p=_p133_Path(path)
        if not p.exists() or not p.is_file():
            return None
        h=_p133_hashlib.sha256()
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024*1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p133_write(payload, stem):
    PATCH_LIVE_READINESS_DIR.mkdir(parents=True, exist_ok=True)
    ts=_p133_stamp()
    jp=PATCH_LIVE_READINESS_DIR / f"{ts}_{stem}.json"
    mp=PATCH_LIVE_READINESS_DIR / f"{ts}_{stem}.md"
    latest_j=PATCH_LIVE_READINESS_DIR / f"latest_{stem}.json"
    latest_m=PATCH_LIVE_READINESS_DIR / f"latest_{stem}.md"
    jp.write_text(_p133_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    lines=[f"# {payload.get('report_type', stem)}", "", f"Status: {payload.get('status')}", f"Created: {payload.get('created_at')}"]
    if payload.get("target"): lines.append(f"Target: {payload.get('target')}")
    if payload.get("eligible_for_live_apply") is not None: lines.append(f"Eligible for live apply: {payload.get('eligible_for_live_apply')}")
    if payload.get("summary"):
        lines.append(""); lines.append("## Summary")
        for k,v in (payload.get("summary") or {}).items(): lines.append(f"- {k}: {v}")
    if payload.get("gates"):
        lines.append(""); lines.append("## Gates")
        for g in payload.get("gates") or []:
            lines.append(f"- {g.get('gate')}: {g.get('status')} — {g.get('reason')}")
    if payload.get("problems"):
        lines.append(""); lines.append("## Problems")
        for x in payload.get("problems") or []: lines.append(f"- {x}")
    mp.write_text("\n".join(lines)+"\n", encoding="utf-8")
    latest_j.write_text(jp.read_text(encoding="utf-8"), encoding="utf-8")
    latest_m.write_text(mp.read_text(encoding="utf-8"), encoding="utf-8")
    return jp, mp


def _p133_exists_rel(path):
    try:
        p=_p133_Path(path)
        return p.exists()
    except Exception:
        return False


def _p133_under(path, root):
    try:
        return _p133_Path(path).resolve().is_relative_to(_p133_Path(root).resolve())
    except Exception:
        return False


def _p133_gate(name, ok, reason, evidence=None, blocking=True):
    return {"gate": name, "status": "PASS" if ok else ("FAIL" if blocking else "WARN"), "pass": bool(ok), "blocking": bool(blocking), "reason": reason, "evidence": evidence or {}}


