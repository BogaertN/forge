def cmd_generic_repair_sandbox_run(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    parts = (arg or "").split()
    if P137_CONFIRM not in parts:
        payload = {"schema_version": P137_SCHEMA_VERSION, "report_type": "GENERIC_REPAIR_SANDBOX_REFUSAL_V1", "created_at": _p137_now(), "status": "GENERIC_REPAIR_SANDBOX_REFUSED_MISSING_CONFIRM_TOKEN", "required_token": P137_CONFIRM, "authority": {"sandbox_copy_authority": False, "model_generation_called": False, "project_file_write_authority": False}}
        jp, _ = _p137_write(payload, "generic_repair_sandbox_refusal_v1")
        print("\n[forge] Refused. Missing confirmation token:", P137_CONFIRM)
        write_audit_entry(session_id, "GENERIC_REPAIR_SANDBOX_REFUSED", str(jp), "missing_confirm_token", "no_sandbox_no_llm")
        return
    plan = _p137_latest_plan()
    problems = list(plan.get("problems") or [])
    if plan.get("status") != "GENERIC_REPAIR_SANDBOX_PLAN_READY":
        problems.append("latest_plan_not_ready")
    target_file = Path(plan.get("target_file") or "")
    candidate_file = Path(plan.get("candidate_file_path") or "")
    test_file = Path(plan.get("test_file") or "") if plan.get("test_file") else None
    sandbox_root = Path(plan.get("sandbox_root") or (P137_DIR / f"sandbox_{_p137_safe_stamp()}"))
    target = str(plan.get("target") or target_file.parent.name)
    sandbox_package_parent = Path(plan.get("sandbox_package_parent") or (sandbox_root / "sandbox_packages"))
    sandbox_engine = Path(plan.get("sandbox_package_dir") or (sandbox_package_parent / target))
    if problems:
        payload = {"schema_version": P137_SCHEMA_VERSION, "report_type": "GENERIC_REPAIR_SANDBOX_RUN_V1", "created_at": _p137_now(), "status": "GENERIC_REPAIR_SANDBOX_BLOCKED", "problems": problems, "authority": {"project_file_write_authority": False}}
        jp, _ = _p137_write(payload, "generic_repair_sandbox_run_v1")
        print("\n[forge] Sandbox blocked:", problems)
        write_audit_entry(session_id, "GENERIC_REPAIR_SANDBOX_BLOCKED", str(jp), "blocked", ",".join(problems))
        return
    import shutil, sys, os
    # Build sandbox copy of target engine directory in package shape:
    #   sandbox_root/sandbox_packages/<engine_name>/...
    # This prevents tests from importing the live /home/nic/aiweb/engines/<engine_name> copy.
    if sandbox_root.exists():
        shutil.rmtree(sandbox_root)
    sandbox_package_parent.mkdir(parents=True, exist_ok=True)
    engine_src = target_file.parent
    shutil.copytree(engine_src, sandbox_engine)
    rel_target = target_file.name
    sandbox_target = sandbox_engine / rel_target
    sandbox_target.write_text(candidate_file.read_text(encoding="utf-8"), encoding="utf-8")
    compile_result = _p137_run_cmd([sys.executable, "-m", "py_compile", str(sandbox_target)], cwd=sandbox_engine, timeout=60)
    test_result = None
    sandbox_test = None
    if test_file and test_file.exists():
        try:
            rel_test = test_file.resolve().relative_to(engine_src.resolve())
            sandbox_test = sandbox_engine / rel_test
        except Exception:
            sandbox_test = sandbox_engine / test_file.name
        env = {"PYTHONPATH": os.pathsep.join([str(sandbox_package_parent), str(sandbox_root), "/home/nic/aiweb"])}
        test_result = _p137_run_cmd([sys.executable, str(sandbox_test)], cwd=sandbox_engine, env=env, timeout=90)
    compile_pass = compile_result.get("returncode") == 0 and not compile_result.get("timeout")
    test_pass = (test_result is not None and test_result.get("returncode") == 0 and not test_result.get("timeout"))
    test_stderr = (test_result or {}).get("stderr", "") if test_result else ""
    live_import_leak_detected = f"/home/nic/aiweb/engines/{target}/" in test_stderr
    sandbox_status = "GENERIC_REPAIR_SANDBOX_TESTS_PASS" if compile_pass and test_pass and not live_import_leak_detected else "GENERIC_REPAIR_SANDBOX_TESTS_ISSUES"
    prompt = f"""You are the local Forge repair-review LLM. Review the sandbox execution result only.

TARGET: {plan.get('target')}
TARGET_FILE: {plan.get('target_file')}
CANDIDATE_DIFF_PATH: {plan.get('diff_path')}
SANDBOX_TARGET: {sandbox_target}
SANDBOX_PACKAGE_PARENT: {sandbox_package_parent}
IMPORT_ISOLATION_MODE: sandbox_package_parent_first_no_live_engine_path
LIVE_IMPORT_LEAK_DETECTED: {live_import_leak_detected}

COMPILE_RESULT:
returncode={compile_result.get('returncode')}
timeout={compile_result.get('timeout')}
stderr:
{compile_result.get('stderr')}
stdout:
{compile_result.get('stdout')}

TEST_RESULT:
{json.dumps(test_result, indent=2)[:7000] if test_result else 'NO_TEST_FILE_FOUND'}

RULES:
- Do not propose live writes.
- If sandbox compile and test pass, say APPROVE_SANDBOX_RESULT and list the exact live test to rerun after approval.
- If sandbox fails, say REVISE_CANDIDATE and explain the next minimal repair needed.
- Focus only on this target and these outputs.
- Do not discuss Chroma, ingestion receipts, vector DBs, or unrelated source documents.

Respond in this exact shape:
RECOMMENDATION: APPROVE_SANDBOX_RESULT or REVISE_CANDIDATE or REJECT_CANDIDATE
WHY: one or two sentences
NEXT_TESTS: paths/commands in plain text
NEXT_REPAIR_IF_NEEDED: plain text or NONE
"""
    llm = _p137_call_llm(prompt, str(plan.get("target") or "target"), session_id)
    payload = {
        "schema_version": P137_SCHEMA_VERSION,
        "report_type": "GENERIC_REPAIR_SANDBOX_RUN_V1",
        "created_at": _p137_now(),
        "status": sandbox_status,
        "target": plan.get("target"),
        "target_file": plan.get("target_file"),
        "sandbox_root": str(sandbox_root),
        "sandbox_package_parent": str(sandbox_package_parent),
        "sandbox_package_dir": str(sandbox_engine),
        "sandbox_target_file": str(sandbox_target),
        "sandbox_target_sha256": _p137_sha(sandbox_target),
        "compile_result": compile_result,
        "test_file": str(test_file) if test_file else None,
        "sandbox_test_file": str(sandbox_test) if sandbox_test else None,
        "test_result": test_result,
        "test_status": "PASS" if test_pass and not live_import_leak_detected else "ISSUES_OR_NOT_RUN",
        "import_isolation": {"mode": "sandbox_package_parent_first_no_live_engine_path", "live_import_leak_detected": live_import_leak_detected, "pythonpath": [str(sandbox_package_parent), str(sandbox_root), "/home/nic/aiweb"]},
        "llm_review": llm,
