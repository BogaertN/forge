def _p159_verify_payload() -> dict:
    plan = _p159_latest_plan()
    dry = _p159_latest_dry_run()
    candidate = dry.get("selected_candidate") or plan.get("selected_candidate") or {}
    files = _p159_verified_files(dry)
    gates = []
    def add(gid, name, status, detail):
        gates.append({"id": gid, "name": name, "status": status, "detail": detail})
    add("V01", "Runtime sandbox plan exists", "PASS" if plan.get("status") == "FORGE_RUNTIME_BUILD_SANDBOX_PLAN_READY" else "FAIL", plan.get("status") or "missing")
    add("V02", "Runtime sandbox dry-run exists", "PASS" if dry.get("status") == "FORGE_RUNTIME_BUILD_SANDBOX_DRY_RUN_READY" else "FAIL", dry.get("status") or "missing")
    add("V03", "Selected candidate preserved", "PASS" if candidate.get("engine") else "FAIL", candidate.get("engine") or "missing")
    zero = dry.get("project_files_written") == 0 and dry.get("engine_files_written") == 0 and dry.get("runtime_files_written") == 0
    add("V04", "Dry-run performed no project/engine/runtime writes", "PASS" if zero else "FAIL", f"project={dry.get('project_files_written')} engine={dry.get('engine_files_written')} runtime={dry.get('runtime_files_written')}")
    expected = dry.get("created_file_count")
    actual = len(dry.get("created_files") or [])
    add("V05", "Dry-run file count matches receipt", "PASS" if expected == actual and actual > 0 else "FAIL", f"expected={expected} actual={actual}")
    ok = bool(files) and all(r.get("exists") and r.get("hash_match") for r in files)
    add("V06", "Dry-run file hashes verify from disk", "PASS" if ok else "FAIL", f"verified={sum(1 for r in files if r.get('hash_match'))}/{len(files)}")
    source_status = str(candidate.get("source_authority_status") or "UNKNOWN")
    add("V07", "Source authority finality recorded", "PASS" if source_status in {"FINAL", "BOUND_FINAL", "VERIFIED_FINAL"} else "WARN", source_status)
    add("V08", "Live build authority remains locked", "PASS" if not candidate.get("live_write_authority") and not candidate.get("live_write_ready") and not dry.get("live_build_ready") else "FAIL", "live_write_authority=False live_build_ready=False")
    blockers = [f"{g['id']} {g['name']}: {g['detail']}" for g in gates if g.get("status") == "FAIL"]
    warnings = [f"{g['id']} {g['name']}: {g['detail']}" for g in gates if g.get("status") == "WARN"]
    planning_ready = not blockers
    return {
        "schema_version": FORGE_RUNTIME_BUILD_SANDBOX_VERIFY_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_BUILD_SANDBOX_VERIFICATION_V1",
        "created_at": _p159_now(),
        "status": "FORGE_RUNTIME_BUILD_SANDBOX_VERIFICATION_READY_PLANNING_ONLY" if planning_ready else "FORGE_RUNTIME_BUILD_SANDBOX_VERIFICATION_HAS_BLOCKERS",
        "current_phase": "S19E — Runtime Build Sandbox Verification / Candidate File Plan",
        "active_patch": "Patch 159 — Runtime Build Sandbox Verification / Candidate File Plan",
        "next_patch": "Patch 160 — Runtime Candidate File Draft / Sandbox Candidate",
        "recommended_next_patch": "Patch 160 — Runtime Candidate File Draft / Sandbox Candidate",
        "planning_ready": planning_ready,
        "live_build_ready": False,
        "selected_candidate": candidate,
        "sandbox_plan_status": plan.get("status"),
        "dry_run_status": dry.get("status"),
        "dry_run_sandbox_dir": dry.get("sandbox_dir"),
        "verified_files": files,
        "verified_file_count": len(files),
        "verified_file_hash_matches": sum(1 for r in files if r.get("hash_match")),
        "gates": gates,
        "warnings": warnings,
        "blockers": blockers,
        "authority": {"forge_owned_report_write_authority": True, "project_file_write_authority": False, "engine_file_write_authority": False, "runtime_file_write_authority": False, "patch_apply_authority": False},
    }


