def _p146_add_gate(gates: list, gate_id: str, label: str, passed: bool, message: str, fail_is_blocking: bool = True, warn: bool = False):
    if passed:
        status = "PASS"
    elif warn or not fail_is_blocking:
        status = "WARN"
    else:
        status = "FAIL"
    gates.append({
        "gate_id": gate_id,
        "label": label,
        "status": status,
        "blocking": bool(fail_is_blocking and status == "FAIL"),
        "message": message,
    })


