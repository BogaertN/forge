    for r in rows or []:
        if r.get("engine_base") == target or r.get("target") == target:
            return r
    return {}


def _p133_build_readiness(arg="latest"):
    paths=_p133_latest_inputs(); data={k:_p133_load(v) for k,v in paths.items()}
    proposal=data.get("proposal") or {}; target=proposal.get("target") or (arg if arg and arg != "latest" else "stack_linker_breather")
    gates=[]; problems=[]
    # 1 proposal exists and is verified
    prop_ok=bool(proposal) and str(proposal.get("status","")).startswith("LLM_SOURCE_GROUNDED_PATCH_PROPOSAL_READY")
    gates.append(_p133_gate("source_grounded_proposal_exists", prop_ok, "latest source-grounded proposal packet present" if prop_ok else "missing or not ready", {"path": str(paths["proposal"]), "sha256": _p133_sha(paths["proposal"])}))
    ver=data.get("proposal_verification") or {}; ver_ok=bool(ver) and ver.get("problem_count", 1)==0 and "VERIFIED" in str(ver.get("status",""))
    gates.append(_p133_gate("source_grounded_proposal_verified", ver_ok, "proposal verification has zero problems" if ver_ok else "proposal verification missing or has problems", {"path": str(paths["proposal_verification"]), "sha256": _p133_sha(paths["proposal_verification"])}))
    # 2 local LLM actually called
    live=data.get("live_llm_draft") or {}; live_ok=bool(live) and (live.get("authority") or {}).get("model_generation_called") is True and live.get("returncode") == 0 and _p133_exists_rel(live.get("raw_response_path",""))
    gates.append(_p133_gate("visible_local_llm_called", live_ok, "local Ollama model call captured with raw response" if live_ok else "live LLM proof missing/not successful", {"model": live.get("model"), "raw_response_sha256": live.get("raw_response_sha256"), "duration_ms": live.get("duration_ms")}))
    # 3 target scope/existence
    tf=proposal.get("target_files") or {}; primary=(tf.get("primary_target") or {})
    primary_path=primary.get("absolute") or primary.get("raw")
    primary_ok=bool(primary_path) and _p133_exists_rel(primary_path) and _p133_under(primary_path, _P133_AIWEB)
    gates.append(_p133_gate("target_file_scope_valid", primary_ok, "primary target exists under /home/nic/aiweb" if primary_ok else "primary target missing or out of scope", {"primary_target": primary_path, "under_aiweb": _p133_under(primary_path or '/', _P133_AIWEB)}))
    tests=tf.get("test_targets") or []
    test_scope_ok=all(_p133_exists_rel(t.get("absolute") or t.get("raw")) and _p133_under(t.get("absolute") or t.get("raw"), _P133_AIWEB) for t in tests) if tests else False
    gates.append(_p133_gate("test_target_scope_valid", test_scope_ok, "test targets exist under /home/nic/aiweb" if test_scope_ok else "test target missing or out of scope", {"count": len(tests)}))
    # 4 source authority candidate evidence exists and sha matches
    se=proposal.get("source_evidence") or {}; candidates=se.get("candidate_documents") or []
    source_ok=bool(candidates) and all(c.get("exists") is True and (not c.get("declared_sha256") or c.get("declared_sha256")==c.get("observed_sha256")) for c in candidates)
    gates.append(_p133_gate("source_evidence_candidate_bound", source_ok, "candidate source evidence exists with observed hashes" if source_ok else "source evidence missing/hash mismatch", {"candidate_count": len(candidates), "authority_claimed": se.get("authority_claimed")}))
    # 5 impact map and tests
    impact=data.get("patch_impact") or {}; rows=impact.get("rows") or []; impact_row=_p133_find_target_row(rows,target)
    impact_ok=bool(impact_row)
    gates.append(_p133_gate("patch_impact_known", impact_ok, "target exists in patch impact map" if impact_ok else "target missing from patch impact map", {"risk_level": impact_row.get("risk_level"), "risk_score": impact_row.get("risk_score")}))
    test_run=data.get("test_run") or {}; test_status=str(test_run.get("status") or "")
    target_issue=bool(impact_row.get("latest_failures")) or str(impact_row.get("test_status","")) == "ISSUES"
    tests_known=bool(test_run) and test_status.startswith("CANONICAL_TEST_RUN_COMPLETED")
    gates.append(_p133_gate("safe_test_result_known", tests_known, "latest canonical safe-test run is recorded" if tests_known else "safe-test result missing", {"test_run_status": test_status, "target_test_status": impact_row.get("test_status")}, blocking=True))
    gates.append(_p133_gate("target_tests_currently_pass", not target_issue, "target tests pass" if not target_issue else "target currently has known test issue; repair patch not live-apply eligible yet", {"target_test_status": impact_row.get("test_status"), "latest_failures": impact_row.get("latest_failures", [])}, blocking=True))
    # 6 rollback/snapshot/sandbox
    rb=proposal.get("rollback_plan") or {}; rb_ok=bool(rb.get("required")) and bool(rb.get("rollback_needs"))
    gates.append(_p133_gate("rollback_plan_present", rb_ok, "rollback plan requirements are recorded" if rb_ok else "rollback plan missing", {"rollback_needs": rb.get("rollback_needs", [])}))
    snap=data.get("self_snapshot") or {}; snap_ok=bool(snap) and "VERIFIED" in str(snap.get("status",""))
    gates.append(_p133_gate("fresh_snapshot_required", snap_ok, "Forge self-snapshot exists/verified" if snap_ok else "no verified relevant snapshot found in this gate input", {"path": str(paths["self_snapshot"]), "status": snap.get("status")}, blocking=True))
    sandbox=data.get("self_sandbox") or {}; sandbox_ok=bool(sandbox) and ("APPLIED_AND_CHECKED" in str(sandbox.get("status","")) or "PASS" in str(sandbox.get("status","")))
    gates.append(_p133_gate("sandbox_pass_required", sandbox_ok, "sandbox report exists and passed" if sandbox_ok else "no passing sandbox report bound to this patch proposal yet", {"path": str(paths["self_sandbox"]), "status": sandbox.get("status")}, blocking=True))
    # 7 human approval intentionally absent
    gates.append(_p133_gate("human_approval_recorded", False, "no explicit human approval token/receipt has been recorded for live apply", {}, blocking=True))
    authority={"readiness_only": True,"project_file_write_authority": False,"engine_file_write_authority": False,"forge_self_write_authority": False,"patch_apply_authority": False,"shell_execution_authority": False,"ledger_mutation_authority": False,"chroma_write_authority": False}
    blocking_failures=[g for g in gates if g.get("blocking") and not g.get("pass")]
    warnings=[g for g in gates if not g.get("blocking") and not g.get("pass")]
    eligible=False
    if blocking_failures:
        problems=[f"{g['gate']}: {g['reason']}" for g in blocking_failures]
    payload={"schema_version":"patch_live_readiness_v1_patch133","report_type":"PATCH_LIVE_READINESS_V1","created_at":_p133_now(),"status":"PATCH_LIFECYCLE_2_GATE_MATRIX_READY","target":target,"eligible_for_live_apply":eligible,"plain_english":"Read-only Patch Lifecycle 2.0 gate matrix. It explains why a proposed repair is or is not eligible for live apply. It does not apply patches.","gates":gates,"problems":problems,"warnings":[f"{g['gate']}: {g['reason']}" for g in warnings],"summary":{"gates_total":len(gates),"blocking_failures":len(blocking_failures),"warnings":len(warnings),"eligible_for_live_apply":eligible,"known_test_issue":target_issue,"recommended_next_patch":"Patch 134 — Gated repair for stack_linker_breather import/test issue"},"inputs":{k:{"path":str(v),"exists":v.exists(),"sha256":_p133_sha(v)} for k,v in paths.items()},"authority":authority,"recommended_next_patch":"Patch 134 — Gated repair for stack_linker_breather import/test issue"}
    return payload


