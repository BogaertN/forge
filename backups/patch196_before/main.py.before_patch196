    return {}


def _patch132_path_status(path_value):
    raw = str(path_value or "").strip()
    if not raw:
        return {"raw": raw, "absolute": None, "exists": False, "under_aiweb": False, "under_forge": False, "sha256": None}
    p = _Patch132Path(raw)
    if not p.is_absolute():
        if raw.startswith("aiweb/"):
            p = _Patch132Path("/home/nic") / raw
        else:
            p = FORGE_ROOT / raw
    try:
        resolved = p.resolve()
    except Exception:
        resolved = p
    exists = resolved.exists()
    s = str(resolved)
    return {
        "raw": raw,
        "absolute": s,
        "exists": exists,
        "under_aiweb": s.startswith("/home/nic/aiweb"),
        "under_forge": s.startswith(str(FORGE_ROOT)),
        "sha256": _patch132_sha256(resolved) if exists and resolved.is_file() else None,
    }


