            "provider": "ollama",
            "model": model,
            "authority": {"model_generation_called": False, "project_file_write_authority": False, "patch_apply_authority": False},
        }
        jp, _ = _p135_write(payload, "generic_repair_llm_proposal_v1")
        print("\n── Generic Repair LLM — Patch 135 ─────────────────")
        print("  Status :", payload["status"])
        print("  JSON   :", jp)
        print("──────────────────────────────────────────────────────\n")
        write_audit_entry(session_id, "GENERIC_REPAIR_LLM_BLOCKED", str(jp), "ollama_not_found", "model_generation_called=false")
