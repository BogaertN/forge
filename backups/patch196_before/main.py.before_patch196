def _patch130_command_base(command_line: str) -> str:
    return (command_line or "").strip().split()[0].lower() if (command_line or "").strip() else ""


def _patch130_allowed_modes_for_command(command_name: str) -> list[str]:
    cmd = _patch130_command_base(command_name)
    if not cmd:
        return ["READ_ONLY"]
    if cmd in {"help", "quit", "exit", "q", "status", "audit", "forge-version", "forge-command-surface"}:
        return ["READ_ONLY", "DASHBOARD"]
    if cmd.startswith("forge-mode") or cmd in {"forge-next", "forge-roadmap-status"}:
        return ["READ_ONLY", "DASHBOARD"]
    if cmd.startswith("forge-master-status") or cmd.startswith("forge-status-api") or cmd.startswith("forge-dashboard"):
        return ["READ_ONLY", "DASHBOARD"]
    if cmd.startswith("exact-") or cmd.endswith("-show") or cmd.endswith("-status") or cmd.endswith("-policy") or cmd.endswith("-export") or cmd.endswith("-gaps") or cmd.endswith("-list"):
        return ["READ_ONLY", "CONTEXT_SEARCH", "DASHBOARD"]
    if cmd.startswith("context-search") or cmd.startswith("code-index-search") or cmd.startswith("code-symbol") or cmd.startswith("code-related") or cmd.startswith("code-risk"):
        return ["CONTEXT_SEARCH", "READ_ONLY"]
    if cmd.startswith("llm-plan") or cmd.startswith("llm-patch") or cmd.startswith("patch-impact") or cmd.startswith("patch-source") or cmd.startswith("patch-runtime") or cmd.startswith("patch-risk"):
        return ["PATCH_PLANNING", "READ_ONLY"]
    if cmd.startswith("patch-propose") or cmd.startswith("patch-grounding") or cmd.startswith("patch-review") or cmd.startswith("patch-preflight"):
        return ["PATCH_PLANNING"]
    if cmd.startswith("patch-sandbox") or cmd.startswith("forge-self-sandbox"):
        return ["SANDBOX", "SELF_UPDATE"]
    if cmd.startswith("canonical-test") or cmd.startswith("test-") or cmd.startswith("patch-test"):
        return ["TEST", "READ_ONLY"]
    if cmd.startswith("snapshot"):
        return ["RECOVERY", "READ_ONLY"]
    if cmd.startswith("rollback"):
        return ["RECOVERY"]
    if cmd.startswith("forge-self-update") or cmd.startswith("forge-self-snapshot"):
        return ["SELF_UPDATE", "READ_ONLY"]
    if cmd.startswith("ingest") or cmd.startswith("corpus-intake") or cmd.startswith("corpus-extract") or cmd.startswith("doc-") or cmd.startswith("rpmc") or cmd.startswith("source-gap") or cmd.startswith("source-law") or cmd.startswith("vector"):
        return ["INGESTION", "READ_ONLY"]
    if cmd.startswith("engine-final-lockfile-apply") or cmd.startswith("engine-review") and cmd.endswith("apply"):
        return ["APPLY"]
    if cmd.startswith("patch-apply") or cmd.startswith("engine-review-batch-commit-apply") or cmd.startswith("engine-review-evidence-commit-apply") or cmd.startswith("engine-review-commit-apply"):
        return ["APPLY"]
    if cmd.startswith("llm-memory") or cmd.startswith("llm-tool") or cmd.startswith("engine-") or cmd.startswith("canonical-"):
        return ["READ_ONLY", "PATCH_PLANNING"]
    return ["READ_ONLY"]


def _patch130_family_for_command(command_name: str) -> str:
    cmd = _patch130_command_base(command_name)
    if not cmd:
        return "empty"
    if cmd.startswith("patch-"):
        return "patch_lifecycle"
    if cmd.startswith("engine-"):
        return "engine_review_or_lockfile"
    if cmd.startswith("forge-self"):
        return "forge_self_update"
    if cmd.startswith("forge-dashboard") or cmd.startswith("forge-status") or cmd.startswith("forge-master") or cmd.startswith("forge-mode"):
        return "forge_control_plane"
    if cmd.startswith("canonical-test") or cmd.startswith("test-"):
        return "test_harness"
    if cmd.startswith("canonical-"):
        return "canonical_engine_intelligence"
    if cmd.startswith("context") or cmd.startswith("code-"):
        return "context_code_search"
    if cmd.startswith("ingest") or cmd.startswith("corpus") or cmd.startswith("doc"):
        return "corpus_ingestion"
    if cmd.startswith("snapshot") or cmd.startswith("rollback"):
        return "recovery_snapshot"
    return "general"


def _patch130_matrix_payload() -> dict:
    command_rows = []
    mode_ids = _patch130_mode_ids()
    for cmd in FORGE_EXPECTED_COMMANDS:
        allowed = [m for m in _patch130_allowed_modes_for_command(cmd) if m in mode_ids]
        if not allowed:
            allowed = ["READ_ONLY"]
        command_rows.append({
            "command": cmd,
            "family": _patch130_family_for_command(cmd),
            "allowed_modes": allowed,
            "hard_blocking_enforced_now": False,
            "guard_check_available": True,
        })
    mode_coverage = {mode: 0 for mode in mode_ids}
    for row in command_rows:
        for mode in row.get("allowed_modes") or []:
            mode_coverage[mode] = mode_coverage.get(mode, 0) + 1
    problems = []
    if not command_rows:
        problems.append("No commands discovered in FORGE_EXPECTED_COMMANDS")
    uncovered = [row.get("command") for row in command_rows if not row.get("allowed_modes")]
    if uncovered:
        problems.append(f"Commands without allowed modes: {', '.join(uncovered[:10])}")
    return {
        "schema_version": FORGE_MODE_ENFORCEMENT_SCHEMA_VERSION,
        "report_type": "FORGE_MODE_PERMISSION_MATRIX_V1",
        "created_at": _patch130_iso_now(),
        "status": "FORGE_MODE_PERMISSION_MATRIX_READY" if not problems else "FORGE_MODE_PERMISSION_MATRIX_READY_WITH_WARNINGS",
        "mode_registry_status": _patch130_registry_payload().get("status"),
        "command_count": len(command_rows),
        "mode_count": len(mode_ids),
        "mode_ids": mode_ids,
        "mode_coverage": mode_coverage,
        "command_rows": command_rows,
        "summary": {
            "commands_mapped": len(command_rows),
            "modes_known": len(mode_ids),
            "hard_blocking_active": False,
            "guard_check_available": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "shell_execution_authority": False,
        },
        "authority": {
            "permission_matrix_authority": True,
            "hard_blocking_active": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "network_authority": False,
            "chroma_write_authority": False,
        },
        "plain_english": "Forge now has a command-to-mode permission matrix and a deterministic check command. This is the verified enforcement map; hard command blocking is intentionally not enabled until the matrix is inspected.",
        "problems": problems,
        "recommended_next_patch": "Patch 131 — Source Authority Runtime Binder",
    }


