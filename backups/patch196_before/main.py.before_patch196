def cmd_forge_self_sandbox_apply(arg: str, session_id: str) -> None:
    from agents.forge.memory import write_audit_entry
    plan_path = _patch122_select_json(arg)
    plan = _patch122_load_json(plan_path, {})
    snapshot_manifest = _patch122_load_json(Path(plan.get("snapshot_manifest_path") or _patch122_latest_snapshot_manifest_path()), {})
    problems = []
    warnings = []
    if not plan:
        problems.append(f"sandbox_plan_not_found:{plan_path}")
    if plan.get("status") != "FORGE_SELF_SANDBOX_PLAN_READY":
        problems.append(f"sandbox_plan_not_ready:{plan.get('status')}")
    entries = snapshot_manifest.get("entries") or []
    if not entries:
        problems.append("snapshot_entries_missing")
    sandbox_root = Path(plan.get("sandbox_root") or (_PATCH122_ROOT / "sandboxes" / ("FSSB-" + _patch122_now_id())))
    sandbox_target_mode = plan.get("sandbox_target_mode") or "snapshot_replay"
    files_root = sandbox_root / "files"
    copied = []
    checks = []
    if not problems:
        for e in entries:
            if not e.get("copied"):
                continue
            src = Path(e.get("snapshot_path") or "")
            rel = e.get("relative_path") or src.name
            dst = files_root / rel
            row = _patch122_copy_file(src, dst)
            copied.append(row)
            if not row.get("ok"):
                problems.append(f"sandbox_copy_failed:{rel}:{row.get('problem')}")
        main_path = files_root / "main.py"
        registry_path = files_root / "config" / "tool_registry.json"
        if main_path.exists():
            checks.append(_patch122_safe_py_compile(main_path))
            checks.append(_patch122_expected_command_scan(main_path, target_mode=sandbox_target_mode))
        else:
            checks.append({"name": "py_compile_main", "status": "FAIL", "error": "sandbox_main_missing"})
