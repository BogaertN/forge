        FORGE_EXPECTED_COMMANDS.append(_patch149_cmd)


def _p149_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p149_stamp() -> str:
    return _p149_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p149_ensure_dir() -> None:
    FORGE_LLM_PATCH_V2_DIR.mkdir(parents=True, exist_ok=True)


def _p149_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p149_sha256(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p149_latest_file(directory: Path, pattern: str):
    try:
        files = sorted(directory.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
        return files[0] if files else None
    except Exception:
        return None


def _p149_write(payload: dict, stem: str):
    _p149_ensure_dir()
    stamp = _p149_stamp()
    json_path = FORGE_LLM_PATCH_V2_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_LLM_PATCH_V2_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "target", "active_patch", "next_patch", "recommended_next_patch"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("summary"):
        md.append("")
        md.append("## Summary")
        for k, v in (payload.get("summary") or {}).items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("problems") is not None:
        md.append("")
        md.append("## Verification")
        md.append(f"- Problems: `{len(payload.get('problems') or [])}`")
        md.append(f"- Warnings: `{len(payload.get('warnings') or [])}`")
    if payload.get("plain_english"):
        md.append("")
        md.append(payload.get("plain_english"))
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")
    latest_json = FORGE_LLM_PATCH_V2_DIR / f"latest_{stem}.json"
    latest_md = FORGE_LLM_PATCH_V2_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


def _p149_latest_proposal_path():
    p = FORGE_LLM_PATCH_V2_DIR / f"latest_{FORGE_LLM_PATCH_V2_STEM}.json"
    return p if p.exists() else _p149_latest_file(FORGE_LLM_PATCH_V2_DIR, f"*_{FORGE_LLM_PATCH_V2_STEM}.json")


