def _p143b_load_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p143b_write(payload: dict, stem: str):
    _p143b_ensure_dir()
    ts = _p143b_now().replace("-", "_").replace(":", "").replace("T", "_")
    json_path = FORGE_ROADMAP_V2_DIR / f"{ts}_{stem}.json"
    md_path = FORGE_ROADMAP_V2_DIR / f"{ts}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "current_milestone", "recommended_next_patch", "next_phase"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if isinstance(payload.get("verified_state"), dict):
        md.append("")
        md.append("## Verified State")
        for k, v in payload["verified_state"].items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("completed_layers"):
        md.append("")
        md.append("## Completed Layers")
        for item in payload.get("completed_layers") or []:
            md.append(f"- {item}")
    if payload.get("deferred_items"):
        md.append("")
        md.append("## Deferred Items")
        for item in payload.get("deferred_items") or []:
            if isinstance(item, dict):
                md.append(f"- **{item.get('name')}**: {item.get('reason')}")
            else:
                md.append(f"- {item}")
    if payload.get("full_roadmap"):
        md.append("")
        md.append("## Full Roadmap")
        for row in payload.get("full_roadmap") or []:
            md.append(f"- **{row.get('status')}** — {row.get('phase')}: {row.get('purpose')}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_ROADMAP_V2_DIR / f"latest_{stem}.json"
    latest_md = FORGE_ROADMAP_V2_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


