def _patch125_read_small_text(path: Path, max_bytes: int = 240000) -> str:
    try:
        data = path.read_bytes()[:max_bytes]
        return data.decode("utf-8", errors="replace")
    except Exception:
        return ""


def _patch125_scan_engine_files(root: Path) -> dict:
    info = {
        "python_files": [],
        "metadata_files": [],
        "import_modules": [],
        "text_blob": "",
        "read_errors": [],
    }
    if not root or not root.exists() or not root.is_dir():
        return info
    text_parts = []
    import_modules = set()
    py_files = []
    meta_files = []
    for p in root.rglob("*"):
        if not p.is_file():
            continue
        rel = str(p.relative_to(root))
        if any(part in {"__pycache__", ".git", ".venv", "node_modules"} for part in p.parts):
            continue
        if p.suffix == ".py":
            py_files.append(rel)
            txt = _patch125_read_small_text(p)
            text_parts.append(f"\n# FILE {rel}\n" + txt[:50000])
            for line in txt.splitlines():
                line = line.strip()
                m = re.match(r"(?:from|import)\s+([A-Za-z_][A-Za-z0-9_\.]+)", line)
                if m:
                    mod = m.group(1).split(".")[0]
                    if mod not in {"os", "sys", "json", "time", "datetime", "pathlib", "typing", "random", "math", "subprocess"}:
                        import_modules.add(mod)
        elif p.name.lower() in {"readme.md", "engine_manifest.json", "manifest.json"} or p.suffix.lower() in {".md", ".json"}:
            meta_files.append(rel)
            text_parts.append(f"\n# FILE {rel}\n" + _patch125_read_small_text(p)[:40000])
    info["python_files"] = sorted(py_files)[:200]
    info["metadata_files"] = sorted(meta_files)[:200]
    info["import_modules"] = sorted(import_modules)
    info["text_blob"] = "\n".join(text_parts).lower()[:300000]
    return info


def _patch125_test_status_by_engine() -> dict:
    report = _patch125_latest_test_report() or {}
    out = {}
    for r in report.get("results") or []:
        eng = r.get("engine_base")
        if not eng:
            continue
        cur = out.setdefault(eng, {"pass": 0, "fail": 0, "timeout": 0, "blocked": 0, "error": 0, "statuses": []})
        st = r.get("status") or "UNKNOWN"
        cur["statuses"].append(st)
        if st == "PASS":
            cur["pass"] += 1
        elif st == "FAIL":
            cur["fail"] += 1
        elif st == "TIMEOUT":
            cur["timeout"] += 1
        elif str(st).startswith("BLOCKED"):
            cur["blocked"] += 1
        else:
            cur["error"] += 1
    for eng, cur in out.items():
        if cur["fail"] or cur["timeout"] or cur["blocked"] or cur["error"]:
            cur["summary"] = "ISSUES"
        elif cur["pass"]:
            cur["summary"] = "PASS"
        else:
            cur["summary"] = "UNKNOWN"
    return out


def _patch125_build_relationship_map() -> dict:
    lock = _patch123_load_final_lockfile()
    if lock.get("_missing") or lock.get("_error"):
        return {
            "status": "CANONICAL_RELATIONSHIP_MAP_BLOCKED_NO_FINAL_LOCKFILE",
            "problems": [lock.get("_error") or "missing final lockfile"],
            "rows": [],
            "counts": {},
        }
    entries = lock.get("canonical_entries") or []
    test_status = _patch125_test_status_by_engine()
    scan_rows = []
    by_base = {}
    for entry in entries:
        base = entry.get("engine_base") or Path(entry.get("canonical_path", "unknown")).name
        resolved = _patch123_resolve_canonical_path(entry.get("canonical_path", ""))
        scan = _patch125_scan_engine_files(resolved) if resolved else {}
        row = {
            "engine_base": base,
            "canonical_path": entry.get("canonical_path"),
            "resolved_path": str(resolved) if resolved else None,
            "path_exists": bool(resolved and resolved.exists()),
            "python_files": scan.get("python_files", []),
            "metadata_files": scan.get("metadata_files", []),
            "import_modules": scan.get("import_modules", []),
            "tokens": sorted(_patch125_engine_tokens(base)),
            "text_blob": scan.get("text_blob", ""),
            "test_status": (test_status.get(base) or {}).get("summary", "NO_TEST_RESULT"),
            "test_counts": test_status.get(base) or {},
        }
        scan_rows.append(row)
        by_base[base] = row
    all_bases = [r["engine_base"] for r in scan_rows]
    rows = []
    risk_rows = []
    total_edges = 0
    for row in scan_rows:
        neighbors = []
        text_blob = row.pop("text_blob", "")
        imports = set(row.get("import_modules") or [])
        row_tokens = set(row.get("tokens") or [])
        for other in scan_rows:
            if other["engine_base"] == row["engine_base"]:
                continue
            other_base = other["engine_base"]
            other_tokens = set(other.get("tokens") or [])
            normalized_other = other_base.lower()
            compact_other = normalized_other.replace("_", "")
            reason = None
            confidence = None
            if other_base in imports or compact_other in {m.replace("_", "").lower() for m in imports}:
                reason = "python_import_reference"
                confidence = "strong"
            elif normalized_other in text_blob or compact_other in text_blob.replace("_", ""):
                reason = "source_text_reference"
                confidence = "medium"
            else:
                shared = sorted(row_tokens & other_tokens)
                if len(shared) >= 2:
                    reason = "shared_runtime_terms:" + ",".join(shared[:5])
                    confidence = "weak"
                elif shared and any(t in {"memory", "phase", "drift", "resonance", "glyph", "field", "recursive", "ping", "loop"} for t in shared):
                    reason = "shared_runtime_term:" + shared[0]
                    confidence = "weak"
            if reason:
                neighbors.append({
                    "engine_base": other_base,
                    "canonical_path": other.get("canonical_path"),
                    "reason": reason,
                    "confidence": confidence,
                })
        neighbors = sorted(neighbors, key=lambda n: {"strong": 0, "medium": 1, "weak": 2}.get(n.get("confidence"), 9))[:25]
        total_edges += len(neighbors)
        rel_count = len(neighbors)
        test_summary = row.get("test_status")
        risk_level = "LOW"
        risk_reason = "normal_relationship_density"
        if test_summary in {"ISSUES", "NO_TEST_RESULT"} and rel_count >= 5:
            risk_level = "HIGH"
            risk_reason = f"{test_summary.lower()}_and_many_relationships"
        elif test_summary in {"ISSUES", "NO_TEST_RESULT"} or rel_count >= 10:
            risk_level = "MEDIUM"
            risk_reason = f"test_status={test_summary}; relationship_count={rel_count}"
        out_row = dict(row)
        out_row["neighbors"] = neighbors
        out_row["relationship_count"] = rel_count
        out_row["risk_level"] = risk_level
        out_row["risk_reason"] = risk_reason
        rows.append(out_row)
        if risk_level in {"MEDIUM", "HIGH"}:
            risk_rows.append({
                "engine_base": out_row.get("engine_base"),
                "risk_level": risk_level,
                "risk_reason": risk_reason,
                "relationship_count": rel_count,
                "test_status": test_summary,
                "top_neighbors": neighbors[:8],
            })
    counts = {
        "canonical_engines": len(entries),
        "relationship_rows": len(rows),
        "total_detected_edges": total_edges,
        "high_risk_neighbors": sum(1 for r in risk_rows if r.get("risk_level") == "HIGH"),
        "medium_risk_neighbors": sum(1 for r in risk_rows if r.get("risk_level") == "MEDIUM"),
        "engines_with_test_issues": sum(1 for r in rows if r.get("test_status") == "ISSUES"),
        "engines_without_test_result": sum(1 for r in rows if r.get("test_status") == "NO_TEST_RESULT"),
    }
    return {
        "schema_version": CANONICAL_RELATIONSHIP_SCHEMA_VERSION,
        "report_type": "CANONICAL_ENGINE_RELATIONSHIP_MAP_V1",
        "created_at": _patch125_iso_now(),
        "status": "CANONICAL_ENGINE_RELATIONSHIP_MAP_READY",
        "plain_english": "Read-only relationship map for final canonical engines using imports, source text references, shared runtime terms, and latest safe-test status. No project files are modified.",
        "source_lockfile_sha256": lock.get("_sha256"),
        "source_lockfile_path": lock.get("_path"),
        "source_test_report_status": (_patch125_latest_test_report() or {}).get("status"),
        "counts": counts,
        "rows": rows,
        "risk_rows": sorted(risk_rows, key=lambda r: ({"HIGH": 0, "MEDIUM": 1}.get(r.get("risk_level"), 9), -int(r.get("relationship_count") or 0))),
        "next_recommended_patch": "Patch 126 — Patch Impact Map",
        "authority": {
            "read_only_analysis": True,
            "engine_file_write_authority": False,
            "project_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "ledger_mutation": False,
