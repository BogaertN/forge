    candidate = capture.get("candidate") or execution.get("candidate") or final_gate.get("candidate") or backup.get("candidate") or static.get("candidate") or "failsafe_manager"
    planned_files = _p168_planned_files_from_sources()
    human_approval_present = bool(capture.get("human_approval_present") or execution.get("human_approval_present") or final_gate.get("human_approval_present"))
