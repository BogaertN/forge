def _p170_now() -> str:
    return _p170_datetime.now().strftime("%Y%m%d_%H%M%S")


def _p170_safe_read_json(path, default=None):
    try:
        p = _P170Path(path)
        if p.exists():
            return _p170_json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p170_latest_json(rel_path: str, default=None):
    return _p170_safe_read_json(_P170Path.home() / "forge" / "memory" / rel_path, default)


def _p170_hash_text(text: str) -> str:
    return _p170_hashlib.sha256((text or "").encode("utf-8")).hexdigest()


def _p170_planned_files_from_sources():
    token_entry = _p170_latest_json("forge_runtime_live_token_entry_v1/latest_forge_runtime_live_token_entry_v1.json", {})
    decision = _p170_latest_json("forge_runtime_live_decision_v1/latest_forge_runtime_live_decision_v1.json", {})
    execution = _p170_latest_json("forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json", {})
    final_gate = _p170_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    backup = _p170_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_v1.json", {})
    files = []
    for src_name, payload in [
        ("token_entry", token_entry),
        ("decision_gate", decision),
        ("execution_plan", execution),
        ("final_gate", final_gate),
        ("backup_dry_run", backup),
    ]:
        for row in payload.get("planned_files", []) or payload.get("files", []) or []:
            if isinstance(row, dict):
                r = dict(row)
                r["source"] = r.get("source") or src_name
                files.append(r)
        if files:
            break
    normalized = []
    seen = set()
    for row in files:
        rel = row.get("relative_path") or row.get("target_relative_path") or row.get("runtime_relative_path") or row.get("path") or row.get("file")
        if not rel:
            continue
        rel = str(rel)
        if rel in seen:
            continue
        seen.add(rel)
        normalized.append({
            "relative_path": rel,
            "target_relative_path": row.get("target_relative_path") or rel,
            "source": row.get("source") or "runtime_live_token_validate",
            "sandbox_source": row.get("sandbox_source") or row.get("source_path") or "candidate_sandbox",
            "live_write_planned_now": False,
        })
    return normalized


def _p170_payload() -> dict:
    token_entry = _p170_latest_json("forge_runtime_live_token_entry_v1/latest_forge_runtime_live_token_entry_v1.json", {})
    decision = _p170_latest_json("forge_runtime_live_decision_v1/latest_forge_runtime_live_decision_v1.json", {})
    approval_capture = _p170_latest_json("forge_runtime_live_approval_capture_v1/latest_forge_runtime_live_approval_capture_v1.json", {})
    final_gate = _p170_latest_json("forge_runtime_live_final_gate_v1/latest_forge_runtime_live_final_gate_v1.json", {})
    execution = _p170_latest_json("forge_runtime_live_execution_v1/latest_forge_runtime_live_execution_gate_v1.json", {})
    backup = _p170_latest_json("forge_runtime_live_backup_v1/latest_forge_runtime_live_backup_v1.json", {})
    static_verify = _p170_latest_json("forge_runtime_candidate_static_verify_v1/latest_forge_runtime_candidate_static_verify_v1.json", {})
    candidate = (
        token_entry.get("candidate")
        or decision.get("candidate")
        or approval_capture.get("candidate")
        or final_gate.get("candidate")
        or execution.get("candidate")
        or "failsafe_manager"
    )
    token_template = token_entry.get("approval_token_template") or {}
    required_phrase = token_template.get("required_phrase") or ""
    required_hash = token_template.get("required_phrase_hash") or ""
    entered_phrase = (
        token_entry.get("entered_token")
        or token_entry.get("approval_token_entered")
        or approval_capture.get("entered_token")
        or ""
    )
    entered_hash = _p170_hash_text(entered_phrase) if entered_phrase else ""
    token_entered = bool(entered_phrase)
    token_hash_matches = bool(entered_hash and required_hash and entered_hash == required_hash)
    explicit_approval_present = bool(token_entered and token_hash_matches)
    planned_files = _p170_planned_files_from_sources()
    problems = []
    if not token_entry:
        problems.append("Missing Patch 169 token-entry report.")
    if not required_phrase or not required_hash:
        problems.append("Missing approval token template phrase/hash.")
    if not planned_files:
        problems.append("No planned runtime files found from prior evidence.")
    gates = [
        {"id": "V01", "name": "Patch 169 token-entry report exists", "status": "PASS" if token_entry else "FAIL", "detail": token_entry.get("status", "missing")},
        {"id": "V02", "name": "Approval token template exists", "status": "PASS" if required_phrase and required_hash else "FAIL", "detail": token_template.get("status", "missing")},
        {"id": "V03", "name": "Entered approval token detected", "status": "LOCKED" if not token_entered else "PASS", "detail": "not_entered" if not token_entered else "entered"},
        {"id": "V04", "name": "Entered token hash validates", "status": "LOCKED" if not token_entered else ("PASS" if token_hash_matches else "FAIL"), "detail": "not_entered" if not token_entered else ("hash_match" if token_hash_matches else "hash_mismatch")},
        {"id": "V05", "name": "Candidate known", "status": "PASS" if candidate else "FAIL", "detail": candidate},
        {"id": "V06", "name": "Planned files available", "status": "PASS" if planned_files else "FAIL", "detail": f"planned_files={len(planned_files)}"},
        {"id": "V07", "name": "Static candidate verification exists", "status": "PASS" if static_verify else "WARN", "detail": static_verify.get("status", "missing_or_not_bundled")},
        {"id": "V08", "name": "Live backup/apply dry-run exists", "status": "PASS" if backup else "WARN", "detail": backup.get("status", "missing_or_not_bundled")},
        {"id": "V09", "name": "Final execution preflight decision", "status": "LOCKED", "detail": "HOLD_FOR_HUMAN_APPROVAL"},
        {"id": "V10", "name": "No live writes performed", "status": "PASS", "detail": "runtime_writes=0 project_writes=0 engine_writes=0"},
    ]
    hard_fails = [g for g in gates if g.get("status") == "FAIL"]
    planning_ready = len(hard_fails) == 0 and len(problems) == 0
    payload = {
        "schema_version": FORGE_RUNTIME_LIVE_TOKEN_VALIDATE_SCHEMA_VERSION,
        "report_type": "FORGE_RUNTIME_LIVE_APPROVAL_TOKEN_VALIDATION_FINAL_PREFLIGHT_V1",
        "created_at": _p170_now(),
        "active_patch": "Patch 170 — Runtime Live Build Approval Token Validation / Final Execution Preflight",
        "current_phase": "S19P — Runtime Live Build Approval Token Validation / Final Execution Preflight",
        "next_patch": "Patch 171 — Runtime Live Build Explicit Approval Capture / Apply Hold",
        "recommended_next_patch": "Patch 171 — Runtime Live Build Explicit Approval Capture / Apply Hold",
        "status": "FORGE_RUNTIME_LIVE_TOKEN_VALIDATION_READY_GATE_LOCKED" if planning_ready else "FORGE_RUNTIME_LIVE_TOKEN_VALIDATION_HAS_BLOCKERS",
        "candidate": candidate,
        "planning_ready": planning_ready,
        "live_build_ready": False,
        "human_approval_present": explicit_approval_present,
        "approval_token_entered": token_entered,
        "approval_token_status": "VALIDATED_APPROVAL_PRESENT" if explicit_approval_present else "TEMPLATE_READY_NOT_APPROVED",
        "token_validation_status": "NOT_ENTERED" if not token_entered else ("VALID" if token_hash_matches else "INVALID_HASH"),
        "execution_decision": "HOLD_FOR_HUMAN_APPROVAL",
        "approval_token_template": token_template,
        "entered_token_hash": entered_hash,
        "required_token_hash": required_hash,
        "planned_file_count": len(planned_files),
        "planned_files": planned_files,
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "problem_count": len(problems),
        "problems": problems,
        "gates": gates,
        "gate_summary": {
            "pass": sum(1 for g in gates if g.get("status") == "PASS"),
            "warn": sum(1 for g in gates if g.get("status") == "WARN"),
            "locked": sum(1 for g in gates if g.get("status") == "LOCKED"),
            "fail": sum(1 for g in gates if g.get("status") == "FAIL"),
        },
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "runtime_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
        },
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 170 validates whether an explicit human approval token has been entered. No token is treated as approval unless the exact required phrase hash matches. This patch performs zero live writes.",
    }
    return payload


def _p170_markdown(payload: dict) -> str:
    lines = []
    lines.append(f"# {payload.get('active_patch','Patch 170')} — Approval Token Validation / Final Preflight")
    lines.append("")
    lines.append(f"Status: {payload.get('status')}")
    lines.append(f"Candidate: {payload.get('candidate')}")
    lines.append(f"Planning ready: {payload.get('planning_ready')}")
    lines.append(f"Live build ready: {payload.get('live_build_ready')}")
    lines.append(f"Human approval present: {payload.get('human_approval_present')}")
    lines.append(f"Token validation: {payload.get('token_validation_status')}")
    lines.append(f"Execution decision: {payload.get('execution_decision')}")
    lines.append(f"Next patch: {payload.get('next_patch')}")
    lines.append("")
    lines.append("## Gates")
    for g in payload.get("gates", []):
        lines.append(f"- {g.get('id')} [{g.get('status')}] {g.get('name')} — {g.get('detail')}")
    lines.append("")
    lines.append("## Planned Files")
    for f in payload.get("planned_files", []):
        lines.append(f"- {f.get('relative_path') or f.get('target_relative_path')} | live_write_now={f.get('live_write_planned_now')}")
    lines.append("")
    return "\n".join(lines)


