    if limit and len(text) > limit:
        return text[:limit] + "\n...[TRUNCATED]..."
    return text


def _p141_extract_import_roots(text):
    import ast, re
    roots = set()
    try:
        tree = ast.parse(text or "")
        for node in ast.walk(tree):
            if isinstance(node, ast.Import):
                for alias in node.names:
                    if alias.name:
                        roots.add(alias.name.split(".")[0])
            elif isinstance(node, ast.ImportFrom):
                if node.level == 0 and node.module:
                    roots.add(node.module.split(".")[0])
    except Exception:
        for m in re.finditer(r"^\s*from\s+([A-Za-z_][A-Za-z0-9_]*)", text or "", re.M):
            roots.add(m.group(1))
        for m in re.finditer(r"^\s*import\s+([A-Za-z_][A-Za-z0-9_]*)", text or "", re.M):
            roots.add(m.group(1))
    return sorted(roots)


def _p141_is_stdlib_or_skip(root, target_engine=None):
    import sys
    builtin = set(sys.builtin_module_names)
    skip = {
        "os", "sys", "json", "time", "math", "pathlib", "subprocess", "shutil", "hashlib",
        "datetime", "typing", "re", "ast", "unittest", "pytest", "collections", "itertools",
        "functools", "dataclasses", "logging", "tempfile", "traceback", "copy", "random",
    }
    if root in builtin or root in skip:
        return True
    if target_engine and root == target_engine:
        return True
    return False


def _p141_find_dependency_candidate(root):
    from pathlib import Path
    engines = Path("/home/nic/aiweb/engines")
    if not engines.exists():
        return None
    direct_dir = engines / root
    if direct_dir.exists() and direct_dir.is_dir():
        return {"kind": "package_dir", "path": str(direct_dir), "requested_module": root, "reason": "direct_engine_package_dir_match"}
    direct_file = engines / f"{root}.py"
    if direct_file.exists() and direct_file.is_file():
        return {"kind": "module_file", "path": str(direct_file), "requested_module": root, "reason": "direct_engine_module_file_match"}
    candidates = []
    try:
        for p in engines.rglob(f"{root}.py"):
            parts = set(p.parts)
            if "__pycache__" in parts or ".venv" in parts or "node_modules" in parts:
                continue
            candidates.append(p)
    except Exception:
        candidates = []
    if candidates:
        candidates.sort(key=lambda x: (len(str(x)), str(x)))
        return {"kind": "module_file", "path": str(candidates[0]), "requested_module": root, "reason": "bounded_rglob_module_file_match"}
    # Look for directories one level below engines that have the requested root as package name.
    try:
        for p in engines.rglob(root):
            if p.is_dir() and "__pycache__" not in p.parts:
                return {"kind": "package_dir", "path": str(p), "requested_module": root, "reason": "bounded_rglob_package_dir_match"}
    except Exception:
        pass
    return None


def _p141_copy_dependency(candidate, sandbox_packages):
    import shutil
    from pathlib import Path
    action = {"requested_module": candidate.get("requested_module"), "chosen_dependency": candidate, "install_result": {}}
    root = candidate.get("requested_module")
    src = Path(candidate.get("path"))
    dst_root = Path(sandbox_packages) / root
    if candidate.get("kind") == "package_dir":
        if dst_root.exists():
            shutil.rmtree(dst_root)
        shutil.copytree(src, dst_root, ignore=shutil.ignore_patterns("__pycache__", "*.pyc", ".venv", "node_modules"))
        init = dst_root / "__init__.py"
        if not init.exists():
            init.write_text("# Forge sandbox package shim\n", encoding="utf-8")
        action["install_result"] = {"strategy": "copy_package_dir", "package_dir": str(dst_root), "installed_paths": [str(dst_root)]}
    else:
        dst_root.mkdir(parents=True, exist_ok=True)
        dst_file = dst_root / f"{root}.py"
        shutil.copy2(src, dst_file)
        init = dst_root / "__init__.py"
        if not init.exists():
            init.write_text("# Forge sandbox package shim\n", encoding="utf-8")
        action["install_result"] = {"strategy": "copy_module_file_as_package", "package_dir": str(dst_root), "installed_paths": [str(dst_file), str(init)]}
    return action


def _p141_run_subprocess(argv, cwd, env=None, timeout=45):
    import subprocess, time
    started = _p141_now()
    try:
        cp = subprocess.run(argv, cwd=str(cwd), env=env, text=True, capture_output=True, timeout=timeout, shell=False)
        return {
            "argv": list(argv), "cwd": str(cwd), "shell": False, "started_at": started,
            "ended_at": _p141_now(), "returncode": cp.returncode, "stdout": cp.stdout,
            "stderr": cp.stderr, "timeout": False,
        }
    except subprocess.TimeoutExpired as e:
        return {
            "argv": list(argv), "cwd": str(cwd), "shell": False, "started_at": started,
            "ended_at": _p141_now(), "returncode": 124, "stdout": e.stdout or "",
            "stderr": e.stderr or "TIMEOUT", "timeout": True,
        }
    except Exception as e:
        return {
            "argv": list(argv), "cwd": str(cwd), "shell": False, "started_at": started,
            "ended_at": _p141_now(), "returncode": 127, "stdout": "", "stderr": repr(e), "timeout": False,
        }


