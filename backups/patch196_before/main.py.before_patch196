for _patch146_cmd in PATCH146_COMMANDS:
    if _patch146_cmd not in FORGE_EXPECTED_COMMANDS:
        FORGE_EXPECTED_COMMANDS.append(_patch146_cmd)


def _p146_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p146_stamp() -> str:
    return _p146_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p146_ensure_dir() -> None:
    FORGE_BUILD_PHASE_GATE_DIR.mkdir(parents=True, exist_ok=True)


def _p146_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p146_sha256_path(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p146_write(payload: dict, stem: str):
    _p146_ensure_dir()
    stamp = _p146_stamp()
    json_path = FORGE_BUILD_PHASE_GATE_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_BUILD_PHASE_GATE_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "active_patch", "current_phase", "next_patch", "gate_pass_count", "gate_warn_count", "gate_fail_count"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("gates"):
        md.append("")
        md.append("## Gates")
        for gate in payload.get("gates") or []:
            md.append(f"- **{gate.get('gate_id')}** — `{gate.get('status')}` — {gate.get('label')}: {gate.get('message')}")
    if payload.get("blocked_items"):
        md.append("")
        md.append("## Blocked Items")
        for item in payload.get("blocked_items") or []:
            md.append(f"- **{item.get('name')}**: {item.get('reason')}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_BUILD_PHASE_GATE_DIR / f"latest_{stem}.json"
    latest_md = FORGE_BUILD_PHASE_GATE_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


