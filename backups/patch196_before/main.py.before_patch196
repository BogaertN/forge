def _patch98_all_latest_evidence_binders() -> list[dict]:
    root = MEMORY_DIR / "engine_evidence_binders_v1"
    if not root.exists():
        return []
    rows = {}
    # Prefer explicit latest aliases.
    for path in sorted(root.glob("latest_*_engine_evidence_binder.json")):
        try:
            data = _patch98_read_json(path)
            fam = data.get("engine_family")
            if fam:
                data["_path"] = str(path)
                data["_sha256"] = _patch98_sha256(path)
                rows[fam] = data
        except Exception:
            continue
    # Fall back to timestamped binders for any family missing an alias.
    for path in sorted(root.glob("*_engine_source_evidence_binder_v1.json"), key=lambda p: p.stat().st_mtime, reverse=True):
        try:
            data = _patch98_read_json(path)
            fam = data.get("engine_family")
            if fam and fam not in rows:
                data["_path"] = str(path)
                data["_sha256"] = _patch98_sha256(path)
                rows[fam] = data
        except Exception:
            continue
    return sorted(rows.values(), key=lambda r: r.get("engine_family") or "")


