def _p152_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p152_stamp() -> str:
    return _p152_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p152_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p152_sha256_file(path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        h = hashlib.sha256()
        with p.open("rb") as f:
            for chunk in iter(lambda: f.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None


def _p152_rel_safe_path(path: Path) -> str:
    raw = str(path).lstrip("/")
    raw = raw.replace("..", "__")
    return raw


def _p152_is_forbidden(path: Path) -> bool:
    s = str(path)
    parts = set(path.parts)
    forbidden_parts = {".ssh", ".gnupg", ".aws", ".config", ".cache", ".venv", "node_modules", "__pycache__"}
    if parts & forbidden_parts:
        return True
    lowered = s.lower()
    forbidden_tokens = ["/secrets", "/secret", "/keys", "/key", ".env", "id_rsa", "id_ed25519", "credentials", "token"]
    return any(tok in lowered for tok in forbidden_tokens)


