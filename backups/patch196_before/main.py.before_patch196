LLM_LIVE_PATCH_DRAFTS_DIR = FORGE_ROOT / "memory" / "llm_live_patch_drafts_v1"
LLM_LIVE_PATCH_DRAFTS_DIR.mkdir(parents=True, exist_ok=True)
PATCH132R_CONFIRM_TOKEN = "CONFIRM_CALL_LOCAL_LLM"

def _p132r_now():
    return _p132r_datetime.now().replace(microsecond=0).isoformat()

def _p132r_stamp():
    return _p132r_datetime.now().strftime("%Y_%m_%d_%H%M%S")

def _p132r_load(path):
    try:
        p=_P132RPath(path)
        return _p132r_json.loads(p.read_text(encoding="utf-8")) if p.exists() else {}
    except Exception:
        return {}

def _p132r_sha(path):
    try:
        h=_p132r_hashlib.sha256(); p=_P132RPath(path)
        with p.open("rb") as f:
            for b in iter(lambda:f.read(1024*1024), b""): h.update(b)
        return h.hexdigest()
    except Exception:
        return None

def _p132r_write(payload, stem):
    ts=_p132r_stamp(); jp=LLM_LIVE_PATCH_DRAFTS_DIR/f"{ts}_{stem}.json"; mp=LLM_LIVE_PATCH_DRAFTS_DIR/f"{ts}_{stem}.md"
    jp.write_text(_p132r_json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    mp.write_text(f"# {payload.get('report_type', stem)}\n\nStatus: `{payload.get('status')}`\n", encoding="utf-8")
    (LLM_LIVE_PATCH_DRAFTS_DIR/f"latest_{stem}.json").write_text(jp.read_text(encoding="utf-8"), encoding="utf-8")
    (LLM_LIVE_PATCH_DRAFTS_DIR/f"latest_{stem}.md").write_text(mp.read_text(encoding="utf-8"), encoding="utf-8")
    return jp, mp

