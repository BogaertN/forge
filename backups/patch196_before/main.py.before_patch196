def _p175_command_family_status():
    source = ""
    try:
        source = _P175Path(__file__).read_text(encoding="utf-8")
    except Exception:
        try:
            source = (_P175Path.home() / "forge" / "main.py").read_text(encoding="utf-8")
        except Exception:
            source = ""
    families = {
        "forge-runtime-module-map": [
            "forge-runtime-module-map-policy",
            "forge-runtime-module-map-build",
            "forge-runtime-module-map-show",
            "forge-runtime-module-map-list",
            "forge-runtime-module-map-next",
            "forge-runtime-module-map-export",
        ],
        "forge-runtime-build-plan": [
            "forge-runtime-build-plan-policy",
            "forge-runtime-build-plan-build",
            "forge-runtime-build-plan-show",
            "forge-runtime-build-plan-list",
            "forge-runtime-build-plan-next",
            "forge-runtime-build-plan-export",
        ],
    }
    rows = []
    for family, commands in families.items():
        found = []
        missing = []
        for cmd in commands:
            in_expected = cmd in FORGE_EXPECTED_COMMANDS
            in_source = (f'"{cmd}"' in source) or (f"'{cmd}'" in source)
            row_ok = bool(in_expected and in_source)
            (found if row_ok else missing).append(cmd)
        rows.append({
            "family": family,
            "command_count": len(commands),
            "found_count": len(found),
            "missing_count": len(missing),
            "status": "PASS" if not missing else "WARN",
            "found": found,
            "missing": missing,
        })
    return rows


def _p175_select_candidate(queue_review: dict):
    queue_decision = queue_review.get("queue_decision") if isinstance(queue_review, dict) else {}
