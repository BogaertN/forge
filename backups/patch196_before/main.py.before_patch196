# Patch 182.1 — Runtime Candidate Sandbox Stage command-definition hotfix.
# Purpose: define the Patch 182 sandbox-stage command family that was already routed,
# registered, and expected in the command surface. This patch remains no-write for
# AI.Web runtime/project/engine files; it writes only Forge-owned receipt/export files.
import json as _p182_json
import hashlib as _p182_hashlib
import shutil as _p182_shutil
import datetime as _p182_datetime
from pathlib import Path as _P182Path

FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_DIR = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_sandbox_stage_v1"
FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_DIR = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_sandbox_preflight_v1"
FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_DIR = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_rollback_v1"
FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_validation_v1"
FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SCOPE_DIR = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_dry_plan_scope_v1"


def _p182_now() -> str:
    return _p182_datetime.datetime.now().strftime("%Y%m%d_%H%M%S")


def _p182_load_json(path):
    try:
        p = _P182Path(path)
        if not p.exists():
            return {}
        data = _p182_json.loads(p.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def _p182_latest_receipts() -> dict:
    return {
        "preflight": _p182_load_json(FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_DIR / "latest_forge_runtime_candidate_sandbox_preflight_v1.json"),
        "rollback": _p182_load_json(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_DIR / "latest_forge_runtime_candidate_dry_plan_rollback_v1.json"),
        "validation": _p182_load_json(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / "latest_forge_runtime_candidate_dry_plan_validation_v1.json"),
        "scope": _p182_load_json(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SCOPE_DIR / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
    }


def _p182_rows_from_receipts(receipts: dict) -> list:
    preflight = receipts.get("preflight") or {}
    summary = preflight.get("candidate_file_summary") or {}
    rows = summary.get("rows_preview") or summary.get("rows") or []
    clean = []
    for row in rows:
        if not isinstance(row, dict):
            continue
        path = row.get("path") or row.get("absolute_path") or row.get("source_path")
        sha = row.get("sha256") or row.get("sha") or row.get("source_sha256")
        rel = row.get("relative_path") or (_P182Path(path).name if path else "")
        if path and sha:
            clean.append({
                "source_path": str(path),
                "relative_path": str(rel),
                "source_sha256": str(sha),
                "size": row.get("size"),
            })
    return clean


def _p182_stage_safe_name(path: str, rel: str, sha: str) -> str:
    basename = _P182Path(rel or path).name or "file"
    prefix = (sha or _p182_hashlib.sha256(path.encode("utf-8")).hexdigest())[:12]
    return f"{prefix}__{basename}"


def _p182_payload() -> dict:
    receipts = _p182_latest_receipts()
    preflight = receipts.get("preflight") or {}
    rollback = receipts.get("rollback") or {}
    validation = receipts.get("validation") or {}
    scope = receipts.get("scope") or {}
    candidate = preflight.get("selected_candidate") or rollback.get("selected_candidate") or validation.get("selected_candidate") or scope.get("selected_candidate") or "failsafe_manager"
    rows = _p182_rows_from_receipts(receipts)
    summary = preflight.get("candidate_file_summary") or {}
    duplicate_basenames = summary.get("duplicate_basenames") or []
    exact_sha_ready = bool(summary.get("exact_sha_rows_present")) and bool(rows)
    planned_stage_root = _P182Path.home() / "forge" / "memory" / "forge_runtime_candidate_sandboxes_v1" / f"{candidate}_stage_preview"
    manifest_rows = []
    for row in rows:
        planned_name = _p182_stage_safe_name(row.get("source_path", ""), row.get("relative_path", ""), row.get("source_sha256", ""))
        manifest_rows.append({
            "source_path": row.get("source_path"),
            "source_sha256": row.get("source_sha256"),
            "source_size": row.get("size"),
            "planned_stage_path": str(planned_stage_root / planned_name),
            "copy_allowed_now": False,
            "sha_verify_required_after_future_copy": True,
        })
    blockers = []
    if not preflight:
        blockers.append("Missing latest sandbox-preflight receipt from Patch 181.")
    if not bool(preflight.get("sandbox_preflight_ready")):
        blockers.append("Patch 181 sandbox preflight is not marked ready.")
    if not exact_sha_ready:
        blockers.append("Exact SHA rows are missing or empty; future sandbox copy must refuse.")
    if not rows:
        blockers.append("No candidate file rows were available to build the stage manifest.")
    warnings = []
    if duplicate_basenames:
        warnings.append("Duplicate basenames observed; every future copy/apply must use exact source path plus SHA, never basename matching.")
    if len(rows) != int(summary.get("file_count") or len(rows)):
        warnings.append("File rows available to Patch 182.1 may be a preview; future copy must verify the full receipt before staging.")
    gates = [
        {"id": "P182-G1", "name": "Patch 181 preflight receipt loaded", "status": "PASS" if preflight else "BLOCKED", "detail": str(FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_DIR / "latest_forge_runtime_candidate_sandbox_preflight_v1.json")},
        {"id": "P182-G2", "name": "Sandbox preflight ready", "status": "PASS" if bool(preflight.get("sandbox_preflight_ready")) else "BLOCKED", "detail": str(preflight.get("status"))},
        {"id": "P182-G3", "name": "Exact path/SHA rows present", "status": "PASS" if exact_sha_ready else "BLOCKED", "detail": f"rows={len(rows)}"},
        {"id": "P182-G4", "name": "Stage root remains Forge-owned", "status": "PASS" if str(planned_stage_root).startswith(str(_P182Path.home() / "forge" / "memory")) else "BLOCKED", "detail": str(planned_stage_root)},
        {"id": "P182-G5", "name": "No file copy allowed in this patch", "status": "PASS", "detail": "copy_allowed_now=False"},
        {"id": "P182-G6", "name": "No live apply allowed", "status": "PASS", "detail": "live_apply_allowed=False"},
    ]
    status = "FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_MANIFEST_READY_NO_WRITE_COPY_PLAN" if not blockers else "FORGE_RUNTIME_CANDIDATE_SANDBOX_STAGE_MANIFEST_BLOCKED_NO_WRITE_COPY_PLAN"
    payload = {
        "schema_version": "forge_runtime_candidate_sandbox_stage_v1.patch182_1",
        "patch": "Patch 182.1 — Runtime Candidate Sandbox Stage Command Definition Hotfix",
        "created_at": _p182_now(),
        "status": status,
        "selected_candidate": candidate,
        "stage_manifest_ready": not blockers,
        "planned_stage_root": str(planned_stage_root),
        "sandbox_creation_allowed": False,
        "sandbox_copy_allowed_now": False,
        "sandbox_execution_allowed": False,
        "test_execution_allowed": False,
        "backup_creation_allowed": False,
        "restore_execution_allowed": False,
        "live_apply_allowed": False,
        "human_approval_present": False,
        "approval_token_entered": False,
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "forge_owned_receipt_writes_only": True,
        "candidate_file_summary": {
            "file_count": len(rows),
            "reported_file_count": summary.get("file_count"),
            "python_file_count": summary.get("python_file_count"),
            "config_file_count": summary.get("config_file_count"),
            "json_file_count": summary.get("json_file_count"),
            "duplicate_basenames": duplicate_basenames,
            "exact_sha_rows_present": exact_sha_ready,
        },
        "stage_manifest": manifest_rows,
        "copy_plan": {
            "mode": "NO_WRITE_COPY_PLAN_ONLY",
            "future_command_may_create_forge_owned_sandbox_only": True,
            "future_copy_must_verify_source_sha_before_copy": True,
            "future_copy_must_verify_staged_sha_after_copy": True,
            "future_copy_must_refuse_basename_only_matching": True,
            "future_copy_must_not_touch_project_files": True,
            "future_copy_must_not_run_tests": True,
            "future_copy_must_not_apply_live": True,
        },
        "source_report": {
            "preflight_latest": str(FORGE_RUNTIME_CANDIDATE_SANDBOX_PREFLIGHT_DIR / "latest_forge_runtime_candidate_sandbox_preflight_v1.json"),
            "preflight_status": preflight.get("status"),
            "rollback_latest": str(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_ROLLBACK_DIR / "latest_forge_runtime_candidate_dry_plan_rollback_v1.json"),
            "rollback_status": rollback.get("status"),
            "validation_latest": str(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_VALIDATION_DIR / "latest_forge_runtime_candidate_dry_plan_validation_v1.json"),
            "validation_status": validation.get("status"),
            "scope_latest": str(FORGE_RUNTIME_CANDIDATE_DRY_PLAN_SCOPE_DIR / "latest_forge_runtime_candidate_dry_plan_scope_v1.json"),
            "scope_status": scope.get("status"),
        },
        "any_file_boundary": {
            "general_any_file_support": "future_only",
            "allowed_now": False,
            "reason": "This patch only plans a selected-runtime-candidate sandbox stage. General file operations require exact scope, exact path, current SHA, sandbox, tests, rollback, explicit approval, and post-write verification.",
        },
        "gates": gates,
        "warnings": warnings,
        "blockers": blockers,
        "next_patch": "Patch 183 — Runtime Candidate Sandbox Stage Create/Verify / Forge-Owned Copy Only",
        "recommended_next_patch": "Patch 183 — Runtime Candidate Sandbox Stage Create/Verify / Forge-Owned Copy Only",
    }
    payload["stage_manifest_fingerprint"] = _p182_hashlib.sha256(_p182_json.dumps({k: v for k, v in payload.items() if k != "stage_manifest_fingerprint"}, sort_keys=True, default=str).encode("utf-8")).hexdigest()
    return payload


