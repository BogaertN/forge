def _p148_build_payload() -> dict:
    source_map = _patch131_payload()
    source_map_path, _ = _patch131_write_json_md(source_map, "engine_source_law_map_v1")
    rows = source_map.get("rows") or []
    summary = source_map.get("summary") or {}
    gap_rows = [r for r in rows if r.get("source_authority_status") == "SOURCE_AUTHORITY_GAP_RECORDED"]
    candidate_rows = [r for r in rows if r.get("source_authority_status") == "CANDIDATE_DOCUMENTS_FOUND_REQUIRES_HUMAN_CONFIRMATION"]
    domain_counts = source_map.get("domain_counts") or {}
    live = _p148_live_tool_state()
    canonical = summary.get("canonical_engines")
    status = "FORGE_SOURCE_AUTHORITY_HARDENING_READY" if canonical == 54 else "FORGE_SOURCE_AUTHORITY_HARDENING_WARN"
