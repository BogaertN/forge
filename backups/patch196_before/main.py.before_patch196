def _p174_payload() -> dict:
    hold = _p174_hold_continuation_report()
    apply_hold = _p174_apply_hold_report()
    explicit = _p174_explicit_approval_report()
    candidate_rows, next_candidates = _p174_candidate_rows()
    held = candidate_rows[0] if candidate_rows else {}
    human_approval = bool(held.get("human_approval_present", False))
    token_entered = bool(held.get("approval_token_entered", False))
    token_status = held.get("token_validation_status") or "NOT_ENTERED"
    source_runtime_writes = int(hold.get("runtime_writes") or apply_hold.get("runtime_writes") or explicit.get("runtime_writes") or 0)
    source_project_writes = int(hold.get("project_writes") or apply_hold.get("project_writes") or explicit.get("project_writes") or 0)
    source_engine_writes = int(hold.get("engine_writes") or apply_hold.get("engine_writes") or explicit.get("engine_writes") or 0)
    problems = []
    if not hold:
        problems.append("latest Patch 173 hold-continuation queue-return receipt is missing")
    if hold and hold.get("status") != "FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_READY_QUEUE_RETURN":
        problems.append(f"latest Patch 173 hold-continuation status is unexpected: {hold.get('status')}")
    if source_runtime_writes or source_project_writes or source_engine_writes:
        problems.append("prior runtime-live queue evidence contains nonzero write counters")
    if human_approval or token_entered:
        problems.append("human approval/token state is no longer absent; live execution still requires a separate fresh execution patch")
    if not candidate_rows:
        problems.append("candidate queue rows could not be built")

    gates = [
        {"id":"CQR01","name":"Patch 173 queue-return receipt exists","status":"PASS" if hold else "FAIL","detail": hold.get("status", "missing") if isinstance(hold, dict) else "missing"},
        {"id":"CQR02","name":"Patch 173 status is ready queue return","status":"PASS" if hold.get("status") == "FORGE_RUNTIME_LIVE_HOLD_CONTINUATION_READY_QUEUE_RETURN" else "FAIL","detail": hold.get("status", "missing")},
        {"id":"CQR03","name":"Source write counters are zero","status":"PASS" if (source_runtime_writes == 0 and source_project_writes == 0 and source_engine_writes == 0) else "FAIL","detail": f"runtime={source_runtime_writes} project={source_project_writes} engine={source_engine_writes}"},
        {"id":"CQR04","name":"Human approval remains absent","status":"LOCKED" if not human_approval else "WARN","detail": f"human_approval_present={human_approval}"},
        {"id":"CQR05","name":"Approval token remains absent","status":"LOCKED" if not token_entered else "WARN","detail": f"approval_token_entered={token_entered} token_status={token_status}"},
        {"id":"CQR06","name":"Live build remains not ready","status":"LOCKED","detail":"live_build_ready=False"},
        {"id":"CQR07","name":"Held candidate queue row exists","status":"PASS" if candidate_rows else "FAIL","detail": f"rows={len(candidate_rows)}"},
        {"id":"CQR08","name":"Next candidate selection is dry-plan only","status":"PASS","detail":"Patch 174 may recommend routing only; no runtime/project/engine writes"},
    ]
    summary = {"pass":0,"warn":0,"locked":0,"fail":0}
    for g in gates:
        key = str(g.get("status", "")).lower()
        if key in summary:
            summary[key] += 1
    queue_decision = {
        "decision_type": "RUNTIME_CANDIDATE_QUEUE_REVIEW_DECISION_V1",
        "selected_candidate": held.get("candidate") or "failsafe_manager",
        "selected_candidate_action": "KEEP_HELD",
        "next_candidate_selection": "DEFER_TO_FUTURE_DRY_PLANNING_PATCH",
        "live_execution_permitted": False,
        "runtime_writes_performed": 0,
        "project_writes_performed": 0,
        "engine_writes_performed": 0,
        "reason": "The queue-return evidence is clean but explicit approval is still absent, so the held runtime candidate stays held and the next candidate may only be selected by a future dry-planning patch.",
        "required_before_any_future_live_apply": "explicit human approval token, fresh token validation, fresh final execution preflight, fresh backup/dry-run readback, and a separate live execution patch",
    }
    payload = {
        "report_type": "FORGE_RUNTIME_CANDIDATE_QUEUE_REVIEW_V1",
        "schema_version": FORGE_RUNTIME_CANDIDATE_QUEUE_SCHEMA_VERSION,
        "created_at": _p174_now(),
        "active_patch": "Patch 174 — Runtime Candidate Queue Review / Next Candidate Selection",
        "current_phase": "S19T — Runtime Candidate Queue Review / Next Candidate Selection",
        "next_patch": "Patch 175 — Runtime Candidate Dry-Plan Selector / No-Write Planning Gate",
        "recommended_next_patch": "Patch 175 — Runtime Candidate Dry-Plan Selector / No-Write Planning Gate",
        "status": "FORGE_RUNTIME_CANDIDATE_QUEUE_REVIEW_READY_NEXT_SELECTION_DEFERRED" if not problems else "FORGE_RUNTIME_CANDIDATE_QUEUE_REVIEW_PROBLEMS_FOUND",
        "planning_ready": not problems,
        "live_build_ready": False,
        "human_approval_present": human_approval,
        "approval_token_entered": token_entered,
        "token_validation_status": token_status,
        "execution_decision": "KEEP_HELD_DEFER_NEXT_SELECTION_TO_DRY_PLAN",
        "runtime_writes": 0,
        "project_writes": 0,
        "engine_writes": 0,
        "candidate_queue_rows": candidate_rows,
        "next_candidate_options": next_candidates,
        "queue_decision": queue_decision,
        "queue_decision_fingerprint": "",
        "source_reports": _p174_source_report_summary(),
        "gates": gates,
        "gate_summary": summary,
        "problem_count": len(problems),
        "problems": problems,
        "authority": {
            "read_only": True,
            "forge_memory_write_only": True,
            "runtime_file_write_authority": False,
            "project_file_write_authority": False,
            "engine_file_write_authority": False,
            "patch_apply_authority": False,
            "shell_execution_authority": False,
            "server_started": False,
            "live_execution_authority": False,
            "candidate_queue_mutation_authority": False,
            "next_candidate_live_selection_authority": False,
        },
        "roadmap_mutation_policy": "APPEND_ONLY",
        "plain_english": "Patch 174 reviews the held runtime candidate queue. failsafe_manager remains held, next live selection is deferred, and no runtime, project, or engine files are written.",
    }
    payload["queue_decision_fingerprint"] = _p174_hash_payload(queue_decision)
    return payload


def _p174_write_json_and_md(stem: str, payload: dict):
