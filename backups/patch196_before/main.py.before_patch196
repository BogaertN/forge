def _p144_sequence_payload() -> dict:
    queue = _p145_latest_queue()
    gate = _p146_latest_gate()
    if not queue:
        queue = _p145_queue_payload()

    base_verified = dict((queue.get("verified_state") or {}))
    if gate:
        base_verified.update({
            "build_gate_status": gate.get("status"),
            "build_gate_pass": gate.get("gate_pass_count"),
            "build_gate_warn": gate.get("gate_warn_count"),
            "build_gate_fail": gate.get("gate_fail_count"),
        })

