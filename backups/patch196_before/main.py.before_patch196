def _p144_now() -> str:
    from datetime import datetime
    return datetime.now().replace(microsecond=0).isoformat()


def _p144_stamp() -> str:
    return _p144_now().replace("-", "_").replace(":", "").replace("T", "_")


def _p144_ensure_dir() -> None:
    FORGE_BUILD_SEQUENCE_DIR.mkdir(parents=True, exist_ok=True)


def _p144_safe_json(path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p144_latest_sequence() -> dict:
    return _p144_safe_json(FORGE_BUILD_SEQUENCE_DIR / f"latest_{FORGE_BUILD_SEQUENCE_STEM}.json", {})


def _p144_write(payload: dict, stem: str):
    _p144_ensure_dir()
    stamp = _p144_stamp()
    json_path = FORGE_BUILD_SEQUENCE_DIR / f"{stamp}_{stem}.json"
    md_path = FORGE_BUILD_SEQUENCE_DIR / f"{stamp}_{stem}.md"
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    md = [f"# {payload.get('report_type', stem)}", ""]
    for key in ("status", "current_phase", "active_patch", "next_patch", "recommended_next_patch"):
        if key in payload:
            md.append(f"- **{key}**: `{payload.get(key)}`")
    if payload.get("verified_state"):
        md.append("")
        md.append("## Verified State")
        for k, v in (payload.get("verified_state") or {}).items():
            md.append(f"- **{k}**: `{v}`")
    if payload.get("build_sequence"):
        md.append("")
        md.append("## Build Sequence")
        for row in payload.get("build_sequence") or []:
            md.append(f"- **{row.get('id')}** — `{row.get('status')}` — {row.get('title')}: {row.get('purpose')}")
    if payload.get("deferred_items"):
        md.append("")
        md.append("## Deferred Items")
        for item in payload.get("deferred_items") or []:
            md.append(f"- **{item.get('name')}**: {item.get('reason')}")
    if payload.get("blocked_items"):
        md.append("")
        md.append("## Blocked Items")
        for item in payload.get("blocked_items") or []:
            md.append(f"- **{item.get('name')}**: {item.get('reason')}")
    if payload.get("next_commands"):
        md.append("")
        md.append("## Next Commands")
        for item in payload.get("next_commands") or []:
            md.append(f"- `{item}`")
    md.append("")
    md.append("## Authority")
    for k, v in (payload.get("authority") or {}).items():
        md.append(f"- **{k}**: `{v}`")
    md_path.write_text("\n".join(md) + "\n", encoding="utf-8")

    latest_json = FORGE_BUILD_SEQUENCE_DIR / f"latest_{stem}.json"
    latest_md = FORGE_BUILD_SEQUENCE_DIR / f"latest_{stem}.md"
    latest_json.write_text(json_path.read_text(encoding="utf-8"), encoding="utf-8")
    latest_md.write_text(md_path.read_text(encoding="utf-8"), encoding="utf-8")
    return json_path, md_path


def _p144_base_state() -> dict:
    try:
        return _p143b_state()
    except Exception:
        return {"verified_state": {}, "deferred_items": [], "full_roadmap": []}


def _p144_verified_state() -> dict:
    base = _p144_base_state()
    verified = dict(base.get("verified_state") or {})
    verified["tools"] = len((_p144_safe_json(CONFIG_DIR / "tool_registry.json", {}).get("tools") or {}))
    verified["expected_commands"] = len(FORGE_EXPECTED_COMMANDS)
    verified.setdefault("trust_level", (_p144_safe_json(CONFIG_DIR / "tool_registry.json", {}).get("current_trust_level")))
    return verified


def _p144_is_state_clean(verified: dict) -> bool:
    return (
        verified.get("canonical_included") == 54 and
        verified.get("canonical_excluded") == 26 and
        verified.get("ledger_pending") == 0 and
        verified.get("latest_test_fail") in (0, None) and
        verified.get("patch_impact_high_risk") in (0, None) and
        verified.get("patch_impact_test_issues") in (0, None) and
        verified.get("stack_linker_breather") == "DEFERRED_AND_EXCLUDED"
    )


