        "summary": f"candidate_engines={candidate_count} source_gaps={gap_count} final_authority_claimed=False",
        "blocks_runtime_planning": False,
        "blocks_live_build": True,
        "note": "Candidate documents are evidence leads only; final source authority still requires human confirmation and/or stronger source-law receipts.",
    })
    shadow_ok = shadow_summary.get("shadow_matches_snapshot") is True and ((inputs.get("shadow_diff") or {}).get("problem_count") in {0, None})
    rows.append({
        "domain_id": "D05",
        "domain": "Snapshot and shadow forensic evidence",
        "status": _p155_status(shadow_ok),
        "summary": f"shadow_matches_snapshot={shadow_summary.get('shadow_matches_snapshot')} problems={(inputs.get('shadow_diff') or {}).get('problem_count')}",
        "blocks_runtime_planning": False,
        "blocks_live_build": not shadow_ok,
    })
    live_status = live.get("status") or "NOT_REFRESHED"
    rows.append({
        "domain_id": "D06",
        "domain": "Live apply eligibility lock",
        "status": "PASS" if live_status == "FORGE_LIVE_APPLY_ELIGIBILITY_V2_READY_NOT_ELIGIBLE" else "WARN",
        "summary": f"eligible={live.get('eligible_for_live_apply')} status={live_status}",
        "blocks_runtime_planning": False,
        "blocks_live_build": True,
        "note": "Not eligible is expected. Runtime build planning may continue; live writes remain locked.",
    })
    rows.append({
        "domain_id": "D07",
        "domain": "Deferred engine queue",
        "status": "WARN" if (queue.get("queue_total") or 0) else "PASS",
        "summary": f"queue_total={queue.get('queue_total')} repair_ready={queue.get('repair_ready_count')} repair_blocked={queue.get('repair_blocked_count')}",
        "blocks_runtime_planning": False,
        "blocks_live_build": False,
