        print(f"    patch-test-gate-check {candidate.name}")
        print("    patch-test-relevance-check latest")
        print(f"    patch-apply {candidate.name}")
        print("──────────────────────────────────────────────────────")
        print()
        return False

    # ── Display all checks that will run ─────────────────────────────────────
