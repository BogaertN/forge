        "dry_run_ready": True,
        "live_build_ready": False,
        "sandbox_id": sandbox_id,
        "sandbox_dir": str(sandbox_dir),
        "selected_candidate": candidate,
        "created_files": files,
        "created_file_count": len(files),
        "project_files_written": 0,
        "engine_files_written": 0,
        "runtime_files_written": 0,
        "future_paths_not_created": plan.get("future_paths_not_created") or [],
