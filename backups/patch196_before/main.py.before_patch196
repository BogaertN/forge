def _p177_status_forward_rows(existing_rows):
    rows = [dict(r) for r in (existing_rows or [])]
    ids = {r.get("id") for r in rows}
    if "S19W" not in ids:
        rows.append({"id":"S19W","status":"ACTIVE","title":"Runtime Candidate Dry-Plan Dependency Review / No-Write Impact Notes","patch":"Patch 177.1 — Runtime Candidate Dry-Plan Dependency Command Definition Hotfix","summary":"Review dependencies and impact notes for the selected runtime candidate without applying changes.","authority":"impact review only; no runtime writes"})
    if "S19X" not in ids:
        rows.append({"id":"S19X","status":"NEXT","title":"Runtime Candidate Dry-Plan Validation Matrix / No-Write Test Plan","patch":"Patch 178 — Runtime Candidate Dry-Plan Validation Matrix / No-Write Test Plan","summary":"Create a no-write validation/test matrix before any future sandbox or live apply.","authority":"validation planning only; no runtime writes"})
    for row in rows:
        rid = row.get("id")
        if rid == "S19":
            row["status"] = "ACTIVE"
        elif rid in {"S19A","S19B","S19C","S19D","S19E","S19F","S19G","S19H","S19I","S19J","S19K","S19L","S19M","S19N","S19O","S19P","S19Q","S19R","S19S","S19T","S19U","S19V"}:
            row["status"] = "DONE"
        elif rid == "S19W":
            row["status"] = "ACTIVE"
        elif rid == "S19X":
            row["status"] = "NEXT"
        elif rid == "S20":
            row["status"] = "FUTURE"
    return rows


