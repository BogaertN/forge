def _p134_now() -> str:
    return datetime.datetime.now().strftime("%Y_%m_%d_%H%M%S")


def _p134_iso() -> str:
    return datetime.datetime.now().isoformat(timespec="seconds")


def _p134_sha(path: Path) -> str | None:
    try:
        p = Path(path)
        if not p.exists() or not p.is_file():
            return None
        return hashlib.sha256(p.read_bytes()).hexdigest()
    except Exception:
        return None


def _p134_load(path: Path, default=None):
    try:
        p = Path(path)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {} if default is None else default


def _p134_tail(text: str, limit: int = 3000) -> str:
    text = text or ""
    return text[-limit:]


def _p134_write(payload: dict, prefix: str) -> tuple[Path, Path]:
    IMPORT_PROBE_DIR.mkdir(parents=True, exist_ok=True)
    ts = _p134_now()
    jp = IMPORT_PROBE_DIR / f"{ts}_{prefix}.json"
    mp = IMPORT_PROBE_DIR / f"{ts}_{prefix}.md"
    latest_jp = IMPORT_PROBE_DIR / f"latest_{prefix}.json"
    latest_mp = IMPORT_PROBE_DIR / f"latest_{prefix}.md"
    raw = json.dumps(payload, indent=2, ensure_ascii=False)
    jp.write_text(raw, encoding="utf-8")
    latest_jp.write_text(raw, encoding="utf-8")
    lines = [
        f"# {payload.get('report_type', prefix)}",
        "",
        f"Status: `{payload.get('status')}`",
        f"Created: `{payload.get('created_at')}`",
        f"Target: `{payload.get('target', payload.get('target_engine', 'unknown'))}`",
        "",
        "## Plain English",
        "",
        str(payload.get("plain_english") or ""),
        "",
        "## Authority",
        "",
    ]
    for k, v in (payload.get("authority") or {}).items():
        lines.append(f"- `{k}`: `{v}`")
    if payload.get("recommendation"):
        lines += ["", "## Recommendation", "", str(payload.get("recommendation"))]
    if payload.get("problems"):
        lines += ["", "## Problems", ""]
        for item in payload.get("problems") or []:
            lines.append(f"- {item}")
    if payload.get("next_commands"):
        lines += ["", "## Next Commands", ""]
        for item in payload.get("next_commands") or []:
            lines.append(f"- `{item}`")
    md = "\n".join(lines) + "\n"
    mp.write_text(md, encoding="utf-8")
    latest_mp.write_text(md, encoding="utf-8")
    return jp, mp


