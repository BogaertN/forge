            md_lines.append(f"| {r['filename']} | {r['sha256_16']} | {r['proposed_folder']} | {r['source_key']} | {'YES' if r['duplicate_sha'] or r['duplicate_fname'] else 'no'} | {icon} |")

    try:
        json_path.write_text(_json.dumps(rpt, indent=2), encoding="utf-8")
