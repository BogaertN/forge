        "blocks_live_build": tool.get("tools") != 504,
    })
    rows.append({
        "domain_id": "D02",
        "domain": "Canonical engine authority",
        "status": _p155_status(status_summary.get("canonical_included") == 54 and status_summary.get("canonical_excluded") == 26),
        "summary": f"included={status_summary.get('canonical_included')} excluded={status_summary.get('canonical_excluded')}",
        "blocks_runtime_planning": False,
        "blocks_live_build": status_summary.get("canonical_included") != 54,
    })
    rows.append({
        "domain_id": "D03",
        "domain": "Canonical tests",
        "status": _p155_status((test_counts.get("fail") == 0) or (status_summary.get("latest_test_fail") == 0)),
        "summary": f"pass={test_counts.get('pass', status_summary.get('latest_test_pass'))} fail={test_counts.get('fail', status_summary.get('latest_test_fail'))}",
        "blocks_runtime_planning": False,
        "blocks_live_build": not ((test_counts.get("fail") == 0) or (status_summary.get("latest_test_fail") == 0)),
    })
    gap_count = source_summary.get("engines_with_source_authority_gaps")
    candidate_count = source_summary.get("engines_with_candidate_source_documents")
    source_ready = (inputs.get("source_authority") or {}).get("status") in {"FORGE_SOURCE_AUTHORITY_HARDENING_READY", "FORGE_SOURCE_AUTHORITY_HARDENING_WARN"}
    rows.append({
        "domain_id": "D04",
