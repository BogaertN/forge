def _patch124_run_one_target(target: dict) -> dict:
    test_path = Path(target.get("test_path") or "").expanduser()
    cwd = Path(target.get("cwd") or test_path.parent).expanduser()
    result = {
        "engine_base": target.get("engine_base"),
        "test_path": str(test_path),
        "cwd": str(cwd),
        "status": "NOT_RUN",
        "returncode": None,
        "duration_seconds": None,
        "stdout_tail": "",
        "stderr_tail": "",
        "problem": None,
    }
    if not test_path.exists() or not test_path.is_file():
        result["status"] = "BLOCKED_TARGET_MISSING"
        result["problem"] = "test path missing"
        return result
    try:
        current_sha = _patch124_sha256(test_path)
        if target.get("test_sha256") and current_sha != target.get("test_sha256"):
            result["status"] = "BLOCKED_SHA_CHANGED"
            result["problem"] = "test file SHA changed since plan"
            return result
        rescanned = _patch123_scan_test_file(test_path)
        if not rescanned.get("safe_candidate"):
            result["status"] = "BLOCKED_RESCAN_NOT_SAFE"
            result["problem"] = rescanned.get("reason")
            return result
        start = datetime.datetime.now()
        proc = subprocess.run(
            [sys.executable, str(test_path)],
            cwd=str(cwd),
            capture_output=True,
            text=True,
            timeout=int(target.get("timeout_seconds") or CANONICAL_TEST_RUN_TIMEOUT_SECONDS),
            shell=False,
        )
        end = datetime.datetime.now()
        result["returncode"] = proc.returncode
        result["duration_seconds"] = round((end - start).total_seconds(), 3)
        result["stdout_tail"] = (proc.stdout or "")[-4000:]
        result["stderr_tail"] = (proc.stderr or "")[-4000:]
        result["status"] = "PASS" if proc.returncode == 0 else "FAIL"
    except subprocess.TimeoutExpired as exc:
        result["status"] = "TIMEOUT"
        result["problem"] = f"timeout after {target.get('timeout_seconds') or CANONICAL_TEST_RUN_TIMEOUT_SECONDS}s"
        result["stdout_tail"] = (exc.stdout or "")[-4000:] if isinstance(exc.stdout, str) else ""
        result["stderr_tail"] = (exc.stderr or "")[-4000:] if isinstance(exc.stderr, str) else ""
    except Exception as exc:
        result["status"] = "ERROR"
        result["problem"] = str(exc)
    return result


