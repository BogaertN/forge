        result["error"] = str(exc)
    return result


def _p140_insert_corebreather_wrapper(candidate_text: str) -> tuple[str, dict]:
    """Conservative generic transform for the exact class-method symbol mismatch exposed by Patch 139.

    It only changes the candidate copy when:
    - the candidate imports breathe_phase as core_breathe from core_breather.core_breather, and
    - the dependency exposes CoreBreather rather than breathe_phase.
    """
    strategy = {"action": "none", "changed": False, "notes": [], "confidence": "LOW"}
    old_import = "from core_breather.core_breather import breathe_phase as core_breathe"
    if old_import not in candidate_text:
        strategy["notes"].append("Expected core_breather breathe_phase import not found; no transform applied.")
        return candidate_text, strategy
    text = candidate_text.replace(old_import, "from core_breather.core_breather import CoreBreather", 1)
    wrapper = (
        "\n"
        "_core_breather_instance = CoreBreather()\n"
        "def core_breathe(phase=None):\n"
        "    return _core_breather_instance.breathe()\n"
    )
    # Insert wrapper after import block and before def unified_breathe_cycle.
    marker = "\ndef unified_breathe_cycle():"
    if marker in text:
        text = text.replace(marker, wrapper + marker, 1)
    else:
        text += wrapper
    strategy.update({
        "action": "USE_COREBREATHER_WRAPPER",
        "changed": True,
        "confidence": "MEDIUM",
        "notes": [
            "Replaced missing breathe_phase import with CoreBreather class import.",
            "Inserted local core_breathe wrapper that accepts optional phase and calls CoreBreather.breathe().",
            "This is candidate/sandbox-only; no live file was changed.",
        ],
    })
    return text, strategy


