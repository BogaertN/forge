{
  "name": "identity-vault",
  "version": "1.0.0",
  "description": "Sovereign Identity Management & Agent Orchestration Platform - A powerful, self-hosted identity management system designed for privacy-conscious individuals and organizations",
  "main": "server.js",
  "keywords": [
    "identity",
    "vault",
    "privacy",
    "blockchain",
    "ai",
    "agents",
    "sovereign",
    "zero-knowledge",
    "encryption",
    "ipfs",
    "langchain",
    "autogen"
  ],
  "author": {
    "name": "Nic Bogaert",
    "email": "contact@identity-vault.com",
    "url": "https://github.com/BogaertN"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BogaertN/identity-vault.git"
  },
  "bugs": {
    "url": "https://github.com/BogaertN/identity-vault/issues"
  },
  "homepage": "https://github.com/BogaertN/identity-vault#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon --inspect=0.0.0.0:9229 server.js",
    "debug": "NODE_ENV=development node --inspect-brk=0.0.0.0:9229 server.js",
    "test": "NODE_ENV=test jest --coverage --passWithNoTests",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:integration": "NODE_ENV=test jest --testPathPattern=integration",
    "test:unit": "NODE_ENV=test jest --testPathPattern=unit",
    "test:e2e": "NODE_ENV=test jest --testPathPattern=e2e",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "cli": "node cli.js",
    "db:migrate": "npm run cli migrate",
    "db:seed": "npm run cli seed",
    "db:backup": "npm run cli backup",
    "db:restore": "npm run cli restore",
    "build": "npm run lint && npm run test && npm run build:docs",
    "build:docs": "typedoc --out docs/api src",
    "security:audit": "npm audit --audit-level high",
    "security:scan": "npm run security:audit && snyk test",
    "docker:build": "docker build -t identity-vault .",
    "docker:build:dev": "docker build --target development -t identity-vault:dev .",
    "docker:run": "docker-compose up -d",
    "docker:run:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:shell": "docker exec -it identity-vault sh",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "monitoring:start": "docker-compose --profile monitoring up -d",
    "monitoring:stop": "docker-compose --profile monitoring down",
    "deploy": "npm run build && npm run docker:build && npm run docker:run",
    "install:dev": "npm install && npm run db:migrate && npm run db:seed",
    "preinstall": "node scripts/check-node-version.js",
    "postinstall": "node scripts/post-install.js",
    "prepare": "husky install",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "health": "curl -f http://localhost:${PORT:-3000}/health || exit 1",
    "validate": "npm run lint:check && npm run format:check && npm run test && npm run security:audit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "ipfs-core": "^0.18.1",
    "snarkjs": "^0.7.0",
    "commander": "^11.0.0",
    "ngrok": "^5.0.0-beta.2",
    "chalk": "^5.3.0",
    "json-diff": "^1.0.6",
    "@langchain/core": "^0.1.0",
    "multiformats": "^12.1.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "joi": "^17.9.2",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "crypto-js": "^4.1.1",
    "node-cron": "^3.0.2",
    "multer": "^1.4.5-lts.1",
    "fs-extra": "^11.1.1",
    "archiver": "^6.0.1",
    "node-fetch": "^3.3.2",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "prom-client": "^14.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.5",
    "eslint": "^8.48.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "semantic-release": "^21.1.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.0.6",
    "@semantic-release/changelog": "^6.0.3",
    "snyk": "^1.1227.0",
    "typedoc": "^0.25.1",
    "typescript": "^5.2.2",
    "@types/node": "^20.5.9",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.14",
    "@types/bcryptjs": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/uuid": "^9.0.4",
    "@types/lodash": "^4.14.198",
    "@types/crypto-js": "^4.1.2",
    "@types/multer": "^1.4.7",
    "@types/archiver": "^5.3.4",
    "@types/ws": "^8.5.6",
    "tsx": "^3.12.10",
    "ts-jest": "^29.1.1"
  },
  "files": [
    "server.js",
    "cli.js",
    "routes/",
    "utils/",
    "templates/",
    "schemas/",
    "public/",
    "docs/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ]
}
